<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2518 — Recovery Inhibition (cheers) | Status: deprecated | Sigma ID: 80efe55e-3d46-5fa3-9142-50e61076440e -->
  <rule id="715185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2518 — Recovery Inhibition (cheers)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>