<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1115 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 3910a080-16e9-5e38-b718-c8ac8ee7bcb2 -->
  <rule id="957008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1115 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>