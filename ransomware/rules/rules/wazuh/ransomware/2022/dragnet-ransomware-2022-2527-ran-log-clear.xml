<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2527 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: bfcd7df5-867f-5b3a-9411-c9a6bdfa1cf4 -->
  <rule id="756285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2527 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>