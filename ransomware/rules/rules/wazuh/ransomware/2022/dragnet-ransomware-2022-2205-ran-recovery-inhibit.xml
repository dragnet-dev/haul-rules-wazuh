<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2205 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: c8b5d8b2-5d89-52e8-be0e-3156ffd17581 -->
  <rule id="695338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2205 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>