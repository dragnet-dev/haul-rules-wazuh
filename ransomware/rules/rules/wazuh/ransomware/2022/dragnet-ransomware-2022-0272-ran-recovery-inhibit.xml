<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0272 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 96802ce0-a655-559d-916a-c67c06f5e1ce -->
  <rule id="748844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0272 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>