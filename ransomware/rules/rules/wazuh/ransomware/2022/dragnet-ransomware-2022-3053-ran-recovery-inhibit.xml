<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3053 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 44e32c87-5108-5446-9817-1aaea2c79875 -->
  <rule id="349324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3053 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>