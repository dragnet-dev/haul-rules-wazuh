<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0407 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 51e1dfa4-028d-5733-acf2-7c328ac38039 -->
  <rule id="425279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0407 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>