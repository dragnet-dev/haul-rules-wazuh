<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1248 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: fa461d22-398b-583e-9284-5e32f485907d -->
  <rule id="507389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1248 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>