<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0364 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: 9683cc52-d58d-5d7a-a95a-5991b5e599f4 -->
  <rule id="779052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0364 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>