<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0532 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: b2a6f8bb-5e94-5566-b6d0-67515f3204d6 -->
  <rule id="284318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0532 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>