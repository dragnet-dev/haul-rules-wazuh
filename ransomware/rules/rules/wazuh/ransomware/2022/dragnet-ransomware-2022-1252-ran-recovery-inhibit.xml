<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1252 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7e7c4d23-387f-5260-8726-03a36ef45741 -->
  <rule id="645517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1252 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>