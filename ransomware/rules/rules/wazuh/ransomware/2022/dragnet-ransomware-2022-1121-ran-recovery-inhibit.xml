<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1121 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: f818b8d4-e3cf-51c2-8bf2-7f4a17469d15 -->
  <rule id="830998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1121 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>