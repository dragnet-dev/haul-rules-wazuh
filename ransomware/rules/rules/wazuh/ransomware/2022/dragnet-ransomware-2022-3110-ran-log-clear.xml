<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3110 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 8d999b1a-7c48-5098-9b21-0a1ee2d8fcfa -->
  <rule id="571995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3110 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>