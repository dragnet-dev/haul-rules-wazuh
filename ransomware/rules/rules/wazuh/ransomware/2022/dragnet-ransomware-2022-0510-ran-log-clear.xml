<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0510 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 0b2dddc4-387b-5427-bb6e-a8c1577107d6 -->
  <rule id="296828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0510 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>