<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2546 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ec56edd4-8e55-5ec3-91c3-0e82e2c204e2 -->
  <rule id="756173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2546 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>