<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0037 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 5e3d2fb0-dfaa-5fd3-9cb1-2ebfa729d9b3 -->
  <rule id="716207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0037 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>