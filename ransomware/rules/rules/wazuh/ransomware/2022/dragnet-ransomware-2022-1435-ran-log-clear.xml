<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1435 — Event Log Clearing (freecivilian) | Status: deprecated | Sigma ID: 0458162b-9d56-57c7-8b91-1a4db2f7f639 -->
  <rule id="230603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1435 — Event Log Clearing (freecivilian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>