<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2220 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: fc536bf3-9ce4-5671-bd21-b3d00078b4c2 -->
  <rule id="540587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2220 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>