<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0371 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: df75cc34-5fba-5ef3-b5e0-28a0d2ff34b4 -->
  <rule id="428204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0371 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>