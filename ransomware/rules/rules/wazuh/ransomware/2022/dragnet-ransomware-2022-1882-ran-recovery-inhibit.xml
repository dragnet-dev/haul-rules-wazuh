<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1882 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 9ba04f76-8876-5f91-a397-e06c1a8648f2 -->
  <rule id="484079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1882 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>