<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0240 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 20b5eb18-356d-580f-973c-2876026afa5b -->
  <rule id="488751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0240 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>