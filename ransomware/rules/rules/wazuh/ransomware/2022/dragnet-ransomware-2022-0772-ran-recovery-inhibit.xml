<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0772 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: b46a3ddc-a8e7-558e-b095-96f273cfb892 -->
  <rule id="335421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0772 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>