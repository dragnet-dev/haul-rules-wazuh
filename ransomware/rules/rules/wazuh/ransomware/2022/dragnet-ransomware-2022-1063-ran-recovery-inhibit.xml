<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1063 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 288fdaff-b1c4-5b33-bb51-fc9e56c09c34 -->
  <rule id="383706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1063 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>