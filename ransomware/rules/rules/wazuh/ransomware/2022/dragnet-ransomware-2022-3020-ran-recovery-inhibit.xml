<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3020 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: d4818445-a732-5cde-9e3c-78ed9bdebdec -->
  <rule id="548184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3020 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
