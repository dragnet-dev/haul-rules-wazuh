<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1444 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: 48aeac1a-a7ec-5716-8d78-820b1c8aac01 -->
  <rule id="590444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1444 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
