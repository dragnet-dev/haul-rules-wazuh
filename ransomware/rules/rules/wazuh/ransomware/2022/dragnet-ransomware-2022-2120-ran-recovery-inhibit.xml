<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2120 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 216cb6a6-a57e-5d52-af06-ea8973e73baa -->
  <rule id="879946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2120 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>