<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2537 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 14d082ca-215c-5515-b683-f169911f15b3 -->
  <rule id="293324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2537 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>