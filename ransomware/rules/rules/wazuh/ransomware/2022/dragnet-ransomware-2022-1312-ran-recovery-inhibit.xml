<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1312 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 155d638a-1a89-5b66-9987-ee56f1217793 -->
  <rule id="793638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1312 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>