<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2229 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 417219d1-65b6-585f-9d64-8f0675211d2a -->
  <rule id="475517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2229 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>