<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0389 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 5b6fcf42-fff0-5878-8b62-5a5a97af2dd6 -->
  <rule id="255983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0389 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>