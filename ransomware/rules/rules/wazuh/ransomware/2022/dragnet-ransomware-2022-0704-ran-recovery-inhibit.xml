<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0704 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 8bf6e09c-7101-5003-a460-dee1b22902b7 -->
  <rule id="983500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0704 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
