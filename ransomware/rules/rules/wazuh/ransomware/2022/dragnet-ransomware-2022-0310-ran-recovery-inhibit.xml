<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0310 — Recovery Inhibition (cheers) | Status: deprecated | Sigma ID: f2fbf078-0b49-5167-97b2-e7aec026e1dd -->
  <rule id="966230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0310 — Recovery Inhibition (cheers)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>