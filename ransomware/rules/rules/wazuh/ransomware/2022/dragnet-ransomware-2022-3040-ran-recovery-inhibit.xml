<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3040 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c507d72a-5139-57cb-8f13-8ed77b5805bb -->
  <rule id="301257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3040 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>