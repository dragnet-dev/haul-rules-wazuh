<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0858 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 225cca8a-7a4b-55d4-abaa-a4e81499f042 -->
  <rule id="348748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0858 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>