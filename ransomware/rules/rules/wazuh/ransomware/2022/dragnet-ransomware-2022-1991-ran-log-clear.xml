<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1991 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 84c2a992-c928-5c2b-89ec-e4567f0ea75c -->
  <rule id="470029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1991 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>