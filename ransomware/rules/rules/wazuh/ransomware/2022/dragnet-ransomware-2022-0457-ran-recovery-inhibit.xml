<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0457 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a6d6bf26-6fc6-5605-a606-fb32c05d6577 -->
  <rule id="876767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0457 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>