<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0288 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: c8182b7b-075f-52dd-956e-fb8d1a4e11e7 -->
  <rule id="350923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0288 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>