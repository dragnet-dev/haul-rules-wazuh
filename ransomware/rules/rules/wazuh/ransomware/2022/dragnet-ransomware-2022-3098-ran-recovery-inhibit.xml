<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3098 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 11dbae66-e3b7-56ec-8a2f-19814ca871b4 -->
  <rule id="671346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3098 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>