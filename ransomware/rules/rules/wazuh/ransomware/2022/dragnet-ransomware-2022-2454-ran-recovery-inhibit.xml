<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2454 — Recovery Inhibition (shaoleaks) | Status: deprecated | Sigma ID: e3198afb-a4d2-5248-886d-c45afb025c39 -->
  <rule id="591178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2454 — Recovery Inhibition (shaoleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>