<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0970 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4d25e13a-05a3-57bf-a9d7-ffd06da3be05 -->
  <rule id="436141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0970 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>