<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2798 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 85c76253-5258-5ed9-8573-0f853e265b83 -->
  <rule id="572762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2798 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
