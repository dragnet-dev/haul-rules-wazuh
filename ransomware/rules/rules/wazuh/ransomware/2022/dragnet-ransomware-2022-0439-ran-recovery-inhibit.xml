<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0439 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c3760178-e1c5-5402-917c-36da42fdb144 -->
  <rule id="437601" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0439 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>