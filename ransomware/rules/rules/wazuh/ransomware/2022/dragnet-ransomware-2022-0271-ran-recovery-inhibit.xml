<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0271 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 920bdcfe-d710-5d6f-b3d2-18226eb781da -->
  <rule id="271356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0271 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>