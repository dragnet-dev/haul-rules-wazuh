<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2907 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e1e1446e-6e03-59b3-824e-bfd3a0021dd5 -->
  <rule id="570144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2907 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>