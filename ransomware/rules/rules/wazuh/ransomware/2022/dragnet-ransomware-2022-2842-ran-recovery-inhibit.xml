<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2842 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: bb175af1-be7d-562e-811f-72f801ee0c05 -->
  <rule id="394810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2842 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>