<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0556 — Event Log Clearing (cheers) | Status: deprecated | Sigma ID: 4b59c190-461c-547c-9198-2b94a8213179 -->
  <rule id="409561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0556 — Event Log Clearing (cheers)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>