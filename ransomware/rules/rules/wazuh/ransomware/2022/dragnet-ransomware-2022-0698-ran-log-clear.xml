<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0698 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 0e78a7a6-4d6b-5551-b04f-1aac94e0c5ea -->
  <rule id="285402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0698 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>