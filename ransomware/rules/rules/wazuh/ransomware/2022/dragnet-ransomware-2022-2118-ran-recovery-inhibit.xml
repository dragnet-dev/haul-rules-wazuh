<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2118 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 82b6c89d-245a-5ac3-abc0-045d391aabf0 -->
  <rule id="417888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2118 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>