<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0181 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: b8a374c0-6cfd-5b1f-8aa6-ed3e782adaef -->
  <rule id="198374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0181 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>