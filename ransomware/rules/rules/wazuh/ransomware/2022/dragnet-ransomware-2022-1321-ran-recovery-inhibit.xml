<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1321 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: d5bdbd5f-0815-50eb-ab91-1547758e6625 -->
  <rule id="895933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1321 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>