<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2432 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3666a93f-de2c-5085-9660-6c2bcdad4429 -->
  <rule id="566693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2432 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>