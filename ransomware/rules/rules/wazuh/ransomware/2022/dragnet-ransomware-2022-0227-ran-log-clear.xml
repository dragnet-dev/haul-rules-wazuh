<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0227 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: a2f32c3e-1f32-51f5-984b-9d73dc0dc86b -->
  <rule id="935724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0227 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>