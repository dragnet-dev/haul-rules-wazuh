<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0476 — Event Log Clearing (redalert) | Status: deprecated | Sigma ID: 10596385-9c18-510c-8710-3bab858274ae -->
  <rule id="259638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0476 — Event Log Clearing (redalert)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>