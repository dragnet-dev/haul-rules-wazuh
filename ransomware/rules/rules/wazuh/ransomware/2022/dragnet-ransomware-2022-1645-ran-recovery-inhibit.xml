<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1645 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: fd538789-92ec-56e5-954f-376c2fe134c5 -->
  <rule id="835387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1645 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>