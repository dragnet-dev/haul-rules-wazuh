<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3158 — Event Log Clearing (play) | Status: deprecated | Sigma ID: 5675ab3e-7ac7-5af4-ad1c-efb9e9f9665e -->
  <rule id="652971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3158 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>