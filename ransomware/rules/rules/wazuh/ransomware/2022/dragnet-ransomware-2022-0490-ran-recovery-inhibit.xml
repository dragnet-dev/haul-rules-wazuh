<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0490 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 84527fe2-bc3a-5fca-9961-7aef99725900 -->
  <rule id="552447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0490 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
