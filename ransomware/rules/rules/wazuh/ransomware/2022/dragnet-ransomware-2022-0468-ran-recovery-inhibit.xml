<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0468 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 85f1c8ff-1dbf-5ce0-9d1b-c4f95057becd -->
  <rule id="500288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0468 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>