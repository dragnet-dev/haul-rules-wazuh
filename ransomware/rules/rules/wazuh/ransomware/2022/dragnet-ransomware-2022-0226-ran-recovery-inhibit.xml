<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0226 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 3cb88a79-b3cc-5f49-867d-10ca8e1f033f -->
  <rule id="755018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0226 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>