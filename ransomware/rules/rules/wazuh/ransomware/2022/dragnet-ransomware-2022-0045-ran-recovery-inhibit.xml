<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0045 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: dd8ff78b-87bf-54ba-bb33-111b9ddc6595 -->
  <rule id="380637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0045 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>