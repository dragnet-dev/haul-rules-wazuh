<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1439 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3a995d4a-8131-561f-9bf0-4650216ee511 -->
  <rule id="539334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1439 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>