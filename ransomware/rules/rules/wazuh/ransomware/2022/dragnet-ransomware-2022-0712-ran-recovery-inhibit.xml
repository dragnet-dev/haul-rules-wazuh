<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0712 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: ba22a707-7afc-5935-8483-0cd61b0e3348 -->
  <rule id="379627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0712 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
