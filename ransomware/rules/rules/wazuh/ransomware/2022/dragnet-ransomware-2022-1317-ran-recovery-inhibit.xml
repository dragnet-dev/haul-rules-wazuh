<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1317 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 7341b85a-4d49-5050-9523-7a40b28d8575 -->
  <rule id="374678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1317 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>