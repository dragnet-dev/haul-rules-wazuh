<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1591 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: b3b8d23c-76b3-5440-b33d-5598d36ed4b9 -->
  <rule id="311812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1591 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>