<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1642 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 76bb8f6b-45c0-59f2-924b-c42cae5df9ce -->
  <rule id="543023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1642 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>