<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0503 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 5f50408f-2135-5333-b740-74bf8a9c69ca -->
  <rule id="650408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0503 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>