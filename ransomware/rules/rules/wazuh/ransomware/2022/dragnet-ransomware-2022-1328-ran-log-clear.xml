<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1328 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 0a4d3aa7-d3af-5999-b5cd-abac495c361d -->
  <rule id="794058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1328 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>