<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1664 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 22ed9b29-684e-5a8c-bc9b-f30cef1fc195 -->
  <rule id="491952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1664 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>