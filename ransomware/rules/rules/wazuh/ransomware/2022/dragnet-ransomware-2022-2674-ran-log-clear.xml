<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2674 — Event Log Clearing (dataleak) | Status: deprecated | Sigma ID: 54634cc0-8c19-5d44-be3a-253672248edb -->
  <rule id="586508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2674 — Event Log Clearing (dataleak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>