<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0652 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: ef6f16cd-7ed2-5e79-a653-928e6e274d82 -->
  <rule id="335116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0652 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>