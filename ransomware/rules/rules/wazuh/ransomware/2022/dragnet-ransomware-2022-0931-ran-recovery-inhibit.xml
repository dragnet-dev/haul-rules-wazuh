<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0931 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 70ce003e-8f94-5729-903a-318766262e59 -->
  <rule id="112600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0931 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
