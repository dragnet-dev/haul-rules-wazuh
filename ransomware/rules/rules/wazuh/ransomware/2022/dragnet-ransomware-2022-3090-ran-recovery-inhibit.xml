<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3090 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e5bd7be8-9621-505a-ba2b-895e053bd2db -->
  <rule id="669563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3090 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>