<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2487 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 9acdb2ef-17dc-50df-a7ab-82adf83e2dab -->
  <rule id="140752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2487 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>