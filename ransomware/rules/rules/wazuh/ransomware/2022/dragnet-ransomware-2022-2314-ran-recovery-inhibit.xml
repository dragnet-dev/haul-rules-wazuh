<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2314 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 32b13429-caab-5dc8-ad47-a742bb6c8aa7 -->
  <rule id="831342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2314 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>