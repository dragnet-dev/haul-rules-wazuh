<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1329 — Event Log Clearing (sparta) | Status: deprecated | Sigma ID: 3c49bc52-2e76-53b0-b9ab-611af52835ed -->
  <rule id="748732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1329 — Event Log Clearing (sparta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>