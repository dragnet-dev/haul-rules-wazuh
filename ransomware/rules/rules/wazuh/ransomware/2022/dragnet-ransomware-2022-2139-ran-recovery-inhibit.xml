<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2139 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ffe7b719-0495-5322-af72-9d229a79050c -->
  <rule id="351637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2139 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>