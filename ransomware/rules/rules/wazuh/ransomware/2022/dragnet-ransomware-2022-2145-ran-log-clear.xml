<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2145 — Event Log Clearing (daixin) | Status: deprecated | Sigma ID: 40564184-ea25-5579-b99e-753375552bde -->
  <rule id="556418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2145 — Event Log Clearing (daixin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>