<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0867 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: de34a0a3-f384-5c8c-94ae-359bd7389ac8 -->
  <rule id="957540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0867 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>