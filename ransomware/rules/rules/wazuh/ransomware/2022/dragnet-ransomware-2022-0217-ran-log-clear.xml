<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0217 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 1c381a2d-2a94-5614-8fc2-a0047cedbf0f -->
  <rule id="141062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0217 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>