<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0201 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 810cbcf3-f5d9-5edf-ae0c-25765f2218db -->
  <rule id="721020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0201 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>