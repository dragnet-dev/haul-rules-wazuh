<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1269 — Event Log Clearing (onyx) | Status: deprecated | Sigma ID: 07c69fe3-5bcf-5e16-af55-eb1067e1b1e7 -->
  <rule id="592318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1269 — Event Log Clearing (onyx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>