<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2133 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c10381f2-eee6-520a-8a8a-9a50d01cb23f -->
  <rule id="410381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2133 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>