<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2455 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 75c809a0-d856-5b99-83b6-c200f62cf087 -->
  <rule id="412809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2455 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>