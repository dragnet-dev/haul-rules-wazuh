<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0853 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d016d53d-725a-5a95-9e75-caee70e53c40 -->
  <rule id="382695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0853 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>