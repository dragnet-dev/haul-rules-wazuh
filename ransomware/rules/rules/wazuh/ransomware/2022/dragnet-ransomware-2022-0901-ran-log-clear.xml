<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0901 — Event Log Clearing (midas) | Status: deprecated | Sigma ID: f2d0ca99-b6b5-5107-9ddc-f20d88c7ab98 -->
  <rule id="959402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0901 — Event Log Clearing (midas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>