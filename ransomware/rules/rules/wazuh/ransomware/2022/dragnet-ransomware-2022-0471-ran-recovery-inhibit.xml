<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0471 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: caa386eb-9298-5c1b-988e-59d038db1837 -->
  <rule id="642386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0471 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>