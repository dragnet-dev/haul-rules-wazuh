<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2009 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: bdff1875-d1b5-57cd-ba01-f0fc47ecbea4 -->
  <rule id="463918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2009 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>