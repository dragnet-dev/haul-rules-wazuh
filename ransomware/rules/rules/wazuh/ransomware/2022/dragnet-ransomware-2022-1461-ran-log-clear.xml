<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1461 — Event Log Clearing (midas) | Status: deprecated | Sigma ID: 16a003ee-6a15-51e2-b29d-fd3ce84811fe -->
  <rule id="756062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1461 — Event Log Clearing (midas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>