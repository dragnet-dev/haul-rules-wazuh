<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0648 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: be2184e7-1c4e-51aa-90ed-1b710e2edb7c -->
  <rule id="202184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0648 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>