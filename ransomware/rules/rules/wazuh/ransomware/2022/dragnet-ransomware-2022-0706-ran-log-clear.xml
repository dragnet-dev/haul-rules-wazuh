<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0706 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 21d8fe37-7d1d-5422-8833-104eaed6c1ba -->
  <rule id="957423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0706 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>