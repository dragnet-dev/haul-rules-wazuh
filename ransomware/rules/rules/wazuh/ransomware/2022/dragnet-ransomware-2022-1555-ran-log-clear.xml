<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1555 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 61e8cfe4-852b-5f8b-aca5-fff2d7fe35a5 -->
  <rule id="836655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1555 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>