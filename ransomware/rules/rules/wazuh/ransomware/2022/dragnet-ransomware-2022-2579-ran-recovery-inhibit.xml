<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2579 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: b4d5ebed-81c1-5168-8782-a44c6f1186c4 -->
  <rule id="304235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2579 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>