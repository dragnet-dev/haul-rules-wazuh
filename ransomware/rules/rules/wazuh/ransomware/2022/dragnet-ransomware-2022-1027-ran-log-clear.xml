<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1027 — Event Log Clearing (unsafe) | Status: deprecated | Sigma ID: e1dbede3-7701-5c4f-8b24-a9210103e170 -->
  <rule id="396877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1027 — Event Log Clearing (unsafe)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>