<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1463 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 901c16d4-6bd7-51ed-81e5-ad9db6f5db89 -->
  <rule id="642816" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1463 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>