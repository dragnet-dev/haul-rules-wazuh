<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2743 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: aa255678-79d7-58b6-ab75-198fef275308 -->
  <rule id="902556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2743 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>