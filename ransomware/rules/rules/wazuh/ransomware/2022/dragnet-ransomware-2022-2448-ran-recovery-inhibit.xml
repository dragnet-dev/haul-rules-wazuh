<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2448 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 259a8e17-cb5c-56da-a1bd-856376131f37 -->
  <rule id="447821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2448 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>