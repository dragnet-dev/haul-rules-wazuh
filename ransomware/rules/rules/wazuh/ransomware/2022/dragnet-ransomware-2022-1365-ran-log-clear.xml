<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1365 — Event Log Clearing (dataleak) | Status: deprecated | Sigma ID: 44a4dfa8-2b79-5a76-b521-0d039f5094a5 -->
  <rule id="129087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1365 — Event Log Clearing (dataleak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>