<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0617 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7b0af87f-47ad-52bd-b728-2d2c1cb8b149 -->
  <rule id="550558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0617 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>