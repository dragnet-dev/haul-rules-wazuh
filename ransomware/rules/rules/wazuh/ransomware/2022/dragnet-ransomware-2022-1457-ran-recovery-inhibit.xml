<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1457 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 246ff4c3-b305-5173-929f-14c2fd56c6b2 -->
  <rule id="317036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1457 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>