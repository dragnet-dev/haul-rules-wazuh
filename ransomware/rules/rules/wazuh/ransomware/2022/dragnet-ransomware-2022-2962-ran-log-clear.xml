<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2962 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 40a98b4b-c91f-5a2b-a2c5-e7853d72e84d -->
  <rule id="241579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2962 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>