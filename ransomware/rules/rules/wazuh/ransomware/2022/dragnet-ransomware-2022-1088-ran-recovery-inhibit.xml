<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1088 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2a17e7d9-3c7c-59e2-a920-ed070235186c -->
  <rule id="997885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1088 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>