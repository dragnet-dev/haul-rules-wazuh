<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2283 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 53033078-891b-50d6-b7d0-91d2233dc306 -->
  <rule id="903307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2283 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>