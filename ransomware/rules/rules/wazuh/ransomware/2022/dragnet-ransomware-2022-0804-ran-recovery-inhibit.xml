<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0804 — Recovery Inhibition (unsafe) | Status: deprecated | Sigma ID: 85331271-3b93-5cb6-8dd2-85da78af59af -->
  <rule id="533127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0804 — Recovery Inhibition (unsafe)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>