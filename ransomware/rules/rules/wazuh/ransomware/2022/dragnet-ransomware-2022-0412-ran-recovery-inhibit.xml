<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0412 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 06080170-bb03-5bfc-8a2a-5c53b5497290 -->
  <rule id="780170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0412 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
