<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1516 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: b374c720-db55-5b64-80f6-bea92c1357fc -->
  <rule id="119967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1516 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>