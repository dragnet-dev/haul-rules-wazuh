<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1992 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: ce8ca97a-8a7e-5ee8-820f-913333c69512 -->
  <rule id="896109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1992 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
