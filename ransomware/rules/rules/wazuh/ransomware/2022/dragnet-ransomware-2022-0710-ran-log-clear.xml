<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0710 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: edfd03e9-4f49-5a10-a1f2-67dbd5a8c593 -->
  <rule id="792503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0710 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>