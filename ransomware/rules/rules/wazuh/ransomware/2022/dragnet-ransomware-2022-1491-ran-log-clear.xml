<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1491 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 6ea43b90-1f1b-5746-95c7-4cd0928f7f63 -->
  <rule id="232699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1491 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>