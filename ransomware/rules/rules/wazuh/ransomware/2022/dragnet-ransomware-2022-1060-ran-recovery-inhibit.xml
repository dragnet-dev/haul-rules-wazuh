<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1060 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 77cffddc-49f4-535e-a2cf-e318f3ff2530 -->
  <rule id="699517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1060 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>