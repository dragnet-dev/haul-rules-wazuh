<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2072 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2021254b-b902-5a7b-bc2c-ea3946d57aea -->
  <rule id="321254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2072 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>