<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2506 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: fe437320-4c4e-51c7-9817-49317667985a -->
  <rule id="844373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2506 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>