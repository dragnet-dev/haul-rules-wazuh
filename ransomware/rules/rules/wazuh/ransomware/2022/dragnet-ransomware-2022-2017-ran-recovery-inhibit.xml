<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2017 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 333979bc-bcdb-574b-9355-38c6e8c90874 -->
  <rule id="943675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2017 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
