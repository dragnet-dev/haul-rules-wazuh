<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1370 — Recovery Inhibition (cheers) | Status: deprecated | Sigma ID: d945355b-85c8-5809-85b7-296fa95bf7f6 -->
  <rule id="594535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1370 — Recovery Inhibition (cheers)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
