<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2918 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 17560b3c-0a14-5962-b8e6-bcb8e5687964 -->
  <rule id="209713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2918 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>