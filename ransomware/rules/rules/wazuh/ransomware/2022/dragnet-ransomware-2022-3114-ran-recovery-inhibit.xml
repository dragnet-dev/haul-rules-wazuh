<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3114 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3674df15-afe0-5c47-83d3-402dec276d22 -->
  <rule id="507671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3114 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>