<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2129 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: e8b64b32-33d2-5a07-ac57-495664157b12 -->
  <rule id="307435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2129 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>