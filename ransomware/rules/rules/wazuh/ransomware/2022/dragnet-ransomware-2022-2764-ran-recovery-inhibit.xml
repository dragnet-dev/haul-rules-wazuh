<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2764 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 21e30474-633f-5d35-915d-6a190b0398d1 -->
  <rule id="903047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2764 — Recovery Inhibition (lockbit2)</description>
