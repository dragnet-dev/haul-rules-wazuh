<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2877 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 59a3efa5-b3f8-5cbf-9447-1eefa198c620 -->
  <rule id="743247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2877 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>