<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0718 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 97e548e7-ea54-580b-aeea-06e2e266427c -->
  <rule id="766548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0718 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
