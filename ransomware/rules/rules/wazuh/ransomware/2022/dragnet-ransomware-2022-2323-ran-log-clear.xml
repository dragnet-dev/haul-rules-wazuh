<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2323 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: d967a065-cd25-5920-b8ce-b578b939ad87 -->
  <rule id="534820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2323 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>