<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2092 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 832c2ab2-f7a2-5853-ae30-9fdf8fc0554a -->
  <rule id="431882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2092 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>