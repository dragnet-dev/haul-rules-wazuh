<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0440 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6fcdbcb6-c7fd-58d9-a18c-a38bd78737a3 -->
  <rule id="227164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0440 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>