<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2769 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: db9e62bc-88b1-5197-bb64-32ef26c02bc6 -->
  <rule id="919862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2769 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>