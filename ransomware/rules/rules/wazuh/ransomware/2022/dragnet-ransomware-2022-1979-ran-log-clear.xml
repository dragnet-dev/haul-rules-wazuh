<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1979 — Event Log Clearing (alphv) | Status: deprecated | Sigma ID: 7d2f162c-e28e-5e97-abe5-d654a8cd8a86 -->
  <rule id="304716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1979 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>