<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0197 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 65df99d8-2014-5417-9bee-b30abe492832 -->
  <rule id="886399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0197 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
