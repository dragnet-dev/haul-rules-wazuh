<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2004 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 21c9c65c-c3d5-5c83-a9d9-abc4c1574122 -->
  <rule id="283665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2004 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>