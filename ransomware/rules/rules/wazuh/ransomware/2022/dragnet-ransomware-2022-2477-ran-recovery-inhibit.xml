<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2477 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 8d523345-f3ab-5fc9-8185-0ae66369cc80 -->
  <rule id="615233" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2477 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>