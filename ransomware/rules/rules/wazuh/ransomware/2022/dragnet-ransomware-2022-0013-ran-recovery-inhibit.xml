<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0013 — Recovery Inhibition (lorenz) | Status: experimental | Sigma ID: 59c01f7d-5e64-53d5-a1c6-780894f2108a -->
  <rule id="729631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0013 — Recovery Inhibition (lorenz)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>