<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0423 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 63a102b7-4add-5a0a-8791-631cd3ee7282 -->
  <rule id="218102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0423 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>