<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2504 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2c499dd4-2c1c-52cd-aa80-d6b36471b180 -->
  <rule id="691965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2504 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>