<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0482 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: b5fea0be-d921-5198-b7e4-5a04de40a999 -->
  <rule id="351140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0482 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>