<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2788 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: 78776fb4-6ad5-5f7f-bc9b-d8f4ad7690fc -->
  <rule id="460431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2788 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>