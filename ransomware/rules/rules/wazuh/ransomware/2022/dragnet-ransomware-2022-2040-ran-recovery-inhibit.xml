<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2040 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5b8e2df3-5cba-5d20-b1ca-43c7ee49891d -->
  <rule id="652365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2040 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>