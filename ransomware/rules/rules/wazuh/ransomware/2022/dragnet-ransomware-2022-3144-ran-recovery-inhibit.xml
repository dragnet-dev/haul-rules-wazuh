<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3144 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6b9b610c-9bd3-5756-ac52-c41904811a04 -->
  <rule id="927561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3144 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>