<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1701 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 59281d02-b66f-5d6b-b097-bbc91d4a7e76 -->
  <rule id="585090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1701 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>