<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0178 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 507a7304-2ad4-5fea-97ab-f76a1c98708c -->
  <rule id="122730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0178 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>