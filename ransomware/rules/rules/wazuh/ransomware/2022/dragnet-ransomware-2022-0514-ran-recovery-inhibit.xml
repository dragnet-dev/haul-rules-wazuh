<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0514 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7ca7f2c2-f903-552e-b6b5-c9031762536a -->
  <rule id="591672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0514 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>