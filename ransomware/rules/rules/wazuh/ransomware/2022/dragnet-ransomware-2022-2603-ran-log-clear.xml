<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2603 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: be9e6e03-da9c-5b6f-a605-39f80d74d7fc -->
  <rule id="489390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2603 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>