<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2923 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e173dd61-9353-5857-a27a-877c12696ff3 -->
  <rule id="128509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2923 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>