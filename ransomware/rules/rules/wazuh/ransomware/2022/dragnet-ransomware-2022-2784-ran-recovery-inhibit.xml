<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2784 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 50481b5a-e1fd-5e8b-8fe2-a539d123c265 -->
  <rule id="977075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2784 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>