<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2880 — Event Log Clearing (icefire) | Status: deprecated | Sigma ID: cf00b905-1855-5c67-b686-27127b32fa97 -->
  <rule id="712119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2880 — Event Log Clearing (icefire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>