<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1968 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: eff6f5c5-af6a-59f8-85f5-239857c5f413 -->
  <rule id="843515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1968 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>