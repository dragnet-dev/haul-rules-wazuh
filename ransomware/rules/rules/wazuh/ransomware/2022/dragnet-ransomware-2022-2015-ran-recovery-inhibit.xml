<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2015 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 535647a3-8ca2-5dc8-a4d9-0162a6785b7e -->
  <rule id="570362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2015 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>