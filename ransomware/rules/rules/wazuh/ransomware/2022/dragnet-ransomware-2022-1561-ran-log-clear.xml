<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1561 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 05cd4a52-01b9-504c-bc10-20a4cc88bd88 -->
  <rule id="676745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1561 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>