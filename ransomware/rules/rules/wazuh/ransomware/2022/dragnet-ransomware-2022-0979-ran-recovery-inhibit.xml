<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0979 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 40632363-7f1b-58a7-8887-18db38df926a -->
  <rule id="563236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0979 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>