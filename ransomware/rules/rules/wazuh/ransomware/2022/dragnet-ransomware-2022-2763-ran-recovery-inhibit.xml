<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2763 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: e495d0ec-ada2-5ea2-b117-dad30031ded4 -->
  <rule id="619330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2763 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>