<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1431 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 593af261-c849-5620-a86a-ef4304093a02 -->
  <rule id="719832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1431 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>