<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2301 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ad0ef629-a89c-5ee3-8157-8c708a19cf88 -->
  <rule id="931196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2301 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>