<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1091 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: ebd5e0ea-5db1-56cf-9a56-e8dd89c3329f -->
  <rule id="737740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1091 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>