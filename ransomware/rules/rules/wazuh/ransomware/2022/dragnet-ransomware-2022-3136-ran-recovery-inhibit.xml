<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3136 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e3781084-dad4-52ab-bbfd-5917d76a526a -->
  <rule id="637810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3136 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>