<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1971 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c242ac49-24b9-5faa-b590-20369900a263 -->
  <rule id="534124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1971 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>