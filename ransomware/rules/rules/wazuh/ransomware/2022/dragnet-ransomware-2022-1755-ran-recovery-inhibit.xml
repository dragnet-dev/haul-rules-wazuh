<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1755 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 8cdb5763-72f6-5089-bfb6-3356bd708a99 -->
  <rule id="105957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1755 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
