<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2136 — Recovery Inhibition (kelvinsecurity) | Status: deprecated | Sigma ID: e879059b-9210-570d-9b42-805399babf7d -->
  <rule id="687905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2136 — Recovery Inhibition (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
