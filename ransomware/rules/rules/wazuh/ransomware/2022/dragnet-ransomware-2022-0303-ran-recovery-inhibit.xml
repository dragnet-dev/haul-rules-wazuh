<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0303 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 1d48e6b8-5f16-5165-8937-00ae98bb1503 -->
  <rule id="449227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0303 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>