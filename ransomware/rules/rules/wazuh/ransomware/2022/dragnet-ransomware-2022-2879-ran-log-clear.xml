<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2879 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: ee6f17ff-95f6-5d90-96d8-2bf4f184de42 -->
  <rule id="319117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2879 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>