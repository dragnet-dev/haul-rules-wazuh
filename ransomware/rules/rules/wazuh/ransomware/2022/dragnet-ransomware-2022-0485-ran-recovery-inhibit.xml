<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0485 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d4ca137f-3257-592b-ad56-6657dc1b06b3 -->
  <rule id="850613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0485 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>