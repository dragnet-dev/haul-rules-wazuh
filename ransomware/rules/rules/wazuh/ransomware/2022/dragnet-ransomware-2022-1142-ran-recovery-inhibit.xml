<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1142 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 9caee600-08fd-58c0-bb38-cfcd00f51f12 -->
  <rule id="217746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1142 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>