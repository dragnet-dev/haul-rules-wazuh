<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0299 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 50152492-946c-5a69-a2dd-0e5b5561304f -->
  <rule id="615249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0299 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>