<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0096 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3c743138-4c30-5ae1-b8b9-05e1156dcfc5 -->
  <rule id="774313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0096 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>