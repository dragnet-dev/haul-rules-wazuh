<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1666 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 676d863a-4449-53e5-8f62-b728578c4afa -->
  <rule id="282986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1666 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>