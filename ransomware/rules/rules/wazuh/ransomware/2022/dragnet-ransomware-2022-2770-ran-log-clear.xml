<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2770 — Event Log Clearing (0mega) | Status: deprecated | Sigma ID: d3bb3790-f948-5745-89c0-47be605d40d5 -->
  <rule id="823537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2770 — Event Log Clearing (0mega)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>