<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0112 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 0aa3aa05-a765-53b5-9814-144e98216ee1 -->
  <rule id="861380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0112 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>