<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0777 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: e4e26c1c-e017-5169-8a47-2e281e6a2ae9 -->
  <rule id="209228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0777 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>