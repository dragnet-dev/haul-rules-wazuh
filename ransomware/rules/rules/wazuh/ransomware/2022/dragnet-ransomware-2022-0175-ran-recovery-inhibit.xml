<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0175 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: 31552991-b2bc-50ae-9745-7077fdb5d24f -->
  <rule id="555299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0175 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>