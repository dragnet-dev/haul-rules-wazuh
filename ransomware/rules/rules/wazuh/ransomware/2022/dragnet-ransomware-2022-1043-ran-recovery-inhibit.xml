<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1043 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 528a305b-61f4-517b-8995-a26cb3ad3e00 -->
  <rule id="458305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1043 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>