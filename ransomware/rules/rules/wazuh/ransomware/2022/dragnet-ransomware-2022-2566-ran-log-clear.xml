<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2566 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 6a083001-dfa5-5035-9e1c-ab1b6dfa55ab -->
  <rule id="260830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2566 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>