<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2500 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 48dc9811-b8bf-5707-85c1-8dd38743b52c -->
  <rule id="450898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2500 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
