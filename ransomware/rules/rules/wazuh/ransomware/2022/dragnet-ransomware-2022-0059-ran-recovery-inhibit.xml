<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0059 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 53265a54-00e4-5a83-8e9c-ca4054d2f31e -->
  <rule id="522505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0059 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>