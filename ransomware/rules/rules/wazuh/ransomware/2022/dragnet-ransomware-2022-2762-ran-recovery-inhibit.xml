<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2762 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d5dbba16-8c62-5824-8e81-c25890f5d727 -->
  <rule id="903610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2762 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>