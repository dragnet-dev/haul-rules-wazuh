<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3137 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 29e4dd2a-70fa-570c-ba45-4b14d2b597e6 -->
  <rule id="424925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3137 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>