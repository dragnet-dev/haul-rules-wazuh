<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1095 — Event Log Clearing (nightsky) | Status: deprecated | Sigma ID: 31db3bb7-c695-5ce1-8d57-3b3c73f7908a -->
  <rule id="504859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1095 — Event Log Clearing (nightsky)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>