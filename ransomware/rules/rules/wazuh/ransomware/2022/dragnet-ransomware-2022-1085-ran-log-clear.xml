<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1085 — Event Log Clearing (freecivilian) | Status: deprecated | Sigma ID: 514062d2-c388-5e6f-bd8c-47a057f63fd4 -->
  <rule id="225005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1085 — Event Log Clearing (freecivilian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>