<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1629 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 6fae8e40-ee00-55e3-9514-59aa7887a9bf -->
  <rule id="174542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1629 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
