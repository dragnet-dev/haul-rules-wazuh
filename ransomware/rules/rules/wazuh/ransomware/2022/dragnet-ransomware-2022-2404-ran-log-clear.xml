<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2404 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: b95f53e6-2673-59b3-8efe-2a9c20e372c2 -->
  <rule id="213553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2404 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>