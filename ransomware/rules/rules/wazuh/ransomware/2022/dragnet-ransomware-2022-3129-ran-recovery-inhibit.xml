<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3129 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f2328718-ee0e-5f39-86ef-003ffa710c23 -->
  <rule id="723287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3129 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
