<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1681 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: b8e27a62-bc8c-52ab-9250-da0cefca5ff9 -->
  <rule id="443642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1681 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>