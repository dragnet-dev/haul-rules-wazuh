<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0102 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1b381427-e9dc-536c-9a18-750f45f1f2e6 -->
  <rule id="138142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0102 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>