<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1762 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 9ed4d146-ddbd-5576-baa9-2c14069e5b37 -->
  <rule id="566371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1762 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>