<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2397 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 54f655e0-d8a5-508f-ba5b-8b6d3fa87824 -->
  <rule id="674494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2397 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
