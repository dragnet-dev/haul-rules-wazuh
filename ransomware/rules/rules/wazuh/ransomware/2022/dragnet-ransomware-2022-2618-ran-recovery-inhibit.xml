<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2618 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a9263e36-dcde-5c06-8b60-611fb4c24824 -->
  <rule id="948222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2618 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>