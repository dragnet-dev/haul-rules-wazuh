<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2334 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 8de3b99a-2256-59ee-9fbc-ce7d5526a14b -->
  <rule id="132599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2334 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>