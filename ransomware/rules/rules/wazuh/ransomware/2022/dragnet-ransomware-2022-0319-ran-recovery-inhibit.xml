<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0319 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 088f9858-bed7-5385-b382-75c89ed3fd67 -->
  <rule id="623985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0319 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>