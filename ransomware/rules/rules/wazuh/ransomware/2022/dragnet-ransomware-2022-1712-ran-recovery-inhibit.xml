<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1712 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 0018d5b8-5065-5e51-adcf-e3603ced304e -->
  <rule id="425185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1712 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>