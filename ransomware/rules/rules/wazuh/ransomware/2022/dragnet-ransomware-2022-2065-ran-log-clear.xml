<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2065 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 451bdb72-9b8d-56c0-abb2-c04c021a01cb -->
  <rule id="150331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2065 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>