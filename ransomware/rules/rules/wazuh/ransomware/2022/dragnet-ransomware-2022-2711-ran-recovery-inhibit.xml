<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2711 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8115b18e-df47-5dd1-aadd-21c4459db936 -->
  <rule id="498511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2711 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>