<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2098 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 2839d05d-ccdc-5827-abd2-3bdc780fbdc1 -->
  <rule id="143705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2098 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>