<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0573 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4a94bfc4-b061-57b2-b6a3-5a04185d0a75 -->
  <rule id="218655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0573 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>