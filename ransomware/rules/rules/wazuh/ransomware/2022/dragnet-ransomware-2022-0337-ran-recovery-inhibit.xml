<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0337 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b3602823-96d1-5144-864c-dee5c5620d78 -->
  <rule id="336028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0337 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>