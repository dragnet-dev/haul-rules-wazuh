<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2167 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 7749a414-fbf1-5898-a1e3-87f0622ca260 -->
  <rule id="439944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2167 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>