<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1324 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 445aaf65-a288-5cea-b4c2-c84b3a987a62 -->
  <rule id="125455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1324 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>