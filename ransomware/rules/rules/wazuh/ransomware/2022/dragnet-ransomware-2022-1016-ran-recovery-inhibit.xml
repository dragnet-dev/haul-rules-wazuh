<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1016 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 1508d676-39a3-5795-bae2-0e3a6812d0f7 -->
  <rule id="714167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1016 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>