<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2524 — Event Log Clearing (shaoleaks) | Status: deprecated | Sigma ID: e2868e18-49db-5f04-9d55-1f381b5ace8d -->
  <rule id="585902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2524 — Event Log Clearing (shaoleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>