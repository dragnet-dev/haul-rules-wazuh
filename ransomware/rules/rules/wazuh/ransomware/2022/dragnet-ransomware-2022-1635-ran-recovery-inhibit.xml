<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1635 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8ddee663-2777-50a2-86fb-f60d9bf7fc9e -->
  <rule id="511026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1635 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>