<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2193 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d6cb6b73-4848-5f37-8a42-f5e2c9b49b57 -->
  <rule id="303147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2193 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>