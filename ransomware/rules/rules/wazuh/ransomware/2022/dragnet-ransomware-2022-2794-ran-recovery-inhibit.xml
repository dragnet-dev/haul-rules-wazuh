<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2794 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: e250636c-81bc-5023-bb44-936ed7910587 -->
  <rule id="625063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2794 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>