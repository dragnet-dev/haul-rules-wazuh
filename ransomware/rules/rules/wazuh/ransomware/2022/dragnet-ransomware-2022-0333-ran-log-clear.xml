<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0333 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 3c0b6ff9-0983-5b48-b54e-7db9f67cabd9 -->
  <rule id="737871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0333 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>