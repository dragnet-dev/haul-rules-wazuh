<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2184 — Event Log Clearing (alphv) | Status: deprecated | Sigma ID: 0f4c95ae-d08c-5636-8484-c7d520cbb4c2 -->
  <rule id="463130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2184 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>