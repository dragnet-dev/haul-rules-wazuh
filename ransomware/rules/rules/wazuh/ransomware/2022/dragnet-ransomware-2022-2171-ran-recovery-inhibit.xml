<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2171 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 93f6f9d0-9c77-5188-900f-189557df30df -->
  <rule id="705919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2171 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>