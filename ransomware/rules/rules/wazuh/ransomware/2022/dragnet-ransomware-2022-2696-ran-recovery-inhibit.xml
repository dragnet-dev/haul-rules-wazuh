<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2696 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e7b2a64f-0949-5f74-beab-9bf1d1489621 -->
  <rule id="281226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2696 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>