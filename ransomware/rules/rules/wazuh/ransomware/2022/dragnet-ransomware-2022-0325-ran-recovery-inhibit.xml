<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0325 — Recovery Inhibition (projectrelic) | Status: deprecated | Sigma ID: ece32472-6d62-509d-8cc9-dd12569fa22f -->
  <rule id="290324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0325 — Recovery Inhibition (projectrelic)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
