<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2146 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: fc828c70-3538-5864-a20b-8aad6044daab -->
  <rule id="545260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2146 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>