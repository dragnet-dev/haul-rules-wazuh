<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0249 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 767742cc-7077-5ac6-a1a0-0f58044f8c61 -->
  <rule id="683884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0249 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>