<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1231 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: b9ef9db6-489f-54bc-9187-ec9dbd1038f2 -->
  <rule id="512637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1231 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>