<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3093 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 81113881-e40d-52e4-bf78-645629a9f717 -->
  <rule id="111388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3093 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>