<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1517 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: a7430885-483d-5cb6-89e5-b8c8fe00ed52 -->
  <rule id="274308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1517 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>