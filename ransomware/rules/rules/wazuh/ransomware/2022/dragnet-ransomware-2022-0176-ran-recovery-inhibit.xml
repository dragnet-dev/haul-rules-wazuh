<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0176 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: d7c5a5a9-f880-508d-9aa8-0129012ea230 -->
  <rule id="927305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0176 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>