<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2382 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: d4d3d3d3-f4b5-589e-aff0-4a01274fffe4 -->
  <rule id="851813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2382 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>