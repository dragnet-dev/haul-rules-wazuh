<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0771 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 6e580e50-f484-57ec-978a-12fae1ac76e6 -->
  <rule id="969294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0771 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
