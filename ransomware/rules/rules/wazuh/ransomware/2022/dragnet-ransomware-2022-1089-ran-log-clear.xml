<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1089 — Event Log Clearing (payloadbin) | Status: deprecated | Sigma ID: 565994c2-638b-5624-9049-854c3194aa5e -->
  <rule id="155916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1089 — Event Log Clearing (payloadbin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>