<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2686 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 71276cd3-49ed-51f6-9251-f5a609fc7f91 -->
  <rule id="340428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2686 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>