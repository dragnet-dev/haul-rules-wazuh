<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2144 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: c01e9f82-7b20-5fcb-a570-382cd801f6db -->
  <rule id="476959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2144 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>