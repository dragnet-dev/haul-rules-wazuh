<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1612 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: 6ffc116c-112b-57fb-98d9-7f25d8b21fa0 -->
  <rule id="266811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1612 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>