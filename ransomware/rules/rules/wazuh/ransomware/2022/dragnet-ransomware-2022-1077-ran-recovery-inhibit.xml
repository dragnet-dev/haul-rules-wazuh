<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1077 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 59ca8ff2-9523-5e18-b603-0cb5e13f2f9e -->
  <rule id="749103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1077 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>