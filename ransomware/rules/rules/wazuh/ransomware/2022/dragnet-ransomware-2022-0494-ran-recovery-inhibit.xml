<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0494 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: b84778d6-351d-508e-93c7-b22cf13f20e1 -->
  <rule id="384778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0494 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>