<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0283 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 7054006c-b187-5c0a-bed4-87e13925b12a -->
  <rule id="854006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0283 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>