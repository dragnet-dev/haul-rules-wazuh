<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1024 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 9154bed8-7857-5525-a31a-9e6922da3c2c -->
  <rule id="643614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1024 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>