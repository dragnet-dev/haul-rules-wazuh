<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1373 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: c2a097f4-d075-5178-84c9-7a4039fd833e -->
  <rule id="262097" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1373 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>