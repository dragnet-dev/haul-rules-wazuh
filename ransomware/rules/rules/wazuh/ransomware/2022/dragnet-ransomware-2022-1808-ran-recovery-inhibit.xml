<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1808 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: a620fdaa-8815-57aa-8b22-ef636966c6e7 -->
  <rule id="118973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1808 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
