<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2756 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ecd32c27-41ac-584b-be08-2df9444df804 -->
  <rule id="762924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2756 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
