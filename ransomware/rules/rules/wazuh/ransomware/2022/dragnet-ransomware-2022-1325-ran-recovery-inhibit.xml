<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1325 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c3ae3b98-1eef-52d6-a6fb-d0d5cc5ecb48 -->
  <rule id="665979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1325 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>