<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0478 — Event Log Clearing (mindware) | Status: deprecated | Sigma ID: eb4c03a3-182d-5592-98de-2b077ebec147 -->
  <rule id="267603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0478 — Event Log Clearing (mindware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>