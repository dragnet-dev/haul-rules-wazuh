<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1786 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b5c96d4f-87b4-585c-90de-f9c1841a5091 -->
  <rule id="364749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1786 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>