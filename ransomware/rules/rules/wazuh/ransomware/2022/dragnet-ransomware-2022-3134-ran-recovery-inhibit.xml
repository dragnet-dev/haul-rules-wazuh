<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3134 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 28e8d40c-ed7e-55c5-adb6-f42580d01fbe -->
  <rule id="306140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3134 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>