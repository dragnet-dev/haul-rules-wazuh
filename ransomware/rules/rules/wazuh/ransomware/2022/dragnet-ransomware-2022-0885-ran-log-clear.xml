<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0885 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 0717f0a8-1428-58e3-969a-3ee3837c002e -->
  <rule id="137930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0885 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>