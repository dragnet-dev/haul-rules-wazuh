<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2981 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a06cc66b-0a21-54eb-abe2-a98914223122 -->
  <rule id="877406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2981 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>