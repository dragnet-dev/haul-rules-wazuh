<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3018 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 77ab1093-e443-5dcd-b43a-3cd775fdc2f5 -->
  <rule id="288310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3018 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>