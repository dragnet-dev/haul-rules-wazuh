<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0606 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 65cb805a-6144-58e4-99d5-65f512156b21 -->
  <rule id="884380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0606 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>