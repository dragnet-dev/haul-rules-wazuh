<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1832 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 532501b5-4489-5ad5-95cf-7109e18b2c53 -->
  <rule id="520027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1832 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>