<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1190 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: de2e10ce-38c4-57a9-a86c-92a11fe3d357 -->
  <rule id="956610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1190 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>