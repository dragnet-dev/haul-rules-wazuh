  <rule id="349407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2200 — Recovery Inhibition (cheers)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
