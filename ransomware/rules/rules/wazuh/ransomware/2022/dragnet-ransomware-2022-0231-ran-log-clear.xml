<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0231 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: bc44dcf8-47ce-57ac-b709-6fa49725c18b -->
  <rule id="424284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0231 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>