<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0985 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8a2af13a-58ba-5af8-a79c-e56573a746b4 -->
  <rule id="939671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0985 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>