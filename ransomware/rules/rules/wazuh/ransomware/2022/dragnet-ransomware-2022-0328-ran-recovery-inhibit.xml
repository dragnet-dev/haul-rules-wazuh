<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0328 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: b228c0c4-e7c4-5185-8759-f02ad68904ef -->
  <rule id="996600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0328 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>