<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3076 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 397b3090-3680-5811-8379-086e55ac5f5c -->
  <rule id="163309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3076 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>