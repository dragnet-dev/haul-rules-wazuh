<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1598 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 56850c8c-63d1-5be7-86c4-8991da141d4c -->
  <rule id="196128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1598 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
