<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2140 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6e78e595-855f-5a57-a2f5-a5be08f372a7 -->
  <rule id="972625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2140 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>