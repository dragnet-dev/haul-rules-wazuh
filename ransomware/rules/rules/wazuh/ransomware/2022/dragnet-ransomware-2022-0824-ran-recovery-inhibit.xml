<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0824 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 42253a7f-0d82-51f4-8b14-01881990b7de -->
  <rule id="560587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0824 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>