<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1083 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: bdc10292-002a-593b-b08e-99d6b5aa8120 -->
  <rule id="436102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1083 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>