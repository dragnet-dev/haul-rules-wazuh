<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1021 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4cea5273-be9a-51a0-b5b7-7fd5b62f2e34 -->
  <rule id="269052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1021 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>