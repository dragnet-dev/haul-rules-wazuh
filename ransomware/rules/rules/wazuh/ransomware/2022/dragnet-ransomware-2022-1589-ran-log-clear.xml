<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1589 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: e7e031ce-6dc3-5b6b-a1d7-13ba42b08c62 -->
  <rule id="666031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1589 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>