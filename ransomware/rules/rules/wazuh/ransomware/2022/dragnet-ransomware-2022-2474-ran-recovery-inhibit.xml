<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2474 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 38658585-e691-52d8-a2e1-15bd3be0a19e -->
  <rule id="365858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2474 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>