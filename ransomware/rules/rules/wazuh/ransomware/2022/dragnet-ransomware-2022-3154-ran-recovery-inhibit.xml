<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3154 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: cc9b3843-4d4c-5761-bc69-3547db37b8bc -->
  <rule id="679538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3154 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
