<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0949 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 21f73742-679d-5549-9b17-3dd647960653 -->
  <rule id="917374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0949 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>