<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2761 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bc206389-c38a-5d64-89d3-431f6b26bbc0 -->
  <rule id="182063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2761 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>