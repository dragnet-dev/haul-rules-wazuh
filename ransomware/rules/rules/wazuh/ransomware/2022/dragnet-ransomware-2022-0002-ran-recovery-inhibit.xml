<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0002 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e1beb48e-5c34-58bc-8fa6-e65cc902eb78 -->
  <rule id="505874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0002 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>