<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2964 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 63c22abc-d41a-5665-88ea-766311a307d7 -->
  <rule id="832362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2964 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
