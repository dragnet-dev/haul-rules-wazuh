<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0483 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 33619f0e-8c05-564b-9741-915e8d903284 -->
  <rule id="979190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0483 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>