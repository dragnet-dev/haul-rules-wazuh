<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2411 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: d8780570-7a7d-520c-a328-ae9184ca48f9 -->
  <rule id="587805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2411 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
