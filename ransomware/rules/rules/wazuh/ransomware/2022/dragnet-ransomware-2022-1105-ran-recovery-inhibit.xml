<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1105 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 134a3b6e-339f-5ce9-ad3a-711ddbe6ebd1 -->
  <rule id="846996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1105 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
