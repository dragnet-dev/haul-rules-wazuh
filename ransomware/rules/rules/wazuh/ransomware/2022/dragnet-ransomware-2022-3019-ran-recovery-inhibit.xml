<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3019 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4d68ce51-6e44-57ef-8e8e-11e163fccec6 -->
  <rule id="288814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3019 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>