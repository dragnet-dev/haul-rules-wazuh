<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0214 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 12838655-7b99-56c3-a115-54ba36f168da -->
  <rule id="483865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0214 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>