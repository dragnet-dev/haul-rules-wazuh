<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0189 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b6c60839-f78d-55e6-9cfe-c0abb0240a0b -->
  <rule id="168608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0189 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>