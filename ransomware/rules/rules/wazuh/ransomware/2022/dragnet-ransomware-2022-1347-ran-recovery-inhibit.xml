<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1347 — Recovery Inhibition (pandora) | Status: deprecated | Sigma ID: c3b209cd-f925-5989-a400-e1844e2f5b94 -->
  <rule id="279209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1347 — Recovery Inhibition (pandora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>