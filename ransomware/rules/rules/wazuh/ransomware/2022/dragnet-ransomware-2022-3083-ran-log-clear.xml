<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3083 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 87aec6d0-3c4f-53aa-b3ff-5dd72b93f2a8 -->
  <rule id="991486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3083 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>