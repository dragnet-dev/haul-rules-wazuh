<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2746 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6b54c783-9103-5163-af7a-4935562b51a0 -->
  <rule id="920767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2746 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>