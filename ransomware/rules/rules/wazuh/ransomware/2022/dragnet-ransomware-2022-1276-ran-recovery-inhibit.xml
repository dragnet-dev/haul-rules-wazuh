<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1276 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7624431d-6544-5c8e-82f4-66f828ba2a8d -->
  <rule id="524431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1276 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>