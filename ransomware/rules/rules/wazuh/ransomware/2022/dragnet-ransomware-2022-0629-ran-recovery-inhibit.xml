<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0629 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 7502c7ab-63b4-5246-851d-a3c78e2d53ad -->
  <rule id="400447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0629 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>