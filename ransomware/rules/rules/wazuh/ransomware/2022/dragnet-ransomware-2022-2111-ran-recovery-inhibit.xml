  <rule id="240858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2111 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
