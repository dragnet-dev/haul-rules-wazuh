<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1653 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: fa3c1ca5-1af8-500d-a556-35a95f2fe401 -->
  <rule id="209628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1653 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>