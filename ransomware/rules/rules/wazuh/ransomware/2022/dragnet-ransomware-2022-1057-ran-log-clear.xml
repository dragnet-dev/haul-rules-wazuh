<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1057 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: b1c5fc03-ebeb-5331-9025-0c2844f88528 -->
  <rule id="178812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1057 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>