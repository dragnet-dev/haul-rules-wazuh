<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0471 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 1b13b40d-66b1-52d9-83a3-3a49b0df7c42 -->
  <rule id="841940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0471 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>