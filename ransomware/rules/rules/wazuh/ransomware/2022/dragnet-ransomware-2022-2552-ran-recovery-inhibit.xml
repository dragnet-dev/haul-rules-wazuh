<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2552 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 377c53a0-2a54-5fd8-9424-06864a9cbd93 -->
  <rule id="771258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2552 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>