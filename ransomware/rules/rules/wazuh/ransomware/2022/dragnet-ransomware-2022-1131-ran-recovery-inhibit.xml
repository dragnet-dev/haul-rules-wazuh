<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1131 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 25017076-b8db-5668-ace1-873b8fb8c565 -->
  <rule id="801707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1131 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>