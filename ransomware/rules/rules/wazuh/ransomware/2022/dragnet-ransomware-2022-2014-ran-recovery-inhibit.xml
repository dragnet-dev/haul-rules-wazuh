<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2014 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: f2dcc463-3e6d-56b4-800d-7a4806d10fc7 -->
  <rule id="961244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2014 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>