<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2925 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 858a550b-2e05-570f-b805-a02ccc8b37d9 -->
  <rule id="573855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2925 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>