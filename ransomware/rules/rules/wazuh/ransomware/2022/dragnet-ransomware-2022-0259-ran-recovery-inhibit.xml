<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0259 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 14e20800-9783-5ca3-8544-c6b8659ad342 -->
  <rule id="682080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0259 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>