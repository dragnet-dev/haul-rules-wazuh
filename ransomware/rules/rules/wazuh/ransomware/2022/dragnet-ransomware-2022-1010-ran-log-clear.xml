<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1010 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: be49e1c6-af52-5acc-96d9-87c601987ae5 -->
  <rule id="447981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1010 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>