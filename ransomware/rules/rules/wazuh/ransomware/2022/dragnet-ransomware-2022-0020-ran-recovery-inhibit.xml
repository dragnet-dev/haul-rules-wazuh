<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0020 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1e5660b3-8b7e-541c-a42a-033483f1d706 -->
  <rule id="490571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0020 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>