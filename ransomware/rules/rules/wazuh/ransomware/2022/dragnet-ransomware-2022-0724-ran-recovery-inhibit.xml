<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0724 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 827f92c2-7fa1-5cee-b86d-327d31fede88 -->
  <rule id="524792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0724 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>