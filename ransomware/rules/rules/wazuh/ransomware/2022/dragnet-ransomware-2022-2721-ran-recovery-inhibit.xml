<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2721 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 37963d43-4de1-5be4-aca2-f0b27f97e344 -->
  <rule id="774214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2721 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>