<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0209 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: b8cf91b5-3460-5840-a827-66fc84b990e3 -->
  <rule id="441591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0209 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>