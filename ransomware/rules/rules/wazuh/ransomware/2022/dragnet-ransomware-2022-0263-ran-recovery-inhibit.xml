<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0263 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: e4ff672e-39a6-5547-bad9-4d8ae68dcfcd -->
  <rule id="211967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0263 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>