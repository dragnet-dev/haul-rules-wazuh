<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3127 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: bf88a1a0-bc82-58f9-aede-8ca7eb7ba4e5 -->
  <rule id="470181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3127 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>