<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0115 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: f5b5c46c-26a9-54f7-a634-4353c7ea1c7d -->
  <rule id="486524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0115 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>