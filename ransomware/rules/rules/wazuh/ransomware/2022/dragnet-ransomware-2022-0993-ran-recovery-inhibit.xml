<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0993 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: fa3f3716-6455-567f-b332-bc4b95aa59df -->
  <rule id="506337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0993 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>