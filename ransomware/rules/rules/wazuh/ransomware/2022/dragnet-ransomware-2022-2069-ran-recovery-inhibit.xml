<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2069 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 56c29b9d-6b25-5e48-a4a2-4a4384c7da28 -->
  <rule id="653275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2069 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>