<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1844 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 3c32d320-3f15-5d9c-b3ac-4dac6f720f39 -->
  <rule id="752532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1844 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>