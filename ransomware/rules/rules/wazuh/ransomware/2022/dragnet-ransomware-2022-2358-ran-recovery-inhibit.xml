  <rule id="424764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2358 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
