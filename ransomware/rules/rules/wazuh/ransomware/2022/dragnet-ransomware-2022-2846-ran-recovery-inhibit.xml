<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2846 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 37de680b-24aa-5881-99db-0095545885c9 -->
  <rule id="794680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2846 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>