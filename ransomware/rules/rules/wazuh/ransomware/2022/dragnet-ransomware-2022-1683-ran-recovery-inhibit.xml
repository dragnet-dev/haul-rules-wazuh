<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1683 — Recovery Inhibition (la_piovra) | Status: experimental | Sigma ID: 1e070186-088b-5532-9a49-507a97c39a95 -->
  <rule id="407018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1683 — Recovery Inhibition (la_piovra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>