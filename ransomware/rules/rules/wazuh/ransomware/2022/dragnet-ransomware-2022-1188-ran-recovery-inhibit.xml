<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1188 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: d1676045-4e59-5495-80f5-6a7d050003eb -->
  <rule id="516760" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1188 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>