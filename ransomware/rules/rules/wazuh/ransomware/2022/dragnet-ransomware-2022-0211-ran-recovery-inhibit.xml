<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0211 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c16ce17e-620b-5888-9b99-d00c5d1ed110 -->
  <rule id="515021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0211 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>