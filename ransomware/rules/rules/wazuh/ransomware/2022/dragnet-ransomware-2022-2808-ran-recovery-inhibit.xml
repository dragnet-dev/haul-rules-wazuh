<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2808 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 785c4257-48c4-5b03-b30d-bfaf535d8121 -->
  <rule id="457242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2808 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>