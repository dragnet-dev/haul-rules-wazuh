<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0737 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c82205c4-89f0-54aa-8f74-f8a16400be3a -->
  <rule id="482205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0737 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>