<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1330 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d0ba5345-88f5-593d-89f2-6370b390c014 -->
  <rule id="746653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1330 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>