<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0163 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 18e8e07d-7ee5-5ae9-b0aa-01efe7c65898 -->
  <rule id="446207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0163 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>