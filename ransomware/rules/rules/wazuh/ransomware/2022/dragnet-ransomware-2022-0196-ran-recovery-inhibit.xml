<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0196 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5cacfad4-15f2-5c6d-a292-a02db219853c -->
  <rule id="773594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0196 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>