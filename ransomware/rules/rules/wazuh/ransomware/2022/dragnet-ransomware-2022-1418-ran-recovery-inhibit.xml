<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1418 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 31e869bd-ec56-576b-8cc2-3b8867ac826d -->
  <rule id="173915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1418 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>