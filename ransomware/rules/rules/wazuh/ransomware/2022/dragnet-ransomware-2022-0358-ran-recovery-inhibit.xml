<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0358 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 8c8d2464-6278-52c2-aaa2-43d3c31a6945 -->
  <rule id="554124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0358 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>