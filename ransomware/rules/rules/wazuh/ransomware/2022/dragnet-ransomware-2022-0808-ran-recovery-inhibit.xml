<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0808 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: fb3fb690-70b4-5b42-8122-f70e009f13f3 -->
  <rule id="235796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0808 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>