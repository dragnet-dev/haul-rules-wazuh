<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2126 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: c0c57a58-6420-5242-a546-2e3163416cd1 -->
  <rule id="492122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2126 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>