<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1797 — Event Log Clearing (lv) | Status: deprecated | Sigma ID: d8e9f1ab-45f3-5cdc-8bfa-e623d0c83c5d -->
  <rule id="956791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1797 — Event Log Clearing (lv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>