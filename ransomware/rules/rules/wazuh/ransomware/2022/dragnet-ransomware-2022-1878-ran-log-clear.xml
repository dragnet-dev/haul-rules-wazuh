<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1878 — Event Log Clearing (play) | Status: deprecated | Sigma ID: 8aed60f2-3b35-59dd-a7aa-2d7b2b540db6 -->
  <rule id="956560" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1878 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>