<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0144 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3afe9028-77de-51e4-9695-bc199b05a705 -->
  <rule id="710290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0144 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>