<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0729 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 32d6ee31-0d31-5aa8-9914-f1c25b5c8f19 -->
  <rule id="545774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0729 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>