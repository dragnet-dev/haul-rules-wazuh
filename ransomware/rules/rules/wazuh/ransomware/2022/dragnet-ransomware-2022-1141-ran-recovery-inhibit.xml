<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1141 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 817f7855-e659-5838-92a0-3fe5121c2857 -->
  <rule id="508778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1141 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
