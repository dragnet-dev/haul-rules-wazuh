<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0210 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b9970b82-57e9-5631-8609-f2ad8dc6f841 -->
  <rule id="219531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0210 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>