<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1220 — Event Log Clearing (play) | Status: deprecated | Sigma ID: ca1bd2fb-1ddb-5e4c-89f7-20a909b882b3 -->
  <rule id="775652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1220 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>