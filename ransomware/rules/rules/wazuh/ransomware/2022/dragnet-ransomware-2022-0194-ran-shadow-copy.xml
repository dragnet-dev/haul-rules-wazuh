<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0194 — Shadow Copy Deletion (leaktheanalyst) | Status: deprecated | Sigma ID: 6760c9a5-f183-54b7-b02a-f291d4284328 -->
  <rule id="281729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0194 — Shadow Copy Deletion (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>