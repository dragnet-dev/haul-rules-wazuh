<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3066 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 7965de1b-de4d-5948-965e-a2748b3b3999 -->
  <rule id="339262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3066 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>