<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1334 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 23400514-303e-5876-a47f-ba3f7f185d93 -->
  <rule id="640051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1334 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>