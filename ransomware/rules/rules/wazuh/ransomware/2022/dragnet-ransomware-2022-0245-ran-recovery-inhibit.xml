<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0245 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 3849e8a9-f350-5329-b7b8-d0cae520019e -->
  <rule id="955818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0245 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>