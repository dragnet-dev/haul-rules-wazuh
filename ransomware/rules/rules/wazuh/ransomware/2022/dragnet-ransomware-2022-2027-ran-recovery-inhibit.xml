<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2027 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ef7eda9a-e292-56c9-8252-73e58b8384e9 -->
  <rule id="921914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2027 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>