<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0832 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 796ac830-f35a-59a5-9bdb-4d8b1c6c1070 -->
  <rule id="339488" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0832 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>