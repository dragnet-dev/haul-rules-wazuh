<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1188 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: d7e1b384-bfc8-5a0b-b8a0-fda33d29f925 -->
  <rule id="929873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1188 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>