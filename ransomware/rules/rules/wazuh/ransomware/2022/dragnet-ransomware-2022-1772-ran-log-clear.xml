<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1772 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 9465aa26-bf22-54fe-befe-f0ce9dfb698e -->
  <rule id="723210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1772 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>