<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2864 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4ac2e186-f484-5060-9a8a-05a1917cb3c1 -->
  <rule id="214061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2864 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>