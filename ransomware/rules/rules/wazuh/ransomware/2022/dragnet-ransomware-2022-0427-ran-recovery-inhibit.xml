<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0427 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e4e2292b-ce27-5735-974f-0085df07d347 -->
  <rule id="618229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0427 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>