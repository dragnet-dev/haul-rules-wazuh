<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2672 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 5fdc6926-dbfb-5949-bdf4-aa4dd0841711 -->
  <rule id="754069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2672 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>