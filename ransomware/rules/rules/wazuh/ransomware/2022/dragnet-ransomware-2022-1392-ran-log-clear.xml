<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1392 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: 1792e5e4-20ff-5a9a-8313-bb9ff1e408e7 -->
  <rule id="189854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1392 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>