<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0766 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c1135f8f-626a-5620-bad6-ae6edea3b056 -->
  <rule id="238175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0766 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>