<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1754 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: 2b9c0518-262d-5dc9-83af-bbb8dc4258c8 -->
  <rule id="836051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1754 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>