<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2856 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: deff8856-2c86-544d-bc74-8f1b2904f75c -->
  <rule id="408788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2856 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>