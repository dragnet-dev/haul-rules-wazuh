<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1777 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: 3a6c96fa-2c4e-52d3-8a98-6bfdb3756e72 -->
  <rule id="722351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1777 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>