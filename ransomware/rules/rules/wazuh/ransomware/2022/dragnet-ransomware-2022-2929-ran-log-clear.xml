<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2929 — Event Log Clearing (dataleak) | Status: deprecated | Sigma ID: f4d80a51-7928-569f-b987-d933504feff6 -->
  <rule id="464490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2929 — Event Log Clearing (dataleak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>