<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0023 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 75dbda54-64a5-5848-bcdb-785f3ee82912 -->
  <rule id="571482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0023 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>