<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0699 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 94e3544d-8ebb-501b-8b36-e13cce3f7627 -->
  <rule id="718354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0699 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>