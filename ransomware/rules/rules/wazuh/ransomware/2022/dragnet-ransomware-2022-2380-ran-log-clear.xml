<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2380 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 4525c1a3-b7ac-5f91-92b3-190f0c2cc8c8 -->
  <rule id="885946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2380 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>