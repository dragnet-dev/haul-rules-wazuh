<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2034 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7763288f-6418-5bb4-92b3-476f845e7bb2 -->
  <rule id="663288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2034 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>