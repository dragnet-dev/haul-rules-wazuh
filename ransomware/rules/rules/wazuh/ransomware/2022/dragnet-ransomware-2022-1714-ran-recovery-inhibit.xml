<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1714 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 79f8d59b-bd68-56ba-b373-299512079d7a -->
  <rule id="347815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1714 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>