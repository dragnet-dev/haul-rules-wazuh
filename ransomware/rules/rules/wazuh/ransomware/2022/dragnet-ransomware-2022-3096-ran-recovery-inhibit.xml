<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3096 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5bf83eab-ab09-5434-ad03-de8f3b19db94 -->
  <rule id="654942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3096 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>