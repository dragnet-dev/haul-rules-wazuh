<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3034 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 3556a2f3-a92f-5e83-9a58-8763e4815ed2 -->
  <rule id="205007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3034 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>