<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2377 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: cf246992-a96e-55cd-9537-77411069094e -->
  <rule id="372469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2377 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>