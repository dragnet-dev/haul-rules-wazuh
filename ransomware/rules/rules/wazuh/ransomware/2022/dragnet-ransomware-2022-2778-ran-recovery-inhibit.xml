<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2778 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 285c4070-b6fc-5dfe-b1c8-7593b45cd8c7 -->
  <rule id="172407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2778 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>