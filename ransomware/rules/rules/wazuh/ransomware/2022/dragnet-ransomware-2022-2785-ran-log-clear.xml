<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2785 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 75ae3e8a-d25d-5ed3-a1ba-c9a84dcaf5ee -->
  <rule id="499902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2785 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>