<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2721 — Event Log Clearing (onyx) | Status: deprecated | Sigma ID: 98f4e801-db1c-5ccc-9ee4-7c88f9ef6a89 -->
  <rule id="833588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2721 — Event Log Clearing (onyx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>