<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2699 — Event Log Clearing (onyx) | Status: deprecated | Sigma ID: 9fdb98e3-36b8-5de3-bb2c-e3aab28b0a6c -->
  <rule id="592398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2699 — Event Log Clearing (onyx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>