<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0914 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 43a49dbf-5b4a-5e29-9b2d-b07f54f7ab7e -->
  <rule id="317597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0914 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>