<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0294 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: 05cef5fb-f054-5da8-a7fb-9bac7daf0bcb -->
  <rule id="306655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0294 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>