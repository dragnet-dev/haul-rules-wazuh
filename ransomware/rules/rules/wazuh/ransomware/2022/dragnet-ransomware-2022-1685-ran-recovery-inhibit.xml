<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1685 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: e2004f58-58ef-5efb-b4e4-341c2132ed43 -->
  <rule id="572079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1685 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>