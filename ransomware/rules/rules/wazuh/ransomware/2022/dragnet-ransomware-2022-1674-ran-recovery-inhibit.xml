<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1674 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 325dc659-c04c-593f-b64f-c78a9fe359fe -->
  <rule id="342065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1674 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>