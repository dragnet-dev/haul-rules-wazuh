<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1592 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: ed804ac1-44b2-5d5e-a248-42c99197362c -->
  <rule id="304874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1592 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>