<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0205 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: accc9d82-51e2-5963-836b-32585d343e78 -->
  <rule id="877917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0205 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>