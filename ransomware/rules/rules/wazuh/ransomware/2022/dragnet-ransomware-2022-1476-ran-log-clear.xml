<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1476 — Event Log Clearing (redalert) | Status: deprecated | Sigma ID: 04791d8c-7a5e-51e4-857f-808e08c31aa7 -->
  <rule id="667180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1476 — Event Log Clearing (redalert)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>