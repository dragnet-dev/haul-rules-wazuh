<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1812 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 4bc8f934-4ae3-51be-92ae-507139882dec -->
  <rule id="240639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1812 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>