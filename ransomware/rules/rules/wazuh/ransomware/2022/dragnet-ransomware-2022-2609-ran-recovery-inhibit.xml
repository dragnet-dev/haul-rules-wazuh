<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2609 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 656f4807-2ead-5ffa-8d49-41ebdfd08979 -->
  <rule id="251148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2609 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
