<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1330 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 8d9a34f3-214e-513b-bce0-aa5c185e1d71 -->
  <rule id="571434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1330 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>