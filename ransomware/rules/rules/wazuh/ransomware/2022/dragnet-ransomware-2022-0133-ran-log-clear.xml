<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0133 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: acdfc5a3-39c6-567f-9ef8-5b97acf4df93 -->
  <rule id="880925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0133 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>