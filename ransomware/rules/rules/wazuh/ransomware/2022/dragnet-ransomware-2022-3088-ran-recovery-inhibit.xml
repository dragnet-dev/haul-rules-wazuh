<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3088 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 17dc5df2-f570-53df-b45b-fd92b94d605b -->
  <rule id="105823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3088 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>