<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1584 — Event Log Clearing (medusalocker) | Status: deprecated | Sigma ID: 3bf8cf33-0c17-5d99-a497-9a02f95334b8 -->
  <rule id="757295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1584 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>