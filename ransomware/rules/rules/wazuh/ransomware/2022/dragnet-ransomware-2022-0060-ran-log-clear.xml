<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0060 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 61b75825-607c-5ca2-9579-0cf5f7fb5cd9 -->
  <rule id="977582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0060 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>