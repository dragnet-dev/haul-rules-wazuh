<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2052 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b394007c-6a31-5fa1-bbd2-1612b86d386f -->
  <rule id="339400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2052 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>