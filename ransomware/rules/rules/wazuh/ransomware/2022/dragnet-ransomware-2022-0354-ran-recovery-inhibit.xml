<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0354 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 50367377-18c8-52d4-a969-960f2d98232f -->
  <rule id="636737" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0354 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>