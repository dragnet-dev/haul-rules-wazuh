<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1841 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: dc93b279-07c0-5282-aca5-7dd30967553f -->
  <rule id="934992" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1841 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>