<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1384 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 824fc139-ce69-569f-9e9b-ccdfcff7c484 -->
  <rule id="411961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1384 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>