<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3157 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b4972eba-beed-552e-99e8-f168c975325f -->
  <rule id="139566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3157 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>