<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1062 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 1187e881-a3d7-5d29-975f-2498a49356ca -->
  <rule id="200688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1062 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>