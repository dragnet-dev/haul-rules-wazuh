<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2365 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 50a2927f-dbb8-5143-97cd-e66624c82d5b -->
  <rule id="102927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2365 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
