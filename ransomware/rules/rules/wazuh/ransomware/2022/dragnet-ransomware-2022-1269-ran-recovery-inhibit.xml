<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1269 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 7a078927-5707-5b7d-b187-4ff14a98c995 -->
  <rule id="420789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1269 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
