<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2214 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: 5dc56fd9-e1d7-5d28-aab6-4eb8ddff7fa9 -->
  <rule id="700911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2214 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>