<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1194 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 4b62d2ce-84ca-528e-9e94-7551f915fb73 -->
  <rule id="410052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1194 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>