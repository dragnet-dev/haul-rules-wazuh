<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0672 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5e7289df-aae6-53cb-8b10-794d3a91994a -->
  <rule id="856637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0672 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>