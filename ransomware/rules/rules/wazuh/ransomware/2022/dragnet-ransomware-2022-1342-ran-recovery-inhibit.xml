<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1342 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 659684ff-9704-5373-99e7-5b8c174ae0d4 -->
  <rule id="754959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1342 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>