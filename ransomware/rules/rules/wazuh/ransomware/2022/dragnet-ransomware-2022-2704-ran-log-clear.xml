<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2704 — Event Log Clearing (bitlocker) | Status: deprecated | Sigma ID: ea6aa4b9-b765-5b33-92b3-679d809c0cb8 -->
  <rule id="707464" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2704 — Event Log Clearing (bitlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>