<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1270 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: ace42f79-1509-559b-a006-7a15ccf016c3 -->
  <rule id="926287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1270 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>