<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1841 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: bf92c1fa-af6c-58f7-894a-6df3d9a90ef0 -->
  <rule id="470841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1841 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>