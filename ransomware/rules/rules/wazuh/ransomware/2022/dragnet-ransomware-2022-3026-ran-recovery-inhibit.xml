<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3026 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 713ccb5d-90fd-50ac-a423-2b7c9bdb45c5 -->
  <rule id="323723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3026 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>