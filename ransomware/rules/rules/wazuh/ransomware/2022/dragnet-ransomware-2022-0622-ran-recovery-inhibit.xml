<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0622 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 4521353d-fddd-50fd-9c6c-040fb29a7f81 -->
  <rule id="121353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0622 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>