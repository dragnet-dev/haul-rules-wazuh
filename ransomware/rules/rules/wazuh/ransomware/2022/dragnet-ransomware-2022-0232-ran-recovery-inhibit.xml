<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0232 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: df3ea178-5f34-5ba3-aad0-09f753554821 -->
  <rule id="418821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0232 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>