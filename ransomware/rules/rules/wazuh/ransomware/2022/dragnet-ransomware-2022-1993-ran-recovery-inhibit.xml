<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1993 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 24d4c222-784e-5862-b5b7-8af9d49a572c -->
  <rule id="159622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1993 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>