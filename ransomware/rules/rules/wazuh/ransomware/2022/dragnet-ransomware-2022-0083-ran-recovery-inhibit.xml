<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0083 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 20304cc9-f261-5479-8e79-d424964f11e4 -->
  <rule id="798028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0083 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>