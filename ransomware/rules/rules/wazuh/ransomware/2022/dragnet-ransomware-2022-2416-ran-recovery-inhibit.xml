<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2416 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d0a0b559-3cbc-59d4-a4dc-4998a60f7a7b -->
  <rule id="744115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2416 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
