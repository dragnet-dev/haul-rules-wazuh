<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0359 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 9fad8b22-c060-59fe-84d0-6c56ee1048e1 -->
  <rule id="340459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0359 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>