<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1173 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 26e125af-b021-556d-b56a-8fc959405cc2 -->
  <rule id="682010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1173 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>