<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0363 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: f15f79b7-f8fa-5e01-92f0-4e81818aea79 -->
  <rule id="725579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0363 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>