<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1741 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 5dac6d26-3fc0-56e5-9867-4eea8b96a4c0 -->
  <rule id="336909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1741 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>