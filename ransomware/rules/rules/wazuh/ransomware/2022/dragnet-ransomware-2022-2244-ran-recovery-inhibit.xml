<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2244 — Recovery Inhibition (lv) | Status: deprecated | Sigma ID: 525fb51d-120c-5a4c-9d6c-5b48322cf80f -->
  <rule id="546515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2244 — Recovery Inhibition (lv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>