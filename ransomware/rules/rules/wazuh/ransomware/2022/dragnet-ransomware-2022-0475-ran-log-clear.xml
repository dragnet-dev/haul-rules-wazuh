<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0475 — Event Log Clearing (mountlocker) | Status: deprecated | Sigma ID: 1fa9f624-1e8e-5573-9bc5-5d7b7b5aa4b9 -->
  <rule id="111962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0475 — Event Log Clearing (mountlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>