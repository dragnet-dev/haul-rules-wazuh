<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2456 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e2c0a021-6219-5bec-9fa7-ee4e161a0742 -->
  <rule id="154500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2456 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>