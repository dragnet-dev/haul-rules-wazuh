<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0413 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 572b9dc2-3272-57f8-9128-af4bc5faf884 -->
  <rule id="666237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0413 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>