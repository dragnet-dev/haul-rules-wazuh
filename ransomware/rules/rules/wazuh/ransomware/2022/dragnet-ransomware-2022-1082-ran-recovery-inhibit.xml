<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1082 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: f6806cd7-a838-5d02-a25f-dfbdebc50499 -->
  <rule id="808908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1082 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>