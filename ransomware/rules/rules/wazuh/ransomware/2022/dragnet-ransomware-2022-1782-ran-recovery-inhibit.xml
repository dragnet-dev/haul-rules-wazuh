<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1782 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9e34dd81-738b-5018-940d-9bd8739b7db5 -->
  <rule id="553725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1782 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>