<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2210 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0f89641d-63f4-5900-8473-73be4dd2e8a0 -->
  <rule id="789641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2210 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
