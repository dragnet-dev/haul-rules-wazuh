<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2531 — Event Log Clearing (lv) | Status: deprecated | Sigma ID: 8076f327-4f83-5a32-991d-c75cfde248ea -->
  <rule id="492313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2531 — Event Log Clearing (lv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>