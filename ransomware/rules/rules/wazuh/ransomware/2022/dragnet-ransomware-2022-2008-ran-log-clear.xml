<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2008 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 80f8cd43-bc9e-5bc2-ba8e-53ef0ac43ec9 -->
  <rule id="717453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2008 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>