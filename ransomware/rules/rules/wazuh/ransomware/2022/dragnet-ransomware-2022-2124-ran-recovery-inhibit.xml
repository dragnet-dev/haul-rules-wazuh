<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2124 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 48bc53d7-68b7-5709-81ee-71078c96d86f -->
  <rule id="447653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2124 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>