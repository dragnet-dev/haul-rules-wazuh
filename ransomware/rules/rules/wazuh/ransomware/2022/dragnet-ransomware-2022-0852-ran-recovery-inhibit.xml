<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0852 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: fade09c8-43c4-561b-a5b9-8059d5125348 -->
  <rule id="222209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0852 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>