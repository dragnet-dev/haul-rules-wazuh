<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2987 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 129c62a4-c9d6-526f-8747-47c1a3b09c31 -->
  <rule id="722602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2987 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>