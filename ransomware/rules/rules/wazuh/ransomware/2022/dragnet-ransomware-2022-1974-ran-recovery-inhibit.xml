<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1974 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2829cda5-45c8-5e61-86f4-6a000b178773 -->
  <rule id="890874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1974 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>