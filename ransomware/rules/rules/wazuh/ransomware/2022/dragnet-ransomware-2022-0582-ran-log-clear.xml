<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0582 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 98d1b5f4-0a3f-5aee-a664-b1ddb78bcffa -->
  <rule id="829875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0582 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>