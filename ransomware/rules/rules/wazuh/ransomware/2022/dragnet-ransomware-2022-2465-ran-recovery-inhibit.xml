<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2465 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a12b69de-2a10-594d-9778-6ce135119d48 -->
  <rule id="820369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2465 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>