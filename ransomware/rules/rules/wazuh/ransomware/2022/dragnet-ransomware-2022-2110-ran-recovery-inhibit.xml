<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2110 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: db5cc08a-21b2-5745-80b0-0c8a08fe4eeb -->
  <rule id="321240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2110 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>