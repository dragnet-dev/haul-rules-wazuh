<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0999 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: 1a042515-681d-5deb-9c59-0375ca6867d0 -->
  <rule id="904251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0999 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>