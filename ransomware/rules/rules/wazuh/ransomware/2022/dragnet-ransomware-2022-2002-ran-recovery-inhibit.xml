<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2002 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 741bd029-8d22-581b-a803-b5f2517051ed -->
  <rule id="198850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2002 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>