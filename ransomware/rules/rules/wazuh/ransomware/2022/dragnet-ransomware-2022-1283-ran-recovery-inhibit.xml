<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1283 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 6ea42521-8001-5e04-9a4b-7b4a67088866 -->
  <rule id="970425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1283 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>