<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2897 — Event Log Clearing (sabbath) | Status: deprecated | Sigma ID: d10c0fbe-3919-5a74-b916-e198bc9fe55e -->
  <rule id="755535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2897 — Event Log Clearing (sabbath)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>