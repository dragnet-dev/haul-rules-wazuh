<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3027 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 540dd5a8-e8e7-5ae6-8db6-3bbf1a2e23ef -->
  <rule id="584615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3027 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>