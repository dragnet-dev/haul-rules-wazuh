<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0258 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8ec39180-e15e-5c50-a4b9-623ac4931a1a -->
  <rule id="584391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0258 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>