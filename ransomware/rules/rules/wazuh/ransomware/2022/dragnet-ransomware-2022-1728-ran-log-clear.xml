<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1728 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 6dc30100-16be-5e03-a690-ab433e1a8ed4 -->
  <rule id="956301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1728 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>