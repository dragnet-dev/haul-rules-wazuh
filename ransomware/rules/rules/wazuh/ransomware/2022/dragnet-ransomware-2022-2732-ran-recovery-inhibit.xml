<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2732 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 40a27b10-a02a-52c2-bc58-36cead6c638c -->
  <rule id="240443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2732 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>