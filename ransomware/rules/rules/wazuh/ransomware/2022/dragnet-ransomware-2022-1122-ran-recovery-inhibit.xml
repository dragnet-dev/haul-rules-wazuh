<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1122 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 710b3276-ec73-5191-a453-4bf7410b40a2 -->
  <rule id="337132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1122 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>