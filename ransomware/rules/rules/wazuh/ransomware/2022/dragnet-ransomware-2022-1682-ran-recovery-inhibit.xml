<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1682 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 302716fe-56e1-533d-b246-1da5a0c6788c -->
  <rule id="443471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1682 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>