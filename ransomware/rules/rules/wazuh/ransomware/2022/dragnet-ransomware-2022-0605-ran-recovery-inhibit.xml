<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0605 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f1925f84-0f05-5e02-8a65-2157128563a7 -->
  <rule id="730815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0605 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>