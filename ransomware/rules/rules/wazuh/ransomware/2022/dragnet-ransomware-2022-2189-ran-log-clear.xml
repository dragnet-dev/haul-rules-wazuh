<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2189 — Event Log Clearing (ransomhouse) | Status: deprecated | Sigma ID: ae56e945-2d2c-5c45-a9e0-7ce28a0c459d -->
  <rule id="193109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2189 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>