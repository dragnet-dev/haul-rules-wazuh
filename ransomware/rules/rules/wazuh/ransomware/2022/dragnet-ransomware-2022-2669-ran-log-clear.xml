<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2669 — Event Log Clearing (karakurt) | Status: experimental | Sigma ID: 8ac2ebe8-9114-562a-a4d2-6d39eed7e03a -->
  <rule id="383947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2669 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>