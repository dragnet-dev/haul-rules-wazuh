<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0100 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 52684bd0-9ffd-53d3-855b-b08c6e2b41f6 -->
  <rule id="987293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0100 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>