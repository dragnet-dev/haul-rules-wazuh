<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2904 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: c2e6c77f-7540-58ed-a159-8fd8b88778a7 -->
  <rule id="546687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2904 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>