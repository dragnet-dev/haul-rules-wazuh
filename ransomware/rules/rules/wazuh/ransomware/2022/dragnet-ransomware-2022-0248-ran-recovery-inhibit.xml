<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0248 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: bb3a0356-c12a-55d7-a35d-8bab202e06c1 -->
  <rule id="397803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0248 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>