<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0069 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 57675d1a-62eb-5a6a-80e3-c53de992f2e9 -->
  <rule id="328131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0069 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>