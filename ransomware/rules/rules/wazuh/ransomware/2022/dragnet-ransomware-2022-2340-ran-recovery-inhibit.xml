<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2340 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 0aef9464-8a7d-53bb-87b4-b480a155660d -->
  <rule id="199946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2340 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>