<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0817 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 430ff105-fce6-5f66-8bf4-599de852943f -->
  <rule id="303351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0817 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>