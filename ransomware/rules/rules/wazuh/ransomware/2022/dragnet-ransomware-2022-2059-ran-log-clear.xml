<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2059 — Event Log Clearing (ransomhouse) | Status: deprecated | Sigma ID: d6d2da82-0127-59f0-85f1-0fb6f7253d06 -->
  <rule id="304570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2059 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>