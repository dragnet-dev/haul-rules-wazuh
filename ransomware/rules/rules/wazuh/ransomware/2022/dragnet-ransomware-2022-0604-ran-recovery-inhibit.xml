<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0604 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 4689f79b-2127-5ea5-9d4c-18e877fd5eac -->
  <rule id="403979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0604 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>