<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2581 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 4f0ebbad-6032-595a-855d-ff429f6130f5 -->
  <rule id="639611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2581 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>