<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0784 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: d4e8a218-0612-546e-a5bd-74354c52f660 -->
  <rule id="854182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0784 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>