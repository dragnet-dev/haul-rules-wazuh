<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1672 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: 3378dbc5-1b1a-5fd7-be71-e633db00e3d9 -->
  <rule id="439804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1672 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>