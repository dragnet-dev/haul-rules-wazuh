<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1421 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 32920a3d-abb2-58b1-842a-abb205b932fb -->
  <rule id="867303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1421 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>