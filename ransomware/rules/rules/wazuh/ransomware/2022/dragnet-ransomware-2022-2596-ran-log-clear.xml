<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2596 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: e3e1019f-d0a0-5994-8948-b8c764dfa2b1 -->
  <rule id="602101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2596 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>