<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0080 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 952fac91-a694-5694-b841-e2d7e99e36c7 -->
  <rule id="403404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0080 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>