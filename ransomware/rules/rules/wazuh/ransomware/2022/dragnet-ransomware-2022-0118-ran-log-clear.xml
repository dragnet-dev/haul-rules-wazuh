<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0118 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 4fc10b3b-cb02-571e-a945-95cf58ebb615 -->
  <rule id="341771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0118 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>