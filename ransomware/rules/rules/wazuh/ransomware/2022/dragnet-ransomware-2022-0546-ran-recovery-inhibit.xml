<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0546 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 298b4ecf-284d-5113-9477-ce93f4cba7f5 -->
  <rule id="635500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0546 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>