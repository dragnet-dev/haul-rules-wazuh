<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0721 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: c41faa74-7a02-5c71-97d8-8c58e7e6bfa2 -->
  <rule id="687146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0721 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>