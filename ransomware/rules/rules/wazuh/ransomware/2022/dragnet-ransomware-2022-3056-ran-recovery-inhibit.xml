<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3056 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 66984542-7001-5bad-8a5f-7e06792f2ad2 -->
  <rule id="498454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3056 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>