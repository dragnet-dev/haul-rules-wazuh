<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3123 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 76ceac82-ad36-5c24-8842-d631355bea7f -->
  <rule id="633644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3123 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>