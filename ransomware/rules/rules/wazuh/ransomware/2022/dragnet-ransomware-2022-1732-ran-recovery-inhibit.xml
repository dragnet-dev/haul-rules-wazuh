<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1732 — Recovery Inhibition (midas) | Status: deprecated | Sigma ID: eabfe5ae-6f79-5b80-ad31-a044bc37416a -->
  <rule id="715345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1732 — Recovery Inhibition (midas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>