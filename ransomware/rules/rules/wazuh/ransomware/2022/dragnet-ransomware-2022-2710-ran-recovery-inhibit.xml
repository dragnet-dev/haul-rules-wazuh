<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2710 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f3f43597-f9a9-573b-a44f-e664d1478b1f -->
  <rule id="763435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2710 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>