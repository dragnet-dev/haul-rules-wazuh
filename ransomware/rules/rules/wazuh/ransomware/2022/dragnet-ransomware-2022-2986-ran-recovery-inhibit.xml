<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2986 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e59d630a-4836-547d-a81e-c801b8a33b1e -->
  <rule id="635763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2986 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>