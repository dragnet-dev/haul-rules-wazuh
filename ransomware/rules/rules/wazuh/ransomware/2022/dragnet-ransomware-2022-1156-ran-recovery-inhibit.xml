<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1156 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e01ae102-b1ec-5a74-a4b3-70edf0a6d834 -->
  <rule id="988301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1156 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>