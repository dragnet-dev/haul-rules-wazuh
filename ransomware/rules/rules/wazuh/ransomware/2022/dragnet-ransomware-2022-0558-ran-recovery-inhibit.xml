<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0558 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 699052e8-d381-55cc-b0db-e9a883783dbb -->
  <rule id="484846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0558 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>