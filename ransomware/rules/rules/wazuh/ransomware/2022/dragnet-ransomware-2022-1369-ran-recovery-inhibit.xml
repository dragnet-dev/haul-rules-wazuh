<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1369 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1b90c9b2-d876-5ebe-bced-ae8dad2ed25e -->
  <rule id="944475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1369 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>