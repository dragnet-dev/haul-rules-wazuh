<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0324 — Event Log Clearing (0mega) | Status: deprecated | Sigma ID: 4b5a5919-f26e-59a7-8351-0f62590387db -->
  <rule id="409059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0324 — Event Log Clearing (0mega)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>