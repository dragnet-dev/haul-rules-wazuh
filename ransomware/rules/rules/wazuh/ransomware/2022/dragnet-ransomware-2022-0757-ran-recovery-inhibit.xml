<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0757 — Recovery Inhibition (projectrelic) | Status: deprecated | Sigma ID: 9616821a-82b8-5128-81f8-963f83727651 -->
  <rule id="716821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0757 — Recovery Inhibition (projectrelic)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
