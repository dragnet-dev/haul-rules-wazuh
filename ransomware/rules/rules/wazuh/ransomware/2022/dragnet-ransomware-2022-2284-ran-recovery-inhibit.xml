<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2284 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a4d66688-2805-5f83-ad80-21fb9822291b -->
  <rule id="877666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2284 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>