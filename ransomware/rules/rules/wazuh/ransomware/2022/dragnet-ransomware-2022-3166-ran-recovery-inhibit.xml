<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3166 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 58478763-78fc-5855-a6aa-56f646126949 -->
  <rule id="547876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3166 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>