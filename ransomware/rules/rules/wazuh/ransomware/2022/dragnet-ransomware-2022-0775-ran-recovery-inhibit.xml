<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0775 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a0d8af9f-0167-5fe7-9d3f-d14379bb782e -->
  <rule id="631503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0775 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>