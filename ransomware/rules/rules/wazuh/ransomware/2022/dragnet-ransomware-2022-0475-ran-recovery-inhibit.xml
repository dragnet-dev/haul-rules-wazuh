<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0475 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: fcd51a98-ad41-5684-b12c-8dacede78104 -->
  <rule id="272826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0475 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>