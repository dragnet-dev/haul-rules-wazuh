<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1076 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: 1078d7ba-baff-5f30-badc-4d9d34def585 -->
  <rule id="161883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1076 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>