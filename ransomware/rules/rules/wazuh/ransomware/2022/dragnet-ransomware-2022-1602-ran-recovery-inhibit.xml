<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1602 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 861f45d8-f426-5b01-9a58-da2ba609dea2 -->
  <rule id="579145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1602 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>