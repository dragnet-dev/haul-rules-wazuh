<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0880 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 50cc025a-2244-543e-af20-065070e09aae -->
  <rule id="500402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0880 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>