<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0642 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: c5834269-9b54-5c8f-92b3-e5c35b3cc0a3 -->
  <rule id="458342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0642 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>