<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0345 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b27cf8ac-badb-5aef-a34c-ae27906a6f14 -->
  <rule id="287198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0345 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>