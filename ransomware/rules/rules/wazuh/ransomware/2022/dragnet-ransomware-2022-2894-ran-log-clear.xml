<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2894 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 52170c0d-2f6f-5cf1-a5d9-8ab9eed9de78 -->
  <rule id="347320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2894 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>