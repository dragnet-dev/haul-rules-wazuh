<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2368 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: badaf3ea-cf3b-5781-b181-3f9a7ceb1d9f -->
  <rule id="553593" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2368 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>