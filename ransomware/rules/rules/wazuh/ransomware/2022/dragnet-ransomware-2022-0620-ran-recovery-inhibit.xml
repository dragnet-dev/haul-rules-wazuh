<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0620 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: e5052050-3ad1-5294-9238-6ba391fd2be3 -->
  <rule id="650520" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0620 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>