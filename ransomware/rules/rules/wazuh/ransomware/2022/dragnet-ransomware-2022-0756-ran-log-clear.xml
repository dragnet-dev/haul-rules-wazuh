<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0756 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: 9a5c7f41-2870-5e26-aa14-7a394a7de7a2 -->
  <rule id="457247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0756 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>