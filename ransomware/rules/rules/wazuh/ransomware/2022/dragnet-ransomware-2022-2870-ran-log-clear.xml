<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2870 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 361d9dd2-0a39-59f5-8cb3-cb1d4e87f670 -->
  <rule id="522365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2870 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>