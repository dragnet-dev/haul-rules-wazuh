<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2901 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 9d983d91-d05d-5899-9623-88cfebb440ac -->
  <rule id="827741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2901 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
