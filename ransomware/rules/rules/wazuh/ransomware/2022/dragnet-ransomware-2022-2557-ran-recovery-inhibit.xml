<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2557 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e05819b5-5f12-5c09-9efa-dfa563367511 -->
  <rule id="605819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2557 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>