<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1488 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0b7897a6-3cec-58b5-95b9-80289c806cff -->
  <rule id="186362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1488 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>