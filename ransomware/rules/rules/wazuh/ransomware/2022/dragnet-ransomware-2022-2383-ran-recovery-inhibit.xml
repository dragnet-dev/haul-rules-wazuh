<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2383 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 7fcc2e8a-3842-5854-a2e9-c5ff79a2bb6b -->
  <rule id="834606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2383 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>