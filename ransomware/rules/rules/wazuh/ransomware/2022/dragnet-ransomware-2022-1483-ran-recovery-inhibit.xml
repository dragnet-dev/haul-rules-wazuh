<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1483 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 57b46f2c-a296-5949-9d3c-f47f9b782537 -->
  <rule id="677551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1483 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>