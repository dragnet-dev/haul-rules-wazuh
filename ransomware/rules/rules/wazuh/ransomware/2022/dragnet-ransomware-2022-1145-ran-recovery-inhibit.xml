<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1145 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 87b462bd-467d-59a9-89e4-ca9cd6af7941 -->
  <rule id="603462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1145 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>