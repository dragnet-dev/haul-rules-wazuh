<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1256 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f4c4d3f4-6a92-5a9c-b59c-83cd15a3b894 -->
  <rule id="462373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1256 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>