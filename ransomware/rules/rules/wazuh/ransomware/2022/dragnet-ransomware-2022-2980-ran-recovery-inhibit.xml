<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2980 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 7aa72669-7b3f-5d66-817b-c3d718ca7ee1 -->
  <rule id="262726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2980 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>