<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2424 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 38903515-407e-54a1-864b-1fde8c04e1e2 -->
  <rule id="390351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2424 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>