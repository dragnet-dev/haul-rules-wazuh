<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1727 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: eadf9b04-9bbb-5254-a984-47f653e82d3f -->
  <rule id="720475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1727 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>