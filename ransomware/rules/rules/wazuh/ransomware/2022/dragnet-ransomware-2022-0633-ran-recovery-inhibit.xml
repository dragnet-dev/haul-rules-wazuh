<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0633 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: bc1bdd9f-f3e4-575b-907b-25321ca2adfa -->
  <rule id="607613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0633 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>