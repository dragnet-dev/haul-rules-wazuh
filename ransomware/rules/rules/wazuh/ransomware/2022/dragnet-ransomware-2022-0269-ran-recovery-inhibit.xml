<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0269 — Recovery Inhibition (cryptbb) | Status: experimental | Sigma ID: ef6c9e4b-2b4f-5993-8836-4b6daa491c7e -->
  <rule id="835838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0269 — Recovery Inhibition (cryptbb)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>