<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0805 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: 65b7b49b-141a-5691-af1a-7efa832d1a80 -->
  <rule id="882834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0805 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>