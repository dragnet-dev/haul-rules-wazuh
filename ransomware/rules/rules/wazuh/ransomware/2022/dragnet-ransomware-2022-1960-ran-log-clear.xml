<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1960 — Event Log Clearing (onyx) | Status: deprecated | Sigma ID: d82ea96e-7ff7-5c52-a31a-adaaabb1b05a -->
  <rule id="940269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1960 — Event Log Clearing (onyx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>