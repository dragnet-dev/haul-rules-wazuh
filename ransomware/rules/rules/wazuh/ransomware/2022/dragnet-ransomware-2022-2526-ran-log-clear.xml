<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2526 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 2ee81c15-a7b2-57d1-b1c0-691f9a1b435d -->
  <rule id="401308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2526 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>