<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2821 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: b250dfa0-94f5-5aac-98d6-91d74b3fc8b4 -->
  <rule id="280223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2821 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>