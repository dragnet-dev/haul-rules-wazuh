<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2560 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: b1c9ef16-c0e0-585e-a833-a6409255c572 -->
  <rule id="179823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2560 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>