<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0751 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: d9ad0e7c-4ba4-526a-9fa0-14fae8d44a71 -->
  <rule id="421134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0751 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>