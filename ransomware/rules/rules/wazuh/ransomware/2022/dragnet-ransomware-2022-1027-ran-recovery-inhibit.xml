<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1027 — Recovery Inhibition (unsafe) | Status: deprecated | Sigma ID: 300366be-e724-511a-8dfd-efe52bd679e8 -->
  <rule id="405867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1027 — Recovery Inhibition (unsafe)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
