<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1286 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: b7477953-336b-5c09-9792-a4201f29e978 -->
  <rule id="374779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1286 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>