<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0492 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: ab4ce413-93d4-5de9-b898-5ba85a97d48b -->
  <rule id="889904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0492 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
