<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1626 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: 3bb975e7-3c57-5f1c-a8a5-6872e7cd7c2c -->
  <rule id="995614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1626 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>