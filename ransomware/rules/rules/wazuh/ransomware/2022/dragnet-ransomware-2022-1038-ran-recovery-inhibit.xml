<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1038 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 458977e4-c42a-5771-a8ac-92d696a037c2 -->
  <rule id="243646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1038 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>