<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3068 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e47923b1-3bd5-5d82-bdaf-6b042ebd7653 -->
  <rule id="647923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3068 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>