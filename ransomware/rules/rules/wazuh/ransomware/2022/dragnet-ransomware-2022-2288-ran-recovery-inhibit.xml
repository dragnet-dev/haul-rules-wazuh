<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2288 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 29d24e9e-1760-593b-a753-7a842a4b2ccc -->
  <rule id="535989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2288 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>