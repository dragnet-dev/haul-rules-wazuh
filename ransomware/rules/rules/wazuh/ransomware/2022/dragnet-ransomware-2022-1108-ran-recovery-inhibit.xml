<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1108 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 4181f535-8d7b-5114-a26f-a7aa160676c9 -->
  <rule id="491153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1108 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>