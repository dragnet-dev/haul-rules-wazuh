<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1840 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 394be448-f5d7-5e10-8f55-e0cf138ea633 -->
  <rule id="210544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1840 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>