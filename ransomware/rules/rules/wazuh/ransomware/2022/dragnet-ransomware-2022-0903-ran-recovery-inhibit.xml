<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0903 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ca8d8773-efd5-5028-beab-075191fdfb2b -->
  <rule id="646187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0903 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>