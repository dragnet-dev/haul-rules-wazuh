<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2029 — Event Log Clearing (shaoleaks) | Status: deprecated | Sigma ID: 354119a6-4a49-5ef4-8aa0-b899c10a93cb -->
  <rule id="365914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2029 — Event Log Clearing (shaoleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>