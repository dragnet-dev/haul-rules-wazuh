<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3000 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 28a3fb08-fa84-5286-b59a-3849cc1dea5a -->
  <rule id="373499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3000 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>