<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3146 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: a4be142e-c31e-550e-b37f-f670779a3005 -->
  <rule id="981414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3146 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>