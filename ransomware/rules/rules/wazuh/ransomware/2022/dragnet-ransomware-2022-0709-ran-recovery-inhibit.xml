<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0709 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d1202081-0bc3-57b5-909d-ad7e9eb82832 -->
  <rule id="512020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0709 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>