<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2475 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 14ba5aa8-397a-5bf6-8653-808b25d1ed70 -->
  <rule id="752650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2475 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>