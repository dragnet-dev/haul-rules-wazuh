<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1485 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 348ce45c-11ca-5025-9a12-4a687f2ac89c -->
  <rule id="929445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1485 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>