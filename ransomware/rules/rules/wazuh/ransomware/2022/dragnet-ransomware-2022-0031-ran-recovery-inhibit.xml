<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0031 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: de2ecfba-de95-5bcb-ac5c-3f2ffbcede46 -->
  <rule id="205103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0031 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>