<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1277 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ed8c959f-e14d-51ce-9845-d9f29f4d2f81 -->
  <rule id="306095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1277 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>