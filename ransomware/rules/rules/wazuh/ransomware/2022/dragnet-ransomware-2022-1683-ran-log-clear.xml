<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1683 — Event Log Clearing (la_piovra) | Status: experimental | Sigma ID: 8c92bf57-1761-5b40-824b-923ee66a3924 -->
  <rule id="107743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1683 — Event Log Clearing (la_piovra)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>