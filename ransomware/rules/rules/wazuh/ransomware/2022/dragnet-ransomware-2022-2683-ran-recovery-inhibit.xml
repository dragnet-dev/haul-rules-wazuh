<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2683 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 53066bbe-72a6-5f1d-ba7e-fea2ee031d32 -->
  <rule id="185083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2683 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>