<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3075 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 60e52b08-2ca8-54f3-a539-c39263deccc9 -->
  <rule id="759243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3075 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>