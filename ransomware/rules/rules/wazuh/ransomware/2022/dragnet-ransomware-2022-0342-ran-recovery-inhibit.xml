<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0342 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 459cf559-8bc4-5127-a291-cc0794d053c6 -->
  <rule id="377115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0342 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>