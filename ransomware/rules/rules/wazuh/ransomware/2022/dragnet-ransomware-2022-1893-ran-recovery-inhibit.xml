<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1893 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: a9b1036b-c1fd-5a93-9864-740e29c7b398 -->
  <rule id="955103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1893 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>