<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0158 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 656e76b6-f15d-5d86-9172-3102193d4288 -->
  <rule id="251076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0158 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
