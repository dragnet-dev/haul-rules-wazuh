<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0234 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 656f057a-26bf-549b-87bb-d8ccb22326d8 -->
  <rule id="251105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0234 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>