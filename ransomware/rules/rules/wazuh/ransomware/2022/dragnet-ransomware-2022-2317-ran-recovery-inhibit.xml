<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2317 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: b4114a24-dfc4-5c45-ad84-274355b8b6cc -->
  <rule id="125834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2317 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>