<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3121 — Event Log Clearing (snatch) | Status: deprecated | Sigma ID: e3259b35-4ba8-5185-8a9e-8559400f7623 -->
  <rule id="592155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3121 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>