<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1565 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 4e8ece58-29a9-521a-8c85-fc47265ffa04 -->
  <rule id="631438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1565 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>