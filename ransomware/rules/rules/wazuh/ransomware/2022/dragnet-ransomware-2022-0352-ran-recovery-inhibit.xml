<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0352 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 3e477237-b2e2-5371-b602-08cd5cdab896 -->
  <rule id="947723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0352 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>