<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0675 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: dea8a232-f5e0-5cba-917d-fe1ad846b955 -->
  <rule id="400582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0675 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>