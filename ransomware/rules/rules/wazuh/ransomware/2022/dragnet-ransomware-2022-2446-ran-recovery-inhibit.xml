<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2446 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 0c8b6c9f-dfe6-5407-95f4-e687e6db7c64 -->
  <rule id="695489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2446 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>