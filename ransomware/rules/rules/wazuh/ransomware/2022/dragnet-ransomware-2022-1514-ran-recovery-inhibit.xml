<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1514 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 58e29578-19dd-5b91-a61a-02fdff30dc0d -->
  <rule id="522957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1514 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>