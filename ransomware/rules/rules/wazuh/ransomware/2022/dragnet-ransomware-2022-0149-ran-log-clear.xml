<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0149 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: 47eda1ca-9128-5b6e-b3b9-12d8c4c4236b -->
  <rule id="263141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0149 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>