<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0273 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 769cd11f-3d9a-54bd-90c8-dd367940c26d -->
  <rule id="270691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0273 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
