<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1345 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 7b2220c3-87b3-5561-a051-2724118e49dd -->
  <rule id="432220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1345 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>