<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1603 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 3acd7481-94b1-581e-a13e-44c7a313d123 -->
  <rule id="705374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1603 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>