<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2097 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 456af9f9-2286-53f8-94b8-6dda897c4474 -->
  <rule id="369119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2097 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>