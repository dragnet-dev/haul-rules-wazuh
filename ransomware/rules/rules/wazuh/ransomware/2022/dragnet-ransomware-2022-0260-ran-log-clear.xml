<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0260 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 0b2c42b5-2a87-5d5c-bae1-6c1a1b48adae -->
  <rule id="287083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0260 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>