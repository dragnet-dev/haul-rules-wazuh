<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0791 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: daec3c1d-62db-5549-b948-4d31aa1ed346 -->
  <rule id="967100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0791 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>