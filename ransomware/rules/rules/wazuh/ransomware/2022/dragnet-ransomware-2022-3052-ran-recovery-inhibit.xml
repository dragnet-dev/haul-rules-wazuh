<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3052 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: e2106778-3490-5cf7-ac06-1f5610f6adbd -->
  <rule id="621067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3052 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>