<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2385 — Shadow Copy Deletion (leaktheanalyst) | Status: deprecated | Sigma ID: 59479e96-67fa-578c-b1f1-68132cb30cc7 -->
  <rule id="616789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2385 — Shadow Copy Deletion (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>