<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1717 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 98dadb37-45e3-549f-bfa0-d5fc26c9ef68 -->
  <rule id="278555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1717 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>