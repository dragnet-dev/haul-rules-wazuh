<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2017 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: ff7a1d84-3a0e-511d-9e22-900c3a50f19d -->
  <rule id="347549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2017 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>