<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1111 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 0701dee8-7963-5535-90b2-724d147046e4 -->
  <rule id="274862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1111 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>