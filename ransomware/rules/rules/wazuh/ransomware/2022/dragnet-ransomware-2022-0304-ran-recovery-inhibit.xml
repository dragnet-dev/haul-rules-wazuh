<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0304 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 243dbf15-1cf3-56a0-b1ab-02d9c373e9df -->
  <rule id="188471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0304 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>