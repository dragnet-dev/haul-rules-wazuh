  <rule id="100686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2985 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
