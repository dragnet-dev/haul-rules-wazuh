<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1370 — Event Log Clearing (cheers) | Status: deprecated | Sigma ID: c8802e35-fb8d-5683-8a10-7c0bc23a2bf5 -->
  <rule id="360846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1370 — Event Log Clearing (cheers)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>