<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1141 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 19b1f92d-3b2c-5838-af6c-607d70b4e274 -->
  <rule id="643192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1141 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>