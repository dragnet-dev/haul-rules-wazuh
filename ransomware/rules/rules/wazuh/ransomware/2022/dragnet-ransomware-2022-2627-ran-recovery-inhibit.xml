<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2627 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 11ff7d89-6cd2-56d2-9836-242bd1e59379 -->
  <rule id="514858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2627 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>