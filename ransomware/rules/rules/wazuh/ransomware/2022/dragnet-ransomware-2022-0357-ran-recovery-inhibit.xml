<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0357 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 601761d2-6c03-5fc3-8e25-209baa13d448 -->
  <rule id="728189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0357 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>