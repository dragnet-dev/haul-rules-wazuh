<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0039 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c00331e3-7752-5c3a-bbd9-20f454a379d9 -->
  <rule id="400331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0039 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>