<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2854 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b1d45e62-7d79-5442-9e99-aa4f3806658a -->
  <rule id="263134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2854 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>