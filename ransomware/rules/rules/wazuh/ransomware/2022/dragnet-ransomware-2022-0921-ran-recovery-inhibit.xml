<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0921 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e2e59262-22ce-512a-8f42-ae5fc8bff8f4 -->
  <rule id="586592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0921 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>