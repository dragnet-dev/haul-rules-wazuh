<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2076 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: f2cd4543-4a81-5ea9-9b11-d6c84e54c604 -->
  <rule id="411745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2076 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>