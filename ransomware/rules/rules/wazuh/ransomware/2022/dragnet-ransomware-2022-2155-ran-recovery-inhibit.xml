<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2155 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 00c86762-3222-5a7e-9640-296516bb596b -->
  <rule id="486762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2155 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>