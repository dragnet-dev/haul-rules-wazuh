<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1429 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 77d76fd9-f9d1-5860-a303-50807e0f1b24 -->
  <rule id="293231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1429 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>