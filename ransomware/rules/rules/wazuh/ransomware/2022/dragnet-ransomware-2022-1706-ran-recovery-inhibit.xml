<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1706 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: aca7d5c9-a377-5526-86fe-5099888fcac5 -->
  <rule id="920455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1706 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>