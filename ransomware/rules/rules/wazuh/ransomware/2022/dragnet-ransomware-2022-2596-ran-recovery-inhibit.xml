<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2596 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 94ac09e2-d37c-5038-a35a-e771c248554c -->
  <rule id="723609" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2596 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
