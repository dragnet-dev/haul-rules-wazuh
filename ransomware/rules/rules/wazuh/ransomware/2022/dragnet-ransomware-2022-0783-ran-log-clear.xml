<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0783 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: ddd79012-da0c-51cc-8a6e-9a8e75fe4d94 -->
  <rule id="949790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0783 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>