<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0335 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ec057f3b-850e-5cc6-a862-259d7877c703 -->
  <rule id="276927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0335 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>