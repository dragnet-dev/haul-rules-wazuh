<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0745 — Event Log Clearing (midas) | Status: deprecated | Sigma ID: 071b30ba-9268-5e79-9b58-2f33c1bc6ff2 -->
  <rule id="135691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0745 — Event Log Clearing (midas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>