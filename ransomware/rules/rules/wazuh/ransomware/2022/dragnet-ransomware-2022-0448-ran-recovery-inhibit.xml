<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0448 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: d2f59395-678b-5f4c-87da-318dc30ae6b2 -->
  <rule id="427593" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0448 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
