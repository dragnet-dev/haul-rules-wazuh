<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2310 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: 514d88c5-31c3-5b28-a571-da2fc557751b -->
  <rule id="680620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2310 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
