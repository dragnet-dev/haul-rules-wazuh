<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0529 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: bee3df2d-9e10-5334-96d6-04ca2d768d11 -->
  <rule id="719231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0529 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>