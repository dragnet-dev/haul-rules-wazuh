<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0629 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 8e414caf-b74c-59a2-8d19-bbcefd3c2e16 -->
  <rule id="578636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0629 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>