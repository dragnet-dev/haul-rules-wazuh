<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1129 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 79a2193b-1d5d-5f86-9d72-00f653922263 -->
  <rule id="474219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1129 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>