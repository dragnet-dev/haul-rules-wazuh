<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0480 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 12eccedb-b0f8-5236-9c6c-271da00a28b0 -->
  <rule id="152877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0480 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>