<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0097 — Event Log Clearing (quantum) | Status: deprecated | Sigma ID: f2024483-ff90-5558-b27a-e816ce66d9a2 -->
  <rule id="720244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0097 — Event Log Clearing (quantum)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>