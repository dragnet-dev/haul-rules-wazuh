<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1771 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a5d05bf1-efd4-5a8d-a269-bac382bcd2f6 -->
  <rule id="108891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1771 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>