<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0453 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: cd224534-083c-5a5e-9f6d-f2b40fa8a107 -->
  <rule id="352245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0453 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>