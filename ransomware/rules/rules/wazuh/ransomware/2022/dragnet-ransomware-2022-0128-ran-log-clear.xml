<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0128 — Event Log Clearing (sparta) | Status: deprecated | Sigma ID: bd379f46-26dd-5bc3-9a13-4e44d49c344e -->
  <rule id="430079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0128 — Event Log Clearing (sparta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>