<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0279 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 5a820ec7-4a33-59c8-afa1-9b994ebe0c17 -->
  <rule id="653134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0279 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>