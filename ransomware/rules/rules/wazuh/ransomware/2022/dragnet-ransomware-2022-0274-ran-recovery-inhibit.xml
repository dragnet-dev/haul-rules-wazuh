<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0274 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: d341c550-94b7-5120-ad14-34cc568f6547 -->
  <rule id="434685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0274 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>