<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2297 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: e895fd6e-924a-54fd-9ac5-1410f2db5c66 -->
  <rule id="313373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2297 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>