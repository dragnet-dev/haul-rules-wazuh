<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0633 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: bcdbcef2-6ce2-5a47-8193-7a74a5c04424 -->
  <rule id="777038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0633 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>