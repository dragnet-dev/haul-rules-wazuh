<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2202 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 00cc0070-bc6e-584c-a0c9-56a61b0f5ecf -->
  <rule id="340070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2202 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>