<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2447 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 30a9b9e5-6d2d-5d6a-a3e9-5d4b73b1d35f -->
  <rule id="968958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2447 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>