<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2624 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 922d4682-e53c-50f0-a0cc-20f15d167224 -->
  <rule id="676546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2624 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>