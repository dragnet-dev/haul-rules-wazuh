<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2405 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 47119af2-58a9-555f-8bad-42d764457be0 -->
  <rule id="462639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2405 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>