<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0094 — Event Log Clearing (ragnarlocker) | Status: experimental | Sigma ID: b32e777a-1a1d-53e3-877e-076fc7e7c7b9 -->
  <rule id="112677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0094 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>