<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0331 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 3a37f132-394b-5f15-9d1a-028e7460610e -->
  <rule id="440713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0331 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>