<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1639 — Event Log Clearing (icefire) | Status: deprecated | Sigma ID: b8998c3b-3ded-5d37-b60e-936879f18043 -->
  <rule id="203980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1639 — Event Log Clearing (icefire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>