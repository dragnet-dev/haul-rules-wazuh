<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2164 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: b618b568-cd72-5e0e-b3e3-078b818175de -->
  <rule id="158995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2164 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
