<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1332 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1ba78f70-2a8b-5fff-a3ad-20a85147a850 -->
  <rule id="884637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1332 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>