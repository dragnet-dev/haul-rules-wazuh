<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1702 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: eb1ee507-9288-50aa-9691-4ebd31233129 -->
  <rule id="720945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1702 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>