<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0296 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: c1a98c96-2ac3-5ccb-98ab-ec30e47b7b5b -->
  <rule id="515180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0296 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>