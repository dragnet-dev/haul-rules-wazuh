<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2332 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 91c2bfa8-3cdd-5b4d-a4c1-23556e53ee8a -->
  <rule id="258783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2332 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>