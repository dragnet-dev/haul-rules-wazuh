<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2501 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 357f7aa3-a20d-5f27-9072-90bba73a4646 -->
  <rule id="363082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2501 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>