<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0688 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f448c061-cc26-58dc-907f-f8104ffece17 -->
  <rule id="771800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0688 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>