<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2747 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 467d9f81-a211-5702-9efe-8f275841ede2 -->
  <rule id="397759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2747 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>