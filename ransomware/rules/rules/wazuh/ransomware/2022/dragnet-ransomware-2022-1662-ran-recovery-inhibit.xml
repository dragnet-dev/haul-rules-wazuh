<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1662 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 26a7408c-f9ca-509b-836f-f42d815854a2 -->
  <rule id="767408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1662 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>