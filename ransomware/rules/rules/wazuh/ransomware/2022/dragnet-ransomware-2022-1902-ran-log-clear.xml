<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1902 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: eabb51f2-a64e-5e7b-9613-9deeb7386743 -->
  <rule id="709151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1902 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>