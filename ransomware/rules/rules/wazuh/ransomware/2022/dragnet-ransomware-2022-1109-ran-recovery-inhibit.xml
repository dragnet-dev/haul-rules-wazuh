<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1109 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 818b85a0-b6a6-5a18-bc70-ddcfd352b432 -->
  <rule id="509985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1109 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>