<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1073 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0f7b6176-8403-53ca-bbb4-4bb831d724fc -->
  <rule id="823617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1073 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>