<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2562 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: b3fbbf47-7d85-5cf4-8f60-a0aefe58ce96 -->
  <rule id="370015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2562 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>