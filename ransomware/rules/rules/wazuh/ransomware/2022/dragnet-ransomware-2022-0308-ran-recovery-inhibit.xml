<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0308 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5ffe97a4-1f65-5633-9547-e689428c8821 -->
  <rule id="757497" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0308 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>