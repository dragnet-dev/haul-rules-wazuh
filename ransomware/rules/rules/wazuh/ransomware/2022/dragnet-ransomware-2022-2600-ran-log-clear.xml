<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2600 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: 2d9abc03-f09a-5ea4-a938-6fc0dbcb70f5 -->
  <rule id="182812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2600 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>