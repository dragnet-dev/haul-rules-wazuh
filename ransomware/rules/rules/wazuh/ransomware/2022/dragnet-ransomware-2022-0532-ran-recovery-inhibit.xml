<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0532 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b2ced6aa-9029-59db-ae80-89370a84d83c -->
  <rule id="220616" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0532 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>