<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0981 — Shadow Copy Deletion (leaktheanalyst) | Status: deprecated | Sigma ID: fe85bcca-3a37-52fa-86cd-2f9f15fc6939 -->
  <rule id="324348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0981 — Shadow Copy Deletion (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>