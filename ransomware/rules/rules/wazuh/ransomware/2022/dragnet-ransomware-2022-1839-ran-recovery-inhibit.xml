<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1839 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 436ba64f-bd7e-5559-a489-d347a0565b3e -->
  <rule id="318026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1839 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>