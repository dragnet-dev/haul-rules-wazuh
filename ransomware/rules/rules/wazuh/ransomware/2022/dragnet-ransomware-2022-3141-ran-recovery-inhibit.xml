<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3141 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2dcb3735-23e3-5473-ba58-6faf42b28046 -->
  <rule id="372337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3141 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>