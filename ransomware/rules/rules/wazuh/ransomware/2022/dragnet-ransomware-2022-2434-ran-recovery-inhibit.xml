<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2434 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 7c13e406-bccd-5fd6-9820-04921fe90256 -->
  <rule id="286224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2434 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
