<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2809 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 44bd3de4-2ed8-5cfa-92d5-4117ac39f1fa -->
  <rule id="132541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2809 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>