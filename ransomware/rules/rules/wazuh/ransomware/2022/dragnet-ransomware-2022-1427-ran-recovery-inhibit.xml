<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1427 — Recovery Inhibition (play) | Status: deprecated | Sigma ID: 400dd4c3-4b51-5421-961c-6f78fbeb1f90 -->
  <rule id="226214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1427 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>