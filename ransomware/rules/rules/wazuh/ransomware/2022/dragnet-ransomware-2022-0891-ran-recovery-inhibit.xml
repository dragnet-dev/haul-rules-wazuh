<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0891 — Recovery Inhibition (pandora) | Status: deprecated | Sigma ID: cf4f1c2f-e700-520a-8cfd-f792a00a122b -->
  <rule id="911868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0891 — Recovery Inhibition (pandora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>