<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0325 — Event Log Clearing (projectrelic) | Status: deprecated | Sigma ID: 6ed62442-62dc-54f9-bfc2-871d52a20d86 -->
  <rule id="973624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0325 — Event Log Clearing (projectrelic)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>