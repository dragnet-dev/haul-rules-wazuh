<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0076 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 5fdba655-5306-534e-99e3-8e8aef26462f -->
  <rule id="426346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0076 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>