<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1960 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 35777275-4496-5d52-a2ae-498b7b6bad18 -->
  <rule id="977727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1960 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
