<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1741 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: ada50f7e-3048-545b-ac55-08b33db865ad -->
  <rule id="945615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1741 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
