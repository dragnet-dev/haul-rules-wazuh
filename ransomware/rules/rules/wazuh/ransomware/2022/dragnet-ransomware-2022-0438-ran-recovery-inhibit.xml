<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0438 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 44fd606c-ba3e-59dd-8bd8-fdda9a7d9a14 -->
  <rule id="351760" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0438 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>