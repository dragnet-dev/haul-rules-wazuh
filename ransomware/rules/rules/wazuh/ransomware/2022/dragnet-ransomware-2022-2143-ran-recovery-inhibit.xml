<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2143 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 93dfba17-b8b7-5041-8671-d6e48a8899ea -->
  <rule id="852122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2143 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>