<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0159 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 6499d844-aa0d-5bd4-8956-cb03fea0e314 -->
  <rule id="239978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0159 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>