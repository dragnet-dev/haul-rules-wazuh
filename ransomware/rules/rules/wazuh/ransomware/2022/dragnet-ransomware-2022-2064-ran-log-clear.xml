<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2064 — Event Log Clearing (lv) | Status: deprecated | Sigma ID: 0826c62d-3c82-5de0-86b0-7e42d6b2b746 -->
  <rule id="522862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2064 — Event Log Clearing (lv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>