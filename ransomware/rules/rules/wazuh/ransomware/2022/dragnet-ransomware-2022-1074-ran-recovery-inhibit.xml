<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1074 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: a96acde7-744e-5f32-b12c-7bea22416a5d -->
  <rule id="991981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1074 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>