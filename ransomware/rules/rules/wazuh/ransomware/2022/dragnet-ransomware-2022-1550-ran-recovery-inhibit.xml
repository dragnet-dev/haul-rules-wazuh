  <rule id="929371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1550 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
