<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2517 — Event Log Clearing (mallox) | Status: deprecated | Sigma ID: 8781e7b9-3e1b-5184-ac60-7cc2042d042e -->
  <rule id="605107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2517 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>