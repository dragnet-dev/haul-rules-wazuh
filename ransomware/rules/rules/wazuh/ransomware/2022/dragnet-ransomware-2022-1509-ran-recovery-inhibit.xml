<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1509 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9699008b-e2cd-5a12-9946-900504d43634 -->
  <rule id="799008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1509 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>