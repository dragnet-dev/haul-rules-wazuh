<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2408 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b6bb4555-dc77-5d9c-a532-dac8dfe2058a -->
  <rule id="388345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2408 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>