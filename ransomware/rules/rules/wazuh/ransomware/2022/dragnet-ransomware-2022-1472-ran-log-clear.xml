<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1472 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 899e88d2-2dd6-591d-8bdf-2bd2c0b153bb -->
  <rule id="639888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1472 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>