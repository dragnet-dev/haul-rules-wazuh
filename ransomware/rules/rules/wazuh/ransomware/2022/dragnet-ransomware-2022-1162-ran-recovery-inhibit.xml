<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1162 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: aa544be1-e77c-5d9b-9b16-a3d419cc355d -->
  <rule id="128715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1162 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>