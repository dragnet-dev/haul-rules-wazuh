<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1804 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f95e8de4-8080-5841-975c-4bf57bbe7d78 -->
  <rule id="585581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1804 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>