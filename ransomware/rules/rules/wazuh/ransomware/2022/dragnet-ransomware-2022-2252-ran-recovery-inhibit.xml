<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2252 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0ad61a5d-4cea-5a04-b47a-8a2a32d31956 -->
  <rule id="177865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2252 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>