<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2838 — Event Log Clearing (daixin) | Status: deprecated | Sigma ID: 5bf91d27-f624-5ee4-b4fa-d9845d2cd3e6 -->
  <rule id="655069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2838 — Event Log Clearing (daixin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>