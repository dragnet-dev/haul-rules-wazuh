<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1184 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7ab2464e-d235-597a-89c3-50fc6c118e1c -->
  <rule id="263246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1184 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>