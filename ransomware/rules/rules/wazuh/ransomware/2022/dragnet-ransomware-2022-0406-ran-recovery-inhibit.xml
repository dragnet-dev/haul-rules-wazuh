<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0406 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: e0478922-c605-5d21-893a-94f2463274a0 -->
  <rule id="604789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0406 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
