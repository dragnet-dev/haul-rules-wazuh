<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0516 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 9111f903-1fbb-57e7-87b2-1fb25dbfae66 -->
  <rule id="657919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0516 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>