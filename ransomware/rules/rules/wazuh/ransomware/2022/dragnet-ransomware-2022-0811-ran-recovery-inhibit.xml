<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0811 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 6fa9d6ec-b99e-5d38-a333-295bcc074374 -->
  <rule id="259176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0811 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
