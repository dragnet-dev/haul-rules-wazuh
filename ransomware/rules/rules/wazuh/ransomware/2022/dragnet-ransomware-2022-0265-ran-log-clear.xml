<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0265 — Event Log Clearing (onyx) | Status: deprecated | Sigma ID: 97adf1c4-59e8-5e43-8794-ebc04f5a0abc -->
  <rule id="500951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0265 — Event Log Clearing (onyx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>