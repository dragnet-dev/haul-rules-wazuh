<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0382 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: bce38296-abaa-56f3-a61e-b6b80f12ef09 -->
  <rule id="422382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0382 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>