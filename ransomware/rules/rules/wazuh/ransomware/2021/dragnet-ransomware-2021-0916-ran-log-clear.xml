<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0916 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: cc0d2f8a-4ed0-5a03-967b-2f0aede53e07 -->
  <rule id="824527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0916 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>