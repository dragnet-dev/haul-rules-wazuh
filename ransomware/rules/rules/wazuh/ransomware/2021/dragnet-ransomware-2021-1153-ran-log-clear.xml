<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1153 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 3e2f599c-8392-5fa6-b3aa-53336505faf2 -->
  <rule id="167599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1153 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>