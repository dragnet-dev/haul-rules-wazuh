<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1496 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: f501a63e-517f-52b5-8d90-31e23f8cf41a -->
  <rule id="780266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1496 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>