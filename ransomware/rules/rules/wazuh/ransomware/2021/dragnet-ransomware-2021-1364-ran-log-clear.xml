<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1364 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 7d438a38-3a4d-5769-b2bc-e8b37eddf53a -->
  <rule id="307018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1364 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>