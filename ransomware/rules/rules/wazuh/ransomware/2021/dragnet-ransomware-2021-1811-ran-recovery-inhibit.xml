<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1811 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 3345ad61-0421-507d-a738-df037320cfe3 -->
  <rule id="564936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1811 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>