<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1671 — Recovery Inhibition (atomsilo) | Status: experimental | Sigma ID: 966b5e26-6aff-554b-b223-cde8aad4bb6a -->
  <rule id="774814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1671 — Recovery Inhibition (atomsilo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>