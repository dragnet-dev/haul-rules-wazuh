<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1186 — Recovery Inhibition (azroteam) | Status: deprecated | Sigma ID: cb074ca2-6381-54e2-9644-ed5a417def24 -->
  <rule id="649196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1186 — Recovery Inhibition (azroteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>