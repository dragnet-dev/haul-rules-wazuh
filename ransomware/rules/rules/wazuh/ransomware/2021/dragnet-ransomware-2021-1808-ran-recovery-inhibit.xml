<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1808 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b8ea397c-7ee3-5039-a7dc-03175887926e -->
  <rule id="444239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1808 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
