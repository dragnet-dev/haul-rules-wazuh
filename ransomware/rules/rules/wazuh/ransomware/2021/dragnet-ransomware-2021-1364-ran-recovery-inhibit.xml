<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1364 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d03466dc-1627-5fb7-84b0-f7727c368774 -->
  <rule id="503466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1364 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>