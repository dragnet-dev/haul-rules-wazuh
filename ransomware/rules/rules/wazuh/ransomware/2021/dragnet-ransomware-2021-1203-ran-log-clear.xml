<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1203 — Event Log Clearing (lv) | Status: deprecated | Sigma ID: 2e5d0e3c-56ed-5623-9218-d97124ff4ed1 -->
  <rule id="392494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1203 — Event Log Clearing (lv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>