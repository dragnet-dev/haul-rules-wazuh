<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0787 — Event Log Clearing (groove) | Status: deprecated | Sigma ID: 2b7aa14e-eb88-5cf9-b829-b628622a447a -->
  <rule id="320421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0787 — Event Log Clearing (groove)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>