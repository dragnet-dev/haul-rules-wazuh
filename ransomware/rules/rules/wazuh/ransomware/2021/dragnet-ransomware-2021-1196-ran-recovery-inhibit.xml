<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1196 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 7df623aa-802e-540b-aee5-de663fae225e -->
  <rule id="315623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1196 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
