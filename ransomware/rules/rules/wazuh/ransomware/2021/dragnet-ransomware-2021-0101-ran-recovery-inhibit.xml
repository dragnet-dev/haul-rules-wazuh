<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0101 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: dee47651-90c6-5406-a9ae-721db5d919a2 -->
  <rule id="966476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0101 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>