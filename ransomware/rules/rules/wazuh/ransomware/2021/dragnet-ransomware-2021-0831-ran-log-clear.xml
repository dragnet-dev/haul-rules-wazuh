<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0831 — Event Log Clearing (lockdata) | Status: deprecated | Sigma ID: e840d6e6-db9a-5b57-b3b2-fcd884c67d98 -->
  <rule id="674536" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0831 — Event Log Clearing (lockdata)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>