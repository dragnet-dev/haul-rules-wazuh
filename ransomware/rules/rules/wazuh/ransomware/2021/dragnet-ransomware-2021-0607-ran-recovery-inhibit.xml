<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0607 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 7a2bcfc1-3a29-5381-a269-78e280c5f2eb -->
  <rule id="608335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0607 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>