<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1059 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: ebf158a4-646c-5cf8-82c7-56a2392a3330 -->
  <rule id="275158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1059 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>