<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0594 — Event Log Clearing (groove) | Status: deprecated | Sigma ID: c3c4f144-2df4-5a5e-b125-11522f5ffe21 -->
  <rule id="568791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0594 — Event Log Clearing (groove)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>