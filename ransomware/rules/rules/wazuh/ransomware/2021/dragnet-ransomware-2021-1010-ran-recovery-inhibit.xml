<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1010 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 274ded31-b469-5555-8ab0-b4bf9471059b -->
  <rule id="325869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1010 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>