<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0141 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 22294044-01e6-538a-97eb-dbdd6ae98a9a -->
  <rule id="529404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0141 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>