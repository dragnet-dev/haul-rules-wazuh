<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1114 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: f6ff915f-4fad-58ba-b42d-c0821c19fcf5 -->
  <rule id="519191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1114 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
