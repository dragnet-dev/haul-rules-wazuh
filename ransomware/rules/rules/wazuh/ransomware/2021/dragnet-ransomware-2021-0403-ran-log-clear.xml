<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0403 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 10849ee3-9d35-5f42-b71a-b2a724d9fbd1 -->
  <rule id="177582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0403 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>