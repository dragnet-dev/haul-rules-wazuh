<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0138 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: 766eb158-f9e9-5b40-9b24-df463aaeffbc -->
  <rule id="263311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0138 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>