<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0906 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 773485fe-f826-5adc-bea4-0090bb5e8cb6 -->
  <rule id="775775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0906 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>