<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1569 — Event Log Clearing (grief) | Status: deprecated | Sigma ID: cb57dc2d-0fdd-5568-8706-9cd80941166c -->
  <rule id="811612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1569 — Event Log Clearing (grief)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>