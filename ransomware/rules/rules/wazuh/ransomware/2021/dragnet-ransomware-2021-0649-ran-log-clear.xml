<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0649 — Event Log Clearing (ragnarok) | Status: deprecated | Sigma ID: d683a505-eb1f-57bb-8bdd-6e371da1142b -->
  <rule id="489385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0649 — Event Log Clearing (ragnarok)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>