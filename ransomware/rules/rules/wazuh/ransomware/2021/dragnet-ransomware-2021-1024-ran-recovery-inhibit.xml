<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1024 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: cb4b22c2-25d4-5984-83a9-b290ef1a99e8 -->
  <rule id="655522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1024 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>