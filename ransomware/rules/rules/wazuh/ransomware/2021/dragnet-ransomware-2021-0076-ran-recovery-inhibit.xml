<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0076 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 800293a2-407e-55d5-8bdc-755ef2631e50 -->
  <rule id="304698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0076 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>