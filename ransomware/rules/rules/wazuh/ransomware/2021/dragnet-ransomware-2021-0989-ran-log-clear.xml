<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0989 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 968d7d4b-1825-58e2-9613-8440bb9b9e34 -->
  <rule id="780285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0989 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>