<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0952 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 33acd10b-21e2-5322-be58-54cbc67d332f -->
  <rule id="579331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0952 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>