<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1681 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 7b245a8c-3901-59ac-bf3f-2c49d2123818 -->
  <rule id="271930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1681 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
