<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0807 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 47e50025-427d-5612-b69a-ffbc59c65334 -->
  <rule id="565002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0807 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>