<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0063 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 4d551a7f-dd5f-5f8a-93be-01599957a154 -->
  <rule id="440826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0063 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>