<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1775 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: f5cc2581-4eaa-5d65-a862-7a683407189c -->
  <rule id="488425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1775 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
