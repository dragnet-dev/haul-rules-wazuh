<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1092 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 24fe08ee-c0a2-5740-b2da-69d6f3b7a746 -->
  <rule id="436942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1092 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>