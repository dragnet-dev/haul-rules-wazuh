<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0324 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: c6d5b662-d888-509d-8bc2-08c4d379e869 -->
  <rule id="647316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0324 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
