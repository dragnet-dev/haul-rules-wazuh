<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0042 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 575c28b6-d73c-5006-a353-b1c9f1b13e03 -->
  <rule id="439659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0042 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>