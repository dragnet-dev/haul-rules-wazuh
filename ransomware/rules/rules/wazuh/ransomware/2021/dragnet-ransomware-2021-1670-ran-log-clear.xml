<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1670 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 8b492c7b-a746-5bfe-a497-8e8826d63d79 -->
  <rule id="531884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1670 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>