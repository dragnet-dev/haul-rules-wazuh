<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0109 — Event Log Clearing (cryp70n1c0d3) | Status: deprecated | Sigma ID: 5e7c3b65-3cb1-5888-a412-fee0cc667216 -->
  <rule id="726299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0109 — Event Log Clearing (cryp70n1c0d3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>