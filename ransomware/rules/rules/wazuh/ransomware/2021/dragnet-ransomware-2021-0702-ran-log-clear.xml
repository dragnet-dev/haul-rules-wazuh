<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0702 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 48bc8db6-8717-5a82-8087-72e63fe2b5b6 -->
  <rule id="296301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0702 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>