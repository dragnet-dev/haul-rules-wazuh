<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0169 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 5215d7a1-ce09-5412-9e73-980daf3f1732 -->
  <rule id="852602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0169 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>