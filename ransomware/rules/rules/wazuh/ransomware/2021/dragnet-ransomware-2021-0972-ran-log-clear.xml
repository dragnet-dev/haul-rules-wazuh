<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0972 — Event Log Clearing (babuk) | Status: experimental | Sigma ID: 5e53089a-7aec-5f5f-bedb-2a978e604642 -->
  <rule id="553089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0972 — Event Log Clearing (babuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>