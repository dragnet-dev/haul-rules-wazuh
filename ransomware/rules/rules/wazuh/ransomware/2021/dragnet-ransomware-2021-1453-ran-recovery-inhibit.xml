  <rule id="350602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1453 — Recovery Inhibition (darkside)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
