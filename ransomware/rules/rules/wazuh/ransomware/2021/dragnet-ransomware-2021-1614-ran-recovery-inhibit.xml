<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1614 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: e20999b6-8d43-51a0-888e-c8fbad6bcc78 -->
  <rule id="620999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1614 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>