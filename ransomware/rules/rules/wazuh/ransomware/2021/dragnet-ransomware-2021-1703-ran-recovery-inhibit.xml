<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1703 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: b42a3677-53c5-5bce-af57-59f07516ab51 -->
  <rule id="128236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1703 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>