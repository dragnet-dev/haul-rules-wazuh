<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0014 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 1e1b2baa-bcab-5c3c-a779-8b338f2d4de3 -->
  <rule id="757818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0014 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>