<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0497 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: c9b20b17-0619-552c-a71c-a957a36a6acb -->
  <rule id="720331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0497 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>