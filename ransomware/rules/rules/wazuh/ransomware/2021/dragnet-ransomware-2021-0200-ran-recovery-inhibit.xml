<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0200 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 15017982-7a81-52f7-aa71-361b8ccb4cdb -->
  <rule id="701798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0200 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>