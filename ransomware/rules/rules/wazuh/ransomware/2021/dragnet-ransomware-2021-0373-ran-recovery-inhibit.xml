<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0373 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 44ef7e83-b23a-5786-ad2d-023952fc32bf -->
  <rule id="140606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0373 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>