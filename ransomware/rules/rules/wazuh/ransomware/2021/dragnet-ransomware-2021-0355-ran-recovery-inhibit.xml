<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0355 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: c2a5c21d-8b01-5849-9740-6f58bc9603b8 -->
  <rule id="540122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0355 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>