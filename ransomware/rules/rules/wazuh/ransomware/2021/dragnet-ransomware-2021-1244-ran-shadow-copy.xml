<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1244 — Shadow Copy Deletion (cryp70n1c0d3) | Status: deprecated | Sigma ID: 05607847-2deb-543d-8d24-066df6e4dd40 -->
  <rule id="307847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1244 — Shadow Copy Deletion (cryp70n1c0d3)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>