<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0401 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: 79dc9927-d625-5959-b40e-6850f720683e -->
  <rule id="344499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0401 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>