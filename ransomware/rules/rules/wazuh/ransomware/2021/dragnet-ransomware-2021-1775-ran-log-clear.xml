<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1775 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: a27e6101-89a2-5e1b-9b21-3f0f14f43731 -->
  <rule id="844661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1775 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>