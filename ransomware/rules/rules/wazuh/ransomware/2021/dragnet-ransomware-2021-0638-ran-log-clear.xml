<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0638 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 31265a2f-d3c2-5b27-8c6e-ec60f84a7c28 -->
  <rule id="602502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0638 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>