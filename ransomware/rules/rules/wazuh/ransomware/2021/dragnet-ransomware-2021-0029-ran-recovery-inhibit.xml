<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0029 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d58ca261-352e-5b04-877e-f71c57b2e720 -->
  <rule id="878502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0029 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>