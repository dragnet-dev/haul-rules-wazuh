<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0562 — Recovery Inhibition (alphv) | Status: deprecated | Sigma ID: 54322313-aee9-5e2c-a341-7d375c514798 -->
  <rule id="132231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0562 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
