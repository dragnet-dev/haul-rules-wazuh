<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0569 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 786d4df1-cef6-5f0d-9735-040b603b3d0f -->
  <rule id="314317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0569 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>