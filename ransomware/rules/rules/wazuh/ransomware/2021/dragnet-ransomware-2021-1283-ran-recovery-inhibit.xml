<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1283 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 49fbc4a4-4629-5773-a584-acbffe55863f -->
  <rule id="347324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1283 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>