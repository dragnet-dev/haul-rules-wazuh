<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0423 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 7cc02b4c-d99c-5801-864e-5090928b2875 -->
  <rule id="593643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0423 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
