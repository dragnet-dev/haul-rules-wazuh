<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1574 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: c86eb20e-c172-5a8d-b769-d1407ea2c5e9 -->
  <rule id="694512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1574 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>