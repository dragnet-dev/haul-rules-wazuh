<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0636 — Event Log Clearing (marketo) | Status: deprecated | Sigma ID: 7c72c238-9cb4-5f86-a259-7603fcc5f597 -->
  <rule id="295642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0636 — Event Log Clearing (marketo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>