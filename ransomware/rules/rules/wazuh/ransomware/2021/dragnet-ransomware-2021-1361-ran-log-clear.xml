<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1361 — Event Log Clearing (karma) | Status: deprecated | Sigma ID: f3c5fdd3-05c9-5ca6-930a-51378dbe6810 -->
  <rule id="999133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1361 — Event Log Clearing (karma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>