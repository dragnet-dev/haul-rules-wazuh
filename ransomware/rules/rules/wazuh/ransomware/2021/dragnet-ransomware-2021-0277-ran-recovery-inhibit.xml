<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0277 — Recovery Inhibition (phoenixcryptolocker) | Status: deprecated | Sigma ID: ba170ef8-e207-5150-add0-df992a012b81 -->
  <rule id="378734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0277 — Recovery Inhibition (phoenixcryptolocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>