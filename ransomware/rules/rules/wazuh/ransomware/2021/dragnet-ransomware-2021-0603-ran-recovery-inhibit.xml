<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0603 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 9f1632c6-16c3-543b-b77b-a26d138068af -->
  <rule id="791632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0603 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>