<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1546 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 487a679a-a287-50c4-a652-56a5251d8d7f -->
  <rule id="702679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1546 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>