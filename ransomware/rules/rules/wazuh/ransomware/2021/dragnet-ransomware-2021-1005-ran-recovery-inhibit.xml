<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1005 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 3bef0012-0b29-53da-8f16-aee2a5842a3e -->
  <rule id="734300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1005 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>