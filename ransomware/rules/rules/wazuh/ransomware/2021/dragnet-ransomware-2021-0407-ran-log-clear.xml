<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0407 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 943f0f1b-12e4-5b3b-a66e-49eada1c1be6 -->
  <rule id="716495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0407 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>