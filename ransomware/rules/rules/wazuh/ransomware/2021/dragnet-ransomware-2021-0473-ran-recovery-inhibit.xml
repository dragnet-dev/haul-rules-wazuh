<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0473 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 7b78ece8-37da-5cf6-9ea9-e21a862ffd48 -->
  <rule id="569004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0473 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>