<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1571 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 47acdf81-a2ba-5ce5-8733-22afb36f803e -->
  <rule id="524447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1571 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>