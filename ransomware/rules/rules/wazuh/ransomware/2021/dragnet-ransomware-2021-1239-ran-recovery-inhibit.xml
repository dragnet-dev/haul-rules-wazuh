<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1239 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 0302133f-6d3c-50a4-827d-62384af29306 -->
  <rule id="434143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1239 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>