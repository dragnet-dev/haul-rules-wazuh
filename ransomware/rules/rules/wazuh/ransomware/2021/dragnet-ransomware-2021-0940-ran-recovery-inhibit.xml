<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0940 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: f9462872-4bbd-54e7-a933-ed387f978d5c -->
  <rule id="794628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0940 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>