<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0439 — Event Log Clearing (lapsus$) | Status: deprecated | Sigma ID: 82d9e87d-60c8-5740-a4b8-f5f997d073a1 -->
  <rule id="421588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0439 — Event Log Clearing (lapsus$)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>