<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1464 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: f96d6ce4-7bb5-54fb-80c8-73551524a5ef -->
  <rule id="587948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1464 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>