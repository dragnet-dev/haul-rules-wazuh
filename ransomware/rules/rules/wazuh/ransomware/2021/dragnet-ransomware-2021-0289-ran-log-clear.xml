<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0289 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: e3329bbb-cdfc-52ec-a6a2-03b99b666664 -->
  <rule id="593275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0289 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>