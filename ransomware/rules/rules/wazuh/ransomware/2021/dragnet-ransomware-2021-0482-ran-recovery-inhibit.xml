<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0482 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 95fcb3da-27de-5dbc-88c7-9aced5a1d2de -->
  <rule id="431633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0482 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>