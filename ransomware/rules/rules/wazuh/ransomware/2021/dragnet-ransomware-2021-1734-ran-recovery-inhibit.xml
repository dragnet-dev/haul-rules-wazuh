<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1734 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d741541d-c583-5e1e-865c-faed8f158686 -->
  <rule id="574154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1734 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
