<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0427 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 1e2eac22-01a5-59e1-a2aa-a097026d2b86 -->
  <rule id="440748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0427 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>