<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0205 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: bb8e7ac9-ff74-59ed-b0c2-32a8e1a53689 -->
  <rule id="410042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0205 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>