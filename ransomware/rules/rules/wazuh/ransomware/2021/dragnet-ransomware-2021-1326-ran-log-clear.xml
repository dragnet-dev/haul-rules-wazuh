<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1326 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 62cedc5a-f772-5c7a-bbb1-a9a1ada665f8 -->
  <rule id="616188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1326 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>