<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0611 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 6c4f79e4-1cf7-57f4-aa98-27d6ddd8698f -->
  <rule id="935979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0611 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>