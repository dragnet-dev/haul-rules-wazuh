<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1274 — Event Log Clearing (sabbath) | Status: deprecated | Sigma ID: 6828866c-7437-53a1-bea0-c055a190c575 -->
  <rule id="628866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1274 — Event Log Clearing (sabbath)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>