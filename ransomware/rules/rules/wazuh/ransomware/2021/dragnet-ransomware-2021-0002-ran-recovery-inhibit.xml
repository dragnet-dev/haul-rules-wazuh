<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0002 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 718c2729-36df-5495-81a2-bbe091057e16 -->
  <rule id="350027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0002 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>