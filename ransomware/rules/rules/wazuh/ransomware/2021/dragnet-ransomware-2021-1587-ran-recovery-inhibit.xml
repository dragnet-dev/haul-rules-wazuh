<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1587 — Recovery Inhibition (lockbit) | Status: deprecated | Sigma ID: 05496318-db7b-506c-98b9-3dc5cdf24fb4 -->
  <rule id="196318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1587 — Recovery Inhibition (lockbit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>