<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1794 — Recovery Inhibition (babuk) | Status: experimental | Sigma ID: f30ee97a-153a-50dc-bd50-b9f3b2dcd4d3 -->
  <rule id="419189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1794 — Recovery Inhibition (babuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>