<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0161 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 6b8e2ebc-1076-58b1-b3ea-472410c5da19 -->
  <rule id="161966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0161 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>