<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0233 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 3ddc4c22-f6de-5012-a172-fa03273d81cb -->
  <rule id="833836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0233 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>