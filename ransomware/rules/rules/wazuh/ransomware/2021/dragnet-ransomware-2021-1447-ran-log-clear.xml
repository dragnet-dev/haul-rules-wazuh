<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1447 — Event Log Clearing (ragnarok) | Status: deprecated | Sigma ID: b8bfd960-3b24-5673-a025-4e3a5662a09b -->
  <rule id="463979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1447 — Event Log Clearing (ragnarok)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>