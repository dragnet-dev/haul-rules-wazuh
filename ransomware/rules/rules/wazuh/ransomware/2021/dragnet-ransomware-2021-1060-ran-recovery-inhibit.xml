<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1060 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1885e6ce-4e40-50cb-8d07-f808f96e09ce -->
  <rule id="427948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1060 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
