<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0775 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: a9e17bc6-4e22-548d-888d-e081f7229888 -->
  <rule id="213083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0775 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
