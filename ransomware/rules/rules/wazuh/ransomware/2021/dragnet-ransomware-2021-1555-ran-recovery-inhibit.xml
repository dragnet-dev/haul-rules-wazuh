<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1555 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 6aee42a7-4867-513b-9171-e306bd9ab64b -->
  <rule id="137442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1555 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
