<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1121 — Event Log Clearing (astroteam) | Status: deprecated | Sigma ID: 91a105a4-5cc7-570e-b18b-a17737c7a0a2 -->
  <rule id="666105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1121 — Event Log Clearing (astroteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>