<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0166 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ce048b15-1bb0-501d-8df9-345895d7252a -->
  <rule id="696779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0166 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
