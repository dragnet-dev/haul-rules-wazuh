<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0231 — Recovery Inhibition (azroteam) | Status: deprecated | Sigma ID: 1bdfcb8c-546e-54f6-bc6f-151bb40197db -->
  <rule id="126763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0231 — Recovery Inhibition (azroteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>