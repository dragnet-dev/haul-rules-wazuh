<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1746 — Event Log Clearing (alphv) | Status: deprecated | Sigma ID: b0c9bf63-8abf-59e7-bd67-12d7c91cf0f1 -->
  <rule id="138815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1746 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>