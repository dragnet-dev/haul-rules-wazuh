<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0306 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 9e9a6c18-6ad3-5bbb-bd58-1d8be7e7af97 -->
  <rule id="569548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0306 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>