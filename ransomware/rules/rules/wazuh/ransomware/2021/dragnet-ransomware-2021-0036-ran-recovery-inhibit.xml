<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0036 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: dbbaaebe-4382-5fb3-8f3c-ba203b84a357 -->
  <rule id="100174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0036 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>