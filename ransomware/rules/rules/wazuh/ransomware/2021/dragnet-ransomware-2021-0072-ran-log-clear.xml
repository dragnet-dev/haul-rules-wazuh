<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0072 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 4940fa3b-bbd3-5a88-a2ec-a0e4019527a1 -->
  <rule id="464890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0072 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>