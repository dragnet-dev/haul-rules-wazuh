<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1594 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 1b3dc2cc-7ee9-5b22-a3c2-a88c078aa2e0 -->
  <rule id="517324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1594 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>