<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0920 — Event Log Clearing (sabbath) | Status: deprecated | Sigma ID: d27aee92-7dd4-5fb1-9dab-9ce8280d1111 -->
  <rule id="138190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0920 — Event Log Clearing (sabbath)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>