<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0100 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 96d30123-7d1d-5c60-a6ac-2b6ee4a9d6e1 -->
  <rule id="749301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0100 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>