<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1332 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: dc8231a3-1fb8-585f-81d3-0fc81377d4af -->
  <rule id="508231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1332 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>