<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1741 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 7048e1fb-7caf-5d57-8e89-4a2b6a3d9d45 -->
  <rule id="327821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1741 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>