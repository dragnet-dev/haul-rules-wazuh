<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0670 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: c66b3440-7f86-56e6-a8cb-6b17f0f85b72 -->
  <rule id="326734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0670 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>