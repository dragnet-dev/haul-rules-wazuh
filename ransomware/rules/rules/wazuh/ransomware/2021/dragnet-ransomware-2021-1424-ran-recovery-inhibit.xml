<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1424 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 05ae4ff1-c858-5897-aef5-f51da36ffd59 -->
  <rule id="223519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1424 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>