<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0366 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 508c98ce-ec8d-5316-9a46-fa70cd368879 -->
  <rule id="525580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0366 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>