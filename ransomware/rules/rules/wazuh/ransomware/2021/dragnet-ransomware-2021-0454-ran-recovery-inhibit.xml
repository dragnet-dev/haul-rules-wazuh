<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0454 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 7b59123d-f939-5658-b34f-1416c21d1ad7 -->
  <rule id="435912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0454 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>