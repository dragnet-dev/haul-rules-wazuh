<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0653 — Recovery Inhibition (atomsilo) | Status: experimental | Sigma ID: 755e0a05-42a7-5145-b1dd-4f52988198a2 -->
  <rule id="235050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0653 — Recovery Inhibition (atomsilo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>