<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0783 — Event Log Clearing (spook) | Status: deprecated | Sigma ID: 1fa8c9ff-9b22-5d63-b273-918038225a40 -->
  <rule id="476159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0783 — Event Log Clearing (spook)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>