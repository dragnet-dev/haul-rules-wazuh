<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1304 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 82d78a5b-7c30-580b-ab5d-a4424cb10aac -->
  <rule id="421258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1304 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>