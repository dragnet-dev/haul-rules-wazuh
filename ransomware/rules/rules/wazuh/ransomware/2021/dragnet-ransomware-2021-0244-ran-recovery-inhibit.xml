<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0244 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 402e970d-d7c2-5e7c-95d7-70624fe523de -->
  <rule id="246970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0244 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>