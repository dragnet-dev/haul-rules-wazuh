<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0277 — Shadow Copy Deletion (phoenixcryptolocker) | Status: deprecated | Sigma ID: 1915893b-b0d0-5b93-8d92-acdffaaa11bc -->
  <rule id="215893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0277 — Shadow Copy Deletion (phoenixcryptolocker)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>