  <rule id="834858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1401 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
