<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1305 — Event Log Clearing (snatch) | Status: deprecated | Sigma ID: 3b4c2683-76d4-54b4-8193-b6103ea94bcc -->
  <rule id="616268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1305 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>