<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0294 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ef13bee5-bd6e-589c-b333-19f4b26951e4 -->
  <rule id="821918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0294 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>