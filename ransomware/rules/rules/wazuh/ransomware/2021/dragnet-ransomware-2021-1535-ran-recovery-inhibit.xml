<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1535 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5e1ea430-4082-545a-a490-b64f63e6b76a -->
  <rule id="711304" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1535 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>