<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1041 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 89b49855-ba4d-5f0c-b5ee-da457ea229d3 -->
  <rule id="635498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1041 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
