<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0056 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 539e5578-97c6-526e-a8f8-c717eeaa762a -->
  <rule id="638557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0056 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>