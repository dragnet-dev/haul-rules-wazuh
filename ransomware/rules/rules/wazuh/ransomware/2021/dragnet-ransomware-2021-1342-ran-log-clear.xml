<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1342 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 2d4a7c7a-10aa-5b5a-a749-ea41391b8cb7 -->
  <rule id="363964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1342 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>