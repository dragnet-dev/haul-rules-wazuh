<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0271 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ffe48430-a809-5a5a-9b97-a46486fc5a19 -->
  <rule id="594484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0271 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>