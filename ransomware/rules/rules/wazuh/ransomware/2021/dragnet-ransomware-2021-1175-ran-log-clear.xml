<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1175 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 6bd607f1-1ed5-548d-80b2-18ef9128414d -->
  <rule id="925607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1175 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>