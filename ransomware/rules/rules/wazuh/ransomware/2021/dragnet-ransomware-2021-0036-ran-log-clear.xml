<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0036 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: faa7aa2e-a3bb-5e2a-81d8-24cf589bd13e -->
  <rule id="467562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0036 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>