<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1771 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: f08c2a63-9717-5251-ab74-5a85a3ef8928 -->
  <rule id="362442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1771 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>