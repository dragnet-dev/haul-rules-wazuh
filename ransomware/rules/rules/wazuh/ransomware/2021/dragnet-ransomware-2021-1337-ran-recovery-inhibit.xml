<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1337 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 3896ba79-8b97-545c-95f9-87720dd3425a -->
  <rule id="175627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1337 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>