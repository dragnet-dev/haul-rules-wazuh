<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1070 — Event Log Clearing (babuk) | Status: experimental | Sigma ID: d7d62594-b32b-5e38-b433-f691c4ea86a1 -->
  <rule id="505625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1070 — Event Log Clearing (babuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>