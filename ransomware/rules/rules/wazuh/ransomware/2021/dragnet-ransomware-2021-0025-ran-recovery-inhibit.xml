<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0025 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: a05d4897-9ad3-5d63-8287-0592513d195e -->
  <rule id="809348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0025 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>