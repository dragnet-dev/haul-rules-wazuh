<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0258 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 2eb48515-ff9b-5d37-aaea-d7c4285a6697 -->
  <rule id="374851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0258 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
