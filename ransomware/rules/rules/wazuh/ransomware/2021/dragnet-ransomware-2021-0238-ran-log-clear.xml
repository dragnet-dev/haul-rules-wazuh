<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0238 — Event Log Clearing (darkside) | Status: deprecated | Sigma ID: 8dc48eed-9b2a-5a7c-9601-d59ba8bb1bb4 -->
  <rule id="129582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0238 — Event Log Clearing (darkside)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>