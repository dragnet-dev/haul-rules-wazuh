<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1671 — Event Log Clearing (atomsilo) | Status: experimental | Sigma ID: 2d56ce30-4eee-56e1-91d6-cbc935d56e67 -->
  <rule id="366542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1671 — Event Log Clearing (atomsilo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>