<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0818 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: ba1453ae-22c5-5476-b5c2-f5bcd382a315 -->
  <rule id="161453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0818 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>