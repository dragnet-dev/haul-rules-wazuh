<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0070 — Recovery Inhibition (payloadbin) | Status: deprecated | Sigma ID: 6f7722d5-fb48-5164-be16-a21ecf0405d2 -->
  <rule id="317722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0070 — Recovery Inhibition (payloadbin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
