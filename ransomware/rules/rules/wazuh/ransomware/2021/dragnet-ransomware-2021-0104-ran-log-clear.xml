<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0104 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 6d9b8fa7-dda8-5236-a9ea-acc2d316cd92 -->
  <rule id="215343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0104 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>