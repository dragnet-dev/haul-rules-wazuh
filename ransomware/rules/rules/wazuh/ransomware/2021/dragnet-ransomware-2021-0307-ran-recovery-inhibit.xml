<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0307 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: 651ea82e-2f1a-540c-9b03-51b94adede52 -->
  <rule id="868908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0307 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
