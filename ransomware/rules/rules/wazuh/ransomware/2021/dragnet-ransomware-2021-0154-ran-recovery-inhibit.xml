<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0154 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: de6c2a3f-bbc6-5072-811d-95af175117ca -->
  <rule id="400522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0154 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>