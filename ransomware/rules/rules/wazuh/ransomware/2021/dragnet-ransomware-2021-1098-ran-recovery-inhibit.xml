<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1098 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: e959373d-6cc3-5854-8173-6cb401eebf3d -->
  <rule id="695937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1098 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>