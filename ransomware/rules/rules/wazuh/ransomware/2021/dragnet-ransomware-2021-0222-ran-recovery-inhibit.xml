<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0222 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 9d999fa2-e774-5a88-b9b7-d35ee52eaf89 -->
  <rule id="827999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0222 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>