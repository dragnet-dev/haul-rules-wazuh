<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0577 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 294d8317-e9d8-56b7-93cb-49499ec38215 -->
  <rule id="317831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0577 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>