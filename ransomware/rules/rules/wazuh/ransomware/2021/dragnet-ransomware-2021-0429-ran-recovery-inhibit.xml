<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0429 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: 683b47e2-571e-5b47-b101-585b2b623b27 -->
  <rule id="293947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0429 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
