<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0475 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: fa3ca514-d1de-5485-ad1e-b3bf3bc43cc4 -->
  <rule id="209705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0475 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>