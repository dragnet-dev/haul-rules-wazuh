<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0683 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ec18c112-20a0-5135-889f-fbc18ab5a740 -->
  <rule id="279001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0683 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>