<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1612 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: cb5a69e3-e5c3-57fb-8837-97826ad74803 -->
  <rule id="657069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1612 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>