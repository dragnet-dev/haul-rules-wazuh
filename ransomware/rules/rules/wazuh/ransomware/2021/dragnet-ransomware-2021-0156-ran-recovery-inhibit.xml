<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0156 — Recovery Inhibition (lockdata) | Status: deprecated | Sigma ID: 9a4ab590-4efe-5896-b295-3f6be5b884f6 -->
  <rule id="454355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0156 — Recovery Inhibition (lockdata)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>