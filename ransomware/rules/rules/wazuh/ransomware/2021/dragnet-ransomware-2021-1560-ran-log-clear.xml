<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1560 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 1a60fed3-e114-593d-ae7d-ccd4a1c671d7 -->
  <rule id="199437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1560 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>