<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1200 — Event Log Clearing (payloadbin) | Status: deprecated | Sigma ID: 3058ad3c-2860-5dad-8cdc-c5bd5eea742c -->
  <rule id="730213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1200 — Event Log Clearing (payloadbin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>