<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0540 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: c96ae6d6-63b7-5ead-b6d3-9548c294b1b6 -->
  <rule id="719506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0540 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>