<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0685 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 548882aa-f8ed-500f-863e-48505c28e2da -->
  <rule id="782122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0685 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>