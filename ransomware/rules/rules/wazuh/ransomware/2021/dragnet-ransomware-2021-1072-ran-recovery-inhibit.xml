<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1072 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 568a9733-593d-5666-8805-fe999fafd19a -->
  <rule id="198973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1072 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>