<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0443 — Recovery Inhibition (midas) | Status: deprecated | Sigma ID: dffae8ce-cef8-5729-9007-d0ee028b8eff -->
  <rule id="274228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0443 — Recovery Inhibition (midas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>