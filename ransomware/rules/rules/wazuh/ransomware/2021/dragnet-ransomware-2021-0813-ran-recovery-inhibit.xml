<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0813 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 585ef568-d82f-54ca-af87-f52f62a9e98e -->
  <rule id="699995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0813 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>