<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0051 — Event Log Clearing (robinhood) | Status: deprecated | Sigma ID: e71e6c19-70d9-55c7-a3f2-8412b77928d5 -->
  <rule id="268108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0051 — Event Log Clearing (robinhood)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>