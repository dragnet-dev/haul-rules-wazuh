<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1599 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: db2b7e40-d3bb-52ed-8ea2-1d42e00e8159 -->
  <rule id="313406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1599 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>