<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0332 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: 81ba88fe-02c1-5052-8ea3-27fb706a2fb2 -->
  <rule id="392288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0332 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>