<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0120 — Recovery Inhibition (blacktor) | Status: deprecated | Sigma ID: d6402ff7-bcc9-5a21-a1d0-eef07020ac60 -->
  <rule id="482447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0120 — Recovery Inhibition (blacktor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>