<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0021 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 9cdaa91b-2b76-5c17-adc6-a59c926ce1c7 -->
  <rule id="224749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0021 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>