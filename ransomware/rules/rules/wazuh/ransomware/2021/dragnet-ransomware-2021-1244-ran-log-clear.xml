<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1244 — Event Log Clearing (cryp70n1c0d3) | Status: deprecated | Sigma ID: 98ac0c30-61ce-5da2-94a1-a934d9289a8a -->
  <rule id="541612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1244 — Event Log Clearing (cryp70n1c0d3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>