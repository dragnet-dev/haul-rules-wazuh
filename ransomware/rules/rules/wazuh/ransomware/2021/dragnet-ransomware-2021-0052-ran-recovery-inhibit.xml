<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0052 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 02a7cbb0-9fcb-591c-b271-578e853ece8c -->
  <rule id="952251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0052 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>