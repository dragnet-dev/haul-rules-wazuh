<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0232 — Recovery Inhibition (xinglocker) | Status: deprecated | Sigma ID: 04f7a771-93a7-57a2-a1c2-398f400a3584 -->
  <rule id="476277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0232 — Recovery Inhibition (xinglocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>