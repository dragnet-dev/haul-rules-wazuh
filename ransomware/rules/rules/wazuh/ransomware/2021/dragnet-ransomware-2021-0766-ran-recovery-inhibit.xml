<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0766 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: fe2055bd-eff4-519b-8298-e992d6641286 -->
  <rule id="842055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0766 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>