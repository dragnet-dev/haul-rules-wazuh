<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1695 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 7bd1b16c-54b0-5e94-88b3-718dd29d6d12 -->
  <rule id="569871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1695 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>