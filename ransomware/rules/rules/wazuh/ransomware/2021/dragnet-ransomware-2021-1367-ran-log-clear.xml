<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1367 — Event Log Clearing (mosesstaff) | Status: deprecated | Sigma ID: 5d3cb1f9-2406-559b-b22d-9051a2101b49 -->
  <rule id="690511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1367 — Event Log Clearing (mosesstaff)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>