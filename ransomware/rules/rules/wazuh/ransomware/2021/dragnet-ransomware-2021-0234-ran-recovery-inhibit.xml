<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0234 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2e348364-9e58-5ba5-9977-ba654c9b1334 -->
  <rule id="234836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0234 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>