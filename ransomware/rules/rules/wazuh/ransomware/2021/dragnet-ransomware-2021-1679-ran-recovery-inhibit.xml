<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1679 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 70eed89a-ade5-5124-a4aa-ff335463ff7a -->
  <rule id="305418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1679 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>