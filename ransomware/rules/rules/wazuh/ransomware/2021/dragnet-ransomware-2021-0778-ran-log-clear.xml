<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0778 — Event Log Clearing (payloadbin) | Status: deprecated | Sigma ID: c8c13b8f-851e-5540-8771-55dd270f2944 -->
  <rule id="696219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0778 — Event Log Clearing (payloadbin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>