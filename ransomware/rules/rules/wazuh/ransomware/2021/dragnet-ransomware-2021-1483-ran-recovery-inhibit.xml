<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1483 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c71846cb-b211-5ada-b214-4fe5ef1339d4 -->
  <rule id="471846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1483 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>