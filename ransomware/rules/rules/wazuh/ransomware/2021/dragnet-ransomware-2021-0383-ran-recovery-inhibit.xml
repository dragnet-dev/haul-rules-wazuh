<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0383 — Recovery Inhibition (darkside) | Status: deprecated | Sigma ID: 6bae5082-ec64-5416-9f5b-4f480bfab253 -->
  <rule id="156650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0383 — Recovery Inhibition (darkside)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>