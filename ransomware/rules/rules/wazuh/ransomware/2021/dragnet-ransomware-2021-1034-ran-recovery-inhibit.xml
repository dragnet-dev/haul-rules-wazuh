<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1034 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e790aa48-d3a2-5302-96a5-ad6662478f27 -->
  <rule id="286410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1034 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>