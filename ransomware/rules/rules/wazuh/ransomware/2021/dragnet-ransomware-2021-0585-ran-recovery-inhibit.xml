<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0585 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 474e5e1b-53a5-529f-82c7-3187058655be -->
  <rule id="415774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0585 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>