<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0354 — Event Log Clearing (xinglocker) | Status: deprecated | Sigma ID: af4fc90d-8899-5882-8abb-76e55f753fa6 -->
  <rule id="992769" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0354 — Event Log Clearing (xinglocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>