<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1708 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: f2f1af55-00db-55ab-bb5a-315c0006fe94 -->
  <rule id="964751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1708 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
