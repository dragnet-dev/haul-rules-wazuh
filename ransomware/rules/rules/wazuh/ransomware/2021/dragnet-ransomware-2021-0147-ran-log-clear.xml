<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0147 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 0ae9d0c0-8255-5082-8d6b-f6ea2108d673 -->
  <rule id="979532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0147 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>