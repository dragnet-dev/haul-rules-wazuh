<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1770 — Event Log Clearing (darkside) | Status: deprecated | Sigma ID: 03569435-42da-5cda-a57c-2df4c3ab512b -->
  <rule id="969435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1770 — Event Log Clearing (darkside)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>