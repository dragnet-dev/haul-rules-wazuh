<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1101 — Shadow Copy Deletion (cryp70n1c0d3) | Status: deprecated | Sigma ID: f88f4195-297e-5115-97aa-b1b7e5fffa02 -->
  <rule id="842341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1101 — Shadow Copy Deletion (cryp70n1c0d3)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>