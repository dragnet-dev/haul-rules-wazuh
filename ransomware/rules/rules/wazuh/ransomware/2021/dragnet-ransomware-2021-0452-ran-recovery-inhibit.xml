<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0452 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: c43cfd99-da4f-5e5d-923e-9367d74ad457 -->
  <rule id="694653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0452 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>