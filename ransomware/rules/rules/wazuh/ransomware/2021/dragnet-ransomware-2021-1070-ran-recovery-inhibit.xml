<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1070 — Recovery Inhibition (babuk) | Status: experimental | Sigma ID: 80b2ba71-50bd-500d-a113-1cc6a7caa70c -->
  <rule id="705658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1070 — Recovery Inhibition (babuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>