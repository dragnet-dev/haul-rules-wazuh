<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0233 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 8d4e8b83-5ce4-5158-9811-7dcdf6bdad4d -->
  <rule id="122219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0233 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>