<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0390 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: b36b3814-b0af-5da2-82e3-57ad0fe7e5f5 -->
  <rule id="118738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0390 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>