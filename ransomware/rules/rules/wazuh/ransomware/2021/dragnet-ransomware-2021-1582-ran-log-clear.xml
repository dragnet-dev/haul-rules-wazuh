<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1582 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 8e37f8f9-7394-5f0d-938b-51e2f1499ed9 -->
  <rule id="578078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1582 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>