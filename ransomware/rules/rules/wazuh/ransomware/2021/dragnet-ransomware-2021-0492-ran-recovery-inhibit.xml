<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0492 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 324e45e4-e4db-5944-95a0-46cdf220fd2f -->
  <rule id="317534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0492 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>