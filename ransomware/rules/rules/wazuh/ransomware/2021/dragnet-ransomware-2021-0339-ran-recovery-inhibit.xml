<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0339 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 3a308275-fb65-5fe2-bb77-f3dba9364a75 -->
  <rule id="530827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0339 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>