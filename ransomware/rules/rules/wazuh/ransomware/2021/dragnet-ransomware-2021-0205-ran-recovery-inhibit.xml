<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0205 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: df8856e2-456c-5117-914d-9eabcb50f71d -->
  <rule id="538856" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0205 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>