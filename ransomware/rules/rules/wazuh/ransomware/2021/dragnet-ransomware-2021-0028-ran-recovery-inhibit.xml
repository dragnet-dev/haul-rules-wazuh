<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0028 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 7c168bed-712c-502a-b92d-4459a57b813b -->
  <rule id="286699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0028 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>