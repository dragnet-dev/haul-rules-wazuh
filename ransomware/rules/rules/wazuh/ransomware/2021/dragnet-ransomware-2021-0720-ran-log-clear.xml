<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0720 — Event Log Clearing (sabbath) | Status: deprecated | Sigma ID: 29e48c46-acdf-54cc-9aed-f02e5f51abd0 -->
  <rule id="555804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0720 — Event Log Clearing (sabbath)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>