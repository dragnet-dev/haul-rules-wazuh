<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0753 — Recovery Inhibition (darkside) | Status: deprecated | Sigma ID: 9915955d-a5d8-5a93-8613-9ccb7e17b303 -->
  <rule id="115955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0753 — Recovery Inhibition (darkside)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
