<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0601 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 82e2495c-495f-5f7e-bcf4-b8c888147619 -->
  <rule id="526249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0601 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>