<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0822 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: 0db5d3ec-666c-58eb-9d0c-09e5af9bca30 -->
  <rule id="321342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0822 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>