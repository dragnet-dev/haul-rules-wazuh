<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0181 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: bdfc9668-79ef-5450-9ca5-7652f9c1e948 -->
  <rule id="463696" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0181 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>