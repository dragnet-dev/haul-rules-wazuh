<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1387 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 2725f5c9-38bf-5664-a8e6-6511da6f61a2 -->
  <rule id="778492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1387 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>