<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0506 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 5d0faaa6-eff9-509b-b443-5411402558f8 -->
  <rule id="313290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0506 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>