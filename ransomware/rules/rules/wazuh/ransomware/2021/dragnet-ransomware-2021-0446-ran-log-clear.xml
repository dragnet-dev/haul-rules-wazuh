<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0446 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: ec11a7ae-c8b4-5020-98ec-39d1957474e0 -->
  <rule id="277867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0446 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>