<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1162 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 4df46738-9547-5c11-a8e0-a46fd683d200 -->
  <rule id="447467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1162 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>