<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1426 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: d6c0c3e2-6e98-5354-9b8f-5fd05aec368d -->
  <rule id="900923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1426 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>