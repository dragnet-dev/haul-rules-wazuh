<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0489 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: b3f73bf8-a05a-5413-bb8a-833d20749e89 -->
  <rule id="317979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0489 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>