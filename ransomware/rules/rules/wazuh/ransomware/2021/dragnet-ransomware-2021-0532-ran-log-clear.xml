<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0532 — Event Log Clearing (lockbit) | Status: deprecated | Sigma ID: 49100dfa-e050-5f9c-95a6-60ddeac94989 -->
  <rule id="969823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0532 — Event Log Clearing (lockbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>