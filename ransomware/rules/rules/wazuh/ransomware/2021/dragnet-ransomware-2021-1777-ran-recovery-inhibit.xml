<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1777 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: cd32555b-9dfe-5365-8be1-10aa5ad35478 -->
  <rule id="353255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1777 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>