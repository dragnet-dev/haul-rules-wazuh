<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0671 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 8b123cb0-21ac-53a2-b334-a5b9a1811ce8 -->
  <rule id="525980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0671 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>