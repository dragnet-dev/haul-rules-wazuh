<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0224 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: f5123b4e-670f-554e-880b-c64f12872bc4 -->
  <rule id="781979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0224 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>