<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0239 — Event Log Clearing (rook) | Status: deprecated | Sigma ID: c51e83c0-edc1-552a-97b9-5be86aee92b0 -->
  <rule id="303083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0239 — Event Log Clearing (rook)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>