<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0582 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 2f9ff421-2a9f-5c3d-a09b-c5649839cc0e -->
  <rule id="428794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0582 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>