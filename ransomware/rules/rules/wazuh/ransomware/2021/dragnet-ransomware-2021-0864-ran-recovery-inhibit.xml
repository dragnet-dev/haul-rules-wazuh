<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0864 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: e5d4b2dc-edfb-551e-8c50-33ac191240e8 -->
  <rule id="233552" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0864 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>