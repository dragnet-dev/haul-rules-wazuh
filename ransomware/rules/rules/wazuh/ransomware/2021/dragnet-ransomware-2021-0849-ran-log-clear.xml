<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0849 — Event Log Clearing (blackmatter) | Status: deprecated | Sigma ID: e8f4a3d6-f62b-55e2-9768-af9b6f15729f -->
  <rule id="313543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0849 — Event Log Clearing (blackmatter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>