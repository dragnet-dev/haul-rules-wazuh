<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0481 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: bce8b7ee-3645-5cb5-b710-6fbd2c107ea1 -->
  <rule id="436597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0481 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>