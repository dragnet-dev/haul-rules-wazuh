<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1349 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: dedb2b1e-7440-5c43-8a6f-99bcd141e566 -->
  <rule id="228203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1349 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>