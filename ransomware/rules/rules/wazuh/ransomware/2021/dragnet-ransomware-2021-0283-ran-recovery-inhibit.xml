<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0283 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5e37955c-1fc3-5f59-a436-bea5aae68ff3 -->
  <rule id="537955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0283 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>