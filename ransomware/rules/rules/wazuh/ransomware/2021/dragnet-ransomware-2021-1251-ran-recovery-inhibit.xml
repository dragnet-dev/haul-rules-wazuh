<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1251 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 2e88edc4-e550-5ab4-8b5c-a32539533d1f -->
  <rule id="400365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1251 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>