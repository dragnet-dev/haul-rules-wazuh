<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0236 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 6b9239df-23a6-543f-bb1a-9aee657a2036 -->
  <rule id="279239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0236 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>