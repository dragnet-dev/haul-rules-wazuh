<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0385 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 26a25d8d-8d2b-5829-8dd5-f4e74504a9a7 -->
  <rule id="620138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0385 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>