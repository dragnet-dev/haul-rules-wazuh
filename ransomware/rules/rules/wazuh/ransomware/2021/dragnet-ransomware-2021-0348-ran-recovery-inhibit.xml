<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0348 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 5540e322-ce85-5877-bdda-cc5d13388d7f -->
  <rule id="865432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0348 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>