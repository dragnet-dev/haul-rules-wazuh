<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0006 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: b888d9f7-247d-5aa7-8580-c91e6c45a646 -->
  <rule id="202219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0006 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>