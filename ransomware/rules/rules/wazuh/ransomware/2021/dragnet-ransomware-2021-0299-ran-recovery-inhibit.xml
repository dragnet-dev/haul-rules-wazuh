<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0299 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: a7220558-8506-5335-b1e2-49cd815bb84f -->
  <rule id="272205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0299 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>