<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1405 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: dacc6879-605b-5009-8a62-a756a088a6c7 -->
  <rule id="301268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1405 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>