<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0622 — Event Log Clearing (blackmatter) | Status: deprecated | Sigma ID: 35a5ec95-76bc-5026-91af-8b65b7cebaaa -->
  <rule id="660716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0622 — Event Log Clearing (blackmatter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>