<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1083 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: bf505805-c0e7-552e-aa6f-63929de7faed -->
  <rule id="215058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1083 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>