<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0592 — Event Log Clearing (blackshadow) | Status: deprecated | Sigma ID: 9e7ef9d8-f1a7-5113-aa6b-b4795f7c2799 -->
  <rule id="565119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0592 — Event Log Clearing (blackshadow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>