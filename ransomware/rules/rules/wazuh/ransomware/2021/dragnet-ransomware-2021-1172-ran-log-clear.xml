<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1172 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 05c3f2b8-9a08-553d-9ce5-5329e826dff2 -->
  <rule id="665323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1172 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>