<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0830 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 39634988-9630-5b4d-ab29-8114b76ef943 -->
  <rule id="463498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0830 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>