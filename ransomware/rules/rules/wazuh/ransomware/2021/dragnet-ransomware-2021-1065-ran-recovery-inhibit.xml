<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1065 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: d314c3bd-28cf-5cf6-8341-885212f8d2f0 -->
  <rule id="430363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1065 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>