<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1494 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 5dc181ae-58ec-574c-b680-57ebb4a6c3cf -->
  <rule id="700181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1494 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>