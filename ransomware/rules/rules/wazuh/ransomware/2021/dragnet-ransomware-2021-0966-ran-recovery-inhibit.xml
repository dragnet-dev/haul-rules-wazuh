<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0966 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 21abbbe7-257e-538d-af6c-2c6d9ab581c4 -->
  <rule id="620219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0966 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>