<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1012 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c36747b8-499d-5854-bb90-1900ce95f6f3 -->
  <rule id="436747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1012 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>