<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0405 — Recovery Inhibition (groove) | Status: deprecated | Sigma ID: 6112c084-1e90-5953-b8f4-fb8d5dc98022 -->
  <rule id="880408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0405 — Recovery Inhibition (groove)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>