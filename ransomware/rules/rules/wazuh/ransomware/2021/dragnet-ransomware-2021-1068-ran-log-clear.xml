<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1068 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 6cb3c716-4470-52db-9b7f-ab85bf7c9780 -->
  <rule id="183007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1068 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>