<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1552 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: 6421a515-bf07-5cbd-a2ca-87f37822ec97 -->
  <rule id="227465" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1552 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>