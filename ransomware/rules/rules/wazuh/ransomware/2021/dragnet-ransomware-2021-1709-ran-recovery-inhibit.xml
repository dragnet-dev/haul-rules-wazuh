<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1709 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 5c9fe3b2-3687-5e26-8493-1e40c26fe186 -->
  <rule id="680783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1709 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>