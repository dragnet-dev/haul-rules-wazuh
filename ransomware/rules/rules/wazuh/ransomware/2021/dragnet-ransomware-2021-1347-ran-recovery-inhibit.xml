<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1347 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 85fbd80d-5a5a-54e5-8c6c-361734c3aaa9 -->
  <rule id="921898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1347 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>