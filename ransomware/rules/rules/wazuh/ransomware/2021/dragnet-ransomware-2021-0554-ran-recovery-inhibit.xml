<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0554 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 55ada341-e52f-5199-853b-fd1179918398 -->
  <rule id="580583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0554 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
