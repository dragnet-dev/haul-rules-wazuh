<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0246 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5041f969-e57b-540e-96fa-61b2b56f38cc -->
  <rule id="967196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0246 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>