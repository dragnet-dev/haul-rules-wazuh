<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0214 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 59c125f8-9453-59c5-b0df-268679bf7873 -->
  <rule id="998015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0214 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>