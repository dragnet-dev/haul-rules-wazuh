<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0062 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 97a902e2-cbd4-5873-bb3e-19e5feffebce -->
  <rule id="762902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0062 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>