<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1561 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2d14ae13-c840-5ce6-81c1-9737b256f5e7 -->
  <rule id="355758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1561 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>