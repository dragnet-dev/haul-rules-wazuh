<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0346 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 97a13d5f-72bb-524c-bd95-440d4a07b38c -->
  <rule id="799421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0346 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
