<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0826 — Event Log Clearing (nefilim) | Status: deprecated | Sigma ID: 18c83f6d-59a8-5ac8-b114-cca8df9ed185 -->
  <rule id="413436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0826 — Event Log Clearing (nefilim)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>