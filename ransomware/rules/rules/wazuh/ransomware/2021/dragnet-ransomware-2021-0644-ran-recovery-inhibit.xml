<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0644 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 35f07d74-c59f-5e73-9948-ee8734c6f9a3 -->
  <rule id="301257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0644 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>