<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0018 — Event Log Clearing (darkside) | Status: deprecated | Sigma ID: 44626863-d63d-5127-9050-542738775cbe -->
  <rule id="962686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0018 — Event Log Clearing (darkside)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>