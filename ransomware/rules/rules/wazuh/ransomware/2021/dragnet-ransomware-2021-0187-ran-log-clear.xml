<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0187 — Event Log Clearing (xinglocker) | Status: deprecated | Sigma ID: 9ff52768-dd47-59d3-b0fe-769fa5ae84f3 -->
  <rule id="859527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0187 — Event Log Clearing (xinglocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>