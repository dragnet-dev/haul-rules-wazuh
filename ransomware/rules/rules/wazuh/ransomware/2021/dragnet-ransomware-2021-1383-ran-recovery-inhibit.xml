<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1383 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: 0b9ab3cc-8aea-513b-82c1-252daa2f5cad -->
  <rule id="501660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1383 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>