<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1107 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: 8474b087-6d4a-5003-8555-3a2ad306362b -->
  <rule id="555950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1107 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>