<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0591 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: eed860ee-11d8-5880-879e-1588b072d458 -->
  <rule id="321860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0591 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>