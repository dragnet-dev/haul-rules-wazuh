<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0142 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: 5355ae6d-2dce-5a78-9d80-1bdfa441fe42 -->
  <rule id="571054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0142 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>