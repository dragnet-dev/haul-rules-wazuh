<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0587 — Event Log Clearing (zeppelin) | Status: deprecated | Sigma ID: 5b82a790-4175-5757-b90d-2574c8651b81 -->
  <rule id="669227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0587 — Event Log Clearing (zeppelin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>