<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0077 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 5871cdab-93d0-5a07-af05-2fe671bcd306 -->
  <rule id="703181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0077 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
