<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1748 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: 5a1b7cca-70ad-5e48-9add-ef16164769f4 -->
  <rule id="608444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1748 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>