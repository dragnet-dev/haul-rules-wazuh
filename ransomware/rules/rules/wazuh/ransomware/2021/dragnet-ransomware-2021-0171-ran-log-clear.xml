<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0171 — Event Log Clearing (networm) | Status: deprecated | Sigma ID: a2626a81-f985-592c-8bf9-023859fcd2d3 -->
  <rule id="842026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0171 — Event Log Clearing (networm)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>