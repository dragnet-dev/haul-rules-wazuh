<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1813 — Recovery Inhibition (xinglocker) | Status: deprecated | Sigma ID: e331ea0c-dd80-56e5-b558-bfd7ec0249be -->
  <rule id="168970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1813 — Recovery Inhibition (xinglocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>