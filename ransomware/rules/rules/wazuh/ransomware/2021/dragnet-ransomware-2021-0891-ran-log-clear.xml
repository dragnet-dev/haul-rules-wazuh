<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0891 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 2c4d7bc1-ddcb-593e-8ce2-d4c0bf2763d7 -->
  <rule id="338843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0891 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>