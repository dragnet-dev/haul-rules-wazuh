<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0302 — Recovery Inhibition (azroteam) | Status: deprecated | Sigma ID: 343e0751-6ba9-5594-844e-6f27e49f2575 -->
  <rule id="202075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0302 — Recovery Inhibition (azroteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>