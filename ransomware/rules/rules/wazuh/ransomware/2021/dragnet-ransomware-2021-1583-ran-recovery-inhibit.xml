<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1583 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 55ac805d-9f33-5397-b411-b567b8305979 -->
  <rule id="625280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1583 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>