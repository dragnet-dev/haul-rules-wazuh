<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1519 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: d8717f56-b4d9-50b0-9f3e-7edb05561d4d -->
  <rule id="519487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1519 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>