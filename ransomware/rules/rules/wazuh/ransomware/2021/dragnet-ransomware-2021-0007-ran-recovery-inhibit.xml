<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0007 — Recovery Inhibition (payloadbin) | Status: deprecated | Sigma ID: 91bad6b8-1d87-5ce9-933d-79c082a95a6a -->
  <rule id="257256" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0007 — Recovery Inhibition (payloadbin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>