<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1181 — Event Log Clearing (azroteam) | Status: deprecated | Sigma ID: 93801a4e-9598-5292-9b43-5004d61b3c54 -->
  <rule id="700826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1181 — Event Log Clearing (azroteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>