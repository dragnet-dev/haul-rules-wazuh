<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0305 — Recovery Inhibition (blacktor) | Status: deprecated | Sigma ID: 20f5c0c1-7145-5460-aabe-062cdd956a06 -->
  <rule id="590732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0305 — Recovery Inhibition (blacktor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>