<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0116 — Event Log Clearing (quantum) | Status: deprecated | Sigma ID: 25833fb4-c251-553c-8e75-ff131043b8e6 -->
  <rule id="413499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0116 — Event Log Clearing (quantum)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>