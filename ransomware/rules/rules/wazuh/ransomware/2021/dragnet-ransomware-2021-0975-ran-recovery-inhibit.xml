<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0975 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 2bc37080-86bc-5d63-8d63-9aa8039939c5 -->
  <rule id="803708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0975 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>