<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1408 — Event Log Clearing (snatch) | Status: deprecated | Sigma ID: 851e2da2-5ee9-58a9-b544-d5d0f8f4c880 -->
  <rule id="480845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1408 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>