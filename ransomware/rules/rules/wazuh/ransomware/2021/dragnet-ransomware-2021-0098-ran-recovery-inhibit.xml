<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0098 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 8a237694-176d-5f6f-aca9-b79e82fe9e69 -->
  <rule id="582376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0098 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>