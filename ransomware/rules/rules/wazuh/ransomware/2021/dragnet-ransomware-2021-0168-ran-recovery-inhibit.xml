<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0168 — Recovery Inhibition (babuk) | Status: experimental | Sigma ID: 235e0b0b-5bb9-5f85-8e6b-9a9861ced448 -->
  <rule id="738510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0168 — Recovery Inhibition (babuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>