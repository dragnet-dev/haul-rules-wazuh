<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0913 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: de8ed02a-587a-5de3-9ae8-80f284e6db94 -->
  <rule id="406050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0913 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>