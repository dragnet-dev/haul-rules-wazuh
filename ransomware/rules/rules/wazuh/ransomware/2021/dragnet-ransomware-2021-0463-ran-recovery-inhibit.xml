<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0463 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 245b4096-29eb-5f10-a165-ff33c7deded7 -->
  <rule id="431409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0463 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>