<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0338 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 56a180d4-3e49-53b0-9cdd-513e46e5a915 -->
  <rule id="198893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0338 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>