<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0681 — Event Log Clearing (grief) | Status: deprecated | Sigma ID: 692ffe39-3111-53fa-9410-7f72553589bc -->
  <rule id="238526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0681 — Event Log Clearing (grief)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>