<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1765 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: f69ce557-aa17-5159-afa6-8fbef8495aa8 -->
  <rule id="518705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1765 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
