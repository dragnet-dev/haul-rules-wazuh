<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0898 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 62667b81-1b7d-5db9-8069-9d0c0d9a7b82 -->
  <rule id="202683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0898 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>