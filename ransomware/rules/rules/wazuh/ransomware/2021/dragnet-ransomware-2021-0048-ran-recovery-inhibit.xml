<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0048 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 32414202-3bee-5e57-995f-dbb3b2702e13 -->
  <rule id="641420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0048 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
