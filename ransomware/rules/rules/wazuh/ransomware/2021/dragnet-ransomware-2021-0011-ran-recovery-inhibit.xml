<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0011 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: c08055aa-86cc-53f9-8938-a4032e98cf49 -->
  <rule id="408055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0011 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>