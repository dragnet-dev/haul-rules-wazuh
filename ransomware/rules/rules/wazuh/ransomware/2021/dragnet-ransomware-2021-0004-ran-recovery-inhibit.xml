<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0004 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ea0312e1-5a63-5db6-9809-851e86fde13b -->
  <rule id="640312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0004 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>