<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1398 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 2ebe9b90-6375-5ba1-ba51-e1815021e4bb -->
  <rule id="214715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1398 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>