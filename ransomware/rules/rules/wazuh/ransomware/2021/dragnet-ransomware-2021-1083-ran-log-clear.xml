<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1083 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: d8f9592e-7f52-5f57-aa8b-70bbda561e4b -->
  <rule id="523959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1083 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>