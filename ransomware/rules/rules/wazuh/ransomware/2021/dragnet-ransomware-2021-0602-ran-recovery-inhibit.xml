<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0602 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5f1e5350-ece8-5291-8ee8-1766533fee03 -->
  <rule id="723053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0602 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>