<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1031 — Event Log Clearing (atomsilo) | Status: deprecated | Sigma ID: ec9b1366-4bc3-52d0-9f3e-5260db4ce25e -->
  <rule id="291513" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1031 — Event Log Clearing (atomsilo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>