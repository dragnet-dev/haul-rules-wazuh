<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0268 — Recovery Inhibition (midas) | Status: deprecated | Sigma ID: 92cb1eac-5d43-5a5d-858e-9be5ce075fb4 -->
  <rule id="300830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0268 — Recovery Inhibition (midas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>