<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1666 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: e3368fef-a870-5fbd-9995-1c81ce1af8ef -->
  <rule id="593903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1666 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>