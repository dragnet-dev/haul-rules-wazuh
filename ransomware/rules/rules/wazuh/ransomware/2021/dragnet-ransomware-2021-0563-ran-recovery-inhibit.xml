<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0563 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: e358c14f-0c55-57bf-8d7d-2e75cdcabaf2 -->
  <rule id="597401" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0563 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>