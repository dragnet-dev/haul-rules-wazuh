<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1040 — Recovery Inhibition (blacktor) | Status: deprecated | Sigma ID: a6eaf326-eee1-5dac-be28-5efb4ad66dcd -->
  <rule id="879353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1040 — Recovery Inhibition (blacktor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>