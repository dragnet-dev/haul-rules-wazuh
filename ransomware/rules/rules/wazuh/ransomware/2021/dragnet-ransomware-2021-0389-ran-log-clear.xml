<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0389 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 7a6fc990-df8b-5d85-b2b2-e9dde6ce1cb5 -->
  <rule id="541089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0389 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>