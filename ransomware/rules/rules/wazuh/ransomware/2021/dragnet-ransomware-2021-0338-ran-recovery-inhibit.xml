<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0338 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: b590e73c-b214-5c81-8bfe-8d4306c0436f -->
  <rule id="154547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0338 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>