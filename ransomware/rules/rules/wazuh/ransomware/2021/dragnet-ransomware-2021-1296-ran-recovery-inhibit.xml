<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1296 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: fe224de8-deb7-5877-b5ba-39f1086ae3d5 -->
  <rule id="567597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1296 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>