<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0223 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: 53ee51e1-c1f1-5a21-8463-7f96de3f248b -->
  <rule id="580651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0223 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>