<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1066 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 35dc297b-c83e-5100-a2ba-011347daa271 -->
  <rule id="280297" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1066 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>