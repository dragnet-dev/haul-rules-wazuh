<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1751 — Event Log Clearing (lv) | Status: deprecated | Sigma ID: 4e1b3836-07e8-5906-a4fe-9e5f6b877bb1 -->
  <rule id="450738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1751 — Event Log Clearing (lv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>