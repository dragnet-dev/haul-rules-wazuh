<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1141 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: 49a5b462-2528-5fe9-9658-1195b6fa7eb8 -->
  <rule id="471314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1141 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>