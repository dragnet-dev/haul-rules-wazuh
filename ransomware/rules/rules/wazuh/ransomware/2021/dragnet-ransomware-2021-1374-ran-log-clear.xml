<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1374 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 0a736ca8-46b8-57af-a4f2-d6b9bfecdc20 -->
  <rule id="148618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1374 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>