<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0380 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 358a4749-7886-5e79-9dbb-fadfd5bebb2e -->
  <rule id="438474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0380 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>