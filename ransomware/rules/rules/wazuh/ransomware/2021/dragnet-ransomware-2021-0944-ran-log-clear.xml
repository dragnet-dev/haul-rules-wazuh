<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0944 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 0fad7fdb-d8f3-54f2-86e4-fe3762add5a3 -->
  <rule id="475325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0944 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>