<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1111 — Event Log Clearing (spook) | Status: deprecated | Sigma ID: fe711f98-0b37-5456-bd8c-b1b6ed5da16a -->
  <rule id="575391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1111 — Event Log Clearing (spook)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>