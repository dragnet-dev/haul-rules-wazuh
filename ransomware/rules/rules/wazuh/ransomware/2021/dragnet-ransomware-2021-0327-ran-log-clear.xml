<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0327 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: d31210c8-69a6-5f6c-957a-ea4b6fc99b55 -->
  <rule id="531210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0327 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>