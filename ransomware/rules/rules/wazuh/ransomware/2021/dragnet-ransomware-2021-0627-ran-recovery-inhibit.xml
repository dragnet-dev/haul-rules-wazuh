<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0627 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 9307d396-04db-5a25-abb7-6576ae764f85 -->
  <rule id="689253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0627 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
