<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0833 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ded3f183-374d-5701-957c-b14e4b5aab53 -->
  <rule id="404631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0833 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>