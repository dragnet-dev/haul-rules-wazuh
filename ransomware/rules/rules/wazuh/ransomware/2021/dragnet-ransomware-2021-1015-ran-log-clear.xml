<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1015 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 3f1fa868-6ca6-56ae-bf63-0a2ca98ff109 -->
  <rule id="817868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1015 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>