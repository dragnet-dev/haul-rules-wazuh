<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0895 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 7c8a4930-f2a3-52a3-a844-2f4c14f4c06f -->
  <rule id="297849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0895 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>