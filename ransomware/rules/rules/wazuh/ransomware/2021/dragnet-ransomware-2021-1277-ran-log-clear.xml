<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1277 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: 52c96193-72f8-5f73-89e8-db6dd50f57e9 -->
  <rule id="449619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1277 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>