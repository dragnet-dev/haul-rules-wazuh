<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1587 — Event Log Clearing (lockbit) | Status: deprecated | Sigma ID: 699c2e7a-c0ec-5888-936d-36a1d7a5dff1 -->
  <rule id="991406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1587 — Event Log Clearing (lockbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>