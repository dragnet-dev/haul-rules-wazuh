<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1307 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 52d4d70a-b35f-593f-856b-0128c01522d8 -->
  <rule id="552777" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1307 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>