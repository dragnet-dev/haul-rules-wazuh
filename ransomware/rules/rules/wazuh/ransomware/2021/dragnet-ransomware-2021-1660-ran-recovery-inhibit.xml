<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1660 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ae727667-90a4-5967-ac36-11f5d46264af -->
  <rule id="947276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1660 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>