<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0929 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: fcdeb18c-6e0c-5d49-94c5-3c30651f33ec -->
  <rule id="235755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0929 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>