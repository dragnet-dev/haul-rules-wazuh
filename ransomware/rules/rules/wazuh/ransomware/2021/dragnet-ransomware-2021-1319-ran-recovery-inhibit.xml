<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1319 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: d4102058-a8fd-548e-8822-69f19a273b4e -->
  <rule id="541020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1319 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>