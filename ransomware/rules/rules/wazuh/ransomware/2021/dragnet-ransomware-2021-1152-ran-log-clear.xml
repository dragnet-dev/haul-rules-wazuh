<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1152 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 47cd62f9-ac51-5cb2-8d9e-7e4ae2037c63 -->
  <rule id="423762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1152 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>