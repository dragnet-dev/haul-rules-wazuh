<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1271 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b94ad410-efe8-5a71-9ac7-1fd549003627 -->
  <rule id="458374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1271 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>