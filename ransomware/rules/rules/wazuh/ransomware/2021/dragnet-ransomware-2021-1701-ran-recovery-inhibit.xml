<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1701 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 48800b16-5963-53fc-8c08-527c5b7fed49 -->
  <rule id="708111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1701 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
