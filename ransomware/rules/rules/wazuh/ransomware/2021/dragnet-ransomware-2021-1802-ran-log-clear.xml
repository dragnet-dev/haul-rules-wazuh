<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1802 — Event Log Clearing (payloadbin) | Status: deprecated | Sigma ID: dcda1ecb-dd63-542f-bc66-85b88eb4eb5b -->
  <rule id="146110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1802 — Event Log Clearing (payloadbin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>