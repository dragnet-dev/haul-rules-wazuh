<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0120 — Event Log Clearing (blacktor) | Status: deprecated | Sigma ID: b17d617b-1391-5f44-a328-aaf5fe2f34f8 -->
  <rule id="988561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0120 — Event Log Clearing (blacktor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>