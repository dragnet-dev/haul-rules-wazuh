<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0149 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: f8523cbd-2442-5f63-adbf-73effe55a4ab -->
  <rule id="836380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0149 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>