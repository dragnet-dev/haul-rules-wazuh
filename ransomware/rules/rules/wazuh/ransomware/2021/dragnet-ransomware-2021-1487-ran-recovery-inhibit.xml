<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1487 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: 8972fce3-aed2-59c7-92da-d9f6a067bf50 -->
  <rule id="597084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1487 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
