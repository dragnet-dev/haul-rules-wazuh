<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1446 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: ba4bee9e-13ea-5990-b6e2-e26920387896 -->
  <rule id="537998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1446 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>