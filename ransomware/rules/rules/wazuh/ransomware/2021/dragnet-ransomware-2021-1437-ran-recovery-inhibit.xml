<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1437 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 7d7b0388-b5d1-5063-80d4-d5eaeed80850 -->
  <rule id="312303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1437 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>