<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1175 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: be87bc13-76e9-5ca2-9095-82c8a3c18c08 -->
  <rule id="486460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1175 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>