<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1667 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 2b25e19f-78c0-565f-81e5-9c4d5abc74a9 -->
  <rule id="721419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1667 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>