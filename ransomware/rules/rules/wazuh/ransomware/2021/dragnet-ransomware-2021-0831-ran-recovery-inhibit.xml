<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0831 — Recovery Inhibition (lockdata) | Status: deprecated | Sigma ID: 2112cc2b-b875-5e56-bf52-4a83c03cb85b -->
  <rule id="108762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0831 — Recovery Inhibition (lockdata)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
