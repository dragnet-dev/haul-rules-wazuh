<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0564 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: ecea8640-b146-5e40-9b6c-6b7f93c6f141 -->
  <rule id="765086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0564 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>