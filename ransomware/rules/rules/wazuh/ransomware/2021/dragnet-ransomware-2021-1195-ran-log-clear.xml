<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1195 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 1ea87a14-45fc-52a1-b9aa-d9d6ce1ef717 -->
  <rule id="754021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1195 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>