<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1242 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 7509be7f-c071-5493-bd54-d7baf4df4a80 -->
  <rule id="222494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1242 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>