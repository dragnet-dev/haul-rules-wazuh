<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0043 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 9ae09c5f-5795-5fc5-bd9c-290bce6bc98f -->
  <rule id="464956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0043 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>