<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0954 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: ce7abb3a-f5d5-52f7-9e63-7ebefde71b6c -->
  <rule id="469179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0954 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>