<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1284 — Shadow Copy Deletion (cryp70n1c0d3) | Status: deprecated | Sigma ID: 37fdb0e9-a751-55a6-bbe9-6bca58a33110 -->
  <rule id="756110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1284 — Shadow Copy Deletion (cryp70n1c0d3)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>