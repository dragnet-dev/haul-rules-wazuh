<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1343 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: f70e5ef6-7e86-5e44-b5d5-2ecbb69b619a -->
  <rule id="521534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1343 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>