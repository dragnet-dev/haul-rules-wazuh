<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0853 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: e9ceeca9-adf0-5a7d-8cd8-81c02e1d678e -->
  <rule id="917836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0853 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>