<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0462 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2761ce2e-5648-5078-8f13-bcff923cb07e -->
  <rule id="870222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0462 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>