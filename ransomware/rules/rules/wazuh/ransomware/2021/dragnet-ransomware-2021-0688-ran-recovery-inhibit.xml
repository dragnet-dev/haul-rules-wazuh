<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0688 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3b186ad4-b79c-5591-9e9b-c8bfc499666e -->
  <rule id="851789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0688 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>