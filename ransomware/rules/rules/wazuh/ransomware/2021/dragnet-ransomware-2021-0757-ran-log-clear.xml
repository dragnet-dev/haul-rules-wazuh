<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0757 — Event Log Clearing (azroteam) | Status: deprecated | Sigma ID: d97e7caa-0e3d-5c1d-af65-966983c9e727 -->
  <rule id="978684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0757 — Event Log Clearing (azroteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>