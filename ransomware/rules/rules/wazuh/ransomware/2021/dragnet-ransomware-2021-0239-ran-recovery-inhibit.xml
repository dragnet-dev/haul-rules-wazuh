<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0239 — Recovery Inhibition (rook) | Status: deprecated | Sigma ID: de88b05d-c4aa-5dd3-a7a1-2fdc40546dd0 -->
  <rule id="966190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0239 — Recovery Inhibition (rook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>