<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1568 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 4d63c252-f48c-5bd2-bfcd-ccfcca6da695 -->
  <rule id="442202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1568 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>