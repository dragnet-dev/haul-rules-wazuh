<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1290 — Event Log Clearing (midas) | Status: deprecated | Sigma ID: aba35180-eada-504f-8fe5-9c92ad7dc572 -->
  <rule id="146351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1290 — Event Log Clearing (midas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>