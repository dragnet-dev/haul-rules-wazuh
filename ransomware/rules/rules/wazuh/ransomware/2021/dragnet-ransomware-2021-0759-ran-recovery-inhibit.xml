<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0759 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 03c337cf-daaf-5bac-a62b-53c42e0b8f3f -->
  <rule id="246479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0759 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>