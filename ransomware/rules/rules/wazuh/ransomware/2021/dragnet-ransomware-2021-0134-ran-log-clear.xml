<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0134 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 2a6ffeb3-d7b1-517e-9ac5-8c924bb2ab86 -->
  <rule id="948990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0134 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>