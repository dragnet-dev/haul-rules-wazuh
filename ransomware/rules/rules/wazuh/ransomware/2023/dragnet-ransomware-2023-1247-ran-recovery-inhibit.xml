<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1247 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c75964d2-7e18-5eb8-ad92-62cf867d942a -->
  <rule id="475964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1247 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>