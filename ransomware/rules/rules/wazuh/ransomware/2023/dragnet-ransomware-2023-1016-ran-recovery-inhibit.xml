<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1016 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: db01516b-c3ed-5b49-bad6-e89ed8f005aa -->
  <rule id="490151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1016 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>