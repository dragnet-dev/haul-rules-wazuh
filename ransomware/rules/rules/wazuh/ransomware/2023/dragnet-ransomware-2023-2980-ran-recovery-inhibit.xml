<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2980 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: c354278b-8ada-572c-b828-4a1df4d50ce1 -->
  <rule id="435427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2980 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>