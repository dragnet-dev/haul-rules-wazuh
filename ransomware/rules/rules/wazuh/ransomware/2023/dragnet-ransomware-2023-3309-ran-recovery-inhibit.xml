<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3309 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 00fd1318-4a5a-5960-a0e4-930dc578821d -->
  <rule id="831318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3309 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>