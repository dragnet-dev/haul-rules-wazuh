<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4114 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 2ff9d6bb-af81-5d2d-8f0c-6d73e7fb932a -->
  <rule id="428776" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4114 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>