<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5209 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 21804fb8-5155-5866-bec2-67cc0eaf9268 -->
  <rule id="282075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5209 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>