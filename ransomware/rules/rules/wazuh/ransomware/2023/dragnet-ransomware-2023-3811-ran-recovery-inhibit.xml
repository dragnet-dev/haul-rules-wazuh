<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3811 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 91ed9393-a102-5fa5-b7fa-126e80e16d0f -->
  <rule id="653393" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3811 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>