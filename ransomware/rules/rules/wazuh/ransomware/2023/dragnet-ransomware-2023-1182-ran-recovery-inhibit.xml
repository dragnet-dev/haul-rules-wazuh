<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1182 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: fa81b3ca-240e-5971-89b8-9ecef2a70885 -->
  <rule id="513073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1182 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>