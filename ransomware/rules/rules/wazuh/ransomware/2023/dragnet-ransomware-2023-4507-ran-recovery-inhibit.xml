<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4507 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 956bf667-f2be-593d-b665-3c920ad70f33 -->
  <rule id="749276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4507 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>