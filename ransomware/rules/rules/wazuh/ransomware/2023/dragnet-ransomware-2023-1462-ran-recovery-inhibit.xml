<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1462 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 24a582fd-03c7-50d7-81bd-210470d3641b -->
  <rule id="113327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1462 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>