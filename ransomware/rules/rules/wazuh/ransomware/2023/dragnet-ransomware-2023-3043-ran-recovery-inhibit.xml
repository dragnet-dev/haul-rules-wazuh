<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3043 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c938bc92-0a80-5a2a-be7d-eeb7d196e0f0 -->
  <rule id="712316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3043 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>