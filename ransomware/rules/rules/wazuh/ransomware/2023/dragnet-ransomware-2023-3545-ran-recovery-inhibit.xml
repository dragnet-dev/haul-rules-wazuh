<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3545 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0ff1e812-67cb-56a2-828e-1f9c2bdee052 -->
  <rule id="583081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3545 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>