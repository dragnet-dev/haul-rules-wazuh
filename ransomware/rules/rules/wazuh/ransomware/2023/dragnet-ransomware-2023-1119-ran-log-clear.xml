<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1119 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 48dda161-24f3-5160-87a3-f03bcb7fa6cf -->
  <rule id="301541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1119 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>