<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1709 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 06041e5c-68c9-5e98-800f-1e519bacc60b -->
  <rule id="267292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1709 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>