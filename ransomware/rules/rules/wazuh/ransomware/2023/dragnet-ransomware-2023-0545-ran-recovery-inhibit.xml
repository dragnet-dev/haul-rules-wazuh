<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0545 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a82e219c-4058-5d61-be94-5ad0698bf789 -->
  <rule id="932621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0545 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>