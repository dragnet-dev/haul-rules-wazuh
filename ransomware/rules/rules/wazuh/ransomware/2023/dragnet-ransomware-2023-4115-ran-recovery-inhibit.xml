<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4115 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0829e35e-58a5-53a9-b5fe-63780c20eeee -->
  <rule id="527835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4115 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>