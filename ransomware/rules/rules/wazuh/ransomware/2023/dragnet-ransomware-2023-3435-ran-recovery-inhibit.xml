<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3435 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fde26a9d-097f-5bca-8f4e-e7648cd7982d -->
  <rule id="299626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3435 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>