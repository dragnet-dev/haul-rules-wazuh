<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1110 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 384a73da-0613-594c-be72-7008e2cf7c0e -->
  <rule id="947581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1110 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>