<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4773 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: a4cb3516-f997-5ba5-87dd-af7f34260c20 -->
  <rule id="982735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4773 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>