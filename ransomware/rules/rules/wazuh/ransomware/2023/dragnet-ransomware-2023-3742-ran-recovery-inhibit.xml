<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3742 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 3dc9ee46-0b58-5df0-8d95-dfa85ffb0eae -->
  <rule id="831822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3742 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>