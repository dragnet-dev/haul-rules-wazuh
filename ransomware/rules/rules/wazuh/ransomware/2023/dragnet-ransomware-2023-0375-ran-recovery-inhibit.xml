<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0375 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 11781855-359a-5df4-9351-e550b31135ea -->
  <rule id="378185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0375 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
