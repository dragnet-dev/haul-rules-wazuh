<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1570 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: edee2758-ca28-5fc8-b7e1-d1a06c10c977 -->
  <rule id="791027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1570 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>