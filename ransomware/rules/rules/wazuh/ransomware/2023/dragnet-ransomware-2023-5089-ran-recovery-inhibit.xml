<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5089 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 69d9548f-1cbe-54b4-ae10-326c69e1a23a -->
  <rule id="317954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5089 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>