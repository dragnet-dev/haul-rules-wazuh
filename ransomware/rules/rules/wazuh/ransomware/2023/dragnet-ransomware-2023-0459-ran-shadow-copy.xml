<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0459 — Shadow Copy Deletion (lockbit3) | Status: deprecated | Sigma ID: 1e43bdbd-dc65-5e7a-9e3f-b518ba9c0fd8 -->
  <rule id="867163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0459 — Shadow Copy Deletion (lockbit3)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>