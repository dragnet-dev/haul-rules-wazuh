<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1485 — Recovery Inhibition (darkpower) | Status: experimental | Sigma ID: b43b34b3-cbb6-51ca-9efa-7df38f054736 -->
  <rule id="129934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1485 — Recovery Inhibition (darkpower)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>