<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5021 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9fa43006-4245-5748-aada-94d2ed55c285 -->
  <rule id="854430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5021 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>