<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3803 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 0f0c9699-4d34-591e-b9b0-dbf30bf8203e -->
  <rule id="712969" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3803 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>