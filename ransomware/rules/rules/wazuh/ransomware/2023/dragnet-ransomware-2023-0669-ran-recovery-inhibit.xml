<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0669 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: c2791cfa-3c71-5263-a91b-5803b1e7b2d2 -->
  <rule id="264668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0669 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>