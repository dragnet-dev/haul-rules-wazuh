<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4163 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c6610805-a3b3-5a68-843a-f84e786043d7 -->
  <rule id="466108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4163 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>