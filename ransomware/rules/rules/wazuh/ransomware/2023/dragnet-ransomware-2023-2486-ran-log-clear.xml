<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2486 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: b7de5600-2952-5b46-89d3-4e9efbf7f5d1 -->
  <rule id="417456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2486 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>