<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3607 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f83f057c-9aaa-5ed8-b7b6-922d9154010a -->
  <rule id="834305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3607 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>