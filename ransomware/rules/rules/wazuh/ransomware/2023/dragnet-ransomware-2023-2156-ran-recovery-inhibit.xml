<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2156 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: cac36cc4-a236-5aff-b6cc-60d6c7c53492 -->
  <rule id="790988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2156 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>