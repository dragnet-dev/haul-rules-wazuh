<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0455 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: dd920ec9-9230-5643-9fb8-4e23cecbc9c9 -->
  <rule id="950734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0455 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>