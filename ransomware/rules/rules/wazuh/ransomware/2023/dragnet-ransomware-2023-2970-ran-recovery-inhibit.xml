<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2970 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2c6c22d3-7294-5214-a3f2-295fe62e198d -->
  <rule id="737165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2970 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>