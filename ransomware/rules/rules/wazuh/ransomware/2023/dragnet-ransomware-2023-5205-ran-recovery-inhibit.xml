<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5205 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: de47ecb9-b837-5e26-8aab-6cfd4eb0bbbc -->
  <rule id="395468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5205 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>