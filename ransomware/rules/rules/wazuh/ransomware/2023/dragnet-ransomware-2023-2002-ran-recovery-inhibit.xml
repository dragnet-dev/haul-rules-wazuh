<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2002 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: eaf0f896-9a2e-54b6-ab25-fc166fce26b7 -->
  <rule id="714558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2002 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>