<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4466 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d817a277-e6f0-5115-a42b-1e1c550e83e9 -->
  <rule id="510822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4466 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>