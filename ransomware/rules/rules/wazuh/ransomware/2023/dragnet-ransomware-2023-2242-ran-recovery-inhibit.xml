<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2242 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 4a86e322-2b2a-5385-bf16-fa75d731ebe2 -->
  <rule id="397903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2242 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>