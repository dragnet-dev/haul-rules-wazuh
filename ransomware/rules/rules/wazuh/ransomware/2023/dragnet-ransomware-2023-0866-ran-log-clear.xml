<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0866 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 018de1d4-e068-5555-a6dc-8d2b5b5a8389 -->
  <rule id="628294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0866 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>