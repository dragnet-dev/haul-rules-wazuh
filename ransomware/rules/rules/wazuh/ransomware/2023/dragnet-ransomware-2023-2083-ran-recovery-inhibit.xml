<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2083 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 6ae8e593-9738-576d-ab87-6ca15d24684f -->
  <rule id="137425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2083 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>