<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4916 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 37b18413-40ae-56e5-a2ac-78874b07313f -->
  <rule id="731841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4916 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>