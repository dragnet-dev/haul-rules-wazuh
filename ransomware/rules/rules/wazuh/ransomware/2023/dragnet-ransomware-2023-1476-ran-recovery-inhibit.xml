<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1476 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4b5705a9-b2b9-5994-9d9f-9324dc4ee4c1 -->
  <rule id="491290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1476 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>