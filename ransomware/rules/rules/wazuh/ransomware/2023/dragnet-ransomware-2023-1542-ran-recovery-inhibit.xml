<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1542 — Recovery Inhibition (play) | Status: experimental | Sigma ID: da39fce9-e5dd-5996-99f0-42e260cc00af -->
  <rule id="291036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1542 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>