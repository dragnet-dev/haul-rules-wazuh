<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2004 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 39233000-8130-56bb-8a60-2d0a12ef89f4 -->
  <rule id="423300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2004 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>