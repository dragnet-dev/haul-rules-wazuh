<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2083 — Event Log Clearing (karakurt) | Status: experimental | Sigma ID: 54c8f1c8-2870-5f9b-8756-2f98c39ff987 -->
  <rule id="603031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2083 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>