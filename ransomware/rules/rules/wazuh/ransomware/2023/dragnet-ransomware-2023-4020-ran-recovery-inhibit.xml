<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4020 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 8cfcaa56-5605-5b6c-89d4-8e2cc23d5b62 -->
  <rule id="339722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4020 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>