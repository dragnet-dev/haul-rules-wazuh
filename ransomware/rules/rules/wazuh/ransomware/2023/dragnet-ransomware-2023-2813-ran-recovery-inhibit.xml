<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2813 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: bcaf2fcf-e963-53b7-98c2-8f88131def24 -->
  <rule id="628527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2813 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>