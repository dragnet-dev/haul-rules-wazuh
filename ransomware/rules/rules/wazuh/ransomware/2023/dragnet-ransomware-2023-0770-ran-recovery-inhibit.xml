<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0770 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: ac42eb42-3b96-54a5-9884-f9f80ef0ba02 -->
  <rule id="914187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0770 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>