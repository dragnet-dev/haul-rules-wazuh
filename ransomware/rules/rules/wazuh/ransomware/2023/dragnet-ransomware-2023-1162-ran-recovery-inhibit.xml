<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1162 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ce7a7714-59f7-598b-aa66-191ee1f356c4 -->
  <rule id="708277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1162 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>