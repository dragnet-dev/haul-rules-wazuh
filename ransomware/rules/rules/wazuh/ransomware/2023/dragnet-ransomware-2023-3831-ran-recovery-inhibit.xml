<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3831 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b38ef322-e51a-5577-ad0f-711b6acf3b4b -->
  <rule id="315673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3831 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>