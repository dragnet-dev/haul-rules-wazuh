<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2090 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 03385514-15b8-50a0-8583-f63bb76fb8b5 -->
  <rule id="785514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2090 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>