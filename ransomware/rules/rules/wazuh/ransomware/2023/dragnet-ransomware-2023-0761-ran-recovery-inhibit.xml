<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0761 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: ced79231-17e9-5394-83bd-fb9f75b09092 -->
  <rule id="709792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0761 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>