<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2158 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9c962a51-c77a-5b7d-83ac-0f51e879f9ce -->
  <rule id="811402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2158 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>