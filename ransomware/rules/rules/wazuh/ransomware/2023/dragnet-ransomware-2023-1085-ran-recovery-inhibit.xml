<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1085 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 39e1ce06-6ddc-5a41-812c-b8a822ac8397 -->
  <rule id="833742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1085 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>