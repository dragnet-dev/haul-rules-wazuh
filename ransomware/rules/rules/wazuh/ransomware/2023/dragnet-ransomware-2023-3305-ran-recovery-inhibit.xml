<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3305 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 4ac5847f-0ad3-55c9-95f5-0cd9c4246928 -->
  <rule id="396584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3305 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>