<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1011 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 48e3c97b-72e5-5f15-ae1a-9983dc68d502 -->
  <rule id="451809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1011 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>