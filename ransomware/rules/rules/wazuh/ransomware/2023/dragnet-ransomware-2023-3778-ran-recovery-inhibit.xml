<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3778 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: cddbf150-514b-51a3-8ecd-a7f7d8c0f3c8 -->
  <rule id="431991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3778 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>