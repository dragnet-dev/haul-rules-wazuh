<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3923 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 4bb7f4e5-9c26-5fff-9d04-2cc645c03b04 -->
  <rule id="238874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3923 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>