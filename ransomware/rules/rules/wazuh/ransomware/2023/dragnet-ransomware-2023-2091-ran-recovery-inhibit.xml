<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2091 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c5d96ceb-8d45-53e9-9990-d2407e30f65f -->
  <rule id="622348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2091 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>