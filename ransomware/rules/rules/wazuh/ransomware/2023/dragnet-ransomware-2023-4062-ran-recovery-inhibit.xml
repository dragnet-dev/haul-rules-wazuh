<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4062 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ed19ab69-2d11-550d-ab0a-77f2137b5058 -->
  <rule id="772235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4062 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>