<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1581 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: d7992c5f-1345-5475-be30-a96780f7f07a -->
  <rule id="507884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1581 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>