<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1572 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5c83bd18-5fd2-5d50-97a3-ffb4db9c3f89 -->
  <rule id="676637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1572 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
