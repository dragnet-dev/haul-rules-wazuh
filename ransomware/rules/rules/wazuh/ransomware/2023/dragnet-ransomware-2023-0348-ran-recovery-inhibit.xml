<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0348 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: a4e94e50-25c9-5366-ad2e-4fff7025ab06 -->
  <rule id="986318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0348 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>