<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0356 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 51f81b85-c4e5-5ec7-aa02-79e09c18e820 -->
  <rule id="530907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0356 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>