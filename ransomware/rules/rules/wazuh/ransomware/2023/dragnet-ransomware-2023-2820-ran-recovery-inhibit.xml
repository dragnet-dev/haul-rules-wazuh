<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2820 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 4d5a4438-28ad-59e4-9b55-eb332442f871 -->
  <rule id="441044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2820 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>