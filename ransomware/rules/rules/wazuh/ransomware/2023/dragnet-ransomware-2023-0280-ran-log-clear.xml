<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0280 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: b3161fbe-eb0d-5f7c-80aa-f6169bfa0f61 -->
  <rule id="110591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0280 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>