<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4318 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: a6762312-3855-5bee-ba3b-41caf683b750 -->
  <rule id="267623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4318 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
