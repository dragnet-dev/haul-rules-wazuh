<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1514 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: c279b5f2-494a-5e88-be5f-3d9cafe21988 -->
  <rule id="264755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1514 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>