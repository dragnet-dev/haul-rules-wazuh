<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2803 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: fe44fe79-98a4-55f8-ae8c-cea048c26a51 -->
  <rule id="313918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2803 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>