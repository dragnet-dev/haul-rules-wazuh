<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2106 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 52c8b16f-4b6c-53e1-b014-16c83fd8b9de -->
  <rule id="551791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2106 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>