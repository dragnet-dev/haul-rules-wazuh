<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4183 — Event Log Clearing (nokoyawa) | Status: experimental | Sigma ID: 77e458a8-3f9d-5339-a8e8-c8d5f5ab59a4 -->
  <rule id="446458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4183 — Event Log Clearing (nokoyawa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>