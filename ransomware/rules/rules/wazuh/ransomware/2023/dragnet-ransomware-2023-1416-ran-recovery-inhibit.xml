<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1416 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 04b97b3c-a1ab-547e-9071-37498e57662f -->
  <rule id="415633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1416 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>