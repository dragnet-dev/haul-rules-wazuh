<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3597 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9a943fb6-f7b8-5139-b5ef-410fa4e26e72 -->
  <rule id="779103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3597 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>