<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4921 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9847320a-0101-52f8-9dcf-4dd284942eca -->
  <rule id="947320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4921 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>