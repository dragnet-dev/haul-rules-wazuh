<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2468 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2a319094-3852-5aa6-abed-dffd52f8deb7 -->
  <rule id="731909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2468 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>