<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3169 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: e932bc8f-ec84-5678-a45c-c4853f05e5b0 -->
  <rule id="322780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3169 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>