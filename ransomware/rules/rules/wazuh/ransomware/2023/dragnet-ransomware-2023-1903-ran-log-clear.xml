<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1903 — Event Log Clearing (noescape) | Status: experimental | Sigma ID: 2ffc7756-9bca-545a-bb59-0b5dd087da0c -->
  <rule id="428477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1903 — Event Log Clearing (noescape)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>