<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5147 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 94edd3e7-1448-5921-b288-5bc87cdf7d73 -->
  <rule id="388293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5147 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>