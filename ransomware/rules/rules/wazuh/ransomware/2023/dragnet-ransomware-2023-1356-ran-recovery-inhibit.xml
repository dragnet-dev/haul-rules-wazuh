<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1356 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f21bb2df-239d-5495-9a70-f5500ad5c268 -->
  <rule id="395632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1356 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>