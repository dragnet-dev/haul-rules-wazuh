<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5081 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 4465a5bb-a2e1-5f87-8ebb-a1630c700f17 -->
  <rule id="732091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5081 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>