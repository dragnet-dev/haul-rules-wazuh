<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5072 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 9e9f3cbb-fc09-59d1-b0a9-bc85d61db812 -->
  <rule id="570300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5072 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>