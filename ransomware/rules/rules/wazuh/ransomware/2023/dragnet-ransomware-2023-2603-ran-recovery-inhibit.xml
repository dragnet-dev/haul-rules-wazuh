<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2603 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1080d841-4439-5680-a04c-ad20661d2cfe -->
  <rule id="929384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2603 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>