<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5223 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2353262d-8601-521d-8028-797e4e53ef92 -->
  <rule id="653262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5223 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>