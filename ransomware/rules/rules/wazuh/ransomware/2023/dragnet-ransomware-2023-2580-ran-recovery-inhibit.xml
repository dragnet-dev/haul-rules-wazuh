<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2580 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3fd26ac8-c584-5991-8131-a322694f4ea5 -->
  <rule id="834026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2580 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>