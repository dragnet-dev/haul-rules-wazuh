<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3280 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: d4c2f1b4-592a-5b4b-bbd7-08c5a3e12f37 -->
  <rule id="850071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3280 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>