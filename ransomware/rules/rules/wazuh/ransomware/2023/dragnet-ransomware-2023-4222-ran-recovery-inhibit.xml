<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4222 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 50b29cdf-f409-5851-84a9-34d97d7d4f2a -->
  <rule id="498076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4222 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>