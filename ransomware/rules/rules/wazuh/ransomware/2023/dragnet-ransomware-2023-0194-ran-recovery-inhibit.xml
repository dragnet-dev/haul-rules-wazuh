<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0194 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9773b595-7fd2-52e4-9179-839a03bca3bf -->
  <rule id="763795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0194 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>