<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3117 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 21fc35ed-c59d-592b-a2cb-cd2ffb4e0a90 -->
  <rule id="105374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3117 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>