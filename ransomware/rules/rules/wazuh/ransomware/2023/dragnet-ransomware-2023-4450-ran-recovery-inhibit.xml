<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4450 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 4c318f8e-413e-50c4-95a2-2829a0f07ebf -->
  <rule id="421103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4450 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>