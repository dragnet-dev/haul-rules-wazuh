<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2821 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: b3a85bb2-b208-568c-8523-e27ee8c35102 -->
  <rule id="310171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2821 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>