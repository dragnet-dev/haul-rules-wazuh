<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5360 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0a0cfea2-2d8c-54e0-8cab-06bb4ab07566 -->
  <rule id="406826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5360 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>