<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3334 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: dad23820-c794-5db6-a376-bbd43b6b15df -->
  <rule id="901238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3334 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>