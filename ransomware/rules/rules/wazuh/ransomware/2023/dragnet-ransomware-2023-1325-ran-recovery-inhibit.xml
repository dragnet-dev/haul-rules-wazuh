<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1325 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9783db30-6a8d-59bc-a368-d209f4bd3592 -->
  <rule id="804667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1325 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
