<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2376 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9a309e97-8c5e-5664-a0e9-cdafd950341a -->
  <rule id="768958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2376 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>