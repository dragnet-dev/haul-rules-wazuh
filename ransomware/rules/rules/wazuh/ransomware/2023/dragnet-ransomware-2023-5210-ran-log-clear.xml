<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5210 — Event Log Clearing (nokoyawa) | Status: experimental | Sigma ID: e99e3a9b-2656-54b9-9b08-ce43b96dd9f2 -->
  <rule id="339738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5210 — Event Log Clearing (nokoyawa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>