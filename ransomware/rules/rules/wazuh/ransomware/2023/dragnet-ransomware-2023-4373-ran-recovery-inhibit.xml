<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4373 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2941c8dc-4235-5612-8e5e-471ed87d3459 -->
  <rule id="431021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4373 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>