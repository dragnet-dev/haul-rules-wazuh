<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3839 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c548fa51-e2d9-5fd7-a6eb-ccfc28335bea -->
  <rule id="612538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3839 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>