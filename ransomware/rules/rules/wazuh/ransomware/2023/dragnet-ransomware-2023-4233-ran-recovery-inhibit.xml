<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4233 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 956280b2-8243-5100-b710-da5f7f2ba3fb -->
  <rule id="100491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4233 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>