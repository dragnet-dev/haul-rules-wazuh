  <rule id="333393" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1588 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
