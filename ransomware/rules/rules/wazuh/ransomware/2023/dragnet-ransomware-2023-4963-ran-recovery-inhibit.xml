<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4963 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 346f34d1-9e71-5d58-9cb7-855ddf5fb5b9 -->
  <rule id="882157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4963 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>