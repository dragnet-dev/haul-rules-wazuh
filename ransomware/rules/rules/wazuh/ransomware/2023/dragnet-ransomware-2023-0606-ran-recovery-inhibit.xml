<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0606 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2314a79b-d670-5399-a80f-e96d7b19e870 -->
  <rule id="203479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0606 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>