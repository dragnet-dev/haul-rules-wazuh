<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3204 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: d78ceab5-4465-5f74-95bb-88febd3a83aa -->
  <rule id="347594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3204 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>