<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5101 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 874639fc-fc11-5ccf-a651-9acb9afd0873 -->
  <rule id="594239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5101 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>