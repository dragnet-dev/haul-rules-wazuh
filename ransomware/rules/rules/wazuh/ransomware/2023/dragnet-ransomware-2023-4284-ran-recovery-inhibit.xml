<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4284 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7315d850-5268-5e43-b641-e531adb3f7c4 -->
  <rule id="370538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4284 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>