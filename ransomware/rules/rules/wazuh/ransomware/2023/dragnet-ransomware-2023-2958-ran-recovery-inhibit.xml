<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2958 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a551b58e-010b-5598-b967-8b49f0ef23e7 -->
  <rule id="888275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2958 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>