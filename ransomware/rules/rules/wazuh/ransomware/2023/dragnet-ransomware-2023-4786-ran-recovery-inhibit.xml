<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4786 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7a561c81-3e63-5d8c-bf4e-5765e698beb1 -->
  <rule id="260988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4786 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>