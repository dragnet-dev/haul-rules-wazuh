<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0005 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 292da228-5428-5597-866b-2ea2e53f1fb6 -->
  <rule id="397022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0005 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>