<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5265 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3afa74bd-536c-5856-acde-a84fde192b35 -->
  <rule id="709874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5265 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>