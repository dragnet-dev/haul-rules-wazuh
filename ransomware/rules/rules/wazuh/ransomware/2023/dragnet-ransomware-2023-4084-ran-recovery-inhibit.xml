<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4084 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 32654d0b-0e7c-56f3-9d76-e46f20e6d077 -->
  <rule id="824770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4084 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>