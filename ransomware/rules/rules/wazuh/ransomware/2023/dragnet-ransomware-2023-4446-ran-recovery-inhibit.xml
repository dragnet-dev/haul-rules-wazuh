<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4446 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f392c73e-6a2a-58ba-9cbf-c55e244c0864 -->
  <rule id="762847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4446 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>