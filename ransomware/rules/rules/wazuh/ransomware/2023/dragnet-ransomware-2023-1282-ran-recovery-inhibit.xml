<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1282 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 97bf9244-54cc-50a8-92b8-973cd61ceb86 -->
  <rule id="802392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1282 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>