<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1043 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: dbe5bc5d-f489-54bc-b9ad-0769bbf6c21a -->
  <rule id="107548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1043 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>