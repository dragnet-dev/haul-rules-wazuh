<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3528 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 3c5f26a5-4f58-5772-adbc-a4dc76c4470d -->
  <rule id="312426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3528 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>