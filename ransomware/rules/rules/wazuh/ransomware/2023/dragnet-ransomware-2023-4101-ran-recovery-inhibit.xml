<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4101 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9e9cae1b-f1a2-547c-8006-104d3b84fbef -->
  <rule id="311790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4101 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>