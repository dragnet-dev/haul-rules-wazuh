<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2654 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 883a75f8-93f3-5802-a06a-42936e15213e -->
  <rule id="613875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2654 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>