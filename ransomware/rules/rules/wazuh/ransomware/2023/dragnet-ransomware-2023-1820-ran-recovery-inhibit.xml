<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1820 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2332f0d6-c019-5077-adfb-06b93914727b -->
  <rule id="672333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1820 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>