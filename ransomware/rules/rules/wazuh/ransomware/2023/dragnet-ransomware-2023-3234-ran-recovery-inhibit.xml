<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3234 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: fd93164c-1e35-5640-9647-9f04ea1a6465 -->
  <rule id="839316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3234 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>