<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2013 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 0da96727-a326-5354-8fd1-f468d35226d7 -->
  <rule id="489672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2013 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>