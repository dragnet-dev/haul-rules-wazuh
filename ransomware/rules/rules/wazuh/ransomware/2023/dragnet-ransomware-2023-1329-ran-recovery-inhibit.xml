<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1329 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2d3d19c2-f66a-55b3-acb9-a9beac3388e3 -->
  <rule id="917916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1329 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>