<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0036 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b227964f-78b1-5764-b6c4-af52fd5f10bc -->
  <rule id="322796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0036 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>