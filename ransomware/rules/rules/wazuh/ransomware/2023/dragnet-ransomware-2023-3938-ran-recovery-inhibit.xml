<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3938 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 089c5bda-2e62-5140-8e8d-441fc526aaf5 -->
  <rule id="177629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3938 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>