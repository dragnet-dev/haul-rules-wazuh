<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2327 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 18132829-87ea-59bc-96e9-b26c11a3a83f -->
  <rule id="113282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2327 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>