<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0318 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 12f75a2d-9a3d-5031-bf80-40f79757dcec -->
  <rule id="724102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0318 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>