<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0476 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c4eb3e9c-6c24-5dbd-89cb-af2e153dbda1 -->
  <rule id="716702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0476 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>