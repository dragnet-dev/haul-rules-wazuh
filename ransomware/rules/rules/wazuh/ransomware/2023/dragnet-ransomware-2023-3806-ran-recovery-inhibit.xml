<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3806 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 9c74efb7-9f14-5faf-8012-b847c419f1bb -->
  <rule id="512783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3806 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>