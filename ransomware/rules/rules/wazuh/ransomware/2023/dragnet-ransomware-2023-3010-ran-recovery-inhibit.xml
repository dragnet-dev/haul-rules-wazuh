<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3010 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 908384a4-9e78-5da9-bb1f-bf6a201a41f2 -->
  <rule id="234154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3010 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>