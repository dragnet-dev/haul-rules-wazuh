<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2758 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 5c4570de-111d-550d-ab3b-41a16bc8ce6e -->
  <rule id="493133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2758 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>