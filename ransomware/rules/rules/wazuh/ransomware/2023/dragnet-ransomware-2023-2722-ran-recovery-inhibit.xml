<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2722 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: 5bd9552a-25a5-57bb-bacc-7f376e303230 -->
  <rule id="669955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2722 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>