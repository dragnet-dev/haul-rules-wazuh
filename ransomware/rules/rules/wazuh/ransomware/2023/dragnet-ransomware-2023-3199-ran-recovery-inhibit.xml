<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3199 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5854c219-1042-573e-badb-925d459a6262 -->
  <rule id="467621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3199 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>