<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1255 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f25c5a5b-c0c0-5670-a7b2-89d88dbcf88b -->
  <rule id="406010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1255 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>