<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5168 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: adec54ac-4a28-587c-bc3b-8b446855f865 -->
  <rule id="952454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5168 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>