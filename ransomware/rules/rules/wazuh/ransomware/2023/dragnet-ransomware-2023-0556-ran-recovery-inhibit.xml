<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0556 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b5047a3a-a817-5dd0-a553-a93db29aab61 -->
  <rule id="140762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0556 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>