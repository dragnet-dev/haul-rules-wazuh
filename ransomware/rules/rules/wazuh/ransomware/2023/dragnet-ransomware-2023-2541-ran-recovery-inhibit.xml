<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2541 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 34537ce5-b6de-5117-92f8-860e9410faf3 -->
  <rule id="841678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2541 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>