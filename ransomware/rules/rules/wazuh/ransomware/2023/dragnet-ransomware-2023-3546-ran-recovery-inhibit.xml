<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3546 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7545179f-23e0-5681-89ce-adfe14540204 -->
  <rule id="445179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3546 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>