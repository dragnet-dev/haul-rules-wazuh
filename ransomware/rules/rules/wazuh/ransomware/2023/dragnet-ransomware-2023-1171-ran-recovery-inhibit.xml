<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1171 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: d6409dc6-e83c-5e51-890f-e1a027ef0175 -->
  <rule id="482557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1171 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>