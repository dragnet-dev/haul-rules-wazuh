<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4105 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ffcfc675-a4d1-59a3-806c-8310bdaf036c -->
  <rule id="247804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4105 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>