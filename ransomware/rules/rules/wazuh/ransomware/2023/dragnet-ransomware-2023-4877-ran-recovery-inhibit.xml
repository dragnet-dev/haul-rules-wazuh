<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4877 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6eb7c445-2f3c-5c3e-beec-d3ed8cf28ec2 -->
  <rule id="234844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4877 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>