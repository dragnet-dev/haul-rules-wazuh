<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4121 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5e2d31fd-9656-5a38-96a4-5018e8ea45f3 -->
  <rule id="708531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4121 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>