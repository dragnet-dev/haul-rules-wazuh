<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0124 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d4b7be26-81c9-5769-970e-5a93a66300d9 -->
  <rule id="218782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0124 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>