<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4664 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 08532c44-bc0f-5aa7-be61-81f030c00a86 -->
  <rule id="565244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4664 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>