<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4684 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 67256628-b994-5cb4-a91d-d1f3ba49e8ad -->
  <rule id="525662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4684 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>