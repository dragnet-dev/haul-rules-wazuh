<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1587 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 43a9e649-b5bb-5dc5-8899-d0bee8ee7627 -->
  <rule id="318386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1587 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
