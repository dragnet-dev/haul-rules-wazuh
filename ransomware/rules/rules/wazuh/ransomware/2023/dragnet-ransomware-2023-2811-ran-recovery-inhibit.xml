<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2811 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: a78e233c-740d-5d4c-b8cd-53dc43dd7a32 -->
  <rule id="926223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2811 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>