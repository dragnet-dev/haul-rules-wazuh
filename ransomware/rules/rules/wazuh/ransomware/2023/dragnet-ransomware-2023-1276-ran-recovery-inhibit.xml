<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1276 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ee6b43d3-811e-54c7-a155-ba4707990527 -->
  <rule id="318743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1276 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>