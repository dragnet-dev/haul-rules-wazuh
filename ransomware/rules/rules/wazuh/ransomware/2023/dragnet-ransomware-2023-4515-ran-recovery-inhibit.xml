<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4515 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5250c479-5f82-54e0-bb4f-72cd4bbe8557 -->
  <rule id="401247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4515 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>