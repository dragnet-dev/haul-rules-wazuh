<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4400 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 66b794f8-a2dc-5e2e-a7f2-38eb6185889e -->
  <rule id="267794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4400 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>