<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0877 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0c3e5e57-686f-5894-94de-0e5b1a16b343 -->
  <rule id="572145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0877 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>