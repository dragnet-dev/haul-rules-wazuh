<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2442 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f0710eeb-93cf-50d6-96c3-9d44af24edfe -->
  <rule id="711374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2442 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>