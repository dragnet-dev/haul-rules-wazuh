<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0112 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 2ef529fe-79c8-5b60-a724-4e1d8508e90c -->
  <rule id="424479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0112 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>