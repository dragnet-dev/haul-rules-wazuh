<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2048 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 8bc30dca-9848-595c-848c-ff13267b8985 -->
  <rule id="978093" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2048 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>