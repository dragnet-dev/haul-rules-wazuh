<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3188 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 841e1285-b676-5de8-9da0-f7f940d11fc4 -->
  <rule id="547012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3188 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>