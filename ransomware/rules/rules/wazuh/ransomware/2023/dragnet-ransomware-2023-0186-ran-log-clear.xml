<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0186 — Event Log Clearing (donutleaks) | Status: experimental | Sigma ID: 22cd45e4-027f-5523-ab22-e609c7258899 -->
  <rule id="439934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0186 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>