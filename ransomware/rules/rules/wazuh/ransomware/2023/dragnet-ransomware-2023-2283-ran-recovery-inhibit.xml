<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2283 — Recovery Inhibition (toufan) | Status: deprecated | Sigma ID: 1d083c23-2dbb-5451-ad59-04e8f308ec5f -->
  <rule id="253402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2283 — Recovery Inhibition (toufan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>