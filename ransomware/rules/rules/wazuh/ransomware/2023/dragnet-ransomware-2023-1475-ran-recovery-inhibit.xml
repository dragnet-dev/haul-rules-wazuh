<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1475 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 37196cd4-8313-50a5-ab40-a6078049e222 -->
  <rule id="622381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1475 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>