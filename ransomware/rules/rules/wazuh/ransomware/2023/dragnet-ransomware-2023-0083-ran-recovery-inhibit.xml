<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0083 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: b549a00e-f56a-5054-ae1b-9f576eebc109 -->
  <rule id="147940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0083 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>