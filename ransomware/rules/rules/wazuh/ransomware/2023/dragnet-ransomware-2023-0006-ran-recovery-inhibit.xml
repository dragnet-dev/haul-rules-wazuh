<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0006 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 16d4b88e-fa76-5d0e-af26-22436d0f5d57 -->
  <rule id="811588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0006 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>