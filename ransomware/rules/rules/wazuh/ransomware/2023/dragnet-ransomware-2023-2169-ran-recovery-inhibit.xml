<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2169 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7503b8cb-34bc-5817-8a26-7b3a606a42b3 -->
  <rule id="400598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2169 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>