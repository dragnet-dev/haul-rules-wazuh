<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2276 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 4635b28f-136c-53f0-b89d-aed1efce2311 -->
  <rule id="317128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2276 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>