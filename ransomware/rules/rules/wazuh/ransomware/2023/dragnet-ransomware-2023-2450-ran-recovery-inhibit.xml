<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2450 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3b555db3-a309-5d29-b725-2781a2928969 -->
  <rule id="946299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2450 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>