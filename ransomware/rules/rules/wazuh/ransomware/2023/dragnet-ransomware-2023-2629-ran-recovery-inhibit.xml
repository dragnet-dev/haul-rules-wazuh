<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2629 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 5997ec51-4590-5369-98f2-58af5e1ca510 -->
  <rule id="735468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2629 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>