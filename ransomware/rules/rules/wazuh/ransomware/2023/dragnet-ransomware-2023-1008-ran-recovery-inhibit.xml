<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1008 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f1be4a7a-6980-5b7e-83fc-5de60bcef984 -->
  <rule id="915434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1008 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>