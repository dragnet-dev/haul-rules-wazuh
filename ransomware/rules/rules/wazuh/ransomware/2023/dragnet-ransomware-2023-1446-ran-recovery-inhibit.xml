<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1446 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ac15f940-5d6b-561a-916d-15b5ac743d6d -->
  <rule id="154559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1446 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>