<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0406 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 9e8e8acd-1715-5ae0-90ab-9696076733d1 -->
  <rule id="567658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0406 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>