<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4056 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6604dbad-0b06-508e-a3f6-c6e3a896faa3 -->
  <rule id="890843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4056 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>