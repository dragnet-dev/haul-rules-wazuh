<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4869 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 90990fd4-cf7d-5a44-a7bd-470c50a257e2 -->
  <rule id="655855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4869 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>