<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4688 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4dd8f244-6ebf-5e22-bfc0-a7ba63415b4a -->
  <rule id="293432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4688 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>