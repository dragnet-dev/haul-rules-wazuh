<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4872 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 251237a6-e18a-58ef-985f-cb710b1f968c -->
  <rule id="519802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4872 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>