<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1541 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: f0848f81-3993-50dc-b3d4-73fc73fefe58 -->
  <rule id="713583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1541 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>