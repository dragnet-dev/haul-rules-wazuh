<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5011 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 2cb9b22b-2c67-5040-a587-d84a2787cfe7 -->
  <rule id="345552" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5011 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>