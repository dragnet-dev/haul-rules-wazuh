<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2854 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: a4c4a931-f8c8-5e1c-aa10-8860e35eadef -->
  <rule id="982349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2854 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>