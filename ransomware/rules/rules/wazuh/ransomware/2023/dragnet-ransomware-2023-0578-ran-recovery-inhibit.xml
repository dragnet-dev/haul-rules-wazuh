<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0578 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 040a8244-e104-5b35-a4c5-59a6f55d9e5e -->
  <rule id="308244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0578 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
