<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1117 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8903e891-b060-5eee-b938-1f1dfd5f6d55 -->
  <rule id="624628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1117 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>