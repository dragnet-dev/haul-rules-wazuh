<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4205 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: cbc2bb69-57a4-58e5-b14d-d5c4b5977e50 -->
  <rule id="346299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4205 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>