<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1638 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 12d8b9f7-6bca-561d-bc06-a83d96165907 -->
  <rule id="870399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1638 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>