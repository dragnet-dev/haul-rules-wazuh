<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2178 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c1a3becf-c0a1-5b7e-914c-78448eb896cb -->
  <rule id="582718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2178 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>