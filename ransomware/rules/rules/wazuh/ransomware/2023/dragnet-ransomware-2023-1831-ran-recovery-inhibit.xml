<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1831 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a4c483d5-49b7-57d9-a034-ffbb6763dd51 -->
  <rule id="876483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1831 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>