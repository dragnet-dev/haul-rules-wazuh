<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0891 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4225d4ae-c83b-5d69-93da-5380e8aaced3 -->
  <rule id="118154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0891 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>