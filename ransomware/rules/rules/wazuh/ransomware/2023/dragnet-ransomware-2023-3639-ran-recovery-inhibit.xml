<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3639 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d7a6bc7b-313a-549d-8f10-6d29fe539ecb -->
  <rule id="338844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3639 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>