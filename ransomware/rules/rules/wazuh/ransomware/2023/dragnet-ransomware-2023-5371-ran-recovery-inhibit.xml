<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5371 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 47fd808f-5754-5d6e-bea0-83b3de9ecce9 -->
  <rule id="428580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5371 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>