<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5221 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0ea56cc6-ce27-59e6-a49e-f9892d8a1d3e -->
  <rule id="704940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5221 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>