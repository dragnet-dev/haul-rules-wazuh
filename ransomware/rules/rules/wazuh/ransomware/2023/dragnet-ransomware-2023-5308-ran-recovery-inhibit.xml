<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5308 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: e47b9163-2c90-5b68-b714-dab5de2502b4 -->
  <rule id="616391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5308 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>