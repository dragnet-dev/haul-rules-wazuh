<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1304 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 35d90ef0-f036-5ae4-b918-5d70423c0548 -->
  <rule id="392079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1304 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>