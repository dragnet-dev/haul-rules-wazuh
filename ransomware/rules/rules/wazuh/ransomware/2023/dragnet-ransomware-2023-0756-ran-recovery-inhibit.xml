<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0756 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 9984bad1-8dca-5456-b4c2-b2ebfab47260 -->
  <rule id="856090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0756 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>