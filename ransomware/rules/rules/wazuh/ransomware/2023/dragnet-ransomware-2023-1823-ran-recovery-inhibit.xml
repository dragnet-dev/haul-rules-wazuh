<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1823 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f9dd8c09-bfda-5f68-8f1e-bafc8e79f58f -->
  <rule id="348140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1823 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>