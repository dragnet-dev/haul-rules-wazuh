<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3276 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 356de26b-a010-5f09-8e63-54b445271c22 -->
  <rule id="235826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3276 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>