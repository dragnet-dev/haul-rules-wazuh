<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2364 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bbc76414-fee7-5305-aec8-bff80943c68b -->
  <rule id="404764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2364 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>