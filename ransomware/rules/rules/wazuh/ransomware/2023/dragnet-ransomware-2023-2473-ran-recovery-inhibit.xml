<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2473 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 642946e4-de79-59ef-a1b3-9b4221958a71 -->
  <rule id="487150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2473 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>