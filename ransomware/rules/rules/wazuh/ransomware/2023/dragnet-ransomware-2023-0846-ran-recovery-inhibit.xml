<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0846 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 24dad1d8-cf99-50a2-b4d8-355d69a8485c -->
  <rule id="218051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0846 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>