<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4779 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 2faec40a-9351-5db1-a21c-4be232d730a8 -->
  <rule id="253084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4779 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>