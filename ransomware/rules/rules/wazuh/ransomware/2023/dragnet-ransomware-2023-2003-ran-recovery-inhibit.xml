<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2003 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7656aa2f-878d-5227-a5de-af60050d29dc -->
  <rule id="260106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2003 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>