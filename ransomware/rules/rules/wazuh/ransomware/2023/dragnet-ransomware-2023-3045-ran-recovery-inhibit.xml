<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3045 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c4cd6867-3ad6-5a98-a30f-a39c816a6390 -->
  <rule id="594968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3045 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>