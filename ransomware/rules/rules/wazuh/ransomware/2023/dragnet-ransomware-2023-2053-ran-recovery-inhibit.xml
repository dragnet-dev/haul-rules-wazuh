<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2053 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dfac3325-d736-5d27-93d8-c3110f5fb146 -->
  <rule id="426033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2053 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>