<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1263 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eecd19d9-a16b-565b-a8ac-ad4eafa09a16 -->
  <rule id="813319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1263 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>