<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4191 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: ce609673-3174-5d17-b19c-72a83ca40e11 -->
  <rule id="366096" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4191 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>