<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2055 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 76594292-6bd9-5f90-bbe6-2e0cea77117d -->
  <rule id="559429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2055 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
