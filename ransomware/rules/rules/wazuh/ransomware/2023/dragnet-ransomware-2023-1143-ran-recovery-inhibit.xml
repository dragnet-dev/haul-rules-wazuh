<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1143 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: e5773a7a-15b4-51a8-bfec-0c59e1b3c9b3 -->
  <rule id="632378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1143 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>