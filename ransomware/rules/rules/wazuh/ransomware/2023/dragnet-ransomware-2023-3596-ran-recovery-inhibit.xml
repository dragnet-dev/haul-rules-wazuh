<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3596 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5911c5d3-c864-5d51-ae9c-56fadcafa696 -->
  <rule id="834173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3596 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>