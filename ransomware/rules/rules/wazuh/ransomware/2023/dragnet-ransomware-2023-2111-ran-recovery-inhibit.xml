<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2111 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 1f634afa-8b93-5a62-a2ef-a8a1dc3ac968 -->
  <rule id="998479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2111 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>