<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2279 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 8dcecd2b-78c8-507d-af62-cd2af314ba5b -->
  <rule id="393517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2279 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>