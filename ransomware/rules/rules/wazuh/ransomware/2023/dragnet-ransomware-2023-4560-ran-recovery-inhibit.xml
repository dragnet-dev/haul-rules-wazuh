<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4560 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fd3ebf4b-dc67-50d6-933f-dc5ac3fb4065 -->
  <rule id="578943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4560 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>