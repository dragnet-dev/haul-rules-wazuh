<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2287 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 0ecc8233-88e9-5b0e-9937-abbf54bbde9d -->
  <rule id="288823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2287 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>