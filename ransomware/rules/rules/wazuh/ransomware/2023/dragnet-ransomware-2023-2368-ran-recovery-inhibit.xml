<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2368 — Recovery Inhibition (medusa) | Status: deprecated | Sigma ID: cc049016-bf79-5dbd-abfb-107ea5e74c5b -->
  <rule id="340490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2368 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>