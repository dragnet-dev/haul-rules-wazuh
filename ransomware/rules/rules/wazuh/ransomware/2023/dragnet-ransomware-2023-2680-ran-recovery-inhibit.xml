<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2680 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 3a597e0d-625f-508a-ba06-fbe092f2be5d -->
  <rule id="475660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2680 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>