<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3327 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 85b0d9af-a12d-5e56-b233-f4d987afc2ab -->
  <rule id="493739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3327 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>