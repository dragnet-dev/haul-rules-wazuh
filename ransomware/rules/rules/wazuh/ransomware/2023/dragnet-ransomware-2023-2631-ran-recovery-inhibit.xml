<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2631 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 08e90d27-255f-5406-9194-422f8ff44243 -->
  <rule id="586532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2631 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>