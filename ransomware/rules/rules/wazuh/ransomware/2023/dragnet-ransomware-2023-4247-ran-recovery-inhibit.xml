<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4247 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 4219ca1e-ffb7-562c-9b92-dbce07ac6aba -->
  <rule id="280266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4247 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>