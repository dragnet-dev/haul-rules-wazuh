<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0491 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f308a970-1e25-59ba-bf13-abd6e6f88a91 -->
  <rule id="749389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0491 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>