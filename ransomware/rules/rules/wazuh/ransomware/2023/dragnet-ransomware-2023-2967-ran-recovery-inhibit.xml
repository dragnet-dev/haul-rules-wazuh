<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2967 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 6fd4983f-4412-5aa5-be10-e71f2b748cb0 -->
  <rule id="989498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2967 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>