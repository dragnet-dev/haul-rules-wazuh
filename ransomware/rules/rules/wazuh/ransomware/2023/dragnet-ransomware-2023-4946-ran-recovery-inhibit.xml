<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4946 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3ceda874-6533-5cda-ad46-b3f6669bfeb8 -->
  <rule id="795628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4946 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>