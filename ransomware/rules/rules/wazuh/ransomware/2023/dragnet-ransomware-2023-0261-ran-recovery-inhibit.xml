<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0261 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 10018332-86d1-511a-8a60-f7508311e3eb -->
  <rule id="201833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0261 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>