<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0322 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3fe88fda-d49c-50c9-b278-71583fa4a047 -->
  <rule id="836623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0322 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>