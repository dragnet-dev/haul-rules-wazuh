<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4477 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d8612886-90f8-5e0a-a36c-234f36ed0363 -->
  <rule id="586128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4477 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>