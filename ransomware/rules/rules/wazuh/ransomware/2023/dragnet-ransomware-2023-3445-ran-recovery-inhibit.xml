<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3445 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 8212e9d8-3a52-53e9-b0dc-ae1f6cf30bbc -->
  <rule id="514069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3445 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>