<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2747 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 551131fb-5889-536c-8284-3bbf6b65c77b -->
  <rule id="818111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2747 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>