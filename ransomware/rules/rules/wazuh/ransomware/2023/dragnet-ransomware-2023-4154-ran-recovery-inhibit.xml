<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4154 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 35682072-fa94-521c-8762-cc7fdf5b33c7 -->
  <rule id="968207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4154 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>