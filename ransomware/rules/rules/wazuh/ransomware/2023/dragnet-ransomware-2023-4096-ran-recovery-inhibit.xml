<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4096 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6fb472cf-b4f7-5598-844d-4c9c37240075 -->
  <rule id="987472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4096 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>