<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1490 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7ce76a5f-2aa7-5fda-b2dc-f1d021823fc8 -->
  <rule id="598026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1490 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>