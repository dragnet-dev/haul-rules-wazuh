<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1184 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e3b6b624-a71f-5add-a81b-53f1ab7cbd43 -->
  <rule id="179476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1184 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>