<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3893 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2e7ec751-2943-566f-9b17-14ae7cf892f8 -->
  <rule id="397887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3893 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>