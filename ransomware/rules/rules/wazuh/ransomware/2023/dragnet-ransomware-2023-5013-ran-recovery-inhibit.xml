<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5013 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 412fe539-8fb0-51fc-a379-639dca1215d8 -->
  <rule id="257265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5013 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>