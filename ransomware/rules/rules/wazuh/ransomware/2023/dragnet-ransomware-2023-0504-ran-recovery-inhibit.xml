<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0504 — Recovery Inhibition (cyclops) | Status: deprecated | Sigma ID: 862e196b-ee35-5c74-8b18-b11e66866c11 -->
  <rule id="580619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0504 — Recovery Inhibition (cyclops)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>