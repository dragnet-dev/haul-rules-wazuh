<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0948 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 217ec395-6a71-529f-8c86-afd0ad8ae819 -->
  <rule id="278839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0948 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>