<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2413 — Recovery Inhibition (toufan) | Status: deprecated | Sigma ID: 67aa069b-8697-5aa2-a21f-13ac9fe1cd16 -->
  <rule id="932206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2413 — Recovery Inhibition (toufan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>