<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0319 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 39982213-5331-577d-ac6d-71ecdad19dbe -->
  <rule id="498221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0319 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>