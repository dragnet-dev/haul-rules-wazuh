<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5076 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 495f33bd-bc7e-5689-a6fc-59d15c1b060c -->
  <rule id="196539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5076 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>