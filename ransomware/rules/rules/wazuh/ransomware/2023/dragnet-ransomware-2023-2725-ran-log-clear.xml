<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2725 — Event Log Clearing (werewolves) | Status: experimental | Sigma ID: f491f189-f20a-5c91-97f3-40e1dcd88054 -->
  <rule id="778711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2725 — Event Log Clearing (werewolves)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>