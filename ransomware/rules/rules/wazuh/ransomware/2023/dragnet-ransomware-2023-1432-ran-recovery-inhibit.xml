<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1432 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 216c60b0-0c15-5375-a16c-401314015680 -->
  <rule id="249771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1432 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>