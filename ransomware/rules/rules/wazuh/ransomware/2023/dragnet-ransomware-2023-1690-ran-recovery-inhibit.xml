<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1690 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2f93b3d8-e03c-5f8a-b7bd-1b64019c7132 -->
  <rule id="671901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1690 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>