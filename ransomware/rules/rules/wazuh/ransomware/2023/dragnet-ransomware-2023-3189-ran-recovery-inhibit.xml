<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3189 — Recovery Inhibition (mallox) | Status: deprecated | Sigma ID: 235ece5d-380d-516e-a1ac-7b9c25eaf371 -->
  <rule id="763505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3189 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>