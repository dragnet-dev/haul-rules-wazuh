<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2944 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: a53d51a7-c9a1-5233-b609-cb9c6701aee2 -->
  <rule id="886151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2944 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>