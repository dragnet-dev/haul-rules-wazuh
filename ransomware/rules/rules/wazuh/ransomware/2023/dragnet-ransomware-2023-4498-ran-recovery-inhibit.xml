<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4498 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6c16573f-8050-50bf-8043-ac22e150c1c6 -->
  <rule id="281657" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4498 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>