<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1477 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 9deff5e6-f6bc-5f44-bc2c-a11835058b5c -->
  <rule id="269115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1477 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>