<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0268 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c8c10ee6-2049-5226-8c0c-45b15119ffc1 -->
  <rule id="696174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0268 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>