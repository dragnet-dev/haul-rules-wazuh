<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4568 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f123d014-99b6-5ff5-ba51-79a51471801a -->
  <rule id="719810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4568 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>