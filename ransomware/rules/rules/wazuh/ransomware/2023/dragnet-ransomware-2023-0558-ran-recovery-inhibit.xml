<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0558 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: fe4fe860-81d4-5adc-a131-c93d9de56ec6 -->
  <rule id="315188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0558 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>