<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4517 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f689c46c-2ed4-587d-a7bf-03759fd60445 -->
  <rule id="810364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4517 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>