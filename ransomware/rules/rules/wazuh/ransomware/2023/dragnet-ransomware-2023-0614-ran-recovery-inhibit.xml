<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0614 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7ae9b74e-47c6-548d-a0a4-2c298fd0cff5 -->
  <rule id="547157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0614 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>