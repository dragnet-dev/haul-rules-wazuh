<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4883 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: db22b2e3-29c1-57cb-ae39-e057a33d4798 -->
  <rule id="907632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4883 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>