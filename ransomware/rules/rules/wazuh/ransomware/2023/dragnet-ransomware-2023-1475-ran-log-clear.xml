<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1475 — Event Log Clearing (raworld) | Status: experimental | Sigma ID: 3c22a7d9-acf2-5a21-857e-1bb0b18f42b5 -->
  <rule id="218045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1475 — Event Log Clearing (raworld)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>