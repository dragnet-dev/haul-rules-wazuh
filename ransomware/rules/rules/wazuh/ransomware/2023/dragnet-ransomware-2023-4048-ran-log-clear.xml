<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4048 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: bd8c1aea-11f4-5fa6-a22e-775eb4d657ab -->
  <rule id="460826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4048 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>