<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1224 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: d832ac1e-442f-5b4b-bb34-6d15ec2b1ff1 -->
  <rule id="941164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1224 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>