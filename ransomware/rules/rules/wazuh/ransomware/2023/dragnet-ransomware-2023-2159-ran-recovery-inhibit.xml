<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2159 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 81bf2e6a-51f5-54ae-a3ed-f37ec4ad3b7a -->
  <rule id="748366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2159 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>