<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5218 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 9a98e587-0fb7-5138-96af-b2fec0c016c5 -->
  <rule id="779825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5218 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>