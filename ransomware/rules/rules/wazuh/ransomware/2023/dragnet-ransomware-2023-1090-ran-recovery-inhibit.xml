<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1090 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: ae84e829-6070-5048-98a7-cf6cae979c1e -->
  <rule id="197588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1090 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>