<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1176 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 025efb21-161c-5bfd-b697-199c11406f27 -->
  <rule id="262352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1176 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>