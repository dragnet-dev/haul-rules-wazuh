<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4317 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0258a551-31e7-5962-a605-199009d2aa7c -->
  <rule id="638551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4317 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>