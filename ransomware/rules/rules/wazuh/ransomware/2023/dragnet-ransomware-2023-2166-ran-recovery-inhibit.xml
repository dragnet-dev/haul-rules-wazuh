<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2166 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 28ec9bfd-1913-505e-8ee1-7221a578258e -->
  <rule id="384795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2166 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>