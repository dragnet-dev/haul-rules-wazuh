<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3457 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4a3dc6b1-cb6a-5071-893b-b5cdfd81b1d9 -->
  <rule id="204286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3457 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>