<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3690 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 5e1e5517-af10-551f-93a3-c460382899c5 -->
  <rule id="707055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3690 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>