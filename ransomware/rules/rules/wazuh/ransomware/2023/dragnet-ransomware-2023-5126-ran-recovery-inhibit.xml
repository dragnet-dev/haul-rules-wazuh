<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5126 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1cbd6d99-f15c-5dc9-8654-476eee9849e7 -->
  <rule id="377229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5126 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>