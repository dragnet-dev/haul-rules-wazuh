<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3585 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d327b898-862e-5c63-8137-014d0611ef34 -->
  <rule id="432438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3585 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>