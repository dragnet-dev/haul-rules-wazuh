<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0418 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: b53e88a0-f35a-55d4-a78b-ee62c1a4476c -->
  <rule id="146288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0418 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>