<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1642 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: fc7256a9-4057-59e8-b051-77a155ab9e04 -->
  <rule id="827256" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1642 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>