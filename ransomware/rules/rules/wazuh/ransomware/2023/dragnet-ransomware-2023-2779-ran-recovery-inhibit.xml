<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2779 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: e04a5be7-578e-5a83-b564-c14846897bc5 -->
  <rule id="995931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2779 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>