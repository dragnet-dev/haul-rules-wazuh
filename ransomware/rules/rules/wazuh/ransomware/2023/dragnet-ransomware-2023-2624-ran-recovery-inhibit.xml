<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2624 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: dc8ead23-2821-5b5d-9e26-e6bd6165fd43 -->
  <rule id="147725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2624 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>