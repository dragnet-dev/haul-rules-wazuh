<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0231 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 9d59d271-047e-539e-9156-28c813a49c59 -->
  <rule id="821572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0231 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>