<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1439 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 4a80054a-40d2-548a-90cb-0f48f7f0c3f1 -->
  <rule id="380054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1439 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>