<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5119 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: e6a50a5d-d2d9-5ef2-84e0-664ea18a24eb -->
  <rule id="254410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5119 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>