<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5039 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f605d5ff-5a9e-5728-a26d-2266938e8c36 -->
  <rule id="796935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5039 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>