<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5032 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 8d81e62f-a5ff-5a51-9e70-1619d2d07c99 -->
  <rule id="569106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5032 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>