<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1285 — Recovery Inhibition (cryptnet) | Status: experimental | Sigma ID: f3a948ed-f9e7-5ef5-b34e-c2e9d4539a31 -->
  <rule id="758948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1285 — Recovery Inhibition (cryptnet)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>