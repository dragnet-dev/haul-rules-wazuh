<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3594 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 813935a9-6025-52f2-a19f-135d1ddecdff -->
  <rule id="522970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3594 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>