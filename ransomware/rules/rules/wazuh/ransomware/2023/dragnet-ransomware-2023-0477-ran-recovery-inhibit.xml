<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0477 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 551e04f6-42b9-5eab-afdc-26f59e324938 -->
  <rule id="728079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0477 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>