<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1097 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e2f0738c-0308-5264-bcf5-472852a7bf2a -->
  <rule id="587073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1097 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>