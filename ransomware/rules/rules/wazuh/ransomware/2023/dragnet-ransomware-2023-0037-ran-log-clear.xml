<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0037 — Event Log Clearing (noescape) | Status: experimental | Sigma ID: 3d83415f-7931-5674-9441-aa4b231e2a80 -->
  <rule id="883415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0037 — Event Log Clearing (noescape)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>