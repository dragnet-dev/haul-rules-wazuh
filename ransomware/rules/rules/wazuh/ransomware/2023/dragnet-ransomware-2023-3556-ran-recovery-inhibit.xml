<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3556 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 86b2d499-4f96-5092-bc6f-0256adaae24c -->
  <rule id="519654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3556 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>