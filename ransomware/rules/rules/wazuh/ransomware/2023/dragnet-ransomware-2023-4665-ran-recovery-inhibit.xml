<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4665 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b08715d5-55dc-5167-84c5-72533d37c3b3 -->
  <rule id="308715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4665 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>