<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1872 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 30e8d2ac-98a9-59fb-9ece-35ab79cf5910 -->
  <rule id="169002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1872 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>