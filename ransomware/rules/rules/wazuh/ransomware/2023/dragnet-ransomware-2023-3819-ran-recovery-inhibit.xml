<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3819 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 856eae60-89f3-5edb-84b6-6cd9b8409842 -->
  <rule id="909934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3819 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>