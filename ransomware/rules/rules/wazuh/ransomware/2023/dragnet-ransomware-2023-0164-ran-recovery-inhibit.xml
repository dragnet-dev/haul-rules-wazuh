<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0164 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d1f24e98-b807-5cb1-b599-744c836682c1 -->
  <rule id="777998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0164 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>