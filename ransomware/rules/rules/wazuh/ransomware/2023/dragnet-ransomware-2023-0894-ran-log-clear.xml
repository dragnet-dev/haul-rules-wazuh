<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0894 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 81f9b4c2-27f0-5499-9c97-1d6b6de404a5 -->
  <rule id="399154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0894 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>