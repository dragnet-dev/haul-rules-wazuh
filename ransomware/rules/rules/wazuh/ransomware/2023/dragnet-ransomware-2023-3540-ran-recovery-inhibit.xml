<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3540 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0f304bcf-6df6-5b33-b9a7-df85cde65e1a -->
  <rule id="418012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3540 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>