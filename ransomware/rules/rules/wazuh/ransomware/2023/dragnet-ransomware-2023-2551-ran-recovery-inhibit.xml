<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2551 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1dfb19f3-75a7-50be-a9c5-79494b539182 -->
  <rule id="680319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2551 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>