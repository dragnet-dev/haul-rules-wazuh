<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5343 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9f7d9042-c7fb-5662-8413-ea27bad9fd09 -->
  <rule id="856590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5343 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>