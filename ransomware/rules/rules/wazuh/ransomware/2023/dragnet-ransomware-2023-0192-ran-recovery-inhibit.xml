<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0192 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4481be85-a347-5c14-8c91-de6e59de67ab -->
  <rule id="347326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0192 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>