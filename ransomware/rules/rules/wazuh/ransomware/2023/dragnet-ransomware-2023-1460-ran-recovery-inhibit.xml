<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1460 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f1222401-52a6-54f3-8acd-e601953d5a98 -->
  <rule id="712224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1460 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>