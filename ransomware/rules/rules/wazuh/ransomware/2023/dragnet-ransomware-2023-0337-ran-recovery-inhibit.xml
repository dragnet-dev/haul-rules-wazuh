<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0337 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 44ffed3d-1408-5ee6-83e8-0f293846d3dc -->
  <rule id="349101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0337 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>