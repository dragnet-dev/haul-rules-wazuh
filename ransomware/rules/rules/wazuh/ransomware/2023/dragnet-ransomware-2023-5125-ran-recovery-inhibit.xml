<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5125 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 983b685e-4193-5d5e-8ca1-fb20e3fd4f2c -->
  <rule id="773968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5125 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>