<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5054 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 3969f371-2c66-55e4-85c7-8ea42856dda5 -->
  <rule id="151937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5054 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>