<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4237 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 93c65cb8-d2a3-52aa-9522-7ddfb62ab1b9 -->
  <rule id="701052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4237 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>