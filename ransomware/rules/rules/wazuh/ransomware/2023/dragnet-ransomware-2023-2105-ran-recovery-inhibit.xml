<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2105 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c78ea97b-5023-586a-93a1-fee21b129fe2 -->
  <rule id="674029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2105 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>