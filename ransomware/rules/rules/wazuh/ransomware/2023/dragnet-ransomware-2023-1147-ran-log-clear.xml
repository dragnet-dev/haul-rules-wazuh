<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1147 — Event Log Clearing (royal) | Status: experimental | Sigma ID: b18e4a8c-a6bf-5a45-9d55-a3ddece2ecfa -->
  <rule id="264394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1147 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>