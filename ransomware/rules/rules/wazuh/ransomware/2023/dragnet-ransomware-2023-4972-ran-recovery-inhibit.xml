<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4972 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 227d6932-95b2-5276-beb6-8f82628c2b09 -->
  <rule id="145693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4972 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>