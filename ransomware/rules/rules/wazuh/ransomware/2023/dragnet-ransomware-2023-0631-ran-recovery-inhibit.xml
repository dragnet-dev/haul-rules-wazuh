<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0631 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 309a7586-17f4-5db6-a5ba-d66219c54305 -->
  <rule id="554758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0631 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>