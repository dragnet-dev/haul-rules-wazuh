<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4003 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 5b2a5cc9-5d3f-5fd5-b54a-13232e84ed83 -->
  <rule id="636412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4003 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>