<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3190 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: bd109f83-23f1-549f-b3da-a00719e0d749 -->
  <rule id="425759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3190 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>