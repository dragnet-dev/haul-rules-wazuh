<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2985 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7a8889cc-3b1e-55de-9de5-4bdeab978aba -->
  <rule id="428889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2985 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>