<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0166 — Event Log Clearing (unsafe) | Status: deprecated | Sigma ID: 660b7f80-d874-5fc4-9f1e-f87dd5b3d7dd -->
  <rule id="891487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0166 — Event Log Clearing (unsafe)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>