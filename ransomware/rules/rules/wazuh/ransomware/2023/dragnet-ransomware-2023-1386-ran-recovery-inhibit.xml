<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1386 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4d4c38ba-24f6-5da7-b426-1f29ccf08ba9 -->
  <rule id="439638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1386 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>