<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4976 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8c047841-21bf-55ec-9597-2b645ce58333 -->
  <rule id="600478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4976 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>