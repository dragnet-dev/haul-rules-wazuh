<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3382 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0041f4cc-65d4-5b49-8d9c-ef2aac93705e -->
  <rule id="918988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3382 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>