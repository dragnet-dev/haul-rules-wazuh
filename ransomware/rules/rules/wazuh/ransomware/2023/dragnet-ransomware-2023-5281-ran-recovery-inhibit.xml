<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5281 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8feeb9b7-0bff-53e1-9fb0-c5953dea6af4 -->
  <rule id="595479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5281 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>