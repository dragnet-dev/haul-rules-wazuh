<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0443 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: b287235d-a189-596f-ab0c-f69c1bf96b99 -->
  <rule id="328723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0443 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>