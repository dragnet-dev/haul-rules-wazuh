<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4914 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 34dbeed2-b32b-503e-93d5-5b20ddf9643d -->
  <rule id="584526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4914 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>