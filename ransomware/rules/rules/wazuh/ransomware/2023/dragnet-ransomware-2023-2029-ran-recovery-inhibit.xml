<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2029 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: aa69997f-6280-5b3a-9a9b-49513316dd97 -->
  <rule id="906999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2029 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>