<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2006 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6b39e0e9-e66f-5c6d-a14c-ab93b1ecc24b -->
  <rule id="918380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2006 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>