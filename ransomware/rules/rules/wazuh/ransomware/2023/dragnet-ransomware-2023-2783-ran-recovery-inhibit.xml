<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2783 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 5b65e4b4-efa1-5512-9483-2f99cc4c0bfd -->
  <rule id="666544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2783 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>