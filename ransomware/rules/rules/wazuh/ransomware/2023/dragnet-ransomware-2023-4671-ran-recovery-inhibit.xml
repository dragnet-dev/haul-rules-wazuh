<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4671 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: cb4d28f6-a292-5feb-854a-3cbe807e9d0b -->
  <rule id="655728" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4671 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>