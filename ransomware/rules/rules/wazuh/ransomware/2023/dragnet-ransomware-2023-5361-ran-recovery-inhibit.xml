<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5361 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 1c7b17c4-d9a8-5c7a-ac0b-26aff4d14308 -->
  <rule id="265084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5361 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>