<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5177 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 50b9a945-a9f1-5ad7-9615-831d749823ba -->
  <rule id="499149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5177 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>