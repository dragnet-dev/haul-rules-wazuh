<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1532 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0c31cf7f-6e55-54fa-8031-72c85b16d120 -->
  <rule id="553437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1532 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>