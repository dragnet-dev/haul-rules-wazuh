<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2517 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: fa0c4d2c-3070-5492-99cc-05981ea9e9b6 -->
  <rule id="201997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2517 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>