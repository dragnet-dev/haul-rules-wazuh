<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1687 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 64ed8406-5c51-54cd-a111-26fc77212de8 -->
  <rule id="862184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1687 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>