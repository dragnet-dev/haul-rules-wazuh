<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3016 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 9df90ea9-733f-5fe2-a5a1-376b97d1f511 -->
  <rule id="544654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3016 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>