<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2896 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 13d45a33-405b-5cfe-9048-804f677dda74 -->
  <rule id="943303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2896 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>