<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4171 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 43f9bad1-1c52-5932-8c5d-12a8d3f6ab2c -->
  <rule id="102170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4171 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>