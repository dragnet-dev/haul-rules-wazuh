<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0386 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 4a1cace2-0967-50ca-ae2d-a0bab24c67ce -->
  <rule id="438380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0386 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>