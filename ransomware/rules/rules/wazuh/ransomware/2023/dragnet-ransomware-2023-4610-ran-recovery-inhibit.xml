<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4610 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ca41b118-004c-5b17-a38a-afcf7a8746df -->
  <rule id="638671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4610 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>