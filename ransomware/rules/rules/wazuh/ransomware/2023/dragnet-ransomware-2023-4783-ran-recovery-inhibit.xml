<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4783 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 28a72f61-0a60-58e7-8ff5-698188625182 -->
  <rule id="239676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4783 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>