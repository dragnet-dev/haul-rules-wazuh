<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1013 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c737f07c-81ce-5c55-92e9-7bc38cc10b46 -->
  <rule id="338070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1013 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>