<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3978 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7f0fb2af-d7c2-5955-860d-f3d89d35e6c4 -->
  <rule id="653712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3978 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>