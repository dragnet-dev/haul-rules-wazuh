<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3012 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 796c393e-6d33-5dc4-bd60-cf1a79e97114 -->
  <rule id="474839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3012 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>