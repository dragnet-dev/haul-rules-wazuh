<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3294 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 45613ce3-f06e-558c-8e26-8f8dd264067b -->
  <rule id="977134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3294 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>