<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2285 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 4e529ab3-7e3a-5c1c-8e64-d4203560b0bb -->
  <rule id="456474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2285 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>