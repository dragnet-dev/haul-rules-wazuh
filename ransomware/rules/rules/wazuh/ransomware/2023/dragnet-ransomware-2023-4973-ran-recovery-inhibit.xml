<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4973 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ff5e1571-fc63-58e0-8b79-f3085cd57367 -->
  <rule id="589415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4973 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>