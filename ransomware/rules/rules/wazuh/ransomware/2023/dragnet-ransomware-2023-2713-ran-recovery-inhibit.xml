<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2713 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: da2726c8-3e84-5b3c-92c1-a33134fa6845 -->
  <rule id="482726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2713 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>