<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0064 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 13c7859c-4a35-5dd4-b5d4-9c7cd34385b1 -->
  <rule id="507859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0064 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>