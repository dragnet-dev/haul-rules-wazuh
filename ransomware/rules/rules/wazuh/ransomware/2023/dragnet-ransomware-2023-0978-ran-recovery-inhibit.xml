<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0978 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ac64591d-1568-5ac0-a8e6-e0021a111287 -->
  <rule id="926459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0978 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
