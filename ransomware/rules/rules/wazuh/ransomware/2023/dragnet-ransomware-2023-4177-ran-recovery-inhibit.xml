<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4177 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 35f0bc7e-cd73-514a-accc-d77989e8deb5 -->
  <rule id="672188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4177 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>