<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1780 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5799336c-a9b2-5a24-bee9-b5bd8b3d83bd -->
  <rule id="499336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1780 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>