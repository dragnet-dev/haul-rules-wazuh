<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1585 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 51ed8ad7-680a-5208-8e36-73489e08dfd5 -->
  <rule id="427018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1585 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>