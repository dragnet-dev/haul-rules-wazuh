<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1340 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: e07c8622-ef45-5927-a775-2c5ccbeb3f83 -->
  <rule id="552486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1340 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>