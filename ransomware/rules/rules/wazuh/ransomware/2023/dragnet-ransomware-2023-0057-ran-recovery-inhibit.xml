<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0057 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 65ac08d4-fca8-5158-8bc2-667a8d04cbde -->
  <rule id="881208" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0057 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>