<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1660 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: fbf2a0e4-a439-595f-a784-20833d1b3553 -->
  <rule id="250020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1660 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>