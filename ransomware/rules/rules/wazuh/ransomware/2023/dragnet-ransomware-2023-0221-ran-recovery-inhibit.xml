<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0221 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a718be08-6a91-5d7e-bc2f-1fb76a820437 -->
  <rule id="143998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0221 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>