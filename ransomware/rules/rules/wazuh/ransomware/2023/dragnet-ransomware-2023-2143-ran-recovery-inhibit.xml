<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2143 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 2161fa48-d9a7-55d8-8089-9b32b9421d5f -->
  <rule id="234664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2143 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>