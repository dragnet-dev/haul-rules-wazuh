<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4531 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 799c78d7-a289-580a-9cc3-8bb8713df41e -->
  <rule id="479678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4531 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>