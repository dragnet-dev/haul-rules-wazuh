<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4762 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3f701219-28a7-5748-b66a-b69fdb9d4085 -->
  <rule id="170121" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4762 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>