<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0493 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ef889229-db86-5f0a-8590-5b514f2fb1e3 -->
  <rule id="698892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0493 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>