<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0008 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 0afdd8cc-7c81-54b5-82c5-ae75e24d5430 -->
  <rule id="103500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0008 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>