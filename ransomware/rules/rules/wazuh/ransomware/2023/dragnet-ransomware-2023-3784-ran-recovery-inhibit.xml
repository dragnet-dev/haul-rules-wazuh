<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3784 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 99023242-979d-5821-8027-f2f35415a907 -->
  <rule id="102324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3784 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>