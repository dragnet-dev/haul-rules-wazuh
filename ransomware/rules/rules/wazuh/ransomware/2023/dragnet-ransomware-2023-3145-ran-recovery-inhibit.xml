<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3145 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e3293b99-5872-556b-8146-0916525d6fdc -->
  <rule id="592699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3145 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>