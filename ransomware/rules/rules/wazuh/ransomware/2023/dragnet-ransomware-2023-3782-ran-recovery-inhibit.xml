<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3782 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f1b197ff-67f7-5c7f-a6d2-e3122c8fee4c -->
  <rule id="727197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3782 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>