<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4249 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 29e620e5-9340-513a-8ae5-4474cca44c20 -->
  <rule id="557934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4249 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>