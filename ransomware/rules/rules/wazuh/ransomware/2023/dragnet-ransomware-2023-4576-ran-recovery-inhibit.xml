<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4576 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 81bac34c-6249-5ca9-adb7-ffb3de9c612f -->
  <rule id="747643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4576 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>