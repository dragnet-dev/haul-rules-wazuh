<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2853 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: ebea8591-9acd-5108-a3be-d94650faf7ac -->
  <rule id="739485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2853 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>