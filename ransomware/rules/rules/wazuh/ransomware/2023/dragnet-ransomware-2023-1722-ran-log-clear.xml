<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1722 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 3013fa4c-95fb-5e45-8777-cdc6e4dd4d1d -->
  <rule id="615784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1722 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>