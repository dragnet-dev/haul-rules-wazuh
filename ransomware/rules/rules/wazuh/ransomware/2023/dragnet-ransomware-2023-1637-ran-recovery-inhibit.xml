<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1637 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e1db2aaf-ffad-5a40-9c79-a2d4e3bb056b -->
  <rule id="510442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1637 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>