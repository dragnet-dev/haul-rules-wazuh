<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1403 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2e4fe25a-d7bc-5b91-885c-ce879f5b23bd -->
  <rule id="390382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1403 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>