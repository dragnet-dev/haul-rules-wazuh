<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0377 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c71558c7-139b-56cc-9cd0-b60736b16a32 -->
  <rule id="471558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0377 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>