<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5114 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9045622d-c8a2-5884-8d3d-ada2f7708087 -->
  <rule id="145622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5114 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>