<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5202 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 61b63cf3-ccc5-536c-b66a-9a6b6b4f4241 -->
  <rule id="780220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5202 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>