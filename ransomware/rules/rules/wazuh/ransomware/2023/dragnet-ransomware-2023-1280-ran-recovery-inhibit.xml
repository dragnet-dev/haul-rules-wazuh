<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1280 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 3b9a62e5-d337-515d-ae52-986168e2bada -->
  <rule id="151406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1280 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>