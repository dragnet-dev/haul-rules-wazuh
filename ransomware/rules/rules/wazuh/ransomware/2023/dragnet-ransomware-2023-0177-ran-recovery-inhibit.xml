<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0177 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a54b2306-6d3e-5da1-9989-cbd82e678d87 -->
  <rule id="887523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0177 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>