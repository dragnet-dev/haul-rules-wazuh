<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0860 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3207f359-0206-539c-8c8a-fbbf74fc3aef -->
  <rule id="732735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0860 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>