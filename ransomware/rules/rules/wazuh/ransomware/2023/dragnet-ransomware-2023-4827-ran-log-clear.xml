<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4827 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 1be63f8d-a0cc-578e-8feb-717a623a0b9b -->
  <rule id="946238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4827 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>