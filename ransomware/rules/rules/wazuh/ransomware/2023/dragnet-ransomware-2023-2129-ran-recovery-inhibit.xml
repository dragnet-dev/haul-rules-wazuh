<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2129 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: f74dd127-4412-568b-9552-0311ce295a26 -->
  <rule id="531651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2129 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>