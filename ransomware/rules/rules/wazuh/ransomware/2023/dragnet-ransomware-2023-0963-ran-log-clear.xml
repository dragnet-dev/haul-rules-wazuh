<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0963 — Event Log Clearing (rancoz) | Status: experimental | Sigma ID: d31d9f7f-1e07-5172-bd71-ee02a3bdb643 -->
  <rule id="809599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0963 — Event Log Clearing (rancoz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>