<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1940 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b132daa8-d671-5a6a-bd8d-198431caa2ff -->
  <rule id="250010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1940 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>