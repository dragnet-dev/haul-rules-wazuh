<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5334 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cc679a8e-f5b1-5207-ac9a-d81506994480 -->
  <rule id="674874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5334 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>