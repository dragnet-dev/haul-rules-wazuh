<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0994 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5bf64f59-b009-587a-8d9e-9c444360421e -->
  <rule id="654639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0994 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>