<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2050 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 15d3c899-3b4c-56e1-bc00-a4d5dc5de8d6 -->
  <rule id="554089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2050 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>