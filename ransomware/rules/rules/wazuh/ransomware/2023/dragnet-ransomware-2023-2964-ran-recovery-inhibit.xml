<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2964 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 660b397f-6f1b-5e39-b757-46bce8563507 -->
  <rule id="257139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2964 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>