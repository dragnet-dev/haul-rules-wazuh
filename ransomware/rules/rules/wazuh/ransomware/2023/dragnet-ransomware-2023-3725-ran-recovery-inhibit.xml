<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3725 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: e2520f2a-c9f7-5eb0-a202-9fb13e05bc78 -->
  <rule id="580335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3725 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>