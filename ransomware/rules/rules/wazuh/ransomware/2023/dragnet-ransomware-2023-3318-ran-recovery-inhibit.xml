<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3318 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: adda32b4-6b1d-57a9-9413-9d17782e37b3 -->
  <rule id="950632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3318 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>