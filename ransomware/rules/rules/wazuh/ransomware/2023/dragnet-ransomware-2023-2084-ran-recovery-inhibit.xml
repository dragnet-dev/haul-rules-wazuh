<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2084 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cf520ccf-0ec6-55fc-92d4-7f0a08e77cb8 -->
  <rule id="720332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2084 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>