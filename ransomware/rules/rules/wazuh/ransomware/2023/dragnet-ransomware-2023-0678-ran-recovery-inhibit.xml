<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0678 — Recovery Inhibition (cryptbb) | Status: experimental | Sigma ID: a21f13df-993a-567c-9161-00896da5955c -->
  <rule id="835113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0678 — Recovery Inhibition (cryptbb)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>