<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3658 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: c2f49aca-2186-54c1-8af9-2899870d6c0b -->
  <rule id="547994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3658 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>