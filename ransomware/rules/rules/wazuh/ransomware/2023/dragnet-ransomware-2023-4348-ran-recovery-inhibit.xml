<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4348 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 2a84212b-a438-54c6-b3b0-619dbb7dddcc -->
  <rule id="784212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4348 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>