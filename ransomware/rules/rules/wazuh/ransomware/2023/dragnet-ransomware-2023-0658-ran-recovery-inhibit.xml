<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0658 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2dc9dce2-8436-5e5e-8c01-5eaed4358450 -->
  <rule id="176444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0658 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>