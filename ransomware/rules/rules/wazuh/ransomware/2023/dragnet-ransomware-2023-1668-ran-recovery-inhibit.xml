<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1668 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 511741cd-20c7-5bd4-a1c6-297f7ede1f90 -->
  <rule id="187868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1668 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>