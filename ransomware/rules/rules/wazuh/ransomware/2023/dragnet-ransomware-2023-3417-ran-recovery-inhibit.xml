<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3417 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c2525601-8c14-50d2-b8bf-acd96016b043 -->
  <rule id="425256" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3417 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>