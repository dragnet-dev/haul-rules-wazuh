<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0752 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7c90cdca-1e3d-55bd-86e6-d30306bfe8b7 -->
  <rule id="597645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0752 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>