<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1459 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 85bb670b-bb5f-5810-be67-a7a08ac9dbed -->
  <rule id="494767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1459 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>