<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0266 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: e7870310-959e-528f-9353-70b6647c9322 -->
  <rule id="678703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0266 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>