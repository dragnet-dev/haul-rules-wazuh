<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2266 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 7439ca64-e947-5f73-b54d-a5682dc9a2e6 -->
  <rule id="204586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2266 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>