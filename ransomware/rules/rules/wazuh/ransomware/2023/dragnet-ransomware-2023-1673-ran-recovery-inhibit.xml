<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1673 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a1721607-eefc-54ac-8242-4abbd6c26fe1 -->
  <rule id="217216" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1673 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>