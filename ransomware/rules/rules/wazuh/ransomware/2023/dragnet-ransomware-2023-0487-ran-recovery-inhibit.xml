<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0487 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a8f23a59-1885-5222-9739-e03ae4ca49d5 -->
  <rule id="189178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0487 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>