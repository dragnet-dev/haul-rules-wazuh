<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3026 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5f8831ed-168f-5dee-959b-96ac919123bc -->
  <rule id="141310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3026 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>