<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5192 — Event Log Clearing (trigona) | Status: deprecated | Sigma ID: 5d3a7cb7-7519-5721-a54a-1c3f9fa5a3b2 -->
  <rule id="690204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5192 — Event Log Clearing (trigona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>