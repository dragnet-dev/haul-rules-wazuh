<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1571 — Event Log Clearing (knight) | Status: experimental | Sigma ID: f254f7dc-618f-533e-b2ab-c7171bff9dcc -->
  <rule id="740797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1571 — Event Log Clearing (knight)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>