<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1240 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 89b8a20c-4775-5146-a3fa-d1122a79cf21 -->
  <rule id="597382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1240 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>