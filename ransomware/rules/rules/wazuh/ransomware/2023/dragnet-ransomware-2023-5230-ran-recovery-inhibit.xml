<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5230 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5517bb4b-724e-50f2-b20d-71c666874ca1 -->
  <rule id="612539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5230 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>