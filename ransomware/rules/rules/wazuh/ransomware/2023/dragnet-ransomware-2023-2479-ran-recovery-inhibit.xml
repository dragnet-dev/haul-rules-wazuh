<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2479 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 89f14f94-9ad9-5c88-83cb-5900c1cc8025 -->
  <rule id="602639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2479 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>