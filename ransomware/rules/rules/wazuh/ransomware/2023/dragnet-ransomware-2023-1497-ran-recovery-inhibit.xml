<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1497 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7fedba18-9267-52ba-8a73-50b558ff33a6 -->
  <rule id="383930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1497 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>