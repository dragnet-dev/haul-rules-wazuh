<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0292 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: ad0db80b-75a6-50ef-b212-1c4dfb39a27d -->
  <rule id="930998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0292 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>