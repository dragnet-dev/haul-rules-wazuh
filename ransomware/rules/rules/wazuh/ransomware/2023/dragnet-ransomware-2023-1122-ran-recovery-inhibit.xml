<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1122 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b5805e1e-f397-5e06-956c-aabf344f0499 -->
  <rule id="152894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1122 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>