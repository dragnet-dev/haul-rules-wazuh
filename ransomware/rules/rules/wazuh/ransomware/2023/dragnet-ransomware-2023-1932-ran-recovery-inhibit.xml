<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1932 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7b7ab0b2-6395-5ae6-b493-0451fcf4057d -->
  <rule id="568430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1932 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>