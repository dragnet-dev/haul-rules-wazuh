<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2135 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 82f8e4a4-dd28-5797-968b-41bac7924136 -->
  <rule id="424624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2135 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>