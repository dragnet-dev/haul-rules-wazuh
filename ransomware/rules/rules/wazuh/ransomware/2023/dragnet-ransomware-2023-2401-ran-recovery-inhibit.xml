<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2401 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e418b121-3aa7-5fd5-9ac3-046db6f25671 -->
  <rule id="606991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2401 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>