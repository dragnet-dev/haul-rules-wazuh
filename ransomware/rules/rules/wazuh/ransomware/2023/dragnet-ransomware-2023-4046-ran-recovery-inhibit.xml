<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4046 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 413c5ae8-5e76-5a2a-bbb4-b4e2ab026ac7 -->
  <rule id="259290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4046 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>