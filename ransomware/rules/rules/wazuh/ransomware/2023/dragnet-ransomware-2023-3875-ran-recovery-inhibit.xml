<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3875 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 686a4026-710c-593d-9461-5e389ce48c94 -->
  <rule id="298640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3875 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>