<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3677 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 096c51ac-8995-5077-9eb0-c518151ce008 -->
  <rule id="777626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3677 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>