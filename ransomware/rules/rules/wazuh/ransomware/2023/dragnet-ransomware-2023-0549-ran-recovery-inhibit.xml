<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0549 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 88f92c73-6c31-5541-aa89-bed4b3f8207a -->
  <rule id="578284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0549 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>