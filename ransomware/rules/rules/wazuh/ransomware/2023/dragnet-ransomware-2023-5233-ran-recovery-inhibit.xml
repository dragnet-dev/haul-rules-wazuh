<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5233 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5df43085-af4e-52b3-b09d-1ad1e9a000db -->
  <rule id="703430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5233 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>