<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3321 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e6e35173-e142-51fe-9de7-c049c6f43fd3 -->
  <rule id="650351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3321 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>