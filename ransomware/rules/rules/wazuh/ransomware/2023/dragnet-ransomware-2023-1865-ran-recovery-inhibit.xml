<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1865 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 198aacc6-f081-57a1-814e-ac1ded757b5a -->
  <rule id="519852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1865 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>