<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1786 — Recovery Inhibition (play) | Status: experimental | Sigma ID: faba5155-fc8d-5e6f-8846-5fe26ccd556b -->
  <rule id="218651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1786 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>