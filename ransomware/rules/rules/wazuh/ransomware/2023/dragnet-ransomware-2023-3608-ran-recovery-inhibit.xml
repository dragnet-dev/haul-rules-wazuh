<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3608 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 0a96446e-f17b-5176-be3e-2181071a41ab -->
  <rule id="296446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3608 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>