<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2291 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a76c5339-8b2d-5698-b489-d73784acf0a2 -->
  <rule id="922853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2291 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>