<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0608 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e5ca709a-35bb-5a9d-a415-0cde38039ceb -->
  <rule id="232270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0608 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>