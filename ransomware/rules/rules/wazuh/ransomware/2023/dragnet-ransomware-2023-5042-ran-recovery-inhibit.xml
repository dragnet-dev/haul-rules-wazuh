<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5042 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 37564db4-9abc-57fc-8bf4-4d6bfa4c9296 -->
  <rule id="716603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5042 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>