<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3444 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 153b8252-c646-553f-98a2-914f907b22b7 -->
  <rule id="759825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3444 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>