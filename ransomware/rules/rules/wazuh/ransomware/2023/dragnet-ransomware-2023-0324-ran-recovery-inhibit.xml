<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0324 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9e0f6c07-c292-5bcd-81b4-f1c379e7da94 -->
  <rule id="547308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0324 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>