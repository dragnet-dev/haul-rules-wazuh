<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2404 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 158a9641-ff7d-5479-a402-e7e781467694 -->
  <rule id="838964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2404 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>