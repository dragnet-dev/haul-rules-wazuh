<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0069 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 1fa2b395-bc5b-5dd2-b5ce-0ccf4cefcc5d -->
  <rule id="100339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0069 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>