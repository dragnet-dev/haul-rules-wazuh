<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1471 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 64a6a7b9-3a9b-52bb-a495-c82037005155 -->
  <rule id="855467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1471 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>