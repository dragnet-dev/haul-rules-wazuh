<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1895 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6bada1bf-fa3a-5418-8835-fa3f921d5ae3 -->
  <rule id="910501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1895 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>