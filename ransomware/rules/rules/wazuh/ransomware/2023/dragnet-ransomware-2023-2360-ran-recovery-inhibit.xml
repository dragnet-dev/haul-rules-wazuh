<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2360 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 29c82100-cbec-5794-a352-661ad7fd349e -->
  <rule id="368210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2360 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>