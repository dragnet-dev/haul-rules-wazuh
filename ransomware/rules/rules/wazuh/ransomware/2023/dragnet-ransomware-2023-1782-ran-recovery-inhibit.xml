<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1782 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 49e6ca79-24ae-5926-aacf-ed1022264887 -->
  <rule id="344618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1782 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>