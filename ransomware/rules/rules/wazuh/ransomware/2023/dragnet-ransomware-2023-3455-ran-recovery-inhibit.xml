<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3455 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4c396fce-317f-55b6-8da9-2ce3d8bb1452 -->
  <rule id="422351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3455 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>