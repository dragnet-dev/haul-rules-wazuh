<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0746 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: bf31e6bb-9ee4-5e6a-bfbf-c9988a8fb576 -->
  <rule id="461106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0746 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>