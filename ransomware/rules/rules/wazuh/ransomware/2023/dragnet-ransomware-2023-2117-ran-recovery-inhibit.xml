<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2117 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: c22e5973-0f14-5a25-acad-5ca11e9d2226 -->
  <rule id="256659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2117 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>