<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4668 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 62143a29-9221-5485-870a-8f76c87d6e3e -->
  <rule id="142982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4668 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>