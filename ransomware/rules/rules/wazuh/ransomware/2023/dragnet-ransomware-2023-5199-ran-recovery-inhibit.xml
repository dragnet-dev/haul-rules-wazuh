<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5199 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4c2d36ab-8914-5cb2-83f8-a8faac5bdb91 -->
  <rule id="420536" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5199 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>