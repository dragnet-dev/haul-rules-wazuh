<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3011 — Event Log Clearing (play) | Status: deprecated | Sigma ID: 5a5b6718-01d4-5e4d-b98e-2e0a6a3e0fb8 -->
  <rule id="649167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3011 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>