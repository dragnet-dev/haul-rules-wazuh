<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4722 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: d52e39e4-ee7e-5d0a-9e2c-a339b105d387 -->
  <rule id="464639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4722 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>