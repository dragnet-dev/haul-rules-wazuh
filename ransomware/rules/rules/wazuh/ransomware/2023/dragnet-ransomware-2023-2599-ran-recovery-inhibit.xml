<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2599 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1c4a7794-eeea-5014-99e9-553735022b46 -->
  <rule id="154779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2599 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>