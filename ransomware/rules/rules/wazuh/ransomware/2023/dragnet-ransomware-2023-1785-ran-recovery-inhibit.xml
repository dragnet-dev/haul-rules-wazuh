<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1785 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5cabf053-e0e5-5328-bd81-1625f8029b60 -->
  <rule id="295830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1785 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>