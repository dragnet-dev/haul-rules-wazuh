<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2234 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0a29cdfa-e89c-5911-8d34-74fe96f4b7f4 -->
  <rule id="718079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2234 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>