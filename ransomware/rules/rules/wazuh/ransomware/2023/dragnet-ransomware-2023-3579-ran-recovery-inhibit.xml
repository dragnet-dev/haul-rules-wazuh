<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3579 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 74c1e62b-d9bb-56e9-8ca9-892db4681af9 -->
  <rule id="213906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3579 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>