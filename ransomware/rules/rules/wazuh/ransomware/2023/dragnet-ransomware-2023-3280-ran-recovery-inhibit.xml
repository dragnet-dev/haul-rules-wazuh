<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3280 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 9a78d26b-22f9-5d8f-baae-decd01cd721e -->
  <rule id="776612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3280 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>