<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4332 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 08890332-aac3-5af1-9a30-ab7fc1c25544 -->
  <rule id="890332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4332 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>