<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0475 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c1b76fce-e1d9-50d7-877a-2d153e031a71 -->
  <rule id="516431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0475 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>