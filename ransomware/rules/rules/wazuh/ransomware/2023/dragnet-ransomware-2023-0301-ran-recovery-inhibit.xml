<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0301 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2c76b8ad-7863-5c77-ae0b-5da653604957 -->
  <rule id="760458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0301 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>