<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4949 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 6a0bcaf3-38f5-52ce-9df8-032ba951a1e4 -->
  <rule id="844778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4949 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>