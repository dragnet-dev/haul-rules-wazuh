<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3273 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: 0a2286ce-b326-5d6a-99e5-f6ca27d7d14f -->
  <rule id="836588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3273 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>