<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0060 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: e6e3c5a4-c04e-5df7-a17f-aaf82840e291 -->
  <rule id="260605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0060 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>