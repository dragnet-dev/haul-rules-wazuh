<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0968 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d7b73038-40c0-5939-a15b-b5e45bfed002 -->
  <rule id="503730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0968 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>