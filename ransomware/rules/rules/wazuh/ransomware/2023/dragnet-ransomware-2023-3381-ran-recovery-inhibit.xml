<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3381 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 60225387-ecb9-5bef-a669-fc85fac176b4 -->
  <rule id="722538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3381 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>