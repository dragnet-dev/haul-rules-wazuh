<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4334 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: dee6acbd-a1aa-552b-8967-42de4ec91080 -->
  <rule id="230668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4334 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>