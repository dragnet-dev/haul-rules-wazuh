<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4093 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 633882f5-484f-5ca4-a5a5-d1a9223226f9 -->
  <rule id="342127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4093 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>