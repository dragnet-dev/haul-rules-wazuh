<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0714 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6b130403-8c01-59e7-a63f-9ac052e06b67 -->
  <rule id="271304" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0714 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>