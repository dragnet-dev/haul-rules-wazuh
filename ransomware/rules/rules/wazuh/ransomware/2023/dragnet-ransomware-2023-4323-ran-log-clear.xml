<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4323 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: 0bcd9dbb-99e3-500e-968c-f26c7e57f008 -->
  <rule id="636283" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4323 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>