<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4444 — Event Log Clearing (noescape) | Status: experimental | Sigma ID: b0df1e0e-d6c6-5d8e-9140-2e521b6b4e97 -->
  <rule id="141310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4444 — Event Log Clearing (noescape)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>