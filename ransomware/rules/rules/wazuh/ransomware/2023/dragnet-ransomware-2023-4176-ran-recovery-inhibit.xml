<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4176 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 29e8b0d0-f246-518c-9b34-ad76593ab554 -->
  <rule id="659053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4176 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>