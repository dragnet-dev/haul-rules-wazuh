<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0133 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cb572a2b-51e6-5d22-8c38-e7ec0228d852 -->
  <rule id="657162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0133 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>