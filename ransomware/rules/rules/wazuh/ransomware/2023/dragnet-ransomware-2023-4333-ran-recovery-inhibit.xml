<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4333 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: e653ea98-f521-5f95-bc23-680aa55f2856 -->
  <rule id="251402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4333 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>