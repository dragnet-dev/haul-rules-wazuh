<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1575 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7d8cf9aa-706d-58ca-8d6e-0a7f144eee22 -->
  <rule id="622559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1575 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>