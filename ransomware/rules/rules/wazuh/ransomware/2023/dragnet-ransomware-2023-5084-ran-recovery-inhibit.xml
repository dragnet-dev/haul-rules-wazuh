<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5084 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8dd3bd31-ac3e-5376-8cce-17f11e8a0044 -->
  <rule id="509597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5084 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>