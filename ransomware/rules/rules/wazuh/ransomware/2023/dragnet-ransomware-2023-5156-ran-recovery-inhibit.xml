<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5156 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cb333935-4c8e-5a05-aeee-fb7873c00a85 -->
  <rule id="333339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5156 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>