<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3278 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 59025cf5-8d5f-55c2-9b3d-220141493621 -->
  <rule id="810607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3278 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
