<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0368 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: ba01ab58-c0c1-58b0-9043-1a2dfd0ce250 -->
  <rule id="362027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0368 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>