<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0991 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a784297f-b045-571f-a193-47de38448356 -->
  <rule id="278429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0991 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>