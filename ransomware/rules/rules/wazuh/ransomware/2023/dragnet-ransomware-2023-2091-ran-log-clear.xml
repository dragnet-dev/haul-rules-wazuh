<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2091 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 018c1b10-8ec1-5efa-8ad7-90ad2bbe8bd1 -->
  <rule id="402710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2091 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>