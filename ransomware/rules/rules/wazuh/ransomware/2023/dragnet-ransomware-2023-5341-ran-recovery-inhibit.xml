<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5341 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 08be4b4f-08ef-5367-806e-a23a945b44bc -->
  <rule id="981554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5341 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>