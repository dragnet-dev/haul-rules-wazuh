<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4677 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: 3514f7bb-7a96-5926-aa40-4b8bd04b6d47 -->
  <rule id="998363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4677 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>