<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1579 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 526aba04-bd8a-5a94-9f69-a1a29e83b1cb -->
  <rule id="457242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1579 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>