<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2108 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cdf4f30f-4c72-54a5-a88a-0d022f4cead5 -->
  <rule id="872793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2108 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>