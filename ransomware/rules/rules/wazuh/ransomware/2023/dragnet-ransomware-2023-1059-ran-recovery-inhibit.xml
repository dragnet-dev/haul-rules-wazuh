<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1059 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: c30ff4b1-0d3e-5ba4-beea-71810932cc63 -->
  <rule id="551354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1059 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>