<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3267 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2113b4b4-ca0a-53b3-8326-f739fcbdc598 -->
  <rule id="111115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3267 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>