<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3386 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 41e65a0c-f058-5080-95fd-26ba498761b3 -->
  <rule id="273050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3386 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>