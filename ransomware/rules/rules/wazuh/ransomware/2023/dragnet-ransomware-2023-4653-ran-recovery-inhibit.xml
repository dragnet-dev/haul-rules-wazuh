<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4653 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 529c48c5-2ec6-5665-9e36-dbfc02276b9b -->
  <rule id="162380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4653 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>