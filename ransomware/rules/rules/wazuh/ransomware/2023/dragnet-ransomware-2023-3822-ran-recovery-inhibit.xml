<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3822 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 23e45178-d868-50ec-a1c4-f1273e2adae9 -->
  <rule id="324517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3822 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>