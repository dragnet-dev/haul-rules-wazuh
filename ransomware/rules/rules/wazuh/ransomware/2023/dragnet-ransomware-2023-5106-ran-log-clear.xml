<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5106 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 84ff5f8c-919e-5bfc-99c9-19d9b4a3e3d2 -->
  <rule id="881535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5106 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>