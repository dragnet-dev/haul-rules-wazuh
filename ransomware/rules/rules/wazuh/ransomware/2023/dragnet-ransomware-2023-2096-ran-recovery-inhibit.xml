<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2096 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 17f29b4a-0be7-5009-b985-c545361649fb -->
  <rule id="196754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2096 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>