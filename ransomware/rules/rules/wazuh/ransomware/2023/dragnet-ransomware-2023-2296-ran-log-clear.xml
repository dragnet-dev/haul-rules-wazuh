<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2296 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: bbd4f7ee-00e2-5e6c-8416-a208b6028dc7 -->
  <rule id="408797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2296 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>