<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2284 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bb7854c1-d980-51eb-acd0-c6346b4e1c27 -->
  <rule id="177854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2284 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>