<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5001 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 363db826-68b1-57b7-a1bc-db7ea6869ab6 -->
  <rule id="414782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5001 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>