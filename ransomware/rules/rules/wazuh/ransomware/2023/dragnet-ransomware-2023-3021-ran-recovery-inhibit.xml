<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3021 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: d603ef4c-a00a-535f-9fdd-113c8bf4ebce -->
  <rule id="882607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3021 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>