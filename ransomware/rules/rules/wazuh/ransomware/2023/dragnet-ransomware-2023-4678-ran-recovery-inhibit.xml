<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4678 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 85d1eecc-f427-5c8b-a6b3-e0c3c9666449 -->
  <rule id="915374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4678 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>