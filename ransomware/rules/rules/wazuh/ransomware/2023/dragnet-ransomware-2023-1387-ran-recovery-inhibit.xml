<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1387 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 73b93631-3d30-5f49-8424-4359e6039918 -->
  <rule id="379936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1387 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>