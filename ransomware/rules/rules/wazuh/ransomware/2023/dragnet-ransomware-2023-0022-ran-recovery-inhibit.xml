<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0022 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 7cc2bd54-b429-5510-b8d1-07221b3969d0 -->
  <rule id="710461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0022 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>