<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0828 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0eda8974-e65d-588e-bffd-df2bf90e46c2 -->
  <rule id="302897" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0828 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
