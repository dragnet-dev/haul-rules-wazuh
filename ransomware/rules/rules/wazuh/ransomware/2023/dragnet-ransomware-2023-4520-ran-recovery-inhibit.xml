<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4520 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4c982061-9879-5707-9830-a7a05f43b0ca -->
  <rule id="598206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4520 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>