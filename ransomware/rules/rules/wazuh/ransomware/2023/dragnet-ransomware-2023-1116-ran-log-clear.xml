<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1116 — Event Log Clearing (arvinclub) | Status: experimental | Sigma ID: 1d7c75f2-4a41-5430-bf71-a049ddf0c9a6 -->
  <rule id="523615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1116 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>