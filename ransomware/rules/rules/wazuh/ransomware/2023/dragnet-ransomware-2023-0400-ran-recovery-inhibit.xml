<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0400 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d4143125-4c4b-52e2-8864-f135c1f40713 -->
  <rule id="541431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0400 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>