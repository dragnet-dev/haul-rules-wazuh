<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2311 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: bc3d2f75-d773-50d5-bbdf-b4c527022945 -->
  <rule id="422607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2311 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>