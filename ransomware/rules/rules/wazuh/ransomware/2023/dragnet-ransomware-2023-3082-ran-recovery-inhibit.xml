<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3082 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 92af4e13-799c-54e8-b676-36165dbbd44c -->
  <rule id="296398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3082 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>