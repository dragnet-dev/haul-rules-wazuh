<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0583 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 62d88543-7fd6-5e45-9497-3a844e9a816f -->
  <rule id="205885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0583 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>