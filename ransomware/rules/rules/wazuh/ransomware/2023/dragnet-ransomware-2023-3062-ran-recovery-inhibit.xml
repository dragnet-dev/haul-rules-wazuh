<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3062 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 23d0c006-6c5f-5d30-a35d-abe936691c34 -->
  <rule id="797200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3062 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>