<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2032 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: be1952d7-40b4-54ba-8a8c-1491b0bbf647 -->
  <rule id="201952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2032 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>