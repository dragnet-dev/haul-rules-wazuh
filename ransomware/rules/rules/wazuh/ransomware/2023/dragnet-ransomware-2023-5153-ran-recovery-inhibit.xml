<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5153 — Recovery Inhibition (play) | Status: experimental | Sigma ID: daa25bb3-9a2a-5d5a-a483-c05010ab8344 -->
  <rule id="297211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5153 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>