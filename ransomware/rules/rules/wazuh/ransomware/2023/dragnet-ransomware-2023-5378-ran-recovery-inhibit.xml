<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5378 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 2fdcefc8-6442-5652-a610-1c3d3edc26a4 -->
  <rule id="536751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5378 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>