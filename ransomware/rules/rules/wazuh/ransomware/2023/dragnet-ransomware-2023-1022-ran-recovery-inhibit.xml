<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1022 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ece1578f-37ea-5c9e-a10d-b95f39bb402f -->
  <rule id="290157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1022 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>