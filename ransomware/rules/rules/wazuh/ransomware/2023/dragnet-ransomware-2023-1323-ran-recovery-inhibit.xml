<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1323 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 18f7b4c3-6d8a-55ce-8c5a-6753eee4e102 -->
  <rule id="676556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1323 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>