<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1149 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e6eccb37-e418-5784-826b-18d6b5b44a53 -->
  <rule id="728875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1149 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>