<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3255 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: 2ef1585a-6b2c-5500-90c1-f4d2b68034b4 -->
  <rule id="411585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3255 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>