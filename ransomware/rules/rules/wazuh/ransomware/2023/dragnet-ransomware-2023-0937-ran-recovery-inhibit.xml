<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0937 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e297ebaf-ee76-5ddc-9fdf-13832ad5ba40 -->
  <rule id="160267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0937 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>