<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0736 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a54f3d1d-a967-5b46-971a-44e82a757194 -->
  <rule id="100701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0736 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>