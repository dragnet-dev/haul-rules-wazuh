<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3115 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2659b235-d3f8-5367-a1a6-2b2ed0adf072 -->
  <rule id="755523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3115 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>