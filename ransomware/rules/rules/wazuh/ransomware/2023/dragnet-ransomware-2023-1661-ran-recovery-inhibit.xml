<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1661 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 86c2728f-4ac8-51d9-9216-689a1d5bbc4e -->
  <rule id="588272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1661 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>