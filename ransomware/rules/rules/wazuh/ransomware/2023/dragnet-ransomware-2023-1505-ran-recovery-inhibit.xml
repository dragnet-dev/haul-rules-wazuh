<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1505 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 34990d73-27cc-5251-8926-bb4e4718a318 -->
  <rule id="298537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1505 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>