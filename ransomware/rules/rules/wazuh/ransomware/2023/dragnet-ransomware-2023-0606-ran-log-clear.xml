<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0606 — Event Log Clearing (play) | Status: experimental | Sigma ID: 8a2bf2b9-7c80-5c10-86d3-45e81b0bf2fa -->
  <rule id="939832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0606 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>