<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1106 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a1b0b17f-c65f-5206-bdf7-9d31cd926f04 -->
  <rule id="903311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1106 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>