<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1851 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5686dc2d-5f79-5d4f-ac1f-fee8bb47d603 -->
  <rule id="655836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1851 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>