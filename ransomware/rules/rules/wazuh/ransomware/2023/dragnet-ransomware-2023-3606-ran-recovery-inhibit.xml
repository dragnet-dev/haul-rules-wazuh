<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3606 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d6558f90-97c8-526d-92fd-d3e326b75ad5 -->
  <rule id="484943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3606 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>