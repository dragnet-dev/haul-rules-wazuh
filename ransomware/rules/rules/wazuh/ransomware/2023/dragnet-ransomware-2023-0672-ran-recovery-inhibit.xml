<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0672 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 5186858b-0cb9-5990-94b3-be521d683cc9 -->
  <rule id="786858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0672 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>