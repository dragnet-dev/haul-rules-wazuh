<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0031 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 3b9a417b-3d89-5c7b-89e8-2aaf610df9b1 -->
  <rule id="694417" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0031 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>