<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1754 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 18262377-18da-51f1-bffa-011656d33129 -->
  <rule id="126237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1754 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>