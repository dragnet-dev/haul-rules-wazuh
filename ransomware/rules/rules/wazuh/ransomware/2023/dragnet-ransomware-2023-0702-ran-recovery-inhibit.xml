<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0702 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 622abbd0-6c66-5ffa-9f92-563d3b726235 -->
  <rule id="850459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0702 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
