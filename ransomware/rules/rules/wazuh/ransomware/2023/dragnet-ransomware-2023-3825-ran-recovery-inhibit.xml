<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3825 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 74fc51d1-a208-5a11-8ec8-85f7fa490847 -->
  <rule id="219651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3825 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>