<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1376 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 17832d15-7de3-5eba-92c0-bbdc2237931b -->
  <rule id="253251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1376 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>