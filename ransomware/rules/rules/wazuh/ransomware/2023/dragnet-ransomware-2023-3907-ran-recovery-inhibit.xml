<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3907 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ad53919d-294a-5bfb-a3f6-20fdcd801ffe -->
  <rule id="935391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3907 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>