<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4944 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 87527777-4360-582d-a28d-58fbabee1c0e -->
  <rule id="752777" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4944 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>