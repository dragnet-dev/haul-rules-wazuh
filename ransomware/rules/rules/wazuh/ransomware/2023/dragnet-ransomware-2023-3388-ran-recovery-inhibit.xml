<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3388 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: cfc2d753-4f14-513f-aec3-d03cb6f277aa -->
  <rule id="918857" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3388 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>