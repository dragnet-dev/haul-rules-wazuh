<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0431 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 6e0ec854-a3a7-55a6-b1b1-3b06f36a7bf0 -->
  <rule id="218368" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0431 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>