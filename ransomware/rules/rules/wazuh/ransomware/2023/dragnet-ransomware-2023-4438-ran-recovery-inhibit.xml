<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4438 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e823db75-1048-58f9-bf75-e66a9303d135 -->
  <rule id="294907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4438 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>