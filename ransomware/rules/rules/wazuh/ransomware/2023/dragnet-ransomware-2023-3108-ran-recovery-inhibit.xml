<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3108 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: da417836-5036-5826-8863-6928af55641b -->
  <rule id="484178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3108 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>