<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1165 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2f3b4bb2-631b-5fef-94e5-bd40f11e89c1 -->
  <rule id="412715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1165 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>