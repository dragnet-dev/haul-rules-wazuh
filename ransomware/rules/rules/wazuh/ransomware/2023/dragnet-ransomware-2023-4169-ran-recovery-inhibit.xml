<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4169 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: f191ceff-ec18-53a1-b344-2882b70924c0 -->
  <rule id="389102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4169 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>