<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0793 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 94130687-9e6a-54ef-a308-76db44af3334 -->
  <rule id="513068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0793 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>