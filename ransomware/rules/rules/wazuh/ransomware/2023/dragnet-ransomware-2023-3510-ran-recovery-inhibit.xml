<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3510 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c60574e6-083a-5062-a6d4-c571fd5847ea -->
  <rule id="460574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3510 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>