<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0659 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8f9df539-bf62-5100-b1b3-9d880be9b2d2 -->
  <rule id="186075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0659 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>