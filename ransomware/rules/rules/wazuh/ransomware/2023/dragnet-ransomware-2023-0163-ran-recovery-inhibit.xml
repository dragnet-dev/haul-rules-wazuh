<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0163 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 44972a8f-fb8c-5ebb-8073-999b98ca58d5 -->
  <rule id="995628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0163 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>