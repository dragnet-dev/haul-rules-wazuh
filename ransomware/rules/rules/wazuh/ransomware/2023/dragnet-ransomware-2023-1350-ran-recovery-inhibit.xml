<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1350 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b02849e1-930e-5b87-b951-7ee420cfc971 -->
  <rule id="302849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1350 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>