<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0320 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 69c7ab6c-3567-5bfc-a5da-cdf09ce28f80 -->
  <rule id="258923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0320 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>