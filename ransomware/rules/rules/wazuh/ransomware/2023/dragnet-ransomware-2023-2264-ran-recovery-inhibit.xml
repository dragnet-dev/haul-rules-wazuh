<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2264 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: bb44344c-f2bf-545a-ba1f-4438acce9dff -->
  <rule id="174434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2264 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>