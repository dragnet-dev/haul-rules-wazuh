<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4261 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 74be32c5-03fb-5965-bb2a-fbb3acf641d5 -->
  <rule id="213432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4261 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
