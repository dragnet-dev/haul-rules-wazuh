<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3253 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eb6cf26d-0c63-59e1-b9d7-0b09f4540c8a -->
  <rule id="733432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3253 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>