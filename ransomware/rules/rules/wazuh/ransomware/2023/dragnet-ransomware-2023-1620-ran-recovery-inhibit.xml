<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1620 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4093742f-9e7b-56b6-9088-5d1fdb6f29bf -->
  <rule id="593742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1620 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>