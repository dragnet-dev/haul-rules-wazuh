<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2402 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 4eef8341-82bc-5502-85c9-45f216489dda -->
  <rule id="320783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2402 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>