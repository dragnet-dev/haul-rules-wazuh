<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0436 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 0654b39d-abbe-55b2-8bf0-39cfca88bef9 -->
  <rule id="247539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0436 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>