<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5257 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 941e477e-376c-5976-8c61-5def736b584c -->
  <rule id="707047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5257 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>