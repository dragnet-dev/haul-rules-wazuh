<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4103 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 07c63e22-15f7-521b-a762-2c480e4ddf42 -->
  <rule id="294222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4103 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>