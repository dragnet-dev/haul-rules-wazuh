<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3195 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: acb13f5d-d92d-58d0-8372-fd34b4da921a -->
  <rule id="921023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3195 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>