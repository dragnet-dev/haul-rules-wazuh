<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3950 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d814023f-4b19-5f97-bc9c-0fe756f6e450 -->
  <rule id="581402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3950 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>