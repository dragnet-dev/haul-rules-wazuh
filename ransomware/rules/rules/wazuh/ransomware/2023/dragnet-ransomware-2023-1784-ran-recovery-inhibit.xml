<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1784 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3413bf8e-8da1-596c-bfbc-003267e89882 -->
  <rule id="739198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1784 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>