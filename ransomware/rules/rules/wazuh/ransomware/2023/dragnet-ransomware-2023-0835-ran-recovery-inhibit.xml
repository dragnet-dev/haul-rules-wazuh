<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0835 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e1e77c11-1eea-5126-b511-0bc951091b58 -->
  <rule id="133244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0835 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>