<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3965 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 54dda77a-f2bc-5d08-bb98-378cdafa4201 -->
  <rule id="547307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3965 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>