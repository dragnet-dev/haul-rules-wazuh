<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4796 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 17bdce9b-ddd9-53da-90ef-04d4d1a340f5 -->
  <rule id="362702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4796 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>