<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0389 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4ddd6142-4efb-5c75-8041-1c21caf5f25a -->
  <rule id="293361" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0389 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>