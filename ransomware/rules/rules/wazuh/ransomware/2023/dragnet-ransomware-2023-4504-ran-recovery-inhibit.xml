<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4504 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cdea4840-4be6-53dd-b90e-1f2e8e8516e1 -->
  <rule id="871448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4504 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>