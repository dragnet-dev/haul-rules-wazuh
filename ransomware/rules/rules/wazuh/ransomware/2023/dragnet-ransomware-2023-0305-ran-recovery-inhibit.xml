<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0305 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e838e7dd-d1db-5589-9ba5-e03c880056b2 -->
  <rule id="674227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0305 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>