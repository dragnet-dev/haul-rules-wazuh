<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0349 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: d6f2f71d-faf5-5822-924a-5e3cf0758ab3 -->
  <rule id="906077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0349 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>