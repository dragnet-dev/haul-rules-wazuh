<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2690 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: ada5611b-3290-5ae4-8e8e-e9cef6b593d8 -->
  <rule id="178561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2690 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>