<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2010 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 053a928c-db53-5d38-a3f5-d6c40e9ba21d -->
  <rule id="342860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2010 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>