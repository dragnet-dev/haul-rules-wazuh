<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1733 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: 11afddfc-77ce-5587-842d-411a9d9d5d47 -->
  <rule id="654687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1733 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>