<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1520 — Recovery Inhibition (darkrace) | Status: experimental | Sigma ID: a2d3113d-1691-5196-b00f-bb3ee3813d31 -->
  <rule id="845311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1520 — Recovery Inhibition (darkrace)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>