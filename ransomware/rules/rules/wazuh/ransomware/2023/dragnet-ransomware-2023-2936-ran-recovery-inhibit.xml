<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2936 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c5ea20c-1d11-57d4-a419-5d322f5813db -->
  <rule id="589542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2936 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>