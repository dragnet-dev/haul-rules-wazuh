<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3878 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 351cea22-bbfa-58e0-b8e5-a9ad3de02bdb -->
  <rule id="641002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3878 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>