<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2116 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 9ccfd08a-54f0-5bc7-bed3-b76b98d20c1c -->
  <rule id="223010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2116 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>