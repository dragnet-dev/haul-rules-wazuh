<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3161 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e2b63a7a-34c5-5710-8f56-03f29b384474 -->
  <rule id="153818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3161 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>