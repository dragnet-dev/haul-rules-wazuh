<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1515 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1f6f6e9d-a9ec-5b5a-843d-9111beff0e9b -->
  <rule id="114709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1515 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>