<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1951 — Event Log Clearing (unsafe) | Status: deprecated | Sigma ID: 045ca598-ccd7-5ee7-9685-38dc447d5ac1 -->
  <rule id="372259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1951 — Event Log Clearing (unsafe)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>