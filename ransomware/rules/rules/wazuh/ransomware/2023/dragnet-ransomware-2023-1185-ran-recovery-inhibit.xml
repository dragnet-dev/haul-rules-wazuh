<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1185 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 23185272-1af6-593f-9fd8-06baa85a272c -->
  <rule id="618527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1185 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>