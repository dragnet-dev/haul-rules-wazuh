<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3156 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 61b26c27-f88a-53ab-98f3-f1c06b9aac27 -->
  <rule id="779628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3156 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>