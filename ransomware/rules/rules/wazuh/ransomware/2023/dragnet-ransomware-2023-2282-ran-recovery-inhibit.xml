<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2282 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 3b9686ab-eb5d-5afd-ac96-d777c857a563 -->
  <rule id="694986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2282 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>