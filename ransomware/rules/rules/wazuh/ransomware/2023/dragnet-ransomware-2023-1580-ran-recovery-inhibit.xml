<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1580 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3937e32e-e3db-56d0-a7aa-40a4281acbf1 -->
  <rule id="100632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1580 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>