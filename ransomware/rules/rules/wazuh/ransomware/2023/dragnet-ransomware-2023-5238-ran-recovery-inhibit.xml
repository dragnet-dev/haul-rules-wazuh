<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5238 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ec9e5dbf-fb51-5dd8-a01f-f31a9f812057 -->
  <rule id="766973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5238 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>