<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2626 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: db320020-d163-5814-974a-3a69daa2761b -->
  <rule id="493200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2626 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>