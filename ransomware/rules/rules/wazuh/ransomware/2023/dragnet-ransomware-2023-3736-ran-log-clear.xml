<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3736 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: 4dcb98cc-bf1c-5536-a6b2-5b0c5b40e7a7 -->
  <rule id="291598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3736 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>