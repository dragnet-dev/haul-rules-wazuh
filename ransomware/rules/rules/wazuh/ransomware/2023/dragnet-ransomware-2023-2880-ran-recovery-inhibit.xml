<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2880 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 913d3c72-c235-5518-87ff-8f076e743901 -->
  <rule id="639420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2880 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>