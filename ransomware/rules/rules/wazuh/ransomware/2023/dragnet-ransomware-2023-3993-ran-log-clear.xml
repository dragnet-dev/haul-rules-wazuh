<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3993 — Event Log Clearing (dunghill) | Status: experimental | Sigma ID: 90de3542-bab7-5df1-aa9c-871183202cfd -->
  <rule id="626235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3993 — Event Log Clearing (dunghill)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>