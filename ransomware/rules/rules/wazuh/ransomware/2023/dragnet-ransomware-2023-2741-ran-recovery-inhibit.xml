<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2741 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 5398c4bf-4a1a-5db7-b609-b9ade658b8cd -->
  <rule id="420875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2741 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>