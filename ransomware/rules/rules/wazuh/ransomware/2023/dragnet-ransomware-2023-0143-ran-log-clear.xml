<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0143 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 02d9440d-cdbc-5bc4-979b-4cca0fb8ea39 -->
  <rule id="251053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0143 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>