<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3001 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: ec612b2b-0405-5b67-8574-4aa73d60dba3 -->
  <rule id="285803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3001 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>