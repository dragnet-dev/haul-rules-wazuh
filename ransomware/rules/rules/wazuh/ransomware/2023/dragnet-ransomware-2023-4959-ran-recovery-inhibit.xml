<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4959 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ff6bb77c-298a-58e4-8fdb-6ca616dd7e4b -->
  <rule id="345237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4959 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>