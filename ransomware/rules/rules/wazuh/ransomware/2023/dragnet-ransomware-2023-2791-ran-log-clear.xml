<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2791 — Event Log Clearing (malas) | Status: experimental | Sigma ID: 0b8d700f-a6d9-5c4b-b6ba-1bf5d8097f33 -->
  <rule id="201700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2791 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>