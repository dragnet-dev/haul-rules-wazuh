<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3519 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d6d8df96-580f-5ae6-b769-23275b14a576 -->
  <rule id="306111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3519 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>