<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0481 — Event Log Clearing (knight) | Status: experimental | Sigma ID: 4fb0fd67-7cab-5f23-aa01-66642004fff0 -->
  <rule id="664253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0481 — Event Log Clearing (knight)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>