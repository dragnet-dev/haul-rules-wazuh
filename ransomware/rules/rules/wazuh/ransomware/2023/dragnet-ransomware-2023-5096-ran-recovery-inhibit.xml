<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5096 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 412eb926-c06f-5c82-80ed-41d6af7aefc0 -->
  <rule id="257079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5096 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>