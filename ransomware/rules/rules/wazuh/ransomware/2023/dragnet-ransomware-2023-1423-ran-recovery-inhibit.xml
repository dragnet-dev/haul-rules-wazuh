<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1423 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 376e8d18-2750-5462-b5ba-8c4dd125cd79 -->
  <rule id="749411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1423 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>