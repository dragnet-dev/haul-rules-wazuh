<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2457 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 36cf4ec6-6e55-5f88-84e6-28020eef9bac -->
  <rule id="707758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2457 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>