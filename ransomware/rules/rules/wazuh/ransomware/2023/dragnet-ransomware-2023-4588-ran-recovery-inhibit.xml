<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4588 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7b807aa1-dcf0-5944-9319-6c1874c8ce58 -->
  <rule id="280922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4588 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
