<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2777 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 5e6dccd6-10a6-5427-a760-64a51f97411f -->
  <rule id="378348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2777 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>