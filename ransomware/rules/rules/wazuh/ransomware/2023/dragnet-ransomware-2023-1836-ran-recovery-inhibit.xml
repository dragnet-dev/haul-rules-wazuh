<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1836 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 44fcba14-226a-5546-aec2-fc950e44ab3f -->
  <rule id="348282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1836 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>