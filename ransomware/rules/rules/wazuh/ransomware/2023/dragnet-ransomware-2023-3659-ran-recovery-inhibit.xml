<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3659 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d63c565d-11e3-5eea-9206-49988872b96d -->
  <rule id="482056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3659 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>