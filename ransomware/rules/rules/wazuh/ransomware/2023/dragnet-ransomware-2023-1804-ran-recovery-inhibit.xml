<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1804 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 578ffb8a-432b-5f51-ac91-40c626f5ca26 -->
  <rule id="671579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1804 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>