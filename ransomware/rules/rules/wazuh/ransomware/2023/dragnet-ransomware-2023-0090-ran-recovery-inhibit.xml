<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0090 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a8832543-a3ec-52c3-a64b-2065002c06c6 -->
  <rule id="288325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0090 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>