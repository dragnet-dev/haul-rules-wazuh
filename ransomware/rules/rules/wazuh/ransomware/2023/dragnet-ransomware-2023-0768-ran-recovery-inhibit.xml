<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0768 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 42000187-a349-5989-bb3d-b68435b6b952 -->
  <rule id="700018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0768 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>