<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2071 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3fe3f9e5-8862-5535-b8d5-95824e0491fb -->
  <rule id="835839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2071 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>