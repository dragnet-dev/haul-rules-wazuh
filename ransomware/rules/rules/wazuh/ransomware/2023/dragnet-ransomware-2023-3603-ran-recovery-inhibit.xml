<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3603 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 5fded791-e9ba-5d64-88db-206e49057c4a -->
  <rule id="426857" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3603 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>