<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2258 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5bd76b9a-788b-5864-9b9c-684521436484 -->
  <rule id="651627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2258 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>