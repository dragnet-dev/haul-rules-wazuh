<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0626 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: fa4d59ed-cc16-5b0f-aed0-65dab07dc365 -->
  <rule id="507759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0626 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>