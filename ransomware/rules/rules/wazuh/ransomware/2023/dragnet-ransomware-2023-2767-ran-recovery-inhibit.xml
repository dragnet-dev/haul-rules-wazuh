<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2767 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: f60feffa-adbb-5cca-94c3-605e2afc57bb -->
  <rule id="193839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2767 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>