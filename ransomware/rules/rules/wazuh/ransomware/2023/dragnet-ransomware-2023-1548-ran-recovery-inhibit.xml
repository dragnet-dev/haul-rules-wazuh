<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1548 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 31fa98a7-c5db-59df-be56-3b30c8bcb01f -->
  <rule id="599178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1548 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>