<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0310 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8f2a4098-740d-5824-a621-7ec5033d294d -->
  <rule id="592240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0310 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>