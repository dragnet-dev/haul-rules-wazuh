<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4027 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5b8bc262-d327-5576-be7b-cc06d202789d -->
  <rule id="651962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4027 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>