<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2195 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 7eb6addb-341d-5c95-996a-1f328296df99 -->
  <rule id="790829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2195 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>