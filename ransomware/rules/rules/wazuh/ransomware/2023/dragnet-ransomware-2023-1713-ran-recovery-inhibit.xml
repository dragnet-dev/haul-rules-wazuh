<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1713 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4fb15e90-f022-5fad-a147-f44654a54d4e -->
  <rule id="340254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1713 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>