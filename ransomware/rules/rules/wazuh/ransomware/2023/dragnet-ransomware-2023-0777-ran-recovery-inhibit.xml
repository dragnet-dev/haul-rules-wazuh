<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0777 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b79488d6-0ed4-5b48-ac9e-4dfa059d29be -->
  <rule id="379488" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0777 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>