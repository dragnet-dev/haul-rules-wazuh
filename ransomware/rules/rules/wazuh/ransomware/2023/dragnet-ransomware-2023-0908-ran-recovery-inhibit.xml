<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0908 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 5d20a7e7-2e62-5188-9268-5364896f26bd -->
  <rule id="691307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0908 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>