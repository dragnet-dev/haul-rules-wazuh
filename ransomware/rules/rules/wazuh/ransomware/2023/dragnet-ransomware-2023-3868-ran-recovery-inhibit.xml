<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3868 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 62451534-fca9-530e-9d89-6eaa6f972d90 -->
  <rule id="945153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3868 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>