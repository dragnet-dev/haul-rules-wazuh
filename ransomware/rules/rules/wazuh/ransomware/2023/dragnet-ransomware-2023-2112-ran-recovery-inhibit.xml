<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2112 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 5fc16125-eed1-51c5-9215-71d078f3c955 -->
  <rule id="732161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2112 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>