<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2535 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e78028ce-3f95-517f-8462-3d3b78c9d18e -->
  <rule id="678028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2535 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>