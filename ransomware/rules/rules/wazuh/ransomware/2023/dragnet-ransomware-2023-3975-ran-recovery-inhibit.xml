<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3975 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 557df922-d726-56c2-a617-1f6ec1ada5e9 -->
  <rule id="628159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3975 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>