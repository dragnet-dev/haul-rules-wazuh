<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3166 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 06f3cce9-ac9a-51ed-9d92-3cad2f8bf579 -->
  <rule id="162126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3166 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>