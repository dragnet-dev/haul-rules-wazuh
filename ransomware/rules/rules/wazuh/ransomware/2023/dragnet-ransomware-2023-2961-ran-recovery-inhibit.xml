<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2961 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: d5a08b88-dcd1-5e9e-baea-6b23f21331f2 -->
  <rule id="872139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2961 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>