<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0113 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7ed7bf88-6949-5e81-aadf-d6ca5c9ebe57 -->
  <rule id="796223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0113 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>