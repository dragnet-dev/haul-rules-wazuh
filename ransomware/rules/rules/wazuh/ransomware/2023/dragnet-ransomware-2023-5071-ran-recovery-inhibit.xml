<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5071 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4883ee95-053c-516f-85e7-f8309e8918ef -->
  <rule id="450286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5071 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>