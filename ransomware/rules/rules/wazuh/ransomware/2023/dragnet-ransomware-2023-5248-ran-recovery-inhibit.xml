<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5248 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3ea6ccfc-5064-5949-be41-8edadcdb2404 -->
  <rule id="866860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5248 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>