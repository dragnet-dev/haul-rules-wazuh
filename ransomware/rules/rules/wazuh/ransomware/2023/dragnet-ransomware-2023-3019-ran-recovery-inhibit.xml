<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3019 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 981c802d-bbe3-57e1-89b2-f8dd46377ccc -->
  <rule id="770880" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3019 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>