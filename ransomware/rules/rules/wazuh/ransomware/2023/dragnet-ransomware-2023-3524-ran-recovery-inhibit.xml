<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3524 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f0a7d583-55f4-5713-a164-cc9bcfd5a626 -->
  <rule id="357255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3524 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>