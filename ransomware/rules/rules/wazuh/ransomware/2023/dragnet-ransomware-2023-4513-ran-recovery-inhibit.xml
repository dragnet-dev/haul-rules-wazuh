<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4513 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d0419f46-abdc-5256-8ce4-8311245b3cbd -->
  <rule id="386719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4513 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>