<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0236 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 6e5eee11-db95-5327-8efe-8c75ed3777af -->
  <rule id="129902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0236 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>