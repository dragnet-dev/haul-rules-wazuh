<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2306 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: d4f6692b-5c83-5913-b87a-1e950457292d -->
  <rule id="459669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2306 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>