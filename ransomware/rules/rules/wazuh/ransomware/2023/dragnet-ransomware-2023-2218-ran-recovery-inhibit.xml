<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2218 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 86bb7df1-ce82-55b9-b08c-49e3b3656a55 -->
  <rule id="952605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2218 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>