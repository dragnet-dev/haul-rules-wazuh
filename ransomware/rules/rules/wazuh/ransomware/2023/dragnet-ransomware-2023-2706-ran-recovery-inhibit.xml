<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2706 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: aac27bfe-1c4c-5a3f-82ac-8de75758fce9 -->
  <rule id="871643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2706 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>