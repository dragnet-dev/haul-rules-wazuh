<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2426 — Event Log Clearing (qilin) | Status: deprecated | Sigma ID: 0557b03f-adc9-5ef9-b25c-c4b9c27d3504 -->
  <rule id="876863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2426 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>