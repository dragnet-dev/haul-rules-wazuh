<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0524 — Event Log Clearing (stormous) | Status: experimental | Sigma ID: 3f7635e6-1e83-5e93-95dc-dd3b22d2dc13 -->
  <rule id="402174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0524 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>