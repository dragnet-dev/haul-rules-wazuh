<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5276 — Event Log Clearing (underground) | Status: experimental | Sigma ID: 9d031097-be0a-5d9d-a7ed-9cc895f14350 -->
  <rule id="770310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5276 — Event Log Clearing (underground)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>