<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2146 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 64fd830e-0ed9-5224-9f45-b5b50b7daf0b -->
  <rule id="863783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2146 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>