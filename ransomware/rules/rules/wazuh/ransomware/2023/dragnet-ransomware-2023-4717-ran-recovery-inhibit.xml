<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4717 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f461327e-ad56-59f3-b318-f02195864c23 -->
  <rule id="746132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4717 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>