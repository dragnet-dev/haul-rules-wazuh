<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0126 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0cec2da1-f2b9-50e2-8187-32312abaf746 -->
  <rule id="469210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0126 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>