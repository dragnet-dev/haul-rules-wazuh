<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3847 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4cc57924-c58e-551e-af59-054474121680 -->
  <rule id="428579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3847 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>