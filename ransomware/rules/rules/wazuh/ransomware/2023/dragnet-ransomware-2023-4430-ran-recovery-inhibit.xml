<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4430 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: fab9b8bd-6672-5a0d-8504-bcb8b0586c43 -->
  <rule id="219158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4430 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>