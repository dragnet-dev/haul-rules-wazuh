<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3958 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ef1cab4d-8a7d-52c3-8238-916e3b24df77 -->
  <rule id="896779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3958 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>