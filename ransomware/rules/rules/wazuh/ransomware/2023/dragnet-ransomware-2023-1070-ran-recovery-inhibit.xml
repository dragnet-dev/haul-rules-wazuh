<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1070 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5eb122be-db56-5576-b6e0-cfe2aa25b965 -->
  <rule id="715122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1070 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>