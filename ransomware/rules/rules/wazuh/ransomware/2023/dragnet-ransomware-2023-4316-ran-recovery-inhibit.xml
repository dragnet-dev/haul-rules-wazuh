<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4316 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 49d33301-b8f1-5b78-969c-6a7350be1970 -->
  <rule id="873330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4316 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>