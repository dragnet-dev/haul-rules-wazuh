<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1540 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c9b8f0bf-2de1-5a73-8b48-0579e8051c1a -->
  <rule id="721430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1540 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>