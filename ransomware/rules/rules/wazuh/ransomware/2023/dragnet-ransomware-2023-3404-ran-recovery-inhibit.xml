<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3404 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1e38c4bd-542a-5dbf-940c-abeac22f0794 -->
  <rule id="679275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3404 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>