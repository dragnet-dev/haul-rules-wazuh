<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0293 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 09d58412-3eb2-5501-8ddb-5328bbbe6a3d -->
  <rule id="775841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0293 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>