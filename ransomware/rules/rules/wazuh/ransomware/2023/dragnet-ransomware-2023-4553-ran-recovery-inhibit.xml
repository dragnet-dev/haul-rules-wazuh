<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4553 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 146bdb8f-da32-5273-874e-e5ce3f60db1c -->
  <rule id="710518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4553 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>