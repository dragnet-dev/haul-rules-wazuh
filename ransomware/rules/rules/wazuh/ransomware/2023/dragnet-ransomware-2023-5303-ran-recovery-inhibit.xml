<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5303 — Recovery Inhibition (malekteam) | Status: experimental | Sigma ID: 57bdabcc-9bdf-58ce-ae1f-4ab6ee3be44b -->
  <rule id="284107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5303 — Recovery Inhibition (malekteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>