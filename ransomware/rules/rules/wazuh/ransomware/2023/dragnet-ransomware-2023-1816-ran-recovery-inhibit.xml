<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1816 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 432cc602-a5a9-555b-82f7-54fc904a9f48 -->
  <rule id="307966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1816 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>