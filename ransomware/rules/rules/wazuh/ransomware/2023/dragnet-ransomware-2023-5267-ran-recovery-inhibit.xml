<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5267 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 87879318-0562-5ed7-a005-2d0250904ae5 -->
  <rule id="787931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5267 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>