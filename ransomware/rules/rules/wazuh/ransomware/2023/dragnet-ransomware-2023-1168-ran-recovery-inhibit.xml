<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1168 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: fed14f68-6bec-5e75-89fd-92365d7dbd2f -->
  <rule id="323439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1168 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>