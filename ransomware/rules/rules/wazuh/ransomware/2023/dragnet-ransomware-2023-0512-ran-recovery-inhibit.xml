<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0512 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fbffc74d-ff4d-5f13-822b-9265657acd35 -->
  <rule id="232188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0512 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>