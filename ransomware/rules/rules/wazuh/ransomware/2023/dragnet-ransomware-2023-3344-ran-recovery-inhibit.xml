<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3344 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 05eb6417-5777-5bf2-ba45-1095403f849a -->
  <rule id="715641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3344 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>