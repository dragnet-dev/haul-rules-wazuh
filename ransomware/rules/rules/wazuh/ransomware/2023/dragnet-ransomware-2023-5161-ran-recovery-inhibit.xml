<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5161 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 0ae0ef76-a77e-5549-bd17-899b9af3ad5a -->
  <rule id="956797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5161 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
