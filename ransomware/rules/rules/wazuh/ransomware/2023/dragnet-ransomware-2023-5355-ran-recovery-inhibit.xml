<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5355 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: ae263c9a-06d3-55ab-a50a-af272d9a02a9 -->
  <rule id="188220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5355 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>