<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4922 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 1785f68e-4f13-542d-aad0-6d6676920513 -->
  <rule id="257568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4922 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>