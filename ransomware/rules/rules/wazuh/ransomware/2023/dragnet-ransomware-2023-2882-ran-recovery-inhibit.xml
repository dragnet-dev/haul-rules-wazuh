<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2882 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 3f9a3499-58e1-564f-a23c-bf5849fb7db5 -->
  <rule id="223434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2882 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>