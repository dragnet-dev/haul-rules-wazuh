<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1218 — Recovery Inhibition (rancoz) | Status: experimental | Sigma ID: c6f0bba5-8ac3-59f8-9cb6-1c16fe25c356 -->
  <rule id="799547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1218 — Recovery Inhibition (rancoz)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>