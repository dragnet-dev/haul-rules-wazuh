<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2196 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 65f7c57c-1980-57cb-962d-1039ce479a5d -->
  <rule id="889245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2196 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>