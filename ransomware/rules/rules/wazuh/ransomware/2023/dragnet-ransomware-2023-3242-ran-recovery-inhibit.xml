<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3242 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: bbaa42c1-9edd-5514-ab66-4682b08cd5f3 -->
  <rule id="404242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3242 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>