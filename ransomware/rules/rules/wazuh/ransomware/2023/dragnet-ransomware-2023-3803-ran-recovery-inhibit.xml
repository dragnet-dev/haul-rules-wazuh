<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3803 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9202adcd-f1b1-5166-818b-e5acfdf6e948 -->
  <rule id="655885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3803 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>