<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3971 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 963582bc-579d-56df-915d-32102efc7627 -->
  <rule id="217323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3971 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>