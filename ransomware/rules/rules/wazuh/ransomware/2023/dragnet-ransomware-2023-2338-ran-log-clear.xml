<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2338 — Event Log Clearing (darkrace) | Status: experimental | Sigma ID: 4f60e1e4-fbb5-5e6a-a812-ffdd7ae79cf9 -->
  <rule id="473741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2338 — Event Log Clearing (darkrace)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>