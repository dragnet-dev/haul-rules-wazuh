<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1556 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a15bf044-c08c-56c4-b06e-a5e19d9cab6e -->
  <rule id="900310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1556 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>