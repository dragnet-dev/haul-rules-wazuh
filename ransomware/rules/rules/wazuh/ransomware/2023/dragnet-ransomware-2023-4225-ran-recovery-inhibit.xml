<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4225 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 48d03996-d669-590a-a9d2-2f0289931001 -->
  <rule id="710399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4225 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>