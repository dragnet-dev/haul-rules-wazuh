<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5035 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c64bf4f-d48b-558c-9397-2ee652d881d3 -->
  <rule id="590975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5035 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>