<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3783 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 560e7339-0c0f-5bdd-835a-2a41c9e53144 -->
  <rule id="974733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3783 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>