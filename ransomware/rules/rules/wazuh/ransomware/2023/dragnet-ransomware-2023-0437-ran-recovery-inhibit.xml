<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0437 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ea192e08-156a-5527-a109-8ccb0b0ee4c7 -->
  <rule id="247086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0437 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>