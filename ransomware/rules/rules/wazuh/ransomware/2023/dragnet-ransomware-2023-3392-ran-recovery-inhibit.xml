<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3392 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a27e5ecd-fab4-56bf-b04f-e9e5d28464c8 -->
  <rule id="931454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3392 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>