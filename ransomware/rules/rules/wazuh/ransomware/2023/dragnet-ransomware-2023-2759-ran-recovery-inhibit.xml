<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2759 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: bf326a7b-f630-5a0b-96bd-e4c9266ff4cd -->
  <rule id="461226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2759 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>