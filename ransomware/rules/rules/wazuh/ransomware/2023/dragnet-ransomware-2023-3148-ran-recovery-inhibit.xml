<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3148 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7988b7b5-22d1-504c-a4a6-023ff513b4fb -->
  <rule id="478197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3148 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>