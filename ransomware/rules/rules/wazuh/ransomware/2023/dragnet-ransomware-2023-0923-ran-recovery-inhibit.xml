<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0923 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 17fa3636-5b0e-55e1-a3e6-f9277113db23 -->
  <rule id="202363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0923 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>