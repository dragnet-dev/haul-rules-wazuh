<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1517 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 094b6fe5-6e9d-5a68-bf1b-671e037aa85f -->
  <rule id="380190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1517 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>