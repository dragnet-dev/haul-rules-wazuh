<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1074 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: b3ee1318-16e5-5fbb-9b5c-2099e341949e -->
  <rule id="316613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1074 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>