<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0649 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8baaf24f-1ef3-5bf8-8bfd-eec67828c460 -->
  <rule id="420792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0649 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>