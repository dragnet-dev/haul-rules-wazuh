<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3888 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: e21ed0b5-a6c6-5b1d-9ff4-84bc75f5faba -->
  <rule id="140130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3888 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>