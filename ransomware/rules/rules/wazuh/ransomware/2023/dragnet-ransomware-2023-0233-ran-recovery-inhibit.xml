<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0233 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 780aa979-82c5-552d-a0ad-1017c1c5240d -->
  <rule id="298509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0233 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>