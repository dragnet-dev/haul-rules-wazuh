<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5374 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f065bdd1-80f7-539b-b905-4b90356d1687 -->
  <rule id="356829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5374 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>