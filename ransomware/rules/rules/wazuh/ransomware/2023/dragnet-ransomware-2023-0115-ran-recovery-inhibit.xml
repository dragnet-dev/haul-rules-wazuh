<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0115 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: b893d432-cb97-5023-9668-f04e9c35911f -->
  <rule id="203014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0115 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>