<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0106 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2d1bcd7d-4c34-5ff4-b3e3-938007fee48e -->
  <rule id="150317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0106 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>