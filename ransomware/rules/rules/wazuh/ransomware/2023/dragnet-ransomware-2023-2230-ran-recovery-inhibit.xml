<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2230 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b6dc3d7c-51be-5a71-b149-6d1493966d20 -->
  <rule id="386621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2230 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>