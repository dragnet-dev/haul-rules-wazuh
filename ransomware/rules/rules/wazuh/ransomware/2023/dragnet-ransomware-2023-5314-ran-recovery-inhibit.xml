<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5314 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7a15f585-9049-5d25-bc91-61de01ba4895 -->
  <rule id="254555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5314 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>