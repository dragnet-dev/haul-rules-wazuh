<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3077 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 260f2153-f588-5aae-8ad5-bb92434ca936 -->
  <rule id="675215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3077 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>