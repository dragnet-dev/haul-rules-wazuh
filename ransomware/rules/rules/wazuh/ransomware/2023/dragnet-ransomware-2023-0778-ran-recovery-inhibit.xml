<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0778 — Recovery Inhibition (coinbasecartel) | Status: experimental | Sigma ID: 2cf9463d-cd1d-5ba3-9d11-6763f0af1158 -->
  <rule id="999463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0778 — Recovery Inhibition (coinbasecartel)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>