<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0769 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: edaeeb19-58f1-5bf1-8a38-7cb07d22cd56 -->
  <rule id="376811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0769 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>