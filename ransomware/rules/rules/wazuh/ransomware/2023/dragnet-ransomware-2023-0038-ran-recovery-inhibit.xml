<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0038 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c5e8ee10-0cca-55e7-a662-701772c69f84 -->
  <rule id="758126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0038 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>