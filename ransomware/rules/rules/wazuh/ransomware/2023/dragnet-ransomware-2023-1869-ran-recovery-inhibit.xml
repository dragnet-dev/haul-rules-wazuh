<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1869 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cae5fd77-098b-5e40-9c66-722a9840ae36 -->
  <rule id="311293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1869 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>