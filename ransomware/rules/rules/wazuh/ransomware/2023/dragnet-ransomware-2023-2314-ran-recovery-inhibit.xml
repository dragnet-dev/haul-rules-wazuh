<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2314 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 6cd2e009-0506-5f76-ab8d-80cddcfeeb51 -->
  <rule id="186060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2314 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>