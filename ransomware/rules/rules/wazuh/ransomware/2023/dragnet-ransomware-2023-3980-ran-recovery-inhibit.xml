<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3980 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 77fa9bd0-2dbc-536c-b842-6be1f74bfa89 -->
  <rule id="594075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3980 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>