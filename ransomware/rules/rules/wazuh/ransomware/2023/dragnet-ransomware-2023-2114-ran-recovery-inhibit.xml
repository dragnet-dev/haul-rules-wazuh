<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2114 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 29ef5ad9-f3df-52bb-8570-2fbe3a11f481 -->
  <rule id="426170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2114 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>