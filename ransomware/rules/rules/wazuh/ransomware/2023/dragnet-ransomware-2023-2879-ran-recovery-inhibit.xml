<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2879 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 479813bd-e51e-508c-91a1-854572f61bf8 -->
  <rule id="577019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2879 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>