<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3193 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 12dda86b-5793-58a8-bfdf-307ca9f28ff5 -->
  <rule id="869886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3193 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>