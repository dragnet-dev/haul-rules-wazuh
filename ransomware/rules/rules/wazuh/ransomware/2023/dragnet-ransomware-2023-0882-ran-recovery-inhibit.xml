<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0882 — Recovery Inhibition (cuba) | Status: experimental | Sigma ID: aa217d2c-5c44-5ac6-a16d-f10cdc587a50 -->
  <rule id="123485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0882 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>