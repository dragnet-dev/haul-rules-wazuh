<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1993 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5a2eb77b-b41e-5586-a37c-5c7ba6d29579 -->
  <rule id="611477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1993 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
