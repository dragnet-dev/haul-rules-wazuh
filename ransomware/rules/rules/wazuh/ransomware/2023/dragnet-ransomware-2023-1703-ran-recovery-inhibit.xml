<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1703 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f9434b02-ae94-5786-8a0e-a93d8efe9a2c -->
  <rule id="850955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1703 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>