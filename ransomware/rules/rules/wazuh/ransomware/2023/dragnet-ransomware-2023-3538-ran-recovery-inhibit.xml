<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3538 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8eebf4ac-811e-5f37-a710-dca551e7aff0 -->
  <rule id="554074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3538 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>