<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2000 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 33c688b6-937b-5dd9-a46d-a315fd4e3091 -->
  <rule id="651019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2000 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>