<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5207 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6ab6653e-a66e-586e-9036-b66e3a23da15 -->
  <rule id="907665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5207 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>