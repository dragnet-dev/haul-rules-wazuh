<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0482 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 1d4d9771-5afa-57fc-8f32-bcc4b3f5d408 -->
  <rule id="317977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0482 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>