<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0836 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 5f43d1e3-2ad3-5257-89fc-316f9ba9997f -->
  <rule id="727011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0836 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>