<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0790 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 58267cd6-0e18-5fce-ac7e-22fc84d7f34e -->
  <rule id="616557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0790 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>