<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2600 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0c350013-9a28-507a-9db7-35c37e9a4573 -->
  <rule id="435001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2600 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>