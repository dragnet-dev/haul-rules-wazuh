<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0388 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 67dce33c-02da-55f6-9e60-a7e1b2259923 -->
  <rule id="179663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0388 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>