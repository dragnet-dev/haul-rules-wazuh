<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3754 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 883ec16f-7aa8-564a-b18d-7b659682e9c5 -->
  <rule id="562841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3754 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>