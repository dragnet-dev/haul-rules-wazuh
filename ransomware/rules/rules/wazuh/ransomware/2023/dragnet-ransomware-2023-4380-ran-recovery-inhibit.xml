<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4380 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: ba076a8b-323a-5375-b202-37e4e4427900 -->
  <rule id="377226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4380 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>