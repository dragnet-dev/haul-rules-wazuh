<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1269 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: abe4bf3f-323a-5aaf-9280-efd6c851eeeb -->
  <rule id="841215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1269 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>