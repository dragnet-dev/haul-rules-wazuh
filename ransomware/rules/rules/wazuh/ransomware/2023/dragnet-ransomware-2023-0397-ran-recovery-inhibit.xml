<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0397 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 8347eb80-b44a-5f12-8083-f8e154e8a37f -->
  <rule id="437067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0397 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>