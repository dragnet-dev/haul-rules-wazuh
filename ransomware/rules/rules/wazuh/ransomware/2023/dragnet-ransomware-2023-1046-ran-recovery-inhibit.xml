<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1046 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 218d4aaa-4ffc-5c6b-aa0d-f4906ca8b369 -->
  <rule id="963754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1046 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>