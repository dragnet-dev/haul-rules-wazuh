<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4172 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: cb3da4f1-4355-56f5-9340-96bf430f9974 -->
  <rule id="806664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4172 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>