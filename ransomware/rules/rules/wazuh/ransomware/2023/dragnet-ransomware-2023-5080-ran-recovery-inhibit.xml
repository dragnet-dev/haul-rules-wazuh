<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5080 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cc929178-344e-5cf4-881d-ec4fec4b4569 -->
  <rule id="349291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5080 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>