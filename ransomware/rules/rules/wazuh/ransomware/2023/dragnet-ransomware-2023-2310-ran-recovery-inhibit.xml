<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2310 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 73b60f5e-50da-5891-b01f-10ed5044d30f -->
  <rule id="187375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2310 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>