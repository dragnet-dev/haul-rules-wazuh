<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4459 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d349732e-7a74-54da-b6a5-301927b3290b -->
  <rule id="534973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4459 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>