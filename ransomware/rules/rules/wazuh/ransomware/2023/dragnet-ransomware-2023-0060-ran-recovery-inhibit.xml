<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0060 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 94bc6e6b-da89-59ec-b63c-a0c53e8c586a -->
  <rule id="380430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0060 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>