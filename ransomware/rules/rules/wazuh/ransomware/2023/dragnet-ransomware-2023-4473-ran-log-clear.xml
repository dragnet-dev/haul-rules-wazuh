<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4473 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: c35ce7f7-6a24-5fe5-bfe9-d9e1c823c95a -->
  <rule id="563667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4473 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>