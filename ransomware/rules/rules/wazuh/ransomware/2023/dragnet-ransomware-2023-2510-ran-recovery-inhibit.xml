<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2510 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 221a8b3b-34cb-548e-ae64-08df3ac36e0b -->
  <rule id="374993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2510 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>