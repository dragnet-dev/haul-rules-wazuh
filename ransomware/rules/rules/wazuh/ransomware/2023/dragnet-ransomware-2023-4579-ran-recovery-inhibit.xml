<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4579 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3af3dfd8-9221-5152-8d6d-c74a37267d61 -->
  <rule id="715071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4579 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>