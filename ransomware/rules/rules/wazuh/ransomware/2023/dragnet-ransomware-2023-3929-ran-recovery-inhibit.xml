<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3929 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9b7f0608-e13f-57db-80bd-f03b93d55a5c -->
  <rule id="792706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3929 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>