<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1519 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 41564049-dc9b-5dcc-b1d4-a2e995c5c650 -->
  <rule id="656404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1519 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>