<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3355 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 52b37481-af41-5418-8ad7-a0ec83a04445 -->
  <rule id="433748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3355 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>