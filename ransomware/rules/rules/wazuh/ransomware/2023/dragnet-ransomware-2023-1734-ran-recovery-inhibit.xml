<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1734 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a8fe9114-a5d0-5557-bba5-de9bfa63ee8f -->
  <rule id="190291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1734 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>