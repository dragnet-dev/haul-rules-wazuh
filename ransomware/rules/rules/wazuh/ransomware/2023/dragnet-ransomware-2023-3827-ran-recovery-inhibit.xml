<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3827 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: 5b4f6051-8298-584b-990c-c83d887954a3 -->
  <rule id="663960" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3827 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>