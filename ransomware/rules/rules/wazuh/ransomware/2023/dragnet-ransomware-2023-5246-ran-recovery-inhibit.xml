<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5246 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a954b4c3-7cc7-52aa-8fb1-cda4b2a3ac2e -->
  <rule id="952754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5246 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>