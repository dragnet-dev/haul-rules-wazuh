<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3688 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: af1980fe-a304-5f85-a9a5-954662e429ee -->
  <rule id="951980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3688 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>