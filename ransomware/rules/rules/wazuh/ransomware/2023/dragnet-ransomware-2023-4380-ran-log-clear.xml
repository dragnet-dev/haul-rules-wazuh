<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4380 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 43af7c6d-a674-54c1-83c0-7f45c7d7c79f -->
  <rule id="989404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4380 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>