<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1681 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9fbb4f20-df96-56f6-b449-c9582aee8b17 -->
  <rule id="342639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1681 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>