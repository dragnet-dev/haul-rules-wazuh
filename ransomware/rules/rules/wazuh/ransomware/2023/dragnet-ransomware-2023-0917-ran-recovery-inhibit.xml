<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0917 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2640e433-9df1-5c78-a43f-47edf656f591 -->
  <rule id="725443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0917 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>