<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4011 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 01e2428f-0907-5492-8283-4e31e905db7d -->
  <rule id="438863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4011 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>