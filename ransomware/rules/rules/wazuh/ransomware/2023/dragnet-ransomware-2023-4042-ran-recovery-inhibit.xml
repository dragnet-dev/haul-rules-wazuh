<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4042 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5fe7a3ba-56fb-5c69-9738-b8254f7b461a -->
  <rule id="755623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4042 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>