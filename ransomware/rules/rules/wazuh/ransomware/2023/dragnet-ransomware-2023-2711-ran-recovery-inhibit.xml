<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2711 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1caac593-c3f2-5df0-bc96-e5f23e8dd0c3 -->
  <rule id="374205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2711 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>