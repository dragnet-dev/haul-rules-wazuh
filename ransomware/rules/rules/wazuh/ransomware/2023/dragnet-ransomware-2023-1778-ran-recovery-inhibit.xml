<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1778 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 40d04119-e494-5330-81a6-a20d5bdc5755 -->
  <rule id="330411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1778 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>