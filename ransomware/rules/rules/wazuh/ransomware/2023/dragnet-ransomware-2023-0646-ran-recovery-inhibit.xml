<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0646 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8e16cd12-4696-57f4-aa51-0c7cdd42af1a -->
  <rule id="139501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0646 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>