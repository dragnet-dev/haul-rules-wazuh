<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0434 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4489b357-8b2c-59d0-8d27-524cbfc6d58f -->
  <rule id="983535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0434 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>