<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2035 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3df30ab8-84f0-57bf-989a-9bd167764f07 -->
  <rule id="786090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2035 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>