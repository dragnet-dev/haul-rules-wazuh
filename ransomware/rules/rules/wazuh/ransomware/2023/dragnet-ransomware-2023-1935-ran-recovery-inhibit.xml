<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1935 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 59a2a683-095e-5ec5-a264-d4cbc9754b6e -->
  <rule id="726826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1935 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>