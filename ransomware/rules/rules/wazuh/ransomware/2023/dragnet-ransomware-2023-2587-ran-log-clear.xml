<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2587 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 1c5c0a1e-2374-5d27-ab80-13071b9b8ef7 -->
  <rule id="215301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2587 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>