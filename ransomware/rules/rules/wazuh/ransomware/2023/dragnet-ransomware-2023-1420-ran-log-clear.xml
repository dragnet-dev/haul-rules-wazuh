<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1420 — Event Log Clearing (medusalocker) | Status: experimental | Sigma ID: 1c08663d-5331-59e5-8a0e-efc3b4cbd76d -->
  <rule id="208663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1420 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>