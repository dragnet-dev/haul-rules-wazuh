<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2926 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 20150e53-785e-5797-9f3f-be342c129706 -->
  <rule id="624145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2926 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>