<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2746 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: e4a4de6d-b9e7-5a4c-af1e-750d90bed04b -->
  <rule id="625086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2746 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>