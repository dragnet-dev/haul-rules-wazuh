<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2979 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3a6e044c-d470-585c-bc3a-f1d9cb7753d9 -->
  <rule id="490044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2979 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>