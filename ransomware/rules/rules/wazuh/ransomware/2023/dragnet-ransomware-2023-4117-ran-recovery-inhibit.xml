<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4117 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e7a52919-2014-5c28-9423-d460c7829229 -->
  <rule id="662529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4117 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>