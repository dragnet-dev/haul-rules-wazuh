<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1574 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 11703073-0026-5359-ba19-f97c559b05b3 -->
  <rule id="370307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1574 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>