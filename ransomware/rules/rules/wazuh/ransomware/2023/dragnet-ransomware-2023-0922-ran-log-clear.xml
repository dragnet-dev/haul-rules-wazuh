<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0922 — Event Log Clearing (ransomhouse) | Status: deprecated | Sigma ID: 7d04aa42-5bd4-589e-970c-25fe99d192e5 -->
  <rule id="601194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0922 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>