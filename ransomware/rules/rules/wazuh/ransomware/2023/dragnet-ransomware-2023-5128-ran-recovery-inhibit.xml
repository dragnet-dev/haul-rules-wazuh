<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5128 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: fed617aa-5414-52b3-8bd6-66162801c79f -->
  <rule id="577617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5128 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>