<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2047 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: a5a18c0d-8197-532b-9070-c6eadfef7c6c -->
  <rule id="104300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2047 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>