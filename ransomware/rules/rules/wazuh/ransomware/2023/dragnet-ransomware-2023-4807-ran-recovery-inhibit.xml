<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4807 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0228fa29-7b1b-5475-9a1f-9f05305dd6ed -->
  <rule id="561829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4807 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>