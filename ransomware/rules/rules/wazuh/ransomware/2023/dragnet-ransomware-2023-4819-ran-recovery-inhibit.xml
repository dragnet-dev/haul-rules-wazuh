<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4819 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 0d34c333-1b15-5e9c-ac20-bdef6e8cd50f -->
  <rule id="435633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4819 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>