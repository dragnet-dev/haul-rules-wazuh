<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3855 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 2ca1e3ad-52e8-53c0-80ff-43cb42b2e5ec -->
  <rule id="342703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3855 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>