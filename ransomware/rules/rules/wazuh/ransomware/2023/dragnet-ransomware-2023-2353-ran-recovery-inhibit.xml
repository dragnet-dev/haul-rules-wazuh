<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2353 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: da38d416-f03b-5f9c-894a-9d6b52eba8d9 -->
  <rule id="894214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2353 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>