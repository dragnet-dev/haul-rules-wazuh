<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0747 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6ca01166-8fff-5ce6-a700-82d14659ba19 -->
  <rule id="938011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0747 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>