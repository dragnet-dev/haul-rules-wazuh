<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4387 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fc5e1f7b-bee2-5461-b3f8-0a9b66ef32f8 -->
  <rule id="266271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4387 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>