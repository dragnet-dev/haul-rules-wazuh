<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4777 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f295c74d-7514-56fe-89d7-f952ceedb921 -->
  <rule id="747327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4777 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>