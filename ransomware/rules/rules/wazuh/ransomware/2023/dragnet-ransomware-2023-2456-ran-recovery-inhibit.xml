<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2456 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: 535be506-e8ed-5a28-9735-f5ef12cf58f4 -->
  <rule id="571505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2456 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>