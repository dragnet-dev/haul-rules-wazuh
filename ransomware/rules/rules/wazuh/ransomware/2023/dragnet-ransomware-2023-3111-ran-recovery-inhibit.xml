<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3111 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 5394c4b5-2b37-57de-af41-5d0ede37814f -->
  <rule id="410635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3111 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>