<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0122 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6dfd553c-64bf-5fde-acab-3f67de73d9c2 -->
  <rule id="215755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0122 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>