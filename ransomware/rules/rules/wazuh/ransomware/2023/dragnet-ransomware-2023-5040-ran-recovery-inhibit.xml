<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5040 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d92529a0-ae73-59e2-9316-5840804fed54 -->
  <rule id="592529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5040 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>