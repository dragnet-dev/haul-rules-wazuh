<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4816 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: 5302385a-9fbd-51ee-96dc-8c44abe5e8b2 -->
  <rule id="902385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4816 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>