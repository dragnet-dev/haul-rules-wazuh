<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2627 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 38630cde-a592-5eea-88d4-5251b7419d74 -->
  <rule id="989485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2627 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>