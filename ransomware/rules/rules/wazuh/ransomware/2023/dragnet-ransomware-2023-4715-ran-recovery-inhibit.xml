<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4715 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5dde5ea5-5872-5d9c-beea-40f01e111ebb -->
  <rule id="344894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4715 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>