<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1954 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 97cbd45d-e237-5088-b3f2-43415ec35aa6 -->
  <rule id="505734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1954 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>