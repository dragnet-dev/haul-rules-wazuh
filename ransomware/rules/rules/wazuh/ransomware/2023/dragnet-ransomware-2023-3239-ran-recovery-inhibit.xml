<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3239 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 890acf94-5123-5544-83cf-2d85ddfe754e -->
  <rule id="148207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3239 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>