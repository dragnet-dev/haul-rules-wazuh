<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5365 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 11786dce-0efb-527b-ba5f-5119bee80ca7 -->
  <rule id="417436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5365 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>