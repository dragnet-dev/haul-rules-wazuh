<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4581 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4d9f09b1-90f2-58c0-8f1a-406ebf9445cf -->
  <rule id="447909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4581 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>