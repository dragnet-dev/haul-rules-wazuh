<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2562 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d1bfc70e-b12f-5810-a80d-57bf563b3d7a -->
  <rule id="996447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2562 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>