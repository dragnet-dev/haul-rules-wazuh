<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3273 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 99eb43b5-25d0-5304-8f7b-dfa6c1993f23 -->
  <rule id="857943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3273 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>