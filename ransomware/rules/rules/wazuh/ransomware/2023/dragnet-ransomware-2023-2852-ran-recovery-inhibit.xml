<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2852 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 1d8b366f-e293-53cd-b544-aa347abfbc89 -->
  <rule id="379366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2852 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>