<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1399 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 72d77a37-3617-5606-bc73-079ed0fde9a7 -->
  <rule id="165242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1399 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>