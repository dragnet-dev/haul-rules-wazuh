<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2994 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 1d4021f4-9d4b-5f27-b87d-96832fa40f44 -->
  <rule id="304351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2994 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>