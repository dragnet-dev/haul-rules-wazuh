<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3628 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 90207f2f-c429-517c-bb6b-9e0646f7dfeb -->
  <rule id="643327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3628 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>