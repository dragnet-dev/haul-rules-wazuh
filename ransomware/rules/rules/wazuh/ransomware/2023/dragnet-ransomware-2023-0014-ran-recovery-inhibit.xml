<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0014 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: ae032836-db66-5900-b101-c67044a840d2 -->
  <rule id="940328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0014 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>