<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1219 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: db470c1e-5bbb-5b55-b815-365478dc6c83 -->
  <rule id="911532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1219 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>