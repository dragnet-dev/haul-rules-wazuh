<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2720 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: 3cc3baf2-4268-533d-9233-c9ca87e084a3 -->
  <rule id="789274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2720 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>