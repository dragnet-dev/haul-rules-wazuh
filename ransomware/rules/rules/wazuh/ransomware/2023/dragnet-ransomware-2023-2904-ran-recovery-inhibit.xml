<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2904 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 4ef590ae-bc31-55cd-a9d1-236a331db834 -->
  <rule id="463590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2904 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>