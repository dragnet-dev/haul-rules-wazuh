<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4016 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e5de953f-fc6b-58e7-b154-5e8a4f335b58 -->
  <rule id="234295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4016 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>