<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4983 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9182b92a-82dd-508b-8d65-c7977ddd0834 -->
  <rule id="669239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4983 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>