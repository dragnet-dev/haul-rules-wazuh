<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2633 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 2234f86e-2317-5df8-a361-7d00fb8266c6 -->
  <rule id="975986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2633 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>