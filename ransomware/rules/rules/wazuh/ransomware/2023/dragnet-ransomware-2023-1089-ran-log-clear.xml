<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1089 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: 1fdb40a2-31c9-50f1-a9e1-7f18d2dacd70 -->
  <rule id="548650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1089 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>