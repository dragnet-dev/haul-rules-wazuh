<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0783 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: da1696d2-d01e-55d9-a7e4-1879cabbeb93 -->
  <rule id="481696" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0783 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>