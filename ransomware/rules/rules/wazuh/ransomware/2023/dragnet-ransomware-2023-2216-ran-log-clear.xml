<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2216 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: 30870ca4-40b7-59f7-aef0-b93e0dc8daf0 -->
  <rule id="802922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2216 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>