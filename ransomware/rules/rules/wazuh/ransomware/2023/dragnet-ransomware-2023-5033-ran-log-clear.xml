<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5033 — Event Log Clearing (play) | Status: deprecated | Sigma ID: 2d24fe37-9ac4-50c3-a06c-70b4c1a71c40 -->
  <rule id="358398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5033 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>