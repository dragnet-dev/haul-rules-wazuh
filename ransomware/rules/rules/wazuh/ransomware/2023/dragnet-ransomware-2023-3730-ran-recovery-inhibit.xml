<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3730 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 536743bc-6feb-5ec8-98ea-605722ea31af -->
  <rule id="587899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3730 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>