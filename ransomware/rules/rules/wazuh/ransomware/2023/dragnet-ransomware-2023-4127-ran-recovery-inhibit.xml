<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4127 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e1b3bc58-dd06-579b-8b9e-b9dfcde1b140 -->
  <rule id="504476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4127 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>