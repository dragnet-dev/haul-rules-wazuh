<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5102 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 7788bb5e-9a23-5de5-bead-f240a8dd6e63 -->
  <rule id="293915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5102 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>