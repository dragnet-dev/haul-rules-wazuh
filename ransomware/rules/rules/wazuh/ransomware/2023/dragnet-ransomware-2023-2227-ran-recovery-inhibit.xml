<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2227 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8560a6b1-e6d7-548d-9815-54bab55bfdce -->
  <rule id="569706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2227 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>