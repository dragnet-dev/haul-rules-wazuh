<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1278 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9aabc513-18e7-5048-92ee-90adfba8c1c0 -->
  <rule id="135325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1278 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>