<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0193 — Recovery Inhibition (darkpower) | Status: experimental | Sigma ID: b21c92ac-f6a5-5e1a-b8d8-1e05983c28fa -->
  <rule id="994892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0193 — Recovery Inhibition (darkpower)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>