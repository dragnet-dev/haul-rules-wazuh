<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0719 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 43e31207-b35b-5d74-b3a8-5216aa4aadc8 -->
  <rule id="823120" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0719 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>