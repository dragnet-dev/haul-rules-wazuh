<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1482 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 3010b8bd-3789-5a39-b524-b1ae0396e085 -->
  <rule id="607499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1482 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>