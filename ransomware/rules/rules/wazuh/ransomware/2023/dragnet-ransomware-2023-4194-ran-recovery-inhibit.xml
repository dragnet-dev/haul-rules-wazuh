<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4194 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1a4f7a59-4472-51f9-99bf-f6eaa2ad386f -->
  <rule id="583625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4194 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>