<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1601 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 13369ad4-2d50-58a1-aae3-abaa3ab297df -->
  <rule id="822637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1601 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>