<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3923 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 198aa8c8-a546-5fea-afba-918a43046413 -->
  <rule id="137420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3923 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>