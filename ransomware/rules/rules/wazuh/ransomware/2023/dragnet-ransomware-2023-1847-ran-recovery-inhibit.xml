<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1847 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 261d2245-70f4-50ec-a2de-561f033bbf9c -->
  <rule id="689224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1847 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>