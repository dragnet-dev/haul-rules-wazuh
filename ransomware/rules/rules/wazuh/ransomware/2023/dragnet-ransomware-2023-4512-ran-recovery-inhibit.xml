<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4512 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 6eee0fb2-83a0-5051-aaef-37b731670d4a -->
  <rule id="143695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4512 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>