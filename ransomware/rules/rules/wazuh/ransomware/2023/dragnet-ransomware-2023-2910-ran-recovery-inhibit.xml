<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2910 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d3ffd8f1-a378-5280-b09e-6885874cbd69 -->
  <rule id="188618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2910 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>