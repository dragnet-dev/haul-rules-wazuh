<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1626 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5b07106b-b5cc-540f-bf23-27e7664ee52b -->
  <rule id="207106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1626 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>