<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3229 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 76725ad6-54f0-5423-8f42-b846af0023ef -->
  <rule id="427610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3229 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>