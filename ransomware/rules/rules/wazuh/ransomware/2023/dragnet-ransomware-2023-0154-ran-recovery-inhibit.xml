<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0154 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a009c840-0ac9-5512-9322-2a0e7625f7a7 -->
  <rule id="801568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0154 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>