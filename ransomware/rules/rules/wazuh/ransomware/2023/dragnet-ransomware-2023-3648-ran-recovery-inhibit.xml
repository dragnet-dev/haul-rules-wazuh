<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3648 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 38ffc96e-7251-52ec-91e6-7e65a9dba133 -->
  <rule id="797409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3648 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>