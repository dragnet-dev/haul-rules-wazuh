<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5330 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 278c950a-83cd-56e0-b2ad-4a033f94cf5f -->
  <rule id="960950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5330 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>