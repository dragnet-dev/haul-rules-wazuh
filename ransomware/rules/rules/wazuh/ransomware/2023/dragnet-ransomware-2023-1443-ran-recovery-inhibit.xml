<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1443 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7ab231f9-9f8a-53b9-beba-6950b82dd8ca -->
  <rule id="263231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1443 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>