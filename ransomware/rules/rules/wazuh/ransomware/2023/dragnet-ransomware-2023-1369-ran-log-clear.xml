<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1369 — Event Log Clearing (mallox) | Status: deprecated | Sigma ID: 8956b166-2821-59cc-9dd5-2f0961360dda -->
  <rule id="633071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1369 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>