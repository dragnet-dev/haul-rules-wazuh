<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3547 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 85b606e1-ad0b-50f5-8598-bcde9072a673 -->
  <rule id="571606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3547 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>