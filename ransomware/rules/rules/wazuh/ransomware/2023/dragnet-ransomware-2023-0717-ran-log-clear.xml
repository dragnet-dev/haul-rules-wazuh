<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0717 — Event Log Clearing (0mega) | Status: deprecated | Sigma ID: 6db6fc6d-b908-5939-84f5-f65470708a65 -->
  <rule id="994588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0717 — Event Log Clearing (0mega)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>