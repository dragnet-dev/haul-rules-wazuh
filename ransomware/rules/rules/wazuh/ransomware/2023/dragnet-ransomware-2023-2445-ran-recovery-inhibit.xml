<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2445 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f9988f0d-c8cf-55dd-8f8e-3481e38bb2a5 -->
  <rule id="859823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2445 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>