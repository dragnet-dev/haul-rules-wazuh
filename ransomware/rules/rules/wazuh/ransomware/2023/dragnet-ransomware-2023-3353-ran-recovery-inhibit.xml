<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3353 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8cd3eca3-0a0b-5223-aa6d-1f40a4b3fee2 -->
  <rule id="468684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3353 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>