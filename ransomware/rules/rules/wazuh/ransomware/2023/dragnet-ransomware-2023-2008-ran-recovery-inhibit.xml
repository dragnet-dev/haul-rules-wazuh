<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2008 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8c63cce9-8164-5140-a98e-09f2e6364303 -->
  <rule id="100332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2008 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>