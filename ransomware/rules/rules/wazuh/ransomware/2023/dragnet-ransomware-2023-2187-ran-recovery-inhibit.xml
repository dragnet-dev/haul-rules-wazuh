<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2187 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c5c26607-cca7-559a-8714-58742cd9910d -->
  <rule id="312266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2187 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>