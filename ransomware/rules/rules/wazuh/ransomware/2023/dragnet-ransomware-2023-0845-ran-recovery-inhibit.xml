<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0845 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8d4f3968-18d6-5053-bd71-e59b3345e281 -->
  <rule id="563939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0845 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>