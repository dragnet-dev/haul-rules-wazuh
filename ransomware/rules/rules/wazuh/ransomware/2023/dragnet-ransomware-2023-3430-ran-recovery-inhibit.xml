<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3430 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: f601bcc2-9935-50f7-9aff-94c4819b76d7 -->
  <rule id="494044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3430 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>