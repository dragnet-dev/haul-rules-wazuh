<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3488 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 09ab93a7-54b4-56a7-a924-3bc8867b14f3 -->
  <rule id="461498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3488 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>