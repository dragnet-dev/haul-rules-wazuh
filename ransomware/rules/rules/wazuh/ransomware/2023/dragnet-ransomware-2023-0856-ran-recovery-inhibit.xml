<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0856 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: da2be031-40ae-5f15-b1de-61bc2252d28d -->
  <rule id="287820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0856 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>