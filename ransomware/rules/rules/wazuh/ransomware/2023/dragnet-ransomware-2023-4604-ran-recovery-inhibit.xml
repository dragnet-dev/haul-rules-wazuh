<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4604 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ce55ffa0-8ae9-5526-9def-a51d46b06ec2 -->
  <rule id="887935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4604 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
