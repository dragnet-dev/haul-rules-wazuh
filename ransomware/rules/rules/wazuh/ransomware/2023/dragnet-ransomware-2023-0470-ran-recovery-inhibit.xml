<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0470 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3c5a3f59-f9c7-5551-9206-a2d59b0c9038 -->
  <rule id="750463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0470 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
