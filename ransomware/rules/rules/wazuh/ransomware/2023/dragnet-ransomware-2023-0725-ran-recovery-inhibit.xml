<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0725 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: cbd638cc-d37d-5e04-bb60-e488e76cf939 -->
  <rule id="661638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0725 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>