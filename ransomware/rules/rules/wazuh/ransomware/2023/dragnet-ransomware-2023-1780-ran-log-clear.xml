<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1780 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 048bac36-37e1-54e2-895a-4d33fbc99cc8 -->
  <rule id="295963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1780 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>