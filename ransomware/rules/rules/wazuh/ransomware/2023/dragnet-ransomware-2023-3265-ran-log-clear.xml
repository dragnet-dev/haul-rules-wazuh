<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3265 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 1dff4e61-e99f-5bb4-b77f-39e7b5d9a0a1 -->
  <rule id="428718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3265 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>