<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2962 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8633ff98-2a28-5755-b1c4-97017405f8bc -->
  <rule id="510303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2962 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>