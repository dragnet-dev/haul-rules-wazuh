<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1778 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 6b6b7a3b-3acf-5db5-a1d1-35131b0b51fa -->
  <rule id="156442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1778 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>