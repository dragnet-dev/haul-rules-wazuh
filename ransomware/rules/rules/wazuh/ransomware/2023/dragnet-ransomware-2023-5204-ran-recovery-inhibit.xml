<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5204 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: b8668799-ab04-5371-ab11-2f57bc512e20 -->
  <rule id="386687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5204 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>