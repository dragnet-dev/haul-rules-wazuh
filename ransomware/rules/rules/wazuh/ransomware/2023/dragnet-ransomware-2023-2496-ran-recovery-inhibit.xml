<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2496 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 2d7b2e3b-0496-553f-b605-5a03865da2f9 -->
  <rule id="371726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2496 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>