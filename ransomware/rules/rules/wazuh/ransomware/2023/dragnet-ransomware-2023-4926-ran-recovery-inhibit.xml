<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4926 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 9496308a-b0a6-5b1f-b033-9caed157a882 -->
  <rule id="596308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4926 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>