<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2672 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 17159d0c-17bc-5737-9fb7-06d5aca1b8e5 -->
  <rule id="145570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2672 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>