<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1546 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d7bb5dc0-a92a-57fe-83cf-031d89c6a5ec -->
  <rule id="341533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1546 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>