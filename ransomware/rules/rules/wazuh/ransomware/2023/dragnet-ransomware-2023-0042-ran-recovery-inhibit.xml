<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0042 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1278269c-f5ca-5811-9696-b39d7cc1b989 -->
  <rule id="478269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0042 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>