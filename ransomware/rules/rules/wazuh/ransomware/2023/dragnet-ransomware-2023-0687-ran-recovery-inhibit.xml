<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0687 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 17377f58-8943-5b2d-b459-539bbab717c2 -->
  <rule id="180475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0687 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>