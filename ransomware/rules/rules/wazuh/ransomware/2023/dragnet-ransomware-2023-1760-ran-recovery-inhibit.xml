<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1760 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 24a243df-3058-53e4-9114-6607d437d3a6 -->
  <rule id="107901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1760 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>