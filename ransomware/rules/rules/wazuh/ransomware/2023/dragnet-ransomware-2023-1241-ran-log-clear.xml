<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1241 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 534285e8-f4f4-5657-a322-55eaffd2b2e7 -->
  <rule id="548574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1241 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>