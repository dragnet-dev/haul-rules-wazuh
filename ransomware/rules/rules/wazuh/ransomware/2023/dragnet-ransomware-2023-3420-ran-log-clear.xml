<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3420 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 3abec9ce-7313-5dbc-81fd-3ca7f2d59f12 -->
  <rule id="706209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3420 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>