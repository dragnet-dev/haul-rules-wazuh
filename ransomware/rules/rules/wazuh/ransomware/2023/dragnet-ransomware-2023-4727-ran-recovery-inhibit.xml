<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4727 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d609b759-14f1-556f-a84a-aaf96e1390a7 -->
  <rule id="477557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4727 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>