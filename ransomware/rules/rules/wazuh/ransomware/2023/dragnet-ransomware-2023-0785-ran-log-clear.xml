<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0785 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 6b730c0e-46f4-5b42-b745-4a8ed4ec9ca1 -->
  <rule id="923692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0785 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>