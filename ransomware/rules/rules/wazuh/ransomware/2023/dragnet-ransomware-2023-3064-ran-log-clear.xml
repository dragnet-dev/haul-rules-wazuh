<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3064 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 9899e23a-dd3e-5780-8c4a-c79be071ebb7 -->
  <rule id="783982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3064 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>