<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3994 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 84da095a-8dc1-5554-b86e-4743921dc216 -->
  <rule id="472209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3994 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>