<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1697 — Recovery Inhibition (mallox) | Status: deprecated | Sigma ID: 650c464e-726f-51b1-bf48-264525446f57 -->
  <rule id="241246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1697 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>