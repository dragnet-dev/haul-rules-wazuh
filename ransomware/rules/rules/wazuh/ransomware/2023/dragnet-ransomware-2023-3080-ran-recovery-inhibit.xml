<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3080 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 121bc9a8-d6fb-530a-95e2-5e3b62afa4d6 -->
  <rule id="586394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3080 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>