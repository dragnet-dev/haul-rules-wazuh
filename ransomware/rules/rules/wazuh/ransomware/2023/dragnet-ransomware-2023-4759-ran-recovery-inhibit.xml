<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4759 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 60f6fc17-3945-5b39-bd90-f96959b2baa1 -->
  <rule id="797788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4759 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>