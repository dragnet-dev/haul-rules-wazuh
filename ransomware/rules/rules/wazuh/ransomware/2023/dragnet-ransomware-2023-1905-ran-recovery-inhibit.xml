<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1905 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 6fcbdbe4-18ec-582c-a8be-f0aa4ecd62f3 -->
  <rule id="226683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1905 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>