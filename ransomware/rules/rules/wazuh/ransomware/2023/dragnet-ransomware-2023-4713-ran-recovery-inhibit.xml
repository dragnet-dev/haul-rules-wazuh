<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4713 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f037513a-8e6e-558d-8141-51e9b70862f3 -->
  <rule id="703751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4713 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>