<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4407 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3a224cce-5f28-5243-a3b8-466a3cf93312 -->
  <rule id="605548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4407 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>