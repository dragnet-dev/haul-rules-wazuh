<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1098 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 09c55fab-76ac-5d64-96dd-0792861e9c52 -->
  <rule id="507930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1098 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>