<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1898 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 15572bc1-f792-57b2-8467-5eb6690e72fb -->
  <rule id="486620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1898 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>