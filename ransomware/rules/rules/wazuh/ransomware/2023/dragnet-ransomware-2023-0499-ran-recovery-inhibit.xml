<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0499 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 36fad362-ea7e-5144-9d09-c104e22eb409 -->
  <rule id="714693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0499 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>