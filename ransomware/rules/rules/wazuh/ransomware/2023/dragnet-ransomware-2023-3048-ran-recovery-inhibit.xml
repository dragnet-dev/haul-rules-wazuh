<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3048 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: be2b15e9-0de5-5e21-b54d-6f3e42a3803a -->
  <rule id="444315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3048 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>