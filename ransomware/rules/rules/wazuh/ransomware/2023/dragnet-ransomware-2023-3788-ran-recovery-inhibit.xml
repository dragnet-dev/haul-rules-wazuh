<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3788 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 353450d1-f006-5a90-b114-8adc5a550595 -->
  <rule id="355213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3788 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>