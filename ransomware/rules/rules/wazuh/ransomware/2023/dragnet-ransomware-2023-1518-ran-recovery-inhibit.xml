<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1518 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e855a129-a3b3-5f03-907e-ad62ed6b1741 -->
  <rule id="676901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1518 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>