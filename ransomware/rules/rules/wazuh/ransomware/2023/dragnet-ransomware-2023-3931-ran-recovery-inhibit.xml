<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3931 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a699a662-5b41-5480-add6-8e6b77ec638a -->
  <rule id="911946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3931 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>