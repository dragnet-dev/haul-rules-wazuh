<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1127 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4d0082ab-2c81-5dd0-8add-da813f459704 -->
  <rule id="721322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1127 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>