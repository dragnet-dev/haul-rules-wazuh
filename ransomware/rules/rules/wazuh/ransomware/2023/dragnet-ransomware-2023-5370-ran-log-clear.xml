<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5370 — Event Log Clearing (cryptbb) | Status: experimental | Sigma ID: fb22f8fe-19e4-5a24-8c8a-5e3fabd5dbd2 -->
  <rule id="519678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5370 — Event Log Clearing (cryptbb)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>