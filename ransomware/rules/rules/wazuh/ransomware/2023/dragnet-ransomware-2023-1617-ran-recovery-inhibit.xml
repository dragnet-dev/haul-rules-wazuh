<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1617 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 202807e8-8fe1-56ab-acc9-379d7be4e3b8 -->
  <rule id="644926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1617 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>