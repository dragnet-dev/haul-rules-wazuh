<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1020 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 66ac2a5f-388b-5894-ac31-468c8fdcc07d -->
  <rule id="130922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1020 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>