<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3715 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3613a8f7-a068-54fc-b8fb-d5f01610498b -->
  <rule id="351023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3715 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>