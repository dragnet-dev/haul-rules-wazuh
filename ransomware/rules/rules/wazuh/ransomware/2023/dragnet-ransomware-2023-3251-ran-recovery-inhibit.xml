<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3251 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 01a41091-ae54-55ca-9a74-eecbbcdeb744 -->
  <rule id="941091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3251 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>