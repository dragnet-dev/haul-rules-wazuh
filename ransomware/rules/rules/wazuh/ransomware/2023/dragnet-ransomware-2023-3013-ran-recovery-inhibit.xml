<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3013 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: ff69b7ea-dfa0-5007-af72-68084e781fbd -->
  <rule id="591157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3013 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
