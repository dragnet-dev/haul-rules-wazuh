<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3616 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e9d22d53-202c-56dc-ba40-980c6c0bfe5a -->
  <rule id="335565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3616 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>