<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0427 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: b0735e2a-9ef6-52f4-9731-caae8555b0e8 -->
  <rule id="971774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0427 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>