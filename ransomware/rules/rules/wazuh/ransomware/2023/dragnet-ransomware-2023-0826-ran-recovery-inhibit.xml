<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0826 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 58bacf44-7145-509b-a55a-021462b3ccd6 -->
  <rule id="348911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0826 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>