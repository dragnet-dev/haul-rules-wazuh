<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3124 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: bfa6def6-cfda-5f89-bb2e-a86d20fd346a -->
  <rule id="750718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3124 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>