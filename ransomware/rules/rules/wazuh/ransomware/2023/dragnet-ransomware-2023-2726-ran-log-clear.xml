<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2726 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 796c4be2-9ce5-5fde-be06-ef6115bf51f8 -->
  <rule id="339755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2726 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>