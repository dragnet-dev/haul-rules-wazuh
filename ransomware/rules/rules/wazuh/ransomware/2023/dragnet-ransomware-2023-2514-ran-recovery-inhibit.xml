<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2514 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 75d923aa-36af-5216-8aa4-fbeffb0c9133 -->
  <rule id="413923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2514 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>