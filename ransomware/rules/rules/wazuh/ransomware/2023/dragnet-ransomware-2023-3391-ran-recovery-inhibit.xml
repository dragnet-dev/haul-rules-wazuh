<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3391 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 375bafa0-36ce-5069-8866-da0fe60091d6 -->
  <rule id="738991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3391 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>