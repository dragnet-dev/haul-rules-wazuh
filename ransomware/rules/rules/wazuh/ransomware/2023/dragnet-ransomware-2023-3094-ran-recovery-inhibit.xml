<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3094 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3fccdbc6-3509-512f-8889-0504930aa30b -->
  <rule id="681211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3094 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>