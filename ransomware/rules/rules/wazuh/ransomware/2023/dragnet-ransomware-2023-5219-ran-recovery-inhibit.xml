<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5219 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e4ecdb50-448e-534d-9be2-59acdd8def4f -->
  <rule id="597819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5219 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>