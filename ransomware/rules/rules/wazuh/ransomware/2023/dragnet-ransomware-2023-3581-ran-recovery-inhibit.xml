<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3581 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 1d3615ba-3365-5c53-8997-e87edf7596db -->
  <rule id="297851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3581 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>