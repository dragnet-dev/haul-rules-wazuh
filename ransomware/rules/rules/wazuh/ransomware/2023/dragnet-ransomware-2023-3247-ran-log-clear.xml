<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3247 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 9c8d36a0-8fd9-53ff-b401-b0e3b6a231f7 -->
  <rule id="810136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3247 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>