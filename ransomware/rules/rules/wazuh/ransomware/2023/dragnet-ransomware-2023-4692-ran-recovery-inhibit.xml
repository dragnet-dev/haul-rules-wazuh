<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4692 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 049809a5-7d2a-52f6-b9cb-4274399ba5ae -->
  <rule id="869545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4692 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>