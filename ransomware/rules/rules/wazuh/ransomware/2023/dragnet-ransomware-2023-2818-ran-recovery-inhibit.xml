<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2818 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 02f38a7c-61d4-5837-9893-1586994168c1 -->
  <rule id="531004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2818 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>