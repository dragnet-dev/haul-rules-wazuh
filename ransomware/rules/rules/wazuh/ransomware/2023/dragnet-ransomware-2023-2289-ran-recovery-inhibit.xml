<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2289 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 28009dcd-8889-54b9-b12d-432e30d1fcc4 -->
  <rule id="970524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2289 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>