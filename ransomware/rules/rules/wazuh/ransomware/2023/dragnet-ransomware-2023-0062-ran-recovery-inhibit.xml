<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0062 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: aae58b29-3bfd-59da-b0fd-0f7788f7e72c -->
  <rule id="875339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0062 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>