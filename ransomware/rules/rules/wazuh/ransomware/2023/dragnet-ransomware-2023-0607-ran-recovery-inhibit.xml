<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0607 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 4ac33ff2-3b9c-5237-a00b-c9566faabe7a -->
  <rule id="214143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0607 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>