<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3953 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f8eca2b7-5960-56d8-8265-bdbfb0b01a3c -->
  <rule id="309542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3953 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>