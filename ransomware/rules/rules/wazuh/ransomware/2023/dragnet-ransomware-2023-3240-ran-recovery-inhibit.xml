<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3240 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4dd1070f-accd-58d6-be2a-6ed8a92362ec -->
  <rule id="445107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3240 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>