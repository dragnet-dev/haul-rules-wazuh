<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1590 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 6b44ad48-e7e8-5915-a41d-a864dd25a49a -->
  <rule id="150637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1590 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>