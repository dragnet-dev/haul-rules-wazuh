<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5215 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9ecf78f9-efb3-50cb-bd07-be596217940d -->
  <rule id="565578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5215 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>