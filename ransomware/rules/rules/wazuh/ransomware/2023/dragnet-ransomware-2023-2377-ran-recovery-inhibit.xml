<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2377 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bbc908b3-5f91-5d76-b284-1dedc4e39e9a -->
  <rule id="404908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2377 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>