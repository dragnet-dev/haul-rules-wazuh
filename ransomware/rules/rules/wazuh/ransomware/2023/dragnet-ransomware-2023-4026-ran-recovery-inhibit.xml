<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4026 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5b74bee5-da15-5a3c-805b-ff1086b7b2c4 -->
  <rule id="648734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4026 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>