<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0285 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f5cd9458-39a4-5305-8a7c-511aafa82437 -->
  <rule id="488594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0285 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>