<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0095 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cb9dee03-ad52-5067-900a-3d05cfecaf03 -->
  <rule id="355310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0095 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>