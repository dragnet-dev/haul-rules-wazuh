<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2652 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 1c0f24e2-b0c2-55b3-92c8-b6f04c4f5b06 -->
  <rule id="992398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2652 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>