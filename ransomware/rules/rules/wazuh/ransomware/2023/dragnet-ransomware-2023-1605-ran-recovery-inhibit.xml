<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1605 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: cabc959d-8dce-5d67-b808-ccf7c40bb25c -->
  <rule id="790095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1605 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>