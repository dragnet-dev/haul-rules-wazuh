<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2168 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 91cc9176-e303-5049-8e3b-92d6486ae2ab -->
  <rule id="650091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2168 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>