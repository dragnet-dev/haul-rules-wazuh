<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0623 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 852d1bcf-f8cf-5f8c-8b4c-7cd636ebc1ef -->
  <rule id="483227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0623 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>