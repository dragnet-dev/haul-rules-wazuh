<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3631 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d4ec461c-1c2e-5454-b36b-eebe631c24c5 -->
  <rule id="854046" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3631 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>