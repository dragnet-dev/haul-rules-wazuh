<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4876 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dea147bd-a4d6-5dda-9f06-941b6e2ad220 -->
  <rule id="962147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4876 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>