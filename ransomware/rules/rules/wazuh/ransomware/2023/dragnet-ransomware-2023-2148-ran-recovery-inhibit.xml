<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2148 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0a291605-4b34-5b17-b3b4-22100f146563 -->
  <rule id="229160" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2148 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>