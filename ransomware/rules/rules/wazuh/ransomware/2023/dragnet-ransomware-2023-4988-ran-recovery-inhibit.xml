<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4988 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 8f8daa13-ca8e-501d-bf8f-a5b1eec505d3 -->
  <rule id="593546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4988 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>