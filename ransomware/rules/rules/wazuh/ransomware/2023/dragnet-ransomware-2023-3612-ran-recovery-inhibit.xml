<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3612 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 63da2344-68bd-570c-afae-5a2f3dcb17d8 -->
  <rule id="834623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3612 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>