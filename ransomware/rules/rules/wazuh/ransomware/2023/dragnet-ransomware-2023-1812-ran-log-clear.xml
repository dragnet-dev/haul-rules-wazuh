<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1812 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: c88ce000-7d6e-5ee5-bc5c-339fef65152f -->
  <rule id="699340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1812 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>