<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2601 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0e182304-2e3f-515a-84fc-db1ebdd342bc -->
  <rule id="618230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2601 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>