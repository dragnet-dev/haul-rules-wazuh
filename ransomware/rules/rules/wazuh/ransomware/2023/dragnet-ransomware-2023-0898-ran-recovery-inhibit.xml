<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0898 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7b7e035e-cf1d-5977-bea4-8d4030610867 -->
  <rule id="280603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0898 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>