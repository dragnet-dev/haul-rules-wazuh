<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1751 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 467cb477-53d7-5a30-a00d-a2fad6a35719 -->
  <rule id="397554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1751 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>