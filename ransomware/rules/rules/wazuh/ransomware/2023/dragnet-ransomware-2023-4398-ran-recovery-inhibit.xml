<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4398 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 6594e200-861c-5db9-ae6b-a42e247bf74f -->
  <rule id="255182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4398 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>