<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0087 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3864649c-d911-51bf-b393-095a4b7f56fa -->
  <rule id="364649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0087 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>