<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3049 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4054e8e0-21b8-5e94-8cb5-7cad4c392d0c -->
  <rule id="580622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3049 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>