<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0230 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e156d6fe-b22d-5d5b-8514-7880b2133a36 -->
  <rule id="565096" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0230 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>