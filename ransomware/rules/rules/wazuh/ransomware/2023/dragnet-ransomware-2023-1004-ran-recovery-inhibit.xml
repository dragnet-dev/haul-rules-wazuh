<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1004 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 81eabef8-a30c-5724-9add-433afa254b94 -->
  <rule id="968510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1004 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>