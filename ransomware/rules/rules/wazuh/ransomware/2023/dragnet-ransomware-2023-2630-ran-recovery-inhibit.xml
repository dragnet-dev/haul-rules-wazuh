<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2630 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 177a2f10-15ed-5486-917e-275b38d1426c -->
  <rule id="147671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2630 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>