<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2074 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 09d82c8f-1ccc-5eca-b77c-90e52460d51c -->
  <rule id="825248" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2074 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>