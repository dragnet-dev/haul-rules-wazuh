<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4414 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5ca647a0-86be-5d3f-8de1-b7f9aadfdba5 -->
  <rule id="682647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4414 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>