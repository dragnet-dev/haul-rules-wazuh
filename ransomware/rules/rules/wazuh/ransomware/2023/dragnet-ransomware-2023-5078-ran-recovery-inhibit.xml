<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5078 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: da68971e-2e83-5166-9ab6-a5d7fd7e30da -->
  <rule id="486897" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5078 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>