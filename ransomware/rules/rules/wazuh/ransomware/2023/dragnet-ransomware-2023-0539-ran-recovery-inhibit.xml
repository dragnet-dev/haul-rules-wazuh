<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0539 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 004b6175-e3d3-5df4-a310-a5c50a3cfea1 -->
  <rule id="498814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0539 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>