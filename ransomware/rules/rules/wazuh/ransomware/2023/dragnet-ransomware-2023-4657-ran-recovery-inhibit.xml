<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4657 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a1aa506e-0f84-549e-a46a-e6a46c695119 -->
  <rule id="902650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4657 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>