<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4336 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 9e17f82f-00bd-5eeb-bd88-189ac9908e50 -->
  <rule id="830878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4336 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>