<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3390 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 110e1dc3-59cd-5291-84b6-0083a93e2ef0 -->
  <rule id="141916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3390 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>