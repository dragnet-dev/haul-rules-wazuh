<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2984 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1c6b8b5a-be6b-57c1-9028-fcea1c042eb1 -->
  <rule id="240595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2984 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>