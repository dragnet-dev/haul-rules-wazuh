<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0294 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9d8977b0-7b18-5e7f-aec3-ac1071cc66cc -->
  <rule id="778977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0294 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>