<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5349 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7093ce89-d620-5df6-8c03-66d9a751d4d1 -->
  <rule id="116014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5349 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>