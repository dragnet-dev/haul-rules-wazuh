<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3704 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 7228bc65-e82b-541a-bd29-4f39acd9435b -->
  <rule id="150556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3704 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>