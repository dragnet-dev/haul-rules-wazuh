<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3755 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 83028623-452c-5f50-a5ba-3b94c96efdf2 -->
  <rule id="302862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3755 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>