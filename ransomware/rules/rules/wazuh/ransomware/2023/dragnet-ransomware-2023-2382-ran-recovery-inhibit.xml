<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2382 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c41ec221-0735-5683-ba24-660992b166ae -->
  <rule id="579322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2382 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>