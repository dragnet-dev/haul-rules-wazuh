<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1214 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 158a0a15-06e7-53c2-ad5d-acc0fabe9bf6 -->
  <rule id="560901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1214 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>