<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4047 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a9bbb66d-4c02-5778-a97c-0a5eb01b8ef3 -->
  <rule id="994676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4047 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>