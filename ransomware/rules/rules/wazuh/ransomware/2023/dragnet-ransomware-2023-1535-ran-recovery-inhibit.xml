<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1535 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ec08b623-b5ce-5cbc-a46d-1da0ff2cfad4 -->
  <rule id="277396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1535 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>