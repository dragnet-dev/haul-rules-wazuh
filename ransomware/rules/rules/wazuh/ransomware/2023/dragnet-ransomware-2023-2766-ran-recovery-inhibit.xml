<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2766 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: ad38e9bd-ef2e-5163-9807-985fd8cde995 -->
  <rule id="174229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2766 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>