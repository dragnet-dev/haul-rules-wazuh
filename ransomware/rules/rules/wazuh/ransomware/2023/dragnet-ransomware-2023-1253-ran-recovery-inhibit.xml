<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1253 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bdefed1b-62c8-5a7f-be4d-533ce3797a73 -->
  <rule id="847725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1253 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>