<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3800 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 19b23289-3e30-55c7-86e7-4c23546a5e31 -->
  <rule id="552328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3800 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>