<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1921 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0a3074bd-75ff-5a2e-a1fc-847e53bf36ef -->
  <rule id="849195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1921 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>