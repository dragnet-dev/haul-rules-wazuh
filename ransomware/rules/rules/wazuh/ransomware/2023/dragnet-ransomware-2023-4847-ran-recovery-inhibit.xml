<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4847 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: aa7b2260-b6bd-5f29-8435-e3b17331fac2 -->
  <rule id="132322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4847 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>