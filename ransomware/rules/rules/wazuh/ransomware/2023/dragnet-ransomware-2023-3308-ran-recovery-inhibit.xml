<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3308 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 840ffffb-dd5b-5ca4-9a08-c277ec702a3f -->
  <rule id="844735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3308 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>