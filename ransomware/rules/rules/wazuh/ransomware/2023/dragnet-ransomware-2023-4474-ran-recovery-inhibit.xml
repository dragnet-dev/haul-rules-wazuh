<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4474 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 992eb13a-7a26-597c-bbde-f52155ae2dd1 -->
  <rule id="841871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4474 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>