<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0091 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 96dcd499-474e-58a9-8787-c2064f4dd1ae -->
  <rule id="467494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0091 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>