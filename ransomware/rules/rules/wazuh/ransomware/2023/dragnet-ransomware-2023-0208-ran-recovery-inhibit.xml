<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0208 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 87e16f3e-d003-59b1-a63f-3593b39205a8 -->
  <rule id="549871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0208 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>