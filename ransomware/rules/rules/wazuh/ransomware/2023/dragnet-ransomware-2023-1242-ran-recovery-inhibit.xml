<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1242 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3bd27a2d-e6d9-501f-9a65-c055b8596ea1 -->
  <rule id="731642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1242 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>