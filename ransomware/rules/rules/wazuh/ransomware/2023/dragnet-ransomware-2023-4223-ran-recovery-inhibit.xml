<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4223 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 1465c1ba-eaae-5993-8644-f87c19084dcd -->
  <rule id="252347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4223 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>