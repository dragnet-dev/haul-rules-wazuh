<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4434 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 946da6d8-ff39-5b68-b773-72c7f071e27d -->
  <rule id="723946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4434 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>