<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1853 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 013c8b6b-3231-5bef-85fe-9f4b35937ade -->
  <rule id="354347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1853 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>