<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1649 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 68c8c896-aaf2-5d02-b2f6-979e50f03c21 -->
  <rule id="961408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1649 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>