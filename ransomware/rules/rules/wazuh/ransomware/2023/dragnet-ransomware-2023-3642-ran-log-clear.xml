<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3642 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 61b4456f-80d2-5da1-91b1-0fdede0a51b1 -->
  <rule id="974456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3642 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>