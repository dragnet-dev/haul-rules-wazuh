<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1937 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: e23580ec-2808-508a-b7e8-1b45e13a7733 -->
  <rule id="623580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1937 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>