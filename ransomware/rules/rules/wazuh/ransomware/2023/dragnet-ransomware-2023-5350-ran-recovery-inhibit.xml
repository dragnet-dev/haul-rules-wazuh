<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5350 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 01594206-0991-5007-95ee-9fd1bf449a00 -->
  <rule id="794206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5350 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
