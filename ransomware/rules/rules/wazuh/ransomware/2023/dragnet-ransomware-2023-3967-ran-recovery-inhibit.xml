<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3967 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c53ac00e-c3e0-5d14-89e8-ef2432407691 -->
  <rule id="609400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3967 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
