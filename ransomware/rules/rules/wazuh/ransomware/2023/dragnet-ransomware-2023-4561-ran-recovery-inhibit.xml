<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4561 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 548b3c12-324e-5253-95b5-c0c269156f7e -->
  <rule id="604700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4561 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>