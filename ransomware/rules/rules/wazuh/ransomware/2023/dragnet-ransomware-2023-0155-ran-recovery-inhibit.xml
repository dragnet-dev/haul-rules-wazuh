<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0155 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1b78177a-dce3-5c08-b437-7aebd94e97ed -->
  <rule id="178177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0155 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>