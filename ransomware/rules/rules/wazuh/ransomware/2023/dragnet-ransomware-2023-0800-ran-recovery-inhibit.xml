<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0800 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 91d32bb4-8f29-5634-b970-e6b46c52ed62 -->
  <rule id="650923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0800 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>