<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1773 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9b4325e9-e240-57f0-aa43-7b710fc68eb8 -->
  <rule id="754325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1773 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>