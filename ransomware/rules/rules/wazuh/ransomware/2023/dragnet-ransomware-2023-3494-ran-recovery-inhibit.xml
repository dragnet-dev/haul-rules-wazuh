<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3494 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 509a2842-b4f4-5ac7-970a-207e9695aa54 -->
  <rule id="154284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3494 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>