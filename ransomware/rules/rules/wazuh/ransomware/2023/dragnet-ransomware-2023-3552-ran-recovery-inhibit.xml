<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3552 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f2d626e3-7f9a-5080-8245-1f0175fb74ab -->
  <rule id="745626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3552 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>