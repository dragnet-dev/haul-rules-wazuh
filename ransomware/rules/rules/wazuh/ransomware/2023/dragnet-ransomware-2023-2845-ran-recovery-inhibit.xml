<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2845 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 492d71b5-40ef-5fe4-bd0f-4795d8a71a4a -->
  <rule id="117147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2845 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>