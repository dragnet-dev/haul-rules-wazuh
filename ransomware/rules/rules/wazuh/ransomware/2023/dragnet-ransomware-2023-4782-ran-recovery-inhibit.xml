<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4782 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5e4a0fdb-34fc-50fe-af52-43ae741571a6 -->
  <rule id="718255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4782 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>