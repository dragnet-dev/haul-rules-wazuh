<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1682 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 80ac6938-9bdd-5ba2-a6d9-da045db1dfd5 -->
  <rule id="365269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1682 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>