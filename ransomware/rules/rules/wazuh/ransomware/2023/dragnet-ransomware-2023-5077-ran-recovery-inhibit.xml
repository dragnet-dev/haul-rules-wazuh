<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5077 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 075778a8-eb41-5989-8c98-392e9156d484 -->
  <rule id="412458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5077 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>