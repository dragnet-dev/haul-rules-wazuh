<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3935 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6d76b19a-529d-58e8-93e7-95f801080570 -->
  <rule id="956271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3935 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>