<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4207 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: af429615-f286-5d1d-b202-0f2fdba7a1cb -->
  <rule id="954296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4207 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>