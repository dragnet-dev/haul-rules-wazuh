<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4122 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 020b8e2e-8b12-5fa6-8db3-30a36cfaa1de -->
  <rule id="496366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4122 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>