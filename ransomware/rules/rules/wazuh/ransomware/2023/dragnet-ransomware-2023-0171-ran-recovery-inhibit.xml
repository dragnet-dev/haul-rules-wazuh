<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0171 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6662825a-99b4-514a-a1c7-28f96b1d6db7 -->
  <rule id="462825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0171 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>