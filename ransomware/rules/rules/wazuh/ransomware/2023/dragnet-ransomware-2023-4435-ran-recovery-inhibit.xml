<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4435 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a15838b1-4b4b-51ac-a3a6-67e70352b384 -->
  <rule id="215838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4435 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>