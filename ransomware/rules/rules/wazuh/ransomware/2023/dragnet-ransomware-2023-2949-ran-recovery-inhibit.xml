<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2949 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b03a05ab-4bea-5fbc-9b90-bde4a4be0de2 -->
  <rule id="965805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2949 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>