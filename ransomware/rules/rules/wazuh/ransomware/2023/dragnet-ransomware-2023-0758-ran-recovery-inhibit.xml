<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0758 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: df2b1a68-49bb-5ed1-ae60-a8dec6eb7a23 -->
  <rule id="415706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0758 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>