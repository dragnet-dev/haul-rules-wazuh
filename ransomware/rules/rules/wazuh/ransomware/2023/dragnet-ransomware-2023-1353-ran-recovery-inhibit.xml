<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1353 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ecef8dba-3252-5299-92fe-ff6be2d98024 -->
  <rule id="804941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1353 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>