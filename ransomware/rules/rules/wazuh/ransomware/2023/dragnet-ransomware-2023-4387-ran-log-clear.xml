<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4387 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 5ef2d88c-0dc8-51e2-8c87-3bfa5d54fe4e -->
  <rule id="730858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4387 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>