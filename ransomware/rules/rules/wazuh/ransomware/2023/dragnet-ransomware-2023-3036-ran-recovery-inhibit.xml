<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3036 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3225fb5b-af1b-5fcb-a1f3-f33fd0f17cc8 -->
  <rule id="258515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3036 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>