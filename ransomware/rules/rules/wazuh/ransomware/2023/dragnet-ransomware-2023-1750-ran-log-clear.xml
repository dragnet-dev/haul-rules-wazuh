<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1750 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: 00c8cb49-8f8f-5353-baff-bdc5f78d8f69 -->
  <rule id="697149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1750 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>