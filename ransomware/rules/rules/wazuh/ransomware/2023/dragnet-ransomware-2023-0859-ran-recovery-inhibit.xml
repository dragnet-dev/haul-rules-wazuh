<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0859 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8377090b-db1f-5a6a-b617-00afedb6466e -->
  <rule id="377090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0859 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>