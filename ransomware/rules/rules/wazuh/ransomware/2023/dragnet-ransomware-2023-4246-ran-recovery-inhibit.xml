<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4246 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 4f39c2b7-4152-5f9d-9c7d-0b1a594cf31c -->
  <rule id="470362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4246 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>