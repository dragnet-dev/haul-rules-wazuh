<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0411 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: cc90c7c8-c63c-5dba-bfee-263bcc92dd45 -->
  <rule id="678527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0411 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>