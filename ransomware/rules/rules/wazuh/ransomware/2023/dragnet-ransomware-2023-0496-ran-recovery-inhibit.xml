<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0496 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 30023eeb-b38d-5241-870c-18a2c60dc39e -->
  <rule id="586126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0496 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>