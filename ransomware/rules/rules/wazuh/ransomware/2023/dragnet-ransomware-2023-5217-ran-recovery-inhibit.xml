<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5217 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c5d5a1f5-2310-55dc-9249-7a84c69279f6 -->
  <rule id="621701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5217 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>