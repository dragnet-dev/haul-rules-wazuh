<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2303 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 50f58ddc-c8d7-550d-938d-ca37e4e1b446 -->
  <rule id="504941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2303 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>