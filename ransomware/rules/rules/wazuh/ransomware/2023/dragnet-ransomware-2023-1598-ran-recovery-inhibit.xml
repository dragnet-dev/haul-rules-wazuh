<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1598 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7df5aec9-ab4a-5110-ad2d-2cfcc5cc12ea -->
  <rule id="759854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1598 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>