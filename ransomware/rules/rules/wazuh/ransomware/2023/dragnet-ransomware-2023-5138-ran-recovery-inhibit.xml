<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5138 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 32d9ab5c-1dce-5b49-a56b-53ffa3ec063d -->
  <rule id="546475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5138 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>