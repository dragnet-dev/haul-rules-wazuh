<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0627 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: 50db9a49-3389-5a80-8f41-78591e687a2d -->
  <rule id="383194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0627 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>