<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0580 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 4eb7e261-3cb0-55e1-be69-2b770d390600 -->
  <rule id="315662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0580 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>