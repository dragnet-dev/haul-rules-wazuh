<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3198 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 36bccda8-f1eb-5bf7-9dce-2735b4d34c31 -->
  <rule id="707629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3198 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>