<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2160 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 428518a4-229a-54b8-bb24-81bcf39677d7 -->
  <rule id="656298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2160 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>