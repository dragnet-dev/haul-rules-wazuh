<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5288 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: b4833d95-8d2f-53ee-8473-ec9f7bfde822 -->
  <rule id="137341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5288 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>