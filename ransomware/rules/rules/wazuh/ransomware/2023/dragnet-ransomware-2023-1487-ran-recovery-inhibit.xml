<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1487 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 03d39cbb-7172-52e2-bffa-b401504b911e -->
  <rule id="771787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1487 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>