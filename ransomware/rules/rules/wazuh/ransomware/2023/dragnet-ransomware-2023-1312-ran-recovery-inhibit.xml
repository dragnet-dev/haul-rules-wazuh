<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1312 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fe348e41-955c-5dab-ae5d-27e19362937d -->
  <rule id="569582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1312 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>