<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4609 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 55854cc8-82d3-5d57-92f6-604f8afb28d7 -->
  <rule id="898828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4609 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>