<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3752 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 00f14e34-88a0-5eb9-85a6-7813b3cea07a -->
  <rule id="723834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3752 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>