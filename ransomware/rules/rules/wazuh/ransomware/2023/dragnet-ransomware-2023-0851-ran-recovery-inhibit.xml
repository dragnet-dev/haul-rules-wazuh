<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0851 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 479fa445-62fb-5891-a9a6-d240eff4bfad -->
  <rule id="428744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0851 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>