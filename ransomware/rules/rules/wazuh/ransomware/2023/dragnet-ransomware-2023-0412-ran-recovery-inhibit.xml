<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0412 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: b7221113-3f57-51b5-847a-541db7835fb1 -->
  <rule id="372211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0412 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>