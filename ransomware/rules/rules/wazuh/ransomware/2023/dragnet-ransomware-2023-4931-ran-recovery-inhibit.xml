<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4931 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 568f9b0d-8fbb-5052-9f44-627e27412ea7 -->
  <rule id="656635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4931 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>