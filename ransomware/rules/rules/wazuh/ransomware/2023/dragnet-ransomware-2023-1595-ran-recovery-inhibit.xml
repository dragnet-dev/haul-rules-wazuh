<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1595 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4f8f8902-cac8-53af-97ce-26a075e0f3b7 -->
  <rule id="478389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1595 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>