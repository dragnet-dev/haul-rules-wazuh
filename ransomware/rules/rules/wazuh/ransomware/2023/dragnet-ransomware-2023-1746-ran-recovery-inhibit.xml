<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1746 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 345076cd-3948-5ac8-9033-f93fcd25eeec -->
  <rule id="221228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1746 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>