<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4881 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f5adf67a-39f8-5794-9078-2db8bd676984 -->
  <rule id="176636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4881 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>