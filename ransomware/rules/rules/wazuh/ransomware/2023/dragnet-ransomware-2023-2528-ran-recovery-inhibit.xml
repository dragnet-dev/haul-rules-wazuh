<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2528 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a3d05b08-14a4-50b6-b7c1-99335d97aadd -->
  <rule id="957691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2528 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>