<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1711 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 28a26f76-f8a2-5835-9cb8-197e9d9bb3a5 -->
  <rule id="232317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1711 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>