<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0059 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 9cc31afc-065f-57bf-855f-09637fc9c1cd -->
  <rule id="513306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0059 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
