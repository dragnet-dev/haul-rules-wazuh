<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3703 — Recovery Inhibition (medusa) | Status: deprecated | Sigma ID: 383662ed-90e8-5f84-af4d-9776a4fd3ee6 -->
  <rule id="838606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3703 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>