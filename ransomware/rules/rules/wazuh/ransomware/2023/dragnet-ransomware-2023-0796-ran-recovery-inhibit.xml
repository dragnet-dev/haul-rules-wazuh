<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0796 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f4ced26c-fb71-5004-8237-756bb4731300 -->
  <rule id="140932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0796 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>