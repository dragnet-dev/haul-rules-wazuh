<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2342 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 91c99bcb-4f5c-5c1f-b76c-5f5f618b5be4 -->
  <rule id="650395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2342 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>