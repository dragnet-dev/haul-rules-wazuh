<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2966 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 77474e57-66e5-5e55-b5c0-6a948b03bdcd -->
  <rule id="439598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2966 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>