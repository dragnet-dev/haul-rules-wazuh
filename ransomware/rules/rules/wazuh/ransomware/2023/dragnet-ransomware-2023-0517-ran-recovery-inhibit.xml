<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0517 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ef535444-ee7f-5b1b-86a7-754472cf3caf -->
  <rule id="695354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0517 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>