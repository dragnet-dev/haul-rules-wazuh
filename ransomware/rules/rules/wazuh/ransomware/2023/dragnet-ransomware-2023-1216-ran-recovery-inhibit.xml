<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1216 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: a95343d3-8b6d-5a03-83e6-ed5df82b673c -->
  <rule id="295343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1216 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>