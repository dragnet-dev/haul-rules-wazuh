<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1343 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: a87f46c9-f475-5fad-9655-fc24fd2437e2 -->
  <rule id="940746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1343 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>