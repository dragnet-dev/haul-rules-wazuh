<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0136 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c5d03329-e21c-5ad3-9f8f-8edb8f430a19 -->
  <rule id="313033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0136 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>