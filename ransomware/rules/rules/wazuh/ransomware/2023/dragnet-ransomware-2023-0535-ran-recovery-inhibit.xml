<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0535 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d289597a-b9b7-5e99-9afb-4f5e0993f903 -->
  <rule id="528959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0535 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>