<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2478 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e7d0768e-7041-5fca-bf80-b047ccb1ebd2 -->
  <rule id="665076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2478 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>