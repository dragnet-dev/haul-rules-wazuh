<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2991 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8a4e12f5-e26e-505f-945b-74eab91faa83 -->
  <rule id="515812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2991 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>