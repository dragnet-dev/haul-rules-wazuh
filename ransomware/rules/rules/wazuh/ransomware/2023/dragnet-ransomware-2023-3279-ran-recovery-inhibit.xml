<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3279 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 08b5e0ef-abe3-5fec-b037-d318094e16b5 -->
  <rule id="973454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3279 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>