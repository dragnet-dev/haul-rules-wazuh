<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4906 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 4007b3c7-43a6-5497-a8a2-7db0792a73d2 -->
  <rule id="459740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4906 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>