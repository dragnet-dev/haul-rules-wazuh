<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2935 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 61dca27d-c004-5995-99ef-a6037cca1d83 -->
  <rule id="833862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2935 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>