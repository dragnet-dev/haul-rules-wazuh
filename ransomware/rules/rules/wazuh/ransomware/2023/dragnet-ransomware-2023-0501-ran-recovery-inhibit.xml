<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0501 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 84ef1f30-1b30-55b0-bcc5-92e9c9f7950a -->
  <rule id="878911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0501 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>