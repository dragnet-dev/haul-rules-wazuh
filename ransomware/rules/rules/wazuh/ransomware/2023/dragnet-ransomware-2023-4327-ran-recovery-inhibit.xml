<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4327 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 06f25f9e-92c7-57e3-9dd7-e09e747d7fd9 -->
  <rule id="980159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4327 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>