<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3614 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 617d6f7d-ae2c-500e-99a3-c7174aa1499c -->
  <rule id="781711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3614 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>