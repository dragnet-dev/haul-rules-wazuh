<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5066 — Event Log Clearing (werewolves) | Status: experimental | Sigma ID: 34d12016-5a64-51bf-897d-fc60c81e3730 -->
  <rule id="271201" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5066 — Event Log Clearing (werewolves)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>