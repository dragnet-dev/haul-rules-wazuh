<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4034 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d4e8afad-0fd6-5998-b49b-ddec550b07a5 -->
  <rule id="226703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4034 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>