<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1018 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bf0447e3-3a25-5047-94fd-03b268650f3e -->
  <rule id="210447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1018 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>