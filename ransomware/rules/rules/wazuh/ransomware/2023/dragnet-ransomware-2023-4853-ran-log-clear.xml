<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4853 — Event Log Clearing (trigona) | Status: experimental | Sigma ID: 48b5a1e8-ebd2-58ae-93d2-e0bb5930d257 -->
  <rule id="447301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4853 — Event Log Clearing (trigona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>