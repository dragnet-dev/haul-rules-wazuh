<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4989 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: df4e3b7b-5df9-5c4e-9fc9-784ae538c4d4 -->
  <rule id="421339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4989 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>