<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2870 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 23fc94ff-b263-5399-aa7e-f6d5beb043c2 -->
  <rule id="925519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2870 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>