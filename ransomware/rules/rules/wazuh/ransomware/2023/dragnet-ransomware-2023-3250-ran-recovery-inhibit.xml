<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3250 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3cf395c6-b0d6-5fce-b7d5-e93efe562ae2 -->
  <rule id="406332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3250 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
