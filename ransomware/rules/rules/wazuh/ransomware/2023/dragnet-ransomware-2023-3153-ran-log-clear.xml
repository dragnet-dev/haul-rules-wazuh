<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3153 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 5d12b2dc-6bce-567f-967b-036ad4cc4180 -->
  <rule id="690032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3153 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>