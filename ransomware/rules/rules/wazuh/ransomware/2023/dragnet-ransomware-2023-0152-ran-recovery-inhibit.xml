<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0152 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 069a1229-41f7-531a-9f6b-65cc46f8c340 -->
  <rule id="314122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0152 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>