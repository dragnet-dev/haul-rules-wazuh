<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0363 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2797a96d-5893-5b73-96ee-942ed0fa6310 -->
  <rule id="976296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0363 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>