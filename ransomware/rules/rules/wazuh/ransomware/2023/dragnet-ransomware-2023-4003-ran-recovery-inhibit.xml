<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4003 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 97163e22-590b-578f-8b8f-662b43b7f8b5 -->
  <rule id="754622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4003 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>