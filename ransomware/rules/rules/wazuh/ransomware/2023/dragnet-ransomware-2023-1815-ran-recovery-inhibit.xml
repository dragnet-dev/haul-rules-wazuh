<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1815 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 326d72dc-4346-5a76-a1f3-4c4bf59ff63b -->
  <rule id="367565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1815 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>