<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4584 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 00ae3b13-0b99-5664-918b-f4d24beffb7d -->
  <rule id="189913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4584 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>