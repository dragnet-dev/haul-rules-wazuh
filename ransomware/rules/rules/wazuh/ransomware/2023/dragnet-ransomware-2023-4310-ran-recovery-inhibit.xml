<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4310 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4833ef16-5943-53ac-9c27-622e251ff6ca -->
  <rule id="437487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4310 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>