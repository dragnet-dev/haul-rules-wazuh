<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1204 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f7c78801-0cd0-5d35-8754-4ca5bfd5e163 -->
  <rule id="824788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1204 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>