<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0174 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 6e6e72e1-fd7c-5078-b258-aa9c90cac8f9 -->
  <rule id="971072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0174 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>