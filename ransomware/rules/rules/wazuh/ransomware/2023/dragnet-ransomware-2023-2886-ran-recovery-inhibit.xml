<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2886 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 1e1eaf8d-4ab4-5d2f-baa1-ee46c50bf20d -->
  <rule id="436655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2886 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>