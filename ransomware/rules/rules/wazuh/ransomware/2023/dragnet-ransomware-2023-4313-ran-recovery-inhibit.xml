<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4313 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1fc785b8-e2fe-5a2e-bc87-331fc55a3bef -->
  <rule id="140571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4313 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>