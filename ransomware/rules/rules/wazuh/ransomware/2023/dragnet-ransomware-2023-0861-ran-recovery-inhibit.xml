<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0861 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 38abf51c-0d23-5e4d-8c68-c51bc284d253 -->
  <rule id="783995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0861 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>