<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2523 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7d8780f8-371b-5c8c-85db-88c07cb41921 -->
  <rule id="458780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2523 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>