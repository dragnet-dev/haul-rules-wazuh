<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1606 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 9ca674b6-62c9-5eae-9230-de4d0bbf1fb2 -->
  <rule id="806674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1606 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>