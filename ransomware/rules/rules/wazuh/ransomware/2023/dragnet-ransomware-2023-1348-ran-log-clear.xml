<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1348 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 349d9c33-d9ae-5d9f-a10b-e3a34054c2f2 -->
  <rule id="956763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1348 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>