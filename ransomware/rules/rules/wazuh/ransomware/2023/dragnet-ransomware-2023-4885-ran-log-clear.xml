<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4885 — Event Log Clearing (cyclops) | Status: deprecated | Sigma ID: 0f2a5b6f-8597-54da-97ff-472d21b3ea8f -->
  <rule id="408116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4885 — Event Log Clearing (cyclops)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>