<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0290 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 9e003a74-7eec-5380-bc9f-f70bc8ade33e -->
  <rule id="828058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0290 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>