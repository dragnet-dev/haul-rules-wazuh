<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5118 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b0daef4b-9c8f-51d8-91ed-5e25c97e521c -->
  <rule id="165007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5118 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>