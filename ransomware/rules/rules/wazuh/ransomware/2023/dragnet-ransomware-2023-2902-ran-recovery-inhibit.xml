<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2902 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 799632e8-5b8d-554b-b054-7f7298e62bc6 -->
  <rule id="294126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2902 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>