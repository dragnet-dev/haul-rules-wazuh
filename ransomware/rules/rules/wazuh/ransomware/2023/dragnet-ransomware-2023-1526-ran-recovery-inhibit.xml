<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1526 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4ec4f895-3161-5be2-9e92-da9efb7f20aa -->
  <rule id="316798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1526 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>