<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1614 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 73fc3491-b145-5929-8f43-6a0fea0053dd -->
  <rule id="194034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1614 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>