<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2941 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 811a8a14-6dca-542c-b471-222831b0f001 -->
  <rule id="377898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2941 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>