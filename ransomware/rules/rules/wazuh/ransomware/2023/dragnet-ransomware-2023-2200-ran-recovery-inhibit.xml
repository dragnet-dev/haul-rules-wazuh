<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2200 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 3b7fbcf4-9beb-542e-9272-d2cf7fb3063c -->
  <rule id="749340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2200 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>