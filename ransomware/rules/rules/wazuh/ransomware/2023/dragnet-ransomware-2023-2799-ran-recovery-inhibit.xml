<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2799 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: a1392a1f-bd77-5971-9475-ee52ac5adee7 -->
  <rule id="822282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2799 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>