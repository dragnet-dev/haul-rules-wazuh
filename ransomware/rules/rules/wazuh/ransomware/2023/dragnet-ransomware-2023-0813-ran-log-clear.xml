<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0813 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: f68c5c07-8d66-538d-9d8e-a0890b8a8010 -->
  <rule id="516092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0813 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>