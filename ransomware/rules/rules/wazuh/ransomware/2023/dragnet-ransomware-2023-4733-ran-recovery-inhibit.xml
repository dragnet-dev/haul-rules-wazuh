<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4733 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 882c56ca-af61-5fa8-801b-4b28eb8a4a07 -->
  <rule id="612456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4733 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>