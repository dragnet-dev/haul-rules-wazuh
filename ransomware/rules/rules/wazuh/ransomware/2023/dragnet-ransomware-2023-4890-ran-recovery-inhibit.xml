<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4890 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 8d63afe3-7088-5cf1-aa1b-2443d199edfc -->
  <rule id="125903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4890 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>