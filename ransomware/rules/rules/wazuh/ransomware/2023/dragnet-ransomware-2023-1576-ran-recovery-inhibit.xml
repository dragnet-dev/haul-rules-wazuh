<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1576 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 59b0d286-29fd-5c4d-9ef0-06d08d235ce4 -->
  <rule id="728132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1576 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>