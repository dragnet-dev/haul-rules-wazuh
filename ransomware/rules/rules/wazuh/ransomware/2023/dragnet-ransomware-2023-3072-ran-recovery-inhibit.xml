<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3072 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 93a53af9-9b82-56fc-ab69-805220bf3d96 -->
  <rule id="697658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3072 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
