<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1884 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6d631bc0-ba48-5cac-b373-97587aeb663a -->
  <rule id="954107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1884 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>