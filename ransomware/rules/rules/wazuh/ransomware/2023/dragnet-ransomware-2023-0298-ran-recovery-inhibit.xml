<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0298 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bbae24c8-67e4-58da-b940-e552c1c61acd -->
  <rule id="404624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0298 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>