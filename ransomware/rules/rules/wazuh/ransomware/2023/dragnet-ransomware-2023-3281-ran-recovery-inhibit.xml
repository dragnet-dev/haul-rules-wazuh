<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3281 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 08a35646-7092-5f58-8025-219fba70aea1 -->
  <rule id="583564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3281 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>