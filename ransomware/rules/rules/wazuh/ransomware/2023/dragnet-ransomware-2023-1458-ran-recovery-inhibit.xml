<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1458 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7a9d28b5-fd0b-5e38-ad7d-432232e205d6 -->
  <rule id="267728" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1458 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>