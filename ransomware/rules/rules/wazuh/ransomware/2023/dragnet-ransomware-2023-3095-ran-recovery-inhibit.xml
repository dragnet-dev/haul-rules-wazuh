<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3095 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 88f198a6-b772-5bf1-ae9a-388515b9fa1f -->
  <rule id="623198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3095 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
