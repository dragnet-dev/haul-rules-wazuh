<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1875 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 4f3d2248-ecce-5b93-b0c1-0c44c2d8f6b5 -->
  <rule id="470122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1875 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>