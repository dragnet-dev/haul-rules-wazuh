<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2497 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: a1b79eda-4db4-5e18-823d-b1bad52bb980 -->
  <rule id="904478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2497 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>