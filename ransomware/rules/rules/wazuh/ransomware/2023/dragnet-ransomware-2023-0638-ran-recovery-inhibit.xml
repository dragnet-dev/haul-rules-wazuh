<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0638 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6142fc34-f470-5608-93bf-c54adfb05adb -->
  <rule id="772604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0638 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>