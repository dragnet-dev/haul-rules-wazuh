<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1308 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3843961e-c476-576e-bf7f-cd6109c59bf6 -->
  <rule id="343961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1308 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>