<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3306 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: bb48086a-5f01-5aab-b6be-d09d5a46b247 -->
  <rule id="174808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3306 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>