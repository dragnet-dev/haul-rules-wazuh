<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0516 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 67e913f5-14df-5d5e-8a3e-69e3f1ef5524 -->
  <rule id="286913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0516 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>