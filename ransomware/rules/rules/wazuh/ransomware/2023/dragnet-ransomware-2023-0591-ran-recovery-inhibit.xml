<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0591 — Recovery Inhibition (play) | Status: experimental | Sigma ID: da132a8a-076e-500c-9294-f0fb89012ceb -->
  <rule id="890122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0591 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>