<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5324 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5c7c729d-7956-51aa-9aee-602c3b4b3184 -->
  <rule id="684472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5324 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>