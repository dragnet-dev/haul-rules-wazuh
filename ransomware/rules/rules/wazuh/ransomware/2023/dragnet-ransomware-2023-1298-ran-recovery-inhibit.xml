<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1298 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 505b19c9-6f3a-5c19-aefa-f6b97e82eb7f -->
  <rule id="445916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1298 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>