<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2269 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7a80fe92-2b7d-5764-87be-ce30bfe99c7e -->
  <rule id="543934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2269 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>