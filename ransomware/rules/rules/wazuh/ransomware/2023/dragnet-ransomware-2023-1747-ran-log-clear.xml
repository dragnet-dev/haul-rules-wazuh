<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1747 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 0d0cc03e-5130-510d-9c30-8c411a0a58f4 -->
  <rule id="748403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1747 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>