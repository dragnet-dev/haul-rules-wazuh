<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2792 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: f41a5944-41ea-572f-a7f8-9e1abc89d66b -->
  <rule id="766659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2792 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>