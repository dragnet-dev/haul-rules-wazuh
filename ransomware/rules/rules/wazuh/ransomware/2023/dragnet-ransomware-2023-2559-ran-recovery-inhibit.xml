<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2559 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 550f0bd3-4cf2-5350-95b3-ed4a0076b73d -->
  <rule id="610411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2559 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>