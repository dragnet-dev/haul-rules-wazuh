<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3702 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d844571f-4c6f-577a-afd5-3dd4df870451 -->
  <rule id="584457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3702 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>