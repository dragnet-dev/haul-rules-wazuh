<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0862 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 1fecb3b9-533b-5c74-8805-a7de0e2db163 -->
  <rule id="507633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0862 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>