<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4145 — Event Log Clearing (cactus) | Status: experimental | Sigma ID: 1b3bef0c-1eb3-5042-a94d-f3c0a349a9d4 -->
  <rule id="321263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4145 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>