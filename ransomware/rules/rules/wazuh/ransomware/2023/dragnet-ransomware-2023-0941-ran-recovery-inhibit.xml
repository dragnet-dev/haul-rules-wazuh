<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0941 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8979d02b-ba41-58ac-be6e-4d33f9007c54 -->
  <rule id="636770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0941 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>