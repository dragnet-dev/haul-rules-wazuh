<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0605 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 196ebabf-0415-5f23-80fc-5f0988b5ef2b -->
  <rule id="405387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0605 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>