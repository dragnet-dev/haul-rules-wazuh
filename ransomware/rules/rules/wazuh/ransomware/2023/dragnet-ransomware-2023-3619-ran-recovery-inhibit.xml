<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3619 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 10394cdf-104e-54a2-93f2-f63fd2dac689 -->
  <rule id="961069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3619 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>