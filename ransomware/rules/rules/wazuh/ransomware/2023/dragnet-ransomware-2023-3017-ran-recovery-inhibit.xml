<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3017 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d9bc5526-bbb7-55d1-8c6a-a832c52a2995 -->
  <rule id="977255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3017 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>