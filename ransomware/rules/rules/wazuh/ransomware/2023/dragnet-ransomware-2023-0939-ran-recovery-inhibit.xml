<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0939 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bba1a610-9227-5471-adcd-2c9ec6a15e3a -->
  <rule id="403466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0939 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>