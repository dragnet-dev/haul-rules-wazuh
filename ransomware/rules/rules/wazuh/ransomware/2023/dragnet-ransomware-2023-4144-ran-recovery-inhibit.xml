<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4144 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4b95deba-3ee9-5722-bfa2-0987eb4fa7e0 -->
  <rule id="244542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4144 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>