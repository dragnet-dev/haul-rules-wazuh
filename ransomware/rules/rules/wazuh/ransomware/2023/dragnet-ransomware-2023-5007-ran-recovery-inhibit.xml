<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5007 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f915a974-ba50-5de5-9fec-09156b27ab25 -->
  <rule id="846509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5007 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>