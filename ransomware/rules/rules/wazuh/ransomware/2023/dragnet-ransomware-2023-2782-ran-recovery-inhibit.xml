<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2782 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 5720a8e9-5129-503f-bbc6-8a66fffc8179 -->
  <rule id="344942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2782 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>