<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3943 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 51f40ad9-17e5-5996-9a02-6a66e474e581 -->
  <rule id="530250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3943 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>