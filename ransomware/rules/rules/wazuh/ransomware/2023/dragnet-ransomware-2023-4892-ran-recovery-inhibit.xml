<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4892 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2f0df802-e2c0-53a7-bad0-06675169de8c -->
  <rule id="405438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4892 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
