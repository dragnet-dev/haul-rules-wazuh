<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2487 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a83878e9-1779-51b2-bd0b-1dab061e3cdd -->
  <rule id="283878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2487 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>