<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2913 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: a98badf6-49c0-51d7-8ee1-96621f2450ff -->
  <rule id="100397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2913 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>