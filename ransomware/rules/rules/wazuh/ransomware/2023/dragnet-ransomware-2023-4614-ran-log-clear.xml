<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4614 — Event Log Clearing (cactus) | Status: deprecated | Sigma ID: 01a210ae-a7e6-59b4-8f51-79ffcd4d3ed3 -->
  <rule id="509934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4614 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>