<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2805 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 15a2192c-558a-5fe6-bbf6-0d708a5a4741 -->
  <rule id="802192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2805 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>