<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3107 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c9092cba-c515-54b8-959e-0ecf3d348e20 -->
  <rule id="365484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3107 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>