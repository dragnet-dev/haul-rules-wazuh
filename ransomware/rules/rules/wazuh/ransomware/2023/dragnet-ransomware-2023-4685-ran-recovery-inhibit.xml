<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4685 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3521b9f6-8c67-5c6c-b30c-6e23b0f756a3 -->
  <rule id="115679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4685 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>