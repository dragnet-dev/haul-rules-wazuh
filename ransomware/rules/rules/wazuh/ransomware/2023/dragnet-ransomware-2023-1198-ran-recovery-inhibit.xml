<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1198 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6ac3fcbd-da9d-59cb-9a20-ccb9b88aded3 -->
  <rule id="873500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1198 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>