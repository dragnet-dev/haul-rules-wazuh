<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5097 — Event Log Clearing (mallox) | Status: experimental | Sigma ID: 1edc0eaa-68c3-5895-bcdf-2aba182b1b74 -->
  <rule id="464014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5097 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>