<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1021 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9f39c6e5-b8e7-597b-a1ff-170d3f46fdf0 -->
  <rule id="850366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1021 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>