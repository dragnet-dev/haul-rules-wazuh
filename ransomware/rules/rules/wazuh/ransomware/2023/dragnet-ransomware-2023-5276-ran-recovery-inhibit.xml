<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5276 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 53aba14f-adbc-5bec-a583-33b7240f1543 -->
  <rule id="498341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5276 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>