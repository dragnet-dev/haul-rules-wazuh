<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1938 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 5a1a7906-c9bb-504e-b422-5b6652252e9d -->
  <rule id="642679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1938 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>