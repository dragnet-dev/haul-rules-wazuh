<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1447 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 71ea028b-5f48-507e-8d80-eb1fa4b9bf82 -->
  <rule id="141002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1447 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>