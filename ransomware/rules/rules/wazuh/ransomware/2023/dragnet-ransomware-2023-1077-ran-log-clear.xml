<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1077 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: c7dd55fc-7641-518f-8dfe-87c7a3ba8cfc -->
  <rule id="673355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1077 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>