<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2918 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 5db099a4-91ca-5d30-b36f-b67e2ac3d253 -->
  <rule id="699099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2918 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>