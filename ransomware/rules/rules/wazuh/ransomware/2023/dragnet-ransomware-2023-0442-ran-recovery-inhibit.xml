<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0442 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8951705f-8100-5efb-9268-c3cf599c2377 -->
  <rule id="951705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0442 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>