<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3737 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 320ce67f-0bc2-59c5-8069-b8d2f0eb20f7 -->
  <rule id="212667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3737 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>