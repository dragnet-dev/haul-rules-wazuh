<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3657 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ff4b108d-fc69-5b0e-804d-d232b154c919 -->
  <rule id="587510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3657 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>