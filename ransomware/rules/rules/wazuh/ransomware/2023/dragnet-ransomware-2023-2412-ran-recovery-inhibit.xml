<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2412 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ccf284e4-c02e-588a-851c-dee414b3db44 -->
  <rule id="679284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2412 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>