<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0365 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3d8c1ca9-0034-5840-be7c-9e3adcca932f -->
  <rule id="784028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0365 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>