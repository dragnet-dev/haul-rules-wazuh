<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4757 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 999f8894-e896-5090-8740-a12423e45c99 -->
  <rule id="799988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4757 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>