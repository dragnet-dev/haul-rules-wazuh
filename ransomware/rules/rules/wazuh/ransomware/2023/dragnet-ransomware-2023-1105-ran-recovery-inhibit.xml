<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1105 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e9cbb358-a76c-589d-bd79-2fad270ee7d1 -->
  <rule id="835633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1105 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>