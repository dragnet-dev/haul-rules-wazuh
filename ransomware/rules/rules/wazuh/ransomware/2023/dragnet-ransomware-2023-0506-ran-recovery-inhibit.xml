<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0506 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 28395998-b7c5-5f39-ae48-473db00a90f3 -->
  <rule id="239599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0506 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>