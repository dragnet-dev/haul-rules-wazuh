<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3319 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5d3081bb-4a15-5ee1-9b6b-20dcfb2af63e -->
  <rule id="629307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3319 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>