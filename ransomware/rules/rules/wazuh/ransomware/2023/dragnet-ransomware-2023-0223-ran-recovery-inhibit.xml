<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0223 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 4c2a99ff-154e-513d-8a6d-fff0de52b852 -->
  <rule id="420299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0223 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>