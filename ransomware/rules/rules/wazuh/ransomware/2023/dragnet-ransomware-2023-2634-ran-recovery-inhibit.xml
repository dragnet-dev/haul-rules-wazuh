<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2634 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7d7903cf-4bb5-5157-aad1-046c457bf72e -->
  <rule id="457903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2634 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>