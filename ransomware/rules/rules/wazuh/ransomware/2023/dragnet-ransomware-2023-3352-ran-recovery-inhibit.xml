<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3352 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 4b530bc0-c4cb-5c0e-995a-adeb58e36bcf -->
  <rule id="408491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3352 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>