<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3116 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 66e6f1ef-b0d4-5cdd-b841-ce004f039497 -->
  <rule id="913111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3116 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>