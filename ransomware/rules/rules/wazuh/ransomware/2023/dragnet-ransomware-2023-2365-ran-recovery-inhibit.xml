<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2365 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 770cf294-ea73-5782-ad50-15aab3a89531 -->
  <rule id="273272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2365 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>