<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5346 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: dbd22851-4373-548f-a354-6d81c88af4eb -->
  <rule id="917228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5346 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>