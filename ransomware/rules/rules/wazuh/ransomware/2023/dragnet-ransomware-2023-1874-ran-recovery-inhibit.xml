<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1874 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a4544c76-f952-5044-a74a-097b926a216a -->
  <rule id="872716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1874 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>