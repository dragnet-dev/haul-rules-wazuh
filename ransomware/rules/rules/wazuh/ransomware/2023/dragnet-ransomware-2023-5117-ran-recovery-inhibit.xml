<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5117 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6a710e79-cc81-5bb0-83bc-2c4688185f10 -->
  <rule id="907374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5117 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>