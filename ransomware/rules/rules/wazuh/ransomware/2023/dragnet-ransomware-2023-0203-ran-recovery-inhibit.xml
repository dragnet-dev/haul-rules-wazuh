<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0203 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c25a0bcf-9317-5c8e-a7df-bc20f28f38dd -->
  <rule id="537611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0203 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>