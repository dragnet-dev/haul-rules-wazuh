<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3304 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9a83324d-9d0c-5f9c-8e06-f2c59bbfc1da -->
  <rule id="748332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3304 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
