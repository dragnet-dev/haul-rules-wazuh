<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4422 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 6c52c923-118d-5d29-ac0a-5cec6203bd3e -->
  <rule id="936449" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4422 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>