<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1201 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 78443716-2608-5faa-972c-4eb8b916dcd8 -->
  <rule id="744371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1201 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>