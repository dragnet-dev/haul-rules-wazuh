<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2448 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: c0ab2c96-0b3a-5a4a-a991-fbc7ab7a852c -->
  <rule id="542604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2448 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>