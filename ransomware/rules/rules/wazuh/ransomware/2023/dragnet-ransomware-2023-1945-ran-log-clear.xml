<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1945 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 0602ae74-c4a0-53aa-a29d-80e7576a0ea7 -->
  <rule id="742867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1945 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>