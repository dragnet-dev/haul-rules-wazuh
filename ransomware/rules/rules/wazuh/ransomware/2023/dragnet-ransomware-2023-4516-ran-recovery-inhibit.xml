<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4516 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 4304738c-26a6-5a2f-b5a1-3ff4b556b44a -->
  <rule id="804738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4516 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>