<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0015 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 277894dc-dc9a-5741-bf5f-7e97e27c0820 -->
  <rule id="946317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0015 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>