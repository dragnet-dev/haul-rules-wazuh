<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4898 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b1e6eea4-4e84-5e46-82f2-a27afd06f4b0 -->
  <rule id="184174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4898 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>