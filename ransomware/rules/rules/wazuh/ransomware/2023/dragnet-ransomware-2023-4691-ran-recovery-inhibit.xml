<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4691 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 384c9541-5727-5f5e-8380-d3d6783e45cd -->
  <rule id="856954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4691 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>