<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5193 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: af7cb078-5ce3-55c3-87ed-a1fad0590c52 -->
  <rule id="999950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5193 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>