<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0350 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 472b46a6-fb86-5571-8620-30fb6eac7da7 -->
  <rule id="501546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0350 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>