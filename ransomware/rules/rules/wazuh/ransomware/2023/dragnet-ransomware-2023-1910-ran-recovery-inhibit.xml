<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1910 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 908e416e-7b25-5f65-9913-dca94f0172a2 -->
  <rule id="654241" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1910 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>