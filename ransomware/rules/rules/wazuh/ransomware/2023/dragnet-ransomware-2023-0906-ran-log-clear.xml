<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0906 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 7844e708-ceb2-57f0-a1aa-08b5e4ad2fcd -->
  <rule id="455187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0906 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>