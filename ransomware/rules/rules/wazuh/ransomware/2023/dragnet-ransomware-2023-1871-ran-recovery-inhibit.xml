<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1871 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b6a5960d-f4c2-511a-b1a8-f12e8784a944 -->
  <rule id="166596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1871 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>