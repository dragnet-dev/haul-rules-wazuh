<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4367 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b92c829c-d4f1-5828-a642-71b8bffa3d5d -->
  <rule id="208482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4367 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>