<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5176 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: f3af7c84-e143-547d-8015-ebf83be31658 -->
  <rule id="995004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5176 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>