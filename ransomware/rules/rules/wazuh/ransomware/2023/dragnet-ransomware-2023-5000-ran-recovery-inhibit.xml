<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5000 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: c373521c-9621-5796-9d74-9fed28ad6e95 -->
  <rule id="437352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5000 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>