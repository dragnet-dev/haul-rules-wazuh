<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2379 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 790c1576-c7fa-5ffe-a56f-862c56ca300f -->
  <rule id="465215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2379 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>