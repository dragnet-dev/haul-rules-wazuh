<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2751 — Event Log Clearing (malas) | Status: experimental | Sigma ID: ffdc22a8-e151-51d8-8aac-28b20d03e7ea -->
  <rule id="350022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2751 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>