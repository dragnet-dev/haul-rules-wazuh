<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2531 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bb6abaa0-355d-5067-b510-13e42ef3e36b -->
  <rule id="586842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2531 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>