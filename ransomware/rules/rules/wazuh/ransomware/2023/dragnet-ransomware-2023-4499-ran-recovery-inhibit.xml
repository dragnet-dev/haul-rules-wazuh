<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4499 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6715039f-af91-5053-897d-22ceccab43a4 -->
  <rule id="515039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4499 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>