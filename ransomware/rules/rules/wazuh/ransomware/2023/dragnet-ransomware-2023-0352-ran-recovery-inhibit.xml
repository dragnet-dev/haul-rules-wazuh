<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0352 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8dce97aa-88d2-5566-a717-b10ff8008344 -->
  <rule id="130297" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0352 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>