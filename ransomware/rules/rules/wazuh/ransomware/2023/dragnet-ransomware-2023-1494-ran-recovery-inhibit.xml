<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1494 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 0b80fb63-15fe-5cfd-b68d-cb6cc61d5a4a -->
  <rule id="423316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1494 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>