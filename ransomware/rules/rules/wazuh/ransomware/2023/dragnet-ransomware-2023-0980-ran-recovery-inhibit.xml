<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0980 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 97f9934b-0e91-5861-8e86-5306a9e6d7f4 -->
  <rule id="767993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0980 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>