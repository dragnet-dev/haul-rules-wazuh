<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3184 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1b3dfea0-5fa5-55ae-97a7-f309c98e74f4 -->
  <rule id="321790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3184 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>