<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3141 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6e6624c5-e699-5a92-a4ce-28cbb5f736b6 -->
  <rule id="306624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3141 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>