<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3497 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a4f806fd-748c-552d-9045-ebb545a8e259 -->
  <rule id="879806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3497 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>