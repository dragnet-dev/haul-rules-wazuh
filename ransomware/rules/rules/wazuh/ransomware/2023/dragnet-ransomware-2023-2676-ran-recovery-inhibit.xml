<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2676 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: d4df813f-964a-5c3f-9a0e-98ea780e1518 -->
  <rule id="852781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2676 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>