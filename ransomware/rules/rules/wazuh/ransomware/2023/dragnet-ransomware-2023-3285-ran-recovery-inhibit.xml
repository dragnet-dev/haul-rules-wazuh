<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3285 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 830ccb8c-62c1-5f8c-b71a-a655d890cdd9 -->
  <rule id="802955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3285 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>