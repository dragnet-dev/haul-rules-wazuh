<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1199 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b5afbff3-0097-5aad-8266-faa9b8a19984 -->
  <rule id="481631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1199 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>