<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3517 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 5904db3a-847f-5bc0-aa5a-a9557a537d5d -->
  <rule id="711643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3517 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>