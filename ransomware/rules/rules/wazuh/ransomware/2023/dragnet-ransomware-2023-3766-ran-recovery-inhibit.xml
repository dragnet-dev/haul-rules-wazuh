<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3766 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7bb76bca-3e8c-5989-b146-ef108a3fded9 -->
  <rule id="567627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3766 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>