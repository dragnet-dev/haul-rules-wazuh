<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4198 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a627feba-7916-54cd-a3b7-de4d51e6cf3c -->
  <rule id="120766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4198 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>