<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5317 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 12afd4c8-1376-5bb9-b6bb-9e71ace1fa8d -->
  <rule id="314476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5317 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>