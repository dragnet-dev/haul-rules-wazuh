<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2665 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f174b5ec-4029-534d-abf2-f547079c4fd5 -->
  <rule id="727955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2665 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>