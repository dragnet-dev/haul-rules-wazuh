<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3846 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 0d3de977-91af-5a77-9a9a-0d21d362feb1 -->
  <rule id="827097" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3846 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>