<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2214 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 48d89acd-e25f-51fb-9bea-16a5447addf2 -->
  <rule id="451034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2214 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>