<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1146 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3c06e9ae-d189-58f3-846f-6d1a22cb9aae -->
  <rule id="177754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1146 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>