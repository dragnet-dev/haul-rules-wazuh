<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3855 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 6e4ef500-e248-5869-9dc5-ec559be904a6 -->
  <rule id="228635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3855 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>