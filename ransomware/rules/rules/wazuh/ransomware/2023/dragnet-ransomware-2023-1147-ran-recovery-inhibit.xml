<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1147 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 4fc7bc97-93d3-5b6c-8793-f5d020461259 -->
  <rule id="668540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1147 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>