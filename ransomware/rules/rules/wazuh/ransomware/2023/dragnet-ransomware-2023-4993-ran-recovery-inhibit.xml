<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4993 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: e91c9608-3033-57c7-a35c-6780543119f6 -->
  <rule id="686896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4993 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>