<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5085 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a222c04c-6f11-5e28-abb0-3d3506913889 -->
  <rule id="835640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5085 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>