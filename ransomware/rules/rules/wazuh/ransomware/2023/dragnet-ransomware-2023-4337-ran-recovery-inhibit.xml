<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4337 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 033c3c6c-622a-5d2a-abf4-75b5dbd8f2ad -->
  <rule id="433708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4337 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>