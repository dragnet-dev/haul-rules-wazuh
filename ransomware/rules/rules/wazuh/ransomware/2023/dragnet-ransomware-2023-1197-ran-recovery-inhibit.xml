<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1197 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 300d829e-8924-519b-8428-83b51cabb137 -->
  <rule id="413829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1197 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>