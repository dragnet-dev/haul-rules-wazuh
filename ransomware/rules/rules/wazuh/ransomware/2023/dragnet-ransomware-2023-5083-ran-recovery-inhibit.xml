<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5083 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: acfba2c8-dbb2-5731-8936-1aacaedc2830 -->
  <rule id="885382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5083 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>