<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4283 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f2cbdb21-6a76-572f-9467-4e0960e1561b -->
  <rule id="213659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4283 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>