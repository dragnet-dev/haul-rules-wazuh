<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3164 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3b3944ff-e702-5b86-9c27-2e07fe998bba -->
  <rule id="603119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3164 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>