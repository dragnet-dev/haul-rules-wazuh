<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2916 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e48dcdac-c3fe-5094-bb35-5b6a97ef0b3a -->
  <rule id="634541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2916 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>