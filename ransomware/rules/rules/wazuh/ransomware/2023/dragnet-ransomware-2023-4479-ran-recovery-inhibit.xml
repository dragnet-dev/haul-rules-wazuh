<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4479 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e785528b-2193-58b5-8f81-4c8cdceb617f -->
  <rule id="678552" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4479 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>