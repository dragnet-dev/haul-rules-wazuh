<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4409 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 6e1bdf21-da2e-542e-8490-e0e57cfbac04 -->
  <rule id="112735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4409 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>