<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1616 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9f012ee8-6625-5034-84bd-54bb7a274d87 -->
  <rule id="844206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1616 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>