<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3789 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5242a585-8c99-51db-b3e1-1bb27bdd5e4b -->
  <rule id="388258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3789 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>