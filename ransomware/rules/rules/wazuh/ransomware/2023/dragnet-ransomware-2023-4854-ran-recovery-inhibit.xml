<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4854 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f8db2784-bae4-507a-844d-029ecdd62c9b -->
  <rule id="566727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4854 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>