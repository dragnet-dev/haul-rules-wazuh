<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3876 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 2c6f4a01-b4d6-5096-b5f3-e5a5e65e84fa -->
  <rule id="344234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3876 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>