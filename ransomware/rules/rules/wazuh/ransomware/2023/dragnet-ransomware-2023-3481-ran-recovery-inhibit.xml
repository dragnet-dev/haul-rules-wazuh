<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3481 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 794270e3-820b-572f-b300-650fc819a1fe -->
  <rule id="208334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3481 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>