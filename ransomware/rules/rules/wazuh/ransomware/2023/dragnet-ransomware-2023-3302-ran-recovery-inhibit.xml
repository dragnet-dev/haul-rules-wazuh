<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3302 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e15b8de2-f9d6-5986-a80c-7348e88b4a82 -->
  <rule id="124301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3302 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>