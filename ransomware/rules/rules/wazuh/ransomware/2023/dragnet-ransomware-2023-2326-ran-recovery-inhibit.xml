<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2326 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: a6665286-ad2e-51fd-bc26-69ff29358c0c -->
  <rule id="266652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2326 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>