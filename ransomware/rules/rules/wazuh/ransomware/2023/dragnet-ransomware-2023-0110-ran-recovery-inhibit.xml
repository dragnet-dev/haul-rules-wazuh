<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0110 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: cd3cfb5b-8980-524b-8856-09c9b1d23697 -->
  <rule id="412411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0110 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>