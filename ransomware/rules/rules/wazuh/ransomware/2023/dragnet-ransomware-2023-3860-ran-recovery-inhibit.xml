<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3860 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: af49cfcd-a280-5fbe-9c6d-6a795c0209ab -->
  <rule id="992751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3860 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>