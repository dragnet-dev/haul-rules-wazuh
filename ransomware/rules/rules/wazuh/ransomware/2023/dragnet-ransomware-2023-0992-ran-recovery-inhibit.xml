<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0992 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ada7bf74-7654-53e5-9ed7-6add2b43f425 -->
  <rule id="913663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0992 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>