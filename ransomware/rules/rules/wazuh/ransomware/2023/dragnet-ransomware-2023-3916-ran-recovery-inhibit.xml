<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3916 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1e388a6a-d4f5-5f25-b329-d78aa894719d -->
  <rule id="462186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3916 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>