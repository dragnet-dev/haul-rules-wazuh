<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3570 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 66cc22c7-ef78-5fd4-b4da-61c1bc415591 -->
  <rule id="910022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3570 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>