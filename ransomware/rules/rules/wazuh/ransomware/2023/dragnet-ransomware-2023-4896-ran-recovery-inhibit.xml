<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4896 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f8a0dff9-4173-52ad-86f7-c07393333a7f -->
  <rule id="297503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4896 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>