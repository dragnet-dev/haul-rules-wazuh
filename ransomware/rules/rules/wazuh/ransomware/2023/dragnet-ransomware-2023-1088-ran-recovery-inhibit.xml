<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1088 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 98f50195-bc96-58a0-ba5f-738531fd3dff -->
  <rule id="783501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1088 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>