<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1867 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 515b7556-110f-5fd5-8817-c6eecaa072d9 -->
  <rule id="251755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1867 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>