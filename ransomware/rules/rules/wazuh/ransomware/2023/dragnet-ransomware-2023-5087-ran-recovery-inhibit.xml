<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5087 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 418d64b9-1527-513f-95ac-8532996c33a9 -->
  <rule id="922635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5087 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>