<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4765 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 64885fd5-cd39-55cf-9e9c-306e31e108f0 -->
  <rule id="238175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4765 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>