<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1341 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 33b5a546-8484-5b3d-8069-e4662b4d517c -->
  <rule id="633054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1341 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>