<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1781 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a834806e-1298-5327-b1d5-ba1ffb388398 -->
  <rule id="283480" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1781 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>