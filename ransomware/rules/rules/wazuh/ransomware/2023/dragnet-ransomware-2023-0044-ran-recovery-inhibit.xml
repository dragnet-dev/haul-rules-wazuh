<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0044 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5026008e-f5c4-5ca2-ba80-5c48574f8c19 -->
  <rule id="626008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0044 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>