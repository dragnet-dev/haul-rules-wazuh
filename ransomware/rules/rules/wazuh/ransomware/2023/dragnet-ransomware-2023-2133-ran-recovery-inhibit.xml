<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2133 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 7cbd8160-15f9-54f2-823c-51fb2abe178b -->
  <rule id="593381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2133 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>