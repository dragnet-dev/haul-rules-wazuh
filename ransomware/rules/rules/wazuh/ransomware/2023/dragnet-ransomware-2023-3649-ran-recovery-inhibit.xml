<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3649 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 38fb7945-ef7b-56e3-a099-628a652ac791 -->
  <rule id="179794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3649 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>