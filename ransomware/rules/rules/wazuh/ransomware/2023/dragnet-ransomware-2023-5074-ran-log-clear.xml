<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5074 — Event Log Clearing (rancoz) | Status: experimental | Sigma ID: 484caf6a-380e-5829-b7a9-883fd8f43c0e -->
  <rule id="285711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5074 — Event Log Clearing (rancoz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>