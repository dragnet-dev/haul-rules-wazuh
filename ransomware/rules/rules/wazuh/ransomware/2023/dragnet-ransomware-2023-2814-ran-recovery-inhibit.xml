<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2814 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 91151240-1d23-56e8-afd3-379ac5c11d0b -->
  <rule id="215124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2814 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>