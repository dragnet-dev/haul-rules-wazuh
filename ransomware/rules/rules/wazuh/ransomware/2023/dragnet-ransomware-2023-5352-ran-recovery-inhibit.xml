<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5352 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f567c792-b177-5161-a114-fb0846c5ab01 -->
  <rule id="790847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5352 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>