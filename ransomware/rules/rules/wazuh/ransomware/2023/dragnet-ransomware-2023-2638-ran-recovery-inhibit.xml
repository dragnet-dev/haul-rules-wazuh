<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2638 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 74c5b28c-bd8b-5de5-b388-97ba90f0af1f -->
  <rule id="214512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2638 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>