<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3551 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 3c8496b1-4acc-5dff-9b9a-e9bb5492d9f6 -->
  <rule id="835947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3551 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>