<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5211 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: f2bb23e3-b2c9-5bb1-a4fc-e425d15618ca -->
  <rule id="409923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5211 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>