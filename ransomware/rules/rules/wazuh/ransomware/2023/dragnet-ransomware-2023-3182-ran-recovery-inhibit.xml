<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3182 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bc87052a-bb64-5fb6-8452-551f05cf47cd -->
  <rule id="188705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3182 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>