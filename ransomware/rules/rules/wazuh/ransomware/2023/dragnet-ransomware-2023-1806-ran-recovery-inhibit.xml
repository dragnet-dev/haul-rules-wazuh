<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1806 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 68aa0675-f0c3-57cf-bd1b-2f756510a6b7 -->
  <rule id="957806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1806 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>