<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1849 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 15b064ea-04ea-5836-8289-fe66ba1087cb -->
  <rule id="517038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1849 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>