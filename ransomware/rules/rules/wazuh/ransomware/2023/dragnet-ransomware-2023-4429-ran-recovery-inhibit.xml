<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4429 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 87c21cd8-dbed-5afc-9ada-bd435a1d33f4 -->
  <rule id="546748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4429 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>