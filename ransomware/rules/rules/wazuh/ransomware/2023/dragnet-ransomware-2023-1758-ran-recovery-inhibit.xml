<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1758 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 7092adb7-ceca-5e70-bb83-df32afc9764b -->
  <rule id="115725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1758 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
