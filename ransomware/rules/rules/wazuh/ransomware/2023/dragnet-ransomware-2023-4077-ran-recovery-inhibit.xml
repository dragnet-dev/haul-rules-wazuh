<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4077 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 99f230b0-a1f8-5f19-9152-a15dac60b041 -->
  <rule id="799230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4077 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>