<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2794 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: aae3c602-bb1f-573e-b86d-39f2ccce0952 -->
  <rule id="875006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2794 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>