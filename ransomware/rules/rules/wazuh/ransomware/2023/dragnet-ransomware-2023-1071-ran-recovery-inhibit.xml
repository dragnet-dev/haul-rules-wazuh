<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1071 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 59a710ba-6c14-5443-b9f2-b8cd38a8deab -->
  <rule id="975371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1071 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>