<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4375 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4f3c7756-526a-5b8d-a127-d98e6e92f522 -->
  <rule id="470077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4375 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>