<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1582 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e1a955b9-b66f-53b4-abdb-557d72355fd2 -->
  <rule id="566955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1582 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>