<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4346 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: d3579480-6674-502e-9563-b31ea5b87d63 -->
  <rule id="535794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4346 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>