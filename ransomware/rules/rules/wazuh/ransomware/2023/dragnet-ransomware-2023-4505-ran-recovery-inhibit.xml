<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4505 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 9e090e4d-00b7-537a-880f-f1e59ac753f4 -->
  <rule id="829454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4505 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>