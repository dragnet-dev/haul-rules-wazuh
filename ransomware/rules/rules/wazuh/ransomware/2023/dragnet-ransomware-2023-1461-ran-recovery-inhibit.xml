<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1461 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7d51c18b-dd50-5fbe-9ac4-e65eb328e784 -->
  <rule id="308281" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1461 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>