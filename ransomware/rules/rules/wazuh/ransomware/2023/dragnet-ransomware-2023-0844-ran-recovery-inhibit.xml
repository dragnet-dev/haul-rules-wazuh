<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0844 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9d7b05ba-15be-50eb-b572-8e082c988d6d -->
  <rule id="824305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0844 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>