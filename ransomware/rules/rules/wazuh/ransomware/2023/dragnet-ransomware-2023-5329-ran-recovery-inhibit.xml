<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5329 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a8cf73d2-08d0-59f1-8c7e-570879b8354f -->
  <rule id="185573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5329 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>