<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0359 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: d5197dc4-88d9-52f2-9c16-ab59be80fa76 -->
  <rule id="463165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0359 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>