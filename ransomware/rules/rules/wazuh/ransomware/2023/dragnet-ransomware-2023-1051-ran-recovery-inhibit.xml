<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1051 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c3640878-3685-5458-bf49-c8cd48933673 -->
  <rule id="436408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1051 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>