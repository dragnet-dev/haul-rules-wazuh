<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1322 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 7090c028-8a82-5454-be9d-4befa621b9b7 -->
  <rule id="334520" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1322 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>