<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1828 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: cbd604ab-52f6-5478-961b-a328e3ca5967 -->
  <rule id="661604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1828 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>