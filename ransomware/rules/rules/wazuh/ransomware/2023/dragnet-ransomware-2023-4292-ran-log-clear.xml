<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4292 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 0d16d07d-bcac-5ba5-ac93-f754d67332d9 -->
  <rule id="406907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4292 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>