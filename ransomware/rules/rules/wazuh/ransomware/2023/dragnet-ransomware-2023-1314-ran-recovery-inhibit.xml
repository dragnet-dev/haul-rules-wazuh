<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1314 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0fcf3298-83fe-549e-b2cf-1765759644aa -->
  <rule id="547329" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1314 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>