<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0030 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: dccdf094-6c39-51ae-a9a9-c4ee00a2f384 -->
  <rule id="144150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0030 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>