<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0297 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 27dcb9d2-da97-550c-8fea-9cd7aab3c7cc -->
  <rule id="341239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0297 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>