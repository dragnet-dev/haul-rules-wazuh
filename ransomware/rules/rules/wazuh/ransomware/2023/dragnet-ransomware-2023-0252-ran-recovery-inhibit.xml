<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0252 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 93939e6b-92a3-5e29-bc01-2d52bfac7e2c -->
  <rule id="703038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0252 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>