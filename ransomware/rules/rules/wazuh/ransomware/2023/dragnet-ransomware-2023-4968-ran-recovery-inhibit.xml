<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4968 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 326758a8-af03-5463-8818-2d07bed9c460 -->
  <rule id="828138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4968 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>