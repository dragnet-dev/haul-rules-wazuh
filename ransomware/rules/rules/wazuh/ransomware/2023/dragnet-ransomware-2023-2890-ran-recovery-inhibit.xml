<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2890 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: af34d480-9509-5ba2-a450-996e065846b4 -->
  <rule id="205574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2890 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>