<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5049 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: bef294bf-1805-56ff-ad32-7e1907e6a35e -->
  <rule id="455294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5049 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>