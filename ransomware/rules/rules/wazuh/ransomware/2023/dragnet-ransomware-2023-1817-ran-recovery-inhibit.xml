<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1817 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: af10d1cf-9a93-5598-9d96-0ea25fd7a49c -->
  <rule id="201731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1817 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>