<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0940 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 99402b37-3e05-5020-b329-df241d87da3d -->
  <rule id="790443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0940 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>