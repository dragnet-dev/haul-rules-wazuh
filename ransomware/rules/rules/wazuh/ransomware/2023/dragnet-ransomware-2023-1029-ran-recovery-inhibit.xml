<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1029 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: e3579911-f7c6-59ba-85c6-f501860a09aa -->
  <rule id="635799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1029 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>