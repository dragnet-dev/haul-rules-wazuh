<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2969 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d3e4e886-d85c-54a0-aa76-945124e43761 -->
  <rule id="827988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2969 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>