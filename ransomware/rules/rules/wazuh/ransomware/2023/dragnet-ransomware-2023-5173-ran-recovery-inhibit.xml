<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5173 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 34a18fb4-fa28-5ed8-93a4-2848d28455ef -->
  <rule id="787259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5173 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>