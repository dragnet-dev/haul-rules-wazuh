<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5229 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 2bb7086d-634c-579f-a62d-4d0f265c90c3 -->
  <rule id="797086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5229 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>