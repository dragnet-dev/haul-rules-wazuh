<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0056 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b49c00cc-b811-5bba-b192-712a0ff5b1d4 -->
  <rule id="139600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0056 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>