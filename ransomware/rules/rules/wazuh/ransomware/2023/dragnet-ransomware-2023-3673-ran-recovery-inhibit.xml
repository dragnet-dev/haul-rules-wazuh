<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3673 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 78ccfd77-4dbd-5c48-8850-5de4d9747427 -->
  <rule id="764285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3673 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>