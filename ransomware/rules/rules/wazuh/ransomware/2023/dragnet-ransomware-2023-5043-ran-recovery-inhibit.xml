<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5043 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3da89146-9d16-543d-8111-b721b77b86c5 -->
  <rule id="968914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5043 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>