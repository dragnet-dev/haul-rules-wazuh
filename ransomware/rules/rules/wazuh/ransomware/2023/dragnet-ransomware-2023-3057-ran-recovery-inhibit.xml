<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3057 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 41995190-c297-57bd-96bd-225c874037a2 -->
  <rule id="699519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3057 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>