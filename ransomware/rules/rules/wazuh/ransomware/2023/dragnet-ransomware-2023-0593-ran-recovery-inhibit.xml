<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0593 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3a2c791b-ce93-568f-95f0-1273612e4503 -->
  <rule id="424791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0593 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
