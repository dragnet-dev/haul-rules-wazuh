<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2476 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: d1538c51-8897-5311-a4c6-ba70f75dd7f5 -->
  <rule id="404620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2476 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>