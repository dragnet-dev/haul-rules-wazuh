<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0704 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 321316c6-127f-59a1-80ee-ef8f0d119b1b -->
  <rule id="741068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0704 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>