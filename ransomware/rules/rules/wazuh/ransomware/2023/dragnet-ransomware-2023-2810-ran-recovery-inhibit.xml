<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2810 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 938a0903-b4fa-5113-9430-9c3f1bf0573e -->
  <rule id="701809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2810 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>