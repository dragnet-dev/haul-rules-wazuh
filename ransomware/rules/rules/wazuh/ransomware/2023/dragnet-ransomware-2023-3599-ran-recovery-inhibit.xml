<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3599 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: a5b3f6e0-9163-580b-a959-d92259bdf6e6 -->
  <rule id="106236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3599 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>