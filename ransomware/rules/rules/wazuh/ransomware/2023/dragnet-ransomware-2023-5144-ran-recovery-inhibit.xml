<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5144 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ec585838-87fa-5a04-b566-738188d8e047 -->
  <rule id="665858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5144 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>