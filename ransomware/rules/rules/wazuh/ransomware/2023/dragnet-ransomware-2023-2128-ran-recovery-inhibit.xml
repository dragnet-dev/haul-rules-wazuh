<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2128 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d893df56-8a3f-5f2f-bd22-4c8aab988d48 -->
  <rule id="956831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2128 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>