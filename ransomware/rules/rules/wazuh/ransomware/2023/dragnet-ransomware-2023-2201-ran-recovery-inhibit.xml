<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2201 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c14d1e76-bce6-5166-bedc-50706db99b67 -->
  <rule id="509950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2201 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>