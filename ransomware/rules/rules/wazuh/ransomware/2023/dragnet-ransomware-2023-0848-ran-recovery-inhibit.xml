<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0848 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: c7e49c8c-ff54-5d96-bef9-ce5ca5e1eeec -->
  <rule id="674396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0848 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>