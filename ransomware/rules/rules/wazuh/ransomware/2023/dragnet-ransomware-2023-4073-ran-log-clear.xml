<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4073 — Event Log Clearing (daixin) | Status: deprecated | Sigma ID: 6df82430-78b5-5591-95e4-3bb1ac53a2ae -->
  <rule id="959824" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4073 — Event Log Clearing (daixin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>