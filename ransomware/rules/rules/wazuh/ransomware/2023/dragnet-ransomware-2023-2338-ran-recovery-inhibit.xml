<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2338 — Recovery Inhibition (darkrace) | Status: experimental | Sigma ID: 6278d793-e8f7-5eb4-8899-51fbd6a62693 -->
  <rule id="204617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2338 — Recovery Inhibition (darkrace)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>