<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3993 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 9dba9a11-377a-511a-a365-bc732438eb56 -->
  <rule id="260634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3993 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>