<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0083 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 9e4f1e81-ee4b-51d0-98bd-fa2c02a82673 -->
  <rule id="557470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0083 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>