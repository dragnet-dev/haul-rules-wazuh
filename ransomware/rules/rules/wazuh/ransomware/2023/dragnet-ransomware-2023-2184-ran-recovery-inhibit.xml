<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2184 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 132d4e75-fc6f-53bf-8bfa-0041c06de59d -->
  <rule id="800787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2184 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>