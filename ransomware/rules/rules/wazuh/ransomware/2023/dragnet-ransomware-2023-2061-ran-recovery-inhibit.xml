<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2061 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bf371258-1002-5a9d-94ba-61dbdc5a9777 -->
  <rule id="213712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2061 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>