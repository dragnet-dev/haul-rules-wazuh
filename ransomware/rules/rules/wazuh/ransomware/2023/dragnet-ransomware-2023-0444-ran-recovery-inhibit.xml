<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0444 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 675d2095-717a-5a40-9194-0c7661b39957 -->
  <rule id="281320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0444 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>