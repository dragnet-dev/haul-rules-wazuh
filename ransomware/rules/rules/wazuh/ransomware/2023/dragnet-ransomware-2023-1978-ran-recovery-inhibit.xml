<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1978 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 90081bfe-6d9f-51bf-ba0f-5636648b77b7 -->
  <rule id="641307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1978 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>