<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4244 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 24ef0b9c-fe72-580e-a7fe-fc967e759f9e -->
  <rule id="221291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4244 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>