<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0206 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e5a7b0cf-e8d0-5256-8b93-64a9509f58c3 -->
  <rule id="229230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0206 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>