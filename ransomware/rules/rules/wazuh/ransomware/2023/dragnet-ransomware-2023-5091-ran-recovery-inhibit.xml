<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5091 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6d9ca0df-e1cf-53b3-b2bd-5278fbb4b6d6 -->
  <rule id="215460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5091 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>