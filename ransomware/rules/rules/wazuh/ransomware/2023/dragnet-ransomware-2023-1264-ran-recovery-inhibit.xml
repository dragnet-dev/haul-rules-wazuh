<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1264 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1aaa1254-b5b6-5917-9820-398fbff4e364 -->
  <rule id="626125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1264 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>