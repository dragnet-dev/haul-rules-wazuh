<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2930 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 010f4aed-1bc3-5363-8872-5f8efb747996 -->
  <rule id="987181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2930 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>