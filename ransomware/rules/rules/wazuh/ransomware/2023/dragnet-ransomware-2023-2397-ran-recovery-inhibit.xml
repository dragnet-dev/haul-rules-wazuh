<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2397 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 32113b00-78d5-55b6-ae39-8b1a2488e6a4 -->
  <rule id="738190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2397 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>