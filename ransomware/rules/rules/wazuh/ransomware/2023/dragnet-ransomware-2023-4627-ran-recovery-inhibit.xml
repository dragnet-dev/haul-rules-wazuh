<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4627 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7e04389f-0762-5e7b-bb01-d1f9d8cafb55 -->
  <rule id="460438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4627 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>