<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4111 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 55d32578-fc05-53f9-bb84-6944fef5918d -->
  <rule id="933257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4111 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>