<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2575 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 394b6e9b-d8b5-53e6-a0f1-5a92dc340e88 -->
  <rule id="210510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2575 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>