<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0602 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d69008cb-c0d0-5e8f-b786-5727b0dbb360 -->
  <rule id="569008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0602 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>