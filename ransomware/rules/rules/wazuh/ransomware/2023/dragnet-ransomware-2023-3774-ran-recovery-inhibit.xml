<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3774 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c08a3777-2555-5cee-8535-0d50dd69748b -->
  <rule id="233837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3774 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>