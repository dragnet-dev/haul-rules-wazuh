<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5088 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: dabad903-8300-5dd1-a504-11250032e717 -->
  <rule id="959179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5088 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>