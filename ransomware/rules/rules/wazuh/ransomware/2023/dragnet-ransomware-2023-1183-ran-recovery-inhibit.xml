<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1183 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c1d834bf-3466-542d-b6eb-e1be88e16331 -->
  <rule id="249834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1183 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>