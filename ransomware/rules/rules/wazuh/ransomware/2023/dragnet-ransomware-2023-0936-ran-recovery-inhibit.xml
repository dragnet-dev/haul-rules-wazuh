<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0936 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bc567982-78bd-519d-a662-04d69b60351e -->
  <rule id="185679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0936 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>