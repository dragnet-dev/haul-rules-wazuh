<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3432 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 80602d2b-719d-5b44-a970-4e92e6e68f48 -->
  <rule id="489645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3432 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>