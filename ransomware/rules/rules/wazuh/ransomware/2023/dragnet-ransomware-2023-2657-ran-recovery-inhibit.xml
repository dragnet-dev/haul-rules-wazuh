<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2657 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: dcb1adf3-af8a-5c63-8174-ed0e91940e7e -->
  <rule id="139789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2657 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>