<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2329 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a8b055d3-bcd8-5988-a2b9-438d38ef27e9 -->
  <rule id="939055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2329 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>