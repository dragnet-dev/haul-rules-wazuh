<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1126 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: a81c96b9-1ab1-5f3c-9216-bbde7e6bbf9f -->
  <rule id="930896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1126 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>