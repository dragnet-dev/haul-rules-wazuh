<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0651 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: d7be9049-6f29-5f9f-91bc-ac1c4454a618 -->
  <rule id="926290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0651 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>