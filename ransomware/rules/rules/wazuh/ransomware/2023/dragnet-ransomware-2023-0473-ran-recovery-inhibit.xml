<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0473 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 85ece201-44cb-5c1a-a84a-5ef7738f2600 -->
  <rule id="919502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0473 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>