<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4168 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 4a2bcf31-3f07-50f7-a4fc-187e2f122d04 -->
  <rule id="442255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4168 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>