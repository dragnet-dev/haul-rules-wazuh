<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0682 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 9d309a81-fe36-5c1b-a712-925e64d0da54 -->
  <rule id="816954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0682 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>