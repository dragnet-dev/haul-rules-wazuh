<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3362 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: ff96929b-ab35-5655-beb0-fdcf1a9f23dc -->
  <rule id="859692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3362 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>