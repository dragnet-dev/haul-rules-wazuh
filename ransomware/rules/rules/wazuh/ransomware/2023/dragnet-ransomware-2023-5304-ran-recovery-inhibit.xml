<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5304 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5d7b46de-91e7-5981-a912-3b7fc462a88f -->
  <rule id="700346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5304 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>