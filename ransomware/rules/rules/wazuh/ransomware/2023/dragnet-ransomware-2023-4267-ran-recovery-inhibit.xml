<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4267 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7b17b8b5-5826-5714-a9fc-b2481c6765bf -->
  <rule id="270838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4267 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>