<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3522 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c509f818-e170-587a-ade3-d33a5e1593d2 -->
  <rule id="301598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3522 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>