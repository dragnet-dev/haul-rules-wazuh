<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3492 — Event Log Clearing (malekteam) | Status: experimental | Sigma ID: 9c416662-3a3d-59d0-afc8-74940ae093dd -->
  <rule id="764166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3492 — Event Log Clearing (malekteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>