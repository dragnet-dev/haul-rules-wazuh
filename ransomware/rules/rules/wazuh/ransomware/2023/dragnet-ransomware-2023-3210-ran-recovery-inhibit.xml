<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3210 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 278413aa-a42b-53ed-a569-9d281b67576b -->
  <rule id="954618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3210 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>