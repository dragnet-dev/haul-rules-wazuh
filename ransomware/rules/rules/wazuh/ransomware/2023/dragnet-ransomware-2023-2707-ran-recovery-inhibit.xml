<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2707 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b724ec6c-f17d-5f09-bde5-f3de89a1720e -->
  <rule id="401580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2707 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>