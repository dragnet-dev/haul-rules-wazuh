<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1546 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: c1cc9b87-ecc6-5e32-864c-7f7ab4e5cee2 -->
  <rule id="588955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1546 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>