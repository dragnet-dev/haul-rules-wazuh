<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4710 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 66496bd3-9fc5-5d56-a6c7-ba0a9b73bd9f -->
  <rule id="263947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4710 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>