<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4081 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1f9ecf33-2955-553a-84c6-58fc475358d0 -->
  <rule id="510415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4081 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>