<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5086 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 18410c32-ddc9-5c3e-adc4-ac868832eefb -->
  <rule id="345723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5086 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>