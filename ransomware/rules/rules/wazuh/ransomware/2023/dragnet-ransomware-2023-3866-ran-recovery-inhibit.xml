<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3866 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6aabaf62-880a-52ae-8ef5-0ee7c7511d20 -->
  <rule id="790767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3866 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>