<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4386 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 731403f1-66bf-50f8-9fe8-068899f99d6e -->
  <rule id="102463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4386 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>