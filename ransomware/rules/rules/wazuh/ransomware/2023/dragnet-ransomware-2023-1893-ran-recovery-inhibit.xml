<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1893 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3fbbe62c-a38f-597c-b2e3-a59086329192 -->
  <rule id="910546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1893 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>