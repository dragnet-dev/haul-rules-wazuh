<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2836 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: e661fca8-388a-5c62-a381-93b2d68aec8d -->
  <rule id="253468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2836 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>