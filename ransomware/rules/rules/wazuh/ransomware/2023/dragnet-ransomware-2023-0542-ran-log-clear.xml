<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0542 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: 1554030d-0cdd-571e-8be1-a20ec2698f85 -->
  <rule id="754030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0542 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>