<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1047 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 35ab8a9f-6cd7-5c00-afbb-805215cf9512 -->
  <rule id="661098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1047 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>