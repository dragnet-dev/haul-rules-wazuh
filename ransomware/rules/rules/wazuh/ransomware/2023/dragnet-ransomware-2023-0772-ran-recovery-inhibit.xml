<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0772 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: b86337b2-b429-5de0-bd90-562225df9daa -->
  <rule id="386337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0772 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
