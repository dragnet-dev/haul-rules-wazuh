<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4197 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 1dfa4eda-dcdf-5138-afbd-114fa070e2dd -->
  <rule id="427918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4197 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>