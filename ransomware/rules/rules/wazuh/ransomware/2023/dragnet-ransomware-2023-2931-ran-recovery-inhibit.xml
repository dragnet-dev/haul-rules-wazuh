<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2931 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 00d81926-5652-56ef-8e7d-529aa6d37821 -->
  <rule id="581926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2931 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>