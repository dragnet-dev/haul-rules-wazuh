<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1779 — Recovery Inhibition (raznatovic) | Status: experimental | Sigma ID: 36348c40-eaa0-5ede-8197-65b035a9ae7d -->
  <rule id="515804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1779 — Recovery Inhibition (raznatovic)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>