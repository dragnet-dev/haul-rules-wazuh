<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5333 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: dc392f15-a633-557e-b3a1-a565f2dd8004 -->
  <rule id="926287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5333 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>