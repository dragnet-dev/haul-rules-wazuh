<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1656 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 53acd7c6-6952-5a68-991c-732e1f6ce5fd -->
  <rule id="498537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1656 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>