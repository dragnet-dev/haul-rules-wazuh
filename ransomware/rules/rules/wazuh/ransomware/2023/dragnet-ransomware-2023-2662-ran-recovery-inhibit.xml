<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2662 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4105bcf6-253d-5dc4-95b2-f0ba35a9c62d -->
  <rule id="251068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2662 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>