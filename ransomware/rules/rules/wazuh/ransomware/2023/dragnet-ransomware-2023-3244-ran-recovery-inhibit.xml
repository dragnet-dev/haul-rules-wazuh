<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3244 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9f53e5cd-137c-5d43-911c-ce18b28fa1a2 -->
  <rule id="852625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3244 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>