<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4940 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: faab2434-aa6b-5149-a980-cc08e2a27d59 -->
  <rule id="217124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4940 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>