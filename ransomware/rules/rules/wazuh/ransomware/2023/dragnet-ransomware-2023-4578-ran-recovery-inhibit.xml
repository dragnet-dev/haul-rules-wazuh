<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4578 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: f5755c5e-3c6f-5b24-8700-2a5a771f1139 -->
  <rule id="792092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4578 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>