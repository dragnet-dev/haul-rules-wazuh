<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0938 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 59e429b5-5ad4-56e1-a1f9-b013c936e2ec -->
  <rule id="134875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0938 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>