<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0798 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 734874fe-e049-535f-b502-638b175edfe1 -->
  <rule id="157999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0798 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>