<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0613 — Event Log Clearing (play) | Status: deprecated | Sigma ID: 489434b6-8c8f-5d0c-bf8c-f9c03f899f45 -->
  <rule id="730955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0613 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>