<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5103 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: c027875a-f78d-5b64-8a75-162eb65151b2 -->
  <rule id="402787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5103 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>