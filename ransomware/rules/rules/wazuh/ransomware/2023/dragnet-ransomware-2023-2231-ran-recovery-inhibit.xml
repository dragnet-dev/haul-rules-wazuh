<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2231 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 814e93a7-2e95-518a-94ea-bc87ab4bd96e -->
  <rule id="503893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2231 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>