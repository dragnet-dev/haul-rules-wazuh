<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2477 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 282985fc-7c02-5680-b83f-9d262101fdb5 -->
  <rule id="127775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2477 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>