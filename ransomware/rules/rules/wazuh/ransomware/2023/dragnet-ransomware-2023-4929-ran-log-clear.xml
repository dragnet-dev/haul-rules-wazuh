<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4929 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 4b922f4b-730f-50a7-8aaa-a0af0fb0055f -->
  <rule id="414767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4929 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>