<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1427 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: b74428dd-e605-5b2e-be96-c96aa9a86aed -->
  <rule id="374428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1427 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>