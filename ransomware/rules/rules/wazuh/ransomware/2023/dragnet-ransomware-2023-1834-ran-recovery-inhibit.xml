<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1834 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4934acbb-212e-58aa-a80e-f135ec844806 -->
  <rule id="463276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1834 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>