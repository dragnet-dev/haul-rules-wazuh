<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0481 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 12931b92-a2f3-589e-b092-a44340a5cb48 -->
  <rule id="369079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0481 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>