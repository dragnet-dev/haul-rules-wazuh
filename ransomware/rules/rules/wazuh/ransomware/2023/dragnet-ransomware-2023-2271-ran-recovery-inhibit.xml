<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2271 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: da2cfd7c-698b-5b98-b074-9a4b7b91066a -->
  <rule id="940797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2271 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>