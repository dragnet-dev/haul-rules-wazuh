<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2723 — Event Log Clearing (moneymessage) | Status: experimental | Sigma ID: cf761190-0fc2-538a-bab5-6716f5358864 -->
  <rule id="377611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2723 — Event Log Clearing (moneymessage)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>