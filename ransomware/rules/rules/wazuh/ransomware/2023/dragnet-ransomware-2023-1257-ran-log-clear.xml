<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1257 — Event Log Clearing (blacklock) | Status: experimental | Sigma ID: 6b7f577e-5ed2-5008-b43d-116f00b6807f -->
  <rule id="924757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1257 — Event Log Clearing (blacklock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>