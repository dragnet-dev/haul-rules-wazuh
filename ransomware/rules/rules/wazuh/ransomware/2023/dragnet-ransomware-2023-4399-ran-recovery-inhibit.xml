<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4399 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: cb80a24b-f411-5842-b69f-e8c2a13201c7 -->
  <rule id="660902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4399 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>