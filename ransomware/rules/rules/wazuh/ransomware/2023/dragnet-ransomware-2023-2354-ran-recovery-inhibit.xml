<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2354 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: cbb961fa-e320-54d2-a84b-cb6f8fee01e6 -->
  <rule id="659961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2354 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>