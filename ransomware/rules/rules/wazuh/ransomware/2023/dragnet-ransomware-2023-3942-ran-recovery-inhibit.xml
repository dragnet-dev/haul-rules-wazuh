<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3942 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fd623e34-11cf-51fb-81c3-47cfec1e74d3 -->
  <rule id="557982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3942 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>