<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4349 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b5d7080d-a8e7-5342-9ea7-66e9768e975f -->
  <rule id="153708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4349 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>