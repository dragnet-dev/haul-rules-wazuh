<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2502 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 8b2404f6-5032-5e7a-890f-c936dad04d27 -->
  <rule id="592404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2502 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>