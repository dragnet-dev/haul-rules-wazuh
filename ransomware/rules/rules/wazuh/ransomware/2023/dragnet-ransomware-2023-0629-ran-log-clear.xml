<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0629 — Event Log Clearing (siegedsec) | Status: experimental | Sigma ID: df4b5433-0c2d-545b-b998-e1bb5ec044b8 -->
  <rule id="975554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0629 — Event Log Clearing (siegedsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>