<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4008 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: d8fc8a0b-a0f0-58c9-a185-22fe039ce6bb -->
  <rule id="392938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4008 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>