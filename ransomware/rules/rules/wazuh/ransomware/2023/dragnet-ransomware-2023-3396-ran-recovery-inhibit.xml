<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3396 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1457c527-ab7c-5a49-a05a-7b117b715025 -->
  <rule id="632452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3396 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>