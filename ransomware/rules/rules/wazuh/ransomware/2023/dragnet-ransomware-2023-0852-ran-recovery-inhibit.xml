<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0852 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 69acc78a-978b-5176-8284-90c5af5f648d -->
  <rule id="253887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0852 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>