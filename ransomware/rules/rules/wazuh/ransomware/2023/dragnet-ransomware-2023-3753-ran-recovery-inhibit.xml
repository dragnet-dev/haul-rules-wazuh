<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3753 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6c3680e5-1f3f-57b5-92d7-631579fc908d -->
  <rule id="283680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3753 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>