<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0799 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8949704e-372b-524b-91cb-e2f57e8950d1 -->
  <rule id="949704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0799 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>