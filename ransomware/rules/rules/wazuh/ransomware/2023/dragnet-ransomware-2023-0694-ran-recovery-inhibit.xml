<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0694 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 24685737-49af-589d-82ff-1ddba24be93f -->
  <rule id="768573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0694 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>