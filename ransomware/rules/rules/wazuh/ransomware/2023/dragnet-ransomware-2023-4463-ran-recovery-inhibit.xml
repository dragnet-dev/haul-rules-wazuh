<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4463 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 26659ecc-860b-586b-9ecb-793c042a0850 -->
  <rule id="624940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4463 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>