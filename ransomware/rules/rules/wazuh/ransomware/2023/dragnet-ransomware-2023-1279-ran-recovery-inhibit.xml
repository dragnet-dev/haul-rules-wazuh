<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1279 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f93af7dc-553e-5384-8e1e-ae76d6ccd82f -->
  <rule id="579837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1279 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>