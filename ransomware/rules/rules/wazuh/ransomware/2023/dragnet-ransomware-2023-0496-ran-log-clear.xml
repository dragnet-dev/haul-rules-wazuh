<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0496 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 2959cadc-abf4-5f29-8a1b-f357ff6b7000 -->
  <rule id="523309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0496 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>