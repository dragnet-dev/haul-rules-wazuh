<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0086 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8291d788-6101-5b02-a8d7-bc65527a6fea -->
  <rule id="526697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0086 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>