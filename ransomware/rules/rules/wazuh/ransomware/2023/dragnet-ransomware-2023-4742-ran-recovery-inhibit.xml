<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4742 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 96a30efe-e0a8-5891-ab24-34cf9cbdb931 -->
  <rule id="774094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4742 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>