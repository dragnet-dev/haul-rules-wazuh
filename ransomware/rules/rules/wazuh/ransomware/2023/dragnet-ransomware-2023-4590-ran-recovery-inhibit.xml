<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4590 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 538ee581-ecbf-51b4-93d3-c7243c580a45 -->
  <rule id="579665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4590 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>