<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2087 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 64eda03c-2602-5a33-a569-41f60cd05347 -->
  <rule id="959460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2087 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>