<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3701 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 698e1e40-3cfd-5b50-997c-01658eaece7f -->
  <rule id="989150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3701 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>