<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1393 — Recovery Inhibition (mallox) | Status: deprecated | Sigma ID: 75def205-54c4-5280-b709-f9de313e1fdf -->
  <rule id="507672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1393 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>