<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0073 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 335741e0-5c0e-5f29-9b3a-c4467fb7c385 -->
  <rule id="971870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0073 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>