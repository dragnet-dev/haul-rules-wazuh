<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5030 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 30ecbfe5-8f26-54ba-b55a-4c70ff4e3d8c -->
  <rule id="326687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5030 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>