<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4148 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 49cc2ead-46e8-55d4-b3f3-698c4cf8902a -->
  <rule id="339726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4148 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>