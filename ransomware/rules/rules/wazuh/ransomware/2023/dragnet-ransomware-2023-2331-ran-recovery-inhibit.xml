<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2331 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d1026e21-b070-5d05-ae92-23eed8931d9d -->
  <rule id="396430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2331 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>