<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2982 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: d00c1e9a-6096-512c-9171-035649519e66 -->
  <rule id="729950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2982 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>