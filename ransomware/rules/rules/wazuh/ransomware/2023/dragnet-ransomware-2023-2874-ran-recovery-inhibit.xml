<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2874 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: cfd23144-f191-5e39-9d15-8d4750a85ea4 -->
  <rule id="725231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2874 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>