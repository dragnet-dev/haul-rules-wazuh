<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3777 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f05c9c59-83ba-57f7-a44f-b63abb072f61 -->
  <rule id="354876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3777 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>