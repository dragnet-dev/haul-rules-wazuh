<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3983 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 2a7c77c7-192c-5d0c-bebf-cf4142b9acb4 -->
  <rule id="251644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3983 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>