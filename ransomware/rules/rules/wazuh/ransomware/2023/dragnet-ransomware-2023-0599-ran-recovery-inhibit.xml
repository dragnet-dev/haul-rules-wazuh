<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0599 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 9b07f096-a27d-5925-909f-cd2fe882f8e1 -->
  <rule id="781270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0599 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>