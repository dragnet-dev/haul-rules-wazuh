<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1375 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: de7c7ad2-01bc-5c7f-9d42-08e98fb17a26 -->
  <rule id="403162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1375 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>