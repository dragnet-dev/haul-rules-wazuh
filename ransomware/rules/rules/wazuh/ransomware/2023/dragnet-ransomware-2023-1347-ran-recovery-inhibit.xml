<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1347 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 0287fa8b-0804-56ce-ba62-8978f29e6908 -->
  <rule id="195659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1347 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>