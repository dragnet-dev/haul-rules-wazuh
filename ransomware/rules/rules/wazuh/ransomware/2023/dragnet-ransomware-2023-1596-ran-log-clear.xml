<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1596 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 3f9e09ba-51c5-5fbd-a4a6-27a075abea7d -->
  <rule id="223809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1596 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>