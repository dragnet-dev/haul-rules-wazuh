<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1975 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 6e99d570-f6f3-58d6-82d6-fcc840b15d1d -->
  <rule id="975975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1975 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>