<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5026 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: ce98fdf4-58c0-531e-8bfc-ab6a18a6edcd -->
  <rule id="898941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5026 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>