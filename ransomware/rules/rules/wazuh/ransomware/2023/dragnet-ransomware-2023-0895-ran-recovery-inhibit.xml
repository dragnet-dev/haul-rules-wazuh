<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0895 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1f396d91-ada6-5f7f-b182-ed69e0b26df7 -->
  <rule id="623499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0895 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>