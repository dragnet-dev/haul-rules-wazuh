<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0635 — Event Log Clearing (werewolves) | Status: experimental | Sigma ID: f1b12ad5-a443-5790-8c9b-ff0f62cf46c8 -->
  <rule id="383402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0635 — Event Log Clearing (werewolves)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>