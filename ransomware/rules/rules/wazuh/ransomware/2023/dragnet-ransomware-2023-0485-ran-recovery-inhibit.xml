<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0485 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7aac7f92-6756-52f1-8619-13a283303b98 -->
  <rule id="624767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0485 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>