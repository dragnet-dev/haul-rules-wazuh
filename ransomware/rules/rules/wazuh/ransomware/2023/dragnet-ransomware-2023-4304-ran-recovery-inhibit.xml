<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4304 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 9d9a8f2d-8e49-58d4-8fda-54f9830c4ab8 -->
  <rule id="543983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4304 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>