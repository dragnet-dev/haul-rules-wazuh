<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2500 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 97fc2d59-3ae6-5f16-a2fc-82f90ff48eca -->
  <rule id="513485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2500 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>