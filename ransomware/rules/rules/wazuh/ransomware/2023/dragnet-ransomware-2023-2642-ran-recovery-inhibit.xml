<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2642 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e045653e-1f7c-5e5e-92c9-f7f8443f79f7 -->
  <rule id="604565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2642 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>