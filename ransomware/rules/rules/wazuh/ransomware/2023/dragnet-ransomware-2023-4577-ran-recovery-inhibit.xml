<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4577 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 31fa1755-624d-5489-be77-f8c11f0e36ad -->
  <rule id="186175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4577 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>