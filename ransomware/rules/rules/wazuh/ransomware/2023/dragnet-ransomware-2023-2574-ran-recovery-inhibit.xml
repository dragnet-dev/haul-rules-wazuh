<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2574 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 49ecfba2-3af5-54ed-b00a-ef4c73707647 -->
  <rule id="671931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2574 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>