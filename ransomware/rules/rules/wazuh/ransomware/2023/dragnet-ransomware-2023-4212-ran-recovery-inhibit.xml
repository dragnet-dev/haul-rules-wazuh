<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4212 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 5474ce50-d423-5190-9797-ea0b8f58ffad -->
  <rule id="601550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4212 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
