<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3009 — Event Log Clearing (play) | Status: experimental | Sigma ID: 9cfd15f8-2f3a-53c3-bff8-d00eb3c5f8f1 -->
  <rule id="518915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3009 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>