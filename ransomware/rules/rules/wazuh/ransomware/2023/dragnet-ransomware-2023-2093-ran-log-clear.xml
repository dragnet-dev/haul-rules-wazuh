<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2093 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: cb07c77a-9ad6-5f4e-abe7-e144f33d1494 -->
  <rule id="649247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2093 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>