<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1371 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d34255d3-c70d-5c59-ae70-d63d6be9e1eb -->
  <rule id="534255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1371 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>