<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2565 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 0cf66699-d6b0-5866-98a3-dddb94ec070c -->
  <rule id="376669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2565 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>