<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2823 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 37312f04-eeb8-5b20-be9d-dfab45a2ee89 -->
  <rule id="670070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2823 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>