<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2441 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 332a7a01-ae65-567e-8eed-4731c7302da8 -->
  <rule id="516420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2441 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>