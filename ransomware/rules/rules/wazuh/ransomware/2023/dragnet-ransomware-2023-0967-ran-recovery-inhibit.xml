<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0967 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 121fb0cf-455b-5e8c-b7bf-aa2bd5d5691c -->
  <rule id="596332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0967 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>