<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1654 — Recovery Inhibition (cryptnet) | Status: experimental | Sigma ID: 5bb3e4ee-f9ca-5d56-959d-42d43bcd10e5 -->
  <rule id="647824" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1654 — Recovery Inhibition (cryptnet)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>