<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0997 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: be42ce1e-9c5a-5ce7-8e65-02ad7d0b2b23 -->
  <rule id="474958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0997 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>