<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0333 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: c048868a-171b-5e90-930b-cadba544b85f -->
  <rule id="404886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0333 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>