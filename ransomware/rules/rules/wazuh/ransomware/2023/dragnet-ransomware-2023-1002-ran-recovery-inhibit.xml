<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1002 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 74795c68-ef72-5321-b4ef-aad3a1151acd -->
  <rule id="396732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1002 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>