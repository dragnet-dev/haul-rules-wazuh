<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1830 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: d388cc6e-d078-55b4-8291-751bcc02f5e6 -->
  <rule id="827532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1830 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>