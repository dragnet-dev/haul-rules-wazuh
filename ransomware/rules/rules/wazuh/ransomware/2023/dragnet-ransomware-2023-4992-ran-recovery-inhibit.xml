<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4992 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5a8883da-2268-5ce1-bccf-7022161e4135 -->
  <rule id="242141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4992 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>