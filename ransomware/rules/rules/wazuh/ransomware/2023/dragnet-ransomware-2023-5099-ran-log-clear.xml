<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5099 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 4b09e58e-b7f7-5273-83a1-16b21cd98fb9 -->
  <rule id="401585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5099 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>