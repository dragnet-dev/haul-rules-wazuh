<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4541 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: a7151a46-57ab-5524-90f3-40bfaca2300d -->
  <rule id="914426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4541 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>