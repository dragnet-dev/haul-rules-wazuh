<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3625 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 43b402a6-b02d-5c12-a582-9dcd0ec7c13d -->
  <rule id="490442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3625 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>