<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3882 — Event Log Clearing (darkpower) | Status: experimental | Sigma ID: cfb30899-6dcf-5424-afe6-f7b9cb11e93b -->
  <rule id="723308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3882 — Event Log Clearing (darkpower)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>