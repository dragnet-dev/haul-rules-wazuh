<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2828 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 4fdb9839-a123-5375-8d66-dc13f67400ec -->
  <rule id="344398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2828 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>