<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0218 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8b018f97-6332-5af9-a70d-2e462bbb4935 -->
  <rule id="524303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0218 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>