<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1589 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: f456598e-5376-5957-927d-3cf9ba26ee6b -->
  <rule id="745659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1589 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>