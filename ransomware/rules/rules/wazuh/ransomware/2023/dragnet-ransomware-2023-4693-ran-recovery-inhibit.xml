<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4693 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 98c211b2-3905-5cab-97ce-afbd3707f195 -->
  <rule id="780211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4693 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>