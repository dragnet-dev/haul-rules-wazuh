<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4151 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 9c68ffa9-5db7-5aa3-a183-0c514a7296da -->
  <rule id="511263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4151 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>