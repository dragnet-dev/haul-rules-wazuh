<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2923 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 2e01ece3-dd3c-506e-ac0d-5a55d9b5626f -->
  <rule id="378092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2923 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>