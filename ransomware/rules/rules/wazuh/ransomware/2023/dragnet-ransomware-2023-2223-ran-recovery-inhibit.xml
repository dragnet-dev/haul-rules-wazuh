<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2223 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3718abcc-a947-5c66-b308-5036900cbf38 -->
  <rule id="931676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2223 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>