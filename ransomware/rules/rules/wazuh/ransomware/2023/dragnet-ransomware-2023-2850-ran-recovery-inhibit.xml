<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2850 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 58facf0f-ff08-51e7-8f17-8f01d81bb504 -->
  <rule id="365295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2850 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>