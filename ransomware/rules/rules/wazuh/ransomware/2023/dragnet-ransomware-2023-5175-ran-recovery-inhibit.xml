<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5175 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: f273f8ff-d002-52af-8b0d-e0a5db0d5cd3 -->
  <rule id="743838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5175 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>