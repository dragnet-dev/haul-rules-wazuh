<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0524 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: f39c21c9-86de-550f-a275-be8d9f9baf75 -->
  <rule id="763621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0524 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>