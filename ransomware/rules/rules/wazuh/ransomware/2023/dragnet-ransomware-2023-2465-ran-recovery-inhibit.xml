<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2465 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: fd74d5fb-b481-5b03-8d38-6cef252648e5 -->
  <rule id="559975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2465 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>