<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0932 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 7e661996-e2bc-530c-be67-01a052846cd3 -->
  <rule id="466619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0932 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>