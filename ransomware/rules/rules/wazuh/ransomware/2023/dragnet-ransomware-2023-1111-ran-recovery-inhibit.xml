<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1111 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1cc4539e-4b8e-5bae-aec7-ab6efef88123 -->
  <rule id="204539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1111 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>