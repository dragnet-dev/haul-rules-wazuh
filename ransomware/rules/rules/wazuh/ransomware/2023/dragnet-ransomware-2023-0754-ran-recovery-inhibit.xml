<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0754 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2c6dcb35-fdb0-5dce-ad4c-aaa1fa121b88 -->
  <rule id="130347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0754 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>