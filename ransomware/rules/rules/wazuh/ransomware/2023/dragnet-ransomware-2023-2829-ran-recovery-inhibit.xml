<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2829 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 5d4c29ef-23ab-54ea-8e00-bf703fdb0604 -->
  <rule id="695629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2829 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>