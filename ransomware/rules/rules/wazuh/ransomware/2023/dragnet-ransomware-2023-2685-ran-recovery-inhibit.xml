<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2685 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ebd4f552-c908-512e-972c-93da0907f435 -->
  <rule id="737595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2685 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>