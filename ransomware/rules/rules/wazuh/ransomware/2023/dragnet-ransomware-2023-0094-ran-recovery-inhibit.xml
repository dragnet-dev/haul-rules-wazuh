<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0094 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f1b70325-f98b-5c22-9604-32b7483e5312 -->
  <rule id="727703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0094 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>