<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4558 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 6fa8241f-1a50-5051-9e51-6b87da1d6fa8 -->
  <rule id="986824" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4558 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>