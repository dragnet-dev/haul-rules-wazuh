<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3028 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b998a465-536f-5f87-8208-1f7bc1d9f538 -->
  <rule id="219784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3028 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>