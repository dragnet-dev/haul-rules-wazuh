<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4370 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6af978f5-544f-57a1-91f6-493d062f3883 -->
  <rule id="911978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4370 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>