<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1384 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 50d19ea8-50ef-55fb-8e83-e8af31c5707a -->
  <rule id="501118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1384 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>