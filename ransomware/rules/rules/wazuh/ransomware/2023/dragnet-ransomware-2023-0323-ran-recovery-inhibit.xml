<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0323 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6ff554e0-668b-51e6-81a4-47f72602b3cf -->
  <rule id="991554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0323 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>