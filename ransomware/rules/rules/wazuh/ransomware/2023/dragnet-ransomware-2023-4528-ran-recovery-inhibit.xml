<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4528 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: efbec842-0c0a-5165-8473-dbe286b5a02a -->
  <rule id="919968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4528 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>