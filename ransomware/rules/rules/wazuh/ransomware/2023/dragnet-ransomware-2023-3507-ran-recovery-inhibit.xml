<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3507 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e633534a-2a8e-55cd-bc13-f177d35ad6a6 -->
  <rule id="663353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3507 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>