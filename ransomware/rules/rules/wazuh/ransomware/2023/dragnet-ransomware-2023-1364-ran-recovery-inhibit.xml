<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1364 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 57a3109f-36aa-5c66-90ba-6de18bf4cd21 -->
  <rule id="323109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1364 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>