<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0875 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0ec3627a-eebd-5b35-9ea4-450941c9b85e -->
  <rule id="663627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0875 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
