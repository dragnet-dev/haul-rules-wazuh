<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4496 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 28f89e14-5822-578b-bf17-794a1a086d88 -->
  <rule id="322381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4496 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>