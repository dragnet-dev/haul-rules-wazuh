<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5214 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 461ba162-f8cf-5136-8d09-356dfbe05613 -->
  <rule id="382021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5214 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>