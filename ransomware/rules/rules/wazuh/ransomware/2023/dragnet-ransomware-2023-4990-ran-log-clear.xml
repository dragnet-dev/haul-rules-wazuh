<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4990 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 6c7fe6c1-9f0f-548a-82ce-79bcd97001f2 -->
  <rule id="185266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4990 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>