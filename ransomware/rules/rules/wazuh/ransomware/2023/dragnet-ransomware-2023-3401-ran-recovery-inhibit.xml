<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3401 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: cb600842-07de-5c0f-b873-0442f2c0ea1b -->
  <rule id="336008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3401 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>