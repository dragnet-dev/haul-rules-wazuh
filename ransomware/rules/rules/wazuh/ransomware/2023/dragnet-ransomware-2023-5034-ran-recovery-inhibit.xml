<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5034 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6b43544c-c76f-5f5c-b9d6-5eb699850d66 -->
  <rule id="274354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5034 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>