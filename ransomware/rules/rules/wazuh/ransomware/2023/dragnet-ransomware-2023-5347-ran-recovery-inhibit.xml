<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5347 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: cd375992-9247-569f-bb7e-7d396c1b4234 -->
  <rule id="353759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5347 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>