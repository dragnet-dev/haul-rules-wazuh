<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4870 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ab0a15b6-c883-5981-af9a-90a677ffdf07 -->
  <rule id="137015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4870 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>