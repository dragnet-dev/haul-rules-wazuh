<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4680 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8a6a75e9-7f06-51c1-aca9-bc91137c3c38 -->
  <rule id="518675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4680 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>