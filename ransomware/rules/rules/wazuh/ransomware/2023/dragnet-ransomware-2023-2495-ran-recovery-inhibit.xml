<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2495 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 78af01c8-6df6-5c3b-a108-99dfcfc25f42 -->
  <rule id="314301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2495 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>