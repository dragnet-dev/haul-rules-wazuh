<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2575 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 28df2308-33b1-57c8-83cf-4831e5878d66 -->
  <rule id="291230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2575 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>