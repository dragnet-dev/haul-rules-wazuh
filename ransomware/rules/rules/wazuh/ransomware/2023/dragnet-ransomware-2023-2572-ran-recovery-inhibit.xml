<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2572 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 99bca8ad-ac16-56a9-a848-b1f1dd561a4e -->
  <rule id="585228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2572 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>