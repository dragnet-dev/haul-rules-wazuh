<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1246 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 773ba3cf-ffe9-56e4-b5ca-4fae3d7fd7e4 -->
  <rule id="280743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1246 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>