<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5011 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4d48fd0f-0d2d-552d-b7a1-dfd4437544c1 -->
  <rule id="283741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5011 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>