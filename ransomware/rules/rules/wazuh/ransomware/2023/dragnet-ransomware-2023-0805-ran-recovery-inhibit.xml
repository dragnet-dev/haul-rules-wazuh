<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0805 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fa175b59-7116-54b0-9ce3-d24318883f8f -->
  <rule id="502811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0805 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>