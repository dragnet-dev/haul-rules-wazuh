<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4630 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 7fb49d7c-20a0-583f-be12-fe61c7f14027 -->
  <rule id="669597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4630 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>