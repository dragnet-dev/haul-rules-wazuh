<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2775 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: ea3b20ba-ac17-5d15-8fb9-6af1d5a6d542 -->
  <rule id="249920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2775 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>