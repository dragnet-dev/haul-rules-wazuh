<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4308 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 3aa674fc-c7f4-5bc2-9ab6-e4123b19b1bb -->
  <rule id="718799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4308 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>