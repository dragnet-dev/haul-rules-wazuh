<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3086 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 99a9126d-5db2-58b3-8eed-89c0c23e9331 -->
  <rule id="794912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3086 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>