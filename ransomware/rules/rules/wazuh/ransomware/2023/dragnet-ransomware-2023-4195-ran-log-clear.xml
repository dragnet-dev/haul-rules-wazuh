<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4195 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: 1b478f40-0e6a-5b5a-9629-5c0a85744ab6 -->
  <rule id="896634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4195 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>