<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5319 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b776d21e-67b6-5f7b-857a-d7fa4ae55370 -->
  <rule id="184292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5319 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>