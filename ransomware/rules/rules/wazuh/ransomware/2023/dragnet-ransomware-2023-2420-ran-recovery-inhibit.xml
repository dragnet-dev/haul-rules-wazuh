<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2420 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 089378a3-3803-5f06-ba21-b0e96d5e39ec -->
  <rule id="630058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2420 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>