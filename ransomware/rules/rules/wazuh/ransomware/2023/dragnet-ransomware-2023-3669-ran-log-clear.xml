<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3669 — Event Log Clearing (cyclops) | Status: deprecated | Sigma ID: fe7e295b-5ede-5ae9-bad8-d276bec0971f -->
  <rule id="576629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3669 — Event Log Clearing (cyclops)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>