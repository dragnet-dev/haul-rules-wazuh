<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4480 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b0ea8c33-c7ea-55c3-b68e-c7ec37f3fb24 -->
  <rule id="143180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4480 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>