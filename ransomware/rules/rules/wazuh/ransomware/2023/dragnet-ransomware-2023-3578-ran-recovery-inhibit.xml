<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3578 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: f63d03de-009f-56fe-b4f9-7b5af2ecef6b -->
  <rule id="802103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3578 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>