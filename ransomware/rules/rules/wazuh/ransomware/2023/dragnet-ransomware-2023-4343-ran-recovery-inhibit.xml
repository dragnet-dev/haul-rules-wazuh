<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4343 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 540f4c30-75f2-5ac3-b6fd-f1f374d7c2f5 -->
  <rule id="584876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4343 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>