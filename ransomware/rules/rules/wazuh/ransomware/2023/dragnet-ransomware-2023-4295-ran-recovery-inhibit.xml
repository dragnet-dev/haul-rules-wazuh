<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4295 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 34bfcf97-6f9c-57dd-83c7-eb1f8ac8736e -->
  <rule id="577327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4295 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>