<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1763 — Recovery Inhibition (darkrace) | Status: experimental | Sigma ID: 9b8d417c-0452-5ad8-b987-a54adc921fd8 -->
  <rule id="794141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1763 — Recovery Inhibition (darkrace)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>