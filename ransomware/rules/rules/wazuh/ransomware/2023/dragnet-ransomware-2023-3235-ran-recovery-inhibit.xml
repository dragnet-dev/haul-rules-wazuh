<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3235 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 07e38656-a938-54fb-9fd5-29b967424767 -->
  <rule id="463865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3235 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>