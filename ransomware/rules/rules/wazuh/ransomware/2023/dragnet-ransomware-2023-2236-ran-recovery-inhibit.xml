<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2236 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7a5fed1e-b33c-5a01-8548-ef3f7201d7bb -->
  <rule id="621677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2236 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>