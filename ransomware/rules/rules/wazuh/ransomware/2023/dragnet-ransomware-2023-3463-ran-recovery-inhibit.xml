<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3463 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 97cd0f83-64bd-56c9-8f52-50fef6a5b5a2 -->
  <rule id="505935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3463 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>