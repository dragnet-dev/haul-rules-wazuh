<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2516 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e362fd41-b3d3-5bf1-837c-c1b4c723e58b -->
  <rule id="176925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2516 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>