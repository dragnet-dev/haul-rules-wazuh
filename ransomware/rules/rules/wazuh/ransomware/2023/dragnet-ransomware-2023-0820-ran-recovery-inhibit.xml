<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0820 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 27789b8d-a0c6-5d6f-89bb-ba61abb1bf6a -->
  <rule id="946358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0820 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>