<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1024 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 8c2be4a7-8f47-54fc-8d19-109da044046f -->
  <rule id="991024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1024 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>