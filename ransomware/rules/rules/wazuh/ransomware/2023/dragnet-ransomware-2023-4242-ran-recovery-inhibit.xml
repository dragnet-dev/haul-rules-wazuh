<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4242 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 74689ce7-f1e2-5d34-a12e-9fefeed8864a -->
  <rule id="395036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4242 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>