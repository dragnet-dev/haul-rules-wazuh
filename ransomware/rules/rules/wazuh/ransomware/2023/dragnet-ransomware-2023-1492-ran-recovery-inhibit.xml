<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1492 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 6891f215-cd20-58c3-89ba-f43401b17f7d -->
  <rule id="302712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1492 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>