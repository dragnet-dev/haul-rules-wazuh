<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4801 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: efdff817-9fde-5bfb-bafa-34b7f94949d2 -->
  <rule id="925278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4801 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
