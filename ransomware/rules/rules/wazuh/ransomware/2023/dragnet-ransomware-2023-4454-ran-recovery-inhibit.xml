<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4454 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d92cfa27-3459-587e-b8d5-e94d9b7649ba -->
  <rule id="404954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4454 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>