<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0665 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ad676d00-2265-5679-b8ca-4d8e3c78b904 -->
  <rule id="178829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0665 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>