<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0109 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bab5e582-0522-5161-8aaa-7191c881362b -->
  <rule id="380145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0109 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>