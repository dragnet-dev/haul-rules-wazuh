<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1571 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: e2da4c19-e43f-5a21-a095-fc2b95542d4d -->
  <rule id="551276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1571 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>