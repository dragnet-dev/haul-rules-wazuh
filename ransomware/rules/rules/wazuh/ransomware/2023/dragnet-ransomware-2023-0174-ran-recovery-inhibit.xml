<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0174 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 003ee22a-2c74-5fdb-b09f-10f4a4886059 -->
  <rule id="809962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0174 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>