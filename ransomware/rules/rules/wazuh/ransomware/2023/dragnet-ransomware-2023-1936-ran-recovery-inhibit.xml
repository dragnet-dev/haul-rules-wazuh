<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1936 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 05b742b1-d415-5b06-952e-4c91e199bac7 -->
  <rule id="667883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1936 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>