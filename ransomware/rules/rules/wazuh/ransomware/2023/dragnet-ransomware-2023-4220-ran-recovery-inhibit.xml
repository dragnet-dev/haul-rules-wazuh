<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4220 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0e15d8f0-f997-5222-a5cc-26d1149ea1d1 -->
  <rule id="124623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4220 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>