<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2695 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ae3e8803-b5af-57f4-938f-106ba17435d2 -->
  <rule id="190288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2695 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>