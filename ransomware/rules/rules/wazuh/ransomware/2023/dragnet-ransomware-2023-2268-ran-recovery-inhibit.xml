<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2268 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6fd68b5f-e3e5-51cc-a06b-04b7fd26c1d5 -->
  <rule id="263499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2268 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>