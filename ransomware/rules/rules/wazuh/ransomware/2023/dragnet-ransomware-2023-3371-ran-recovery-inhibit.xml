<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3371 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5eca70a0-c54e-5d99-86f3-21b02fd6d3e3 -->
  <rule id="726670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3371 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
