<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2596 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 658eb323-c477-5a81-8151-307e12499777 -->
  <rule id="886833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2596 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>