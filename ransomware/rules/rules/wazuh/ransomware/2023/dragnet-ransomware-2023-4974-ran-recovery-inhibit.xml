<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4974 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fa567d5c-39c4-5deb-8b32-ecdae8145973 -->
  <rule id="509085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4974 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>