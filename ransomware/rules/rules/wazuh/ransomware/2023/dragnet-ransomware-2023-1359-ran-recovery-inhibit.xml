<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1359 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 241394f6-9515-55c1-b9cd-b8e445512ea1 -->
  <rule id="362319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1359 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>