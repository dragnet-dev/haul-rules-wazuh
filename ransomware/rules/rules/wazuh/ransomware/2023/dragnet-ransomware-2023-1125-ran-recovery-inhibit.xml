<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1125 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: eeea4122-02d8-5343-80ad-70c412b2fb6d -->
  <rule id="816241" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1125 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>