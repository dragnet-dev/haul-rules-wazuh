<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2057 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 47fa25cf-1373-59ac-ba55-c0f6ba14c509 -->
  <rule id="428225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2057 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>