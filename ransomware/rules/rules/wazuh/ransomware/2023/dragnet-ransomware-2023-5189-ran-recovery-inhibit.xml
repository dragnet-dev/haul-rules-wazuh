<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5189 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: cf2140f8-a3cc-534e-b1c9-8107dd8b86de -->
  <rule id="372140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5189 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>