<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5353 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: 29ab0c6e-c866-5aab-ba9e-f35c86409870 -->
  <rule id="415212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5353 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>