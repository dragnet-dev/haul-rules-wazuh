<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2443 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f570799e-df8a-5c8c-b83d-3cf737ca55bc -->
  <rule id="757079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2443 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>