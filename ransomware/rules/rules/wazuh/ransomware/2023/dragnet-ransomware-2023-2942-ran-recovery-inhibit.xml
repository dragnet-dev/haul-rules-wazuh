<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2942 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ebcb5e7c-93e0-5fb3-ad3b-68726216a53b -->
  <rule id="758174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2942 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>