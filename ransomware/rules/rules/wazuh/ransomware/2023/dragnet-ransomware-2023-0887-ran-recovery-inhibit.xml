<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0887 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 79e82900-c9b2-53f4-a41e-5324a558b8d8 -->
  <rule id="478829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0887 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>