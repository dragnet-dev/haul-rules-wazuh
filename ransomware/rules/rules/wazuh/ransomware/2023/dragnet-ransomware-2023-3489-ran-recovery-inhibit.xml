<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3489 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 923dac4a-23da-5310-8e98-1df7d99ca5d4 -->
  <rule id="284108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3489 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>