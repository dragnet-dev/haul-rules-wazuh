<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4467 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 20e52d99-9a9d-5733-a3fd-88dd626c7487 -->
  <rule id="952459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4467 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>