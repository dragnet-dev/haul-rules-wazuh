<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5212 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 98a37572-f0b3-500b-bebd-e804a553d92b -->
  <rule id="778375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5212 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>