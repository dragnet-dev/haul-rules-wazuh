<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2089 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 140481cb-9901-5ff8-9958-c39cd70720c2 -->
  <rule id="547708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2089 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>