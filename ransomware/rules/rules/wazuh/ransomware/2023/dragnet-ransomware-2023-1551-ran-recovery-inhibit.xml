<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1551 — Recovery Inhibition (toufan) | Status: deprecated | Sigma ID: aee168f8-10b1-5bac-87d3-33360bd853ef -->
  <rule id="198168" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1551 — Recovery Inhibition (toufan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>