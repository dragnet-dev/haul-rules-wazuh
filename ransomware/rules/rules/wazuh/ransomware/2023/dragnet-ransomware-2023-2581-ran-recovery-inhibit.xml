<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2581 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 87534eda-d109-513d-89a3-791897959c78 -->
  <rule id="600558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2581 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>