<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0528 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 00fec892-97d7-5b97-99b1-6e1cca366c2f -->
  <rule id="576892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0528 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>