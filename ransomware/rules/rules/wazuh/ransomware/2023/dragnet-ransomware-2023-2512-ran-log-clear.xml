<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2512 — Event Log Clearing (play) | Status: experimental | Sigma ID: b3d5cf08-7ec9-5b0e-9cc6-1eb1f5ca2fc8 -->
  <rule id="263247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2512 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>