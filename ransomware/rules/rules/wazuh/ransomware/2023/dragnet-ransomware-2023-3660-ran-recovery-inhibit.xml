<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3660 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: c67dbb08-80cd-541a-8848-b6cf721a1047 -->
  <rule id="793147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3660 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>