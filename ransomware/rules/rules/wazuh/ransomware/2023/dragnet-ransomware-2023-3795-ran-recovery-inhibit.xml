<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3795 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 9f68ba84-f036-5888-99cf-f28227cd07eb -->
  <rule id="587994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3795 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>