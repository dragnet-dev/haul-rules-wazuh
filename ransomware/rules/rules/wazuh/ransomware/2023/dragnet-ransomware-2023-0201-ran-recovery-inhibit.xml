<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0201 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 91674ebb-4087-5750-9526-4fc8638f642e -->
  <rule id="666798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0201 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>