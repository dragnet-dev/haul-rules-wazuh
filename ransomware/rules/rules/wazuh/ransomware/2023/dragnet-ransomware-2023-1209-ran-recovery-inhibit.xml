<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1209 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5cb11953-2697-5367-9e14-d11e2e3126db -->
  <rule id="683119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1209 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>