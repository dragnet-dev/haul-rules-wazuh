<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0440 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e0c002fb-0a8c-57da-a227-2af1921981d3 -->
  <rule id="552002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0440 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>