<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0650 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: a988c527-67bb-52c3-94bf-4a10e411a35b -->
  <rule id="958205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0650 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>