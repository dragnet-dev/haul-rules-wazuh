<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2869 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: dc68c6aa-18e5-5ad3-b954-8a1646a5aafd -->
  <rule id="931006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2869 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>