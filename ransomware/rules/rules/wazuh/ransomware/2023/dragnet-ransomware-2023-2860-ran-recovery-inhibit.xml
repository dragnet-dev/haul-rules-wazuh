<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2860 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: baf64d75-8423-5c65-a0e7-f91e976cf812 -->
  <rule id="386637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2860 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>