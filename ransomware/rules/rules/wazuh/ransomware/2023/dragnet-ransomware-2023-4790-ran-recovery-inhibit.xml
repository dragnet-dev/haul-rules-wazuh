<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4790 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: ada4808e-7fdf-5983-98ff-47c078d23195 -->
  <rule id="178480" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4790 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
