<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2304 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3fc41c09-9d37-57cd-881e-bcfd98a6a9f4 -->
  <rule id="832668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2304 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>