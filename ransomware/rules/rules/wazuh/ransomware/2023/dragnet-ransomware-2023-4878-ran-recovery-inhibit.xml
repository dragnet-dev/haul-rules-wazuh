<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4878 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eaa6b358-38c2-51ba-bdf2-b57c35f3afff -->
  <rule id="707473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4878 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>