<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3379 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2f2cdaeb-5768-5373-99dd-2defbd204dfa -->
  <rule id="236602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3379 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>