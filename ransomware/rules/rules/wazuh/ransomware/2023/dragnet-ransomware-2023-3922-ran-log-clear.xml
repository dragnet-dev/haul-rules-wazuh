<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3922 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: f87f7fe4-9fd2-5d53-ad5e-5c09b625f43c -->
  <rule id="565247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3922 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>