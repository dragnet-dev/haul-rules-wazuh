<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2866 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: b38e83fb-1960-5a9c-adef-df572011f559 -->
  <rule id="122283" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2866 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>