<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2062 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 3d4dab10-b516-53a6-ae8f-7e34e77dee21 -->
  <rule id="818443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2062 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>