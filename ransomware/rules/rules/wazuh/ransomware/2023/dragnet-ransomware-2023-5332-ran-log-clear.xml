<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5332 — Event Log Clearing (dunghill) | Status: experimental | Sigma ID: 4115d884-f27a-5a52-9697-a07bbd0c3bbf -->
  <rule id="385388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5332 — Event Log Clearing (dunghill)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>