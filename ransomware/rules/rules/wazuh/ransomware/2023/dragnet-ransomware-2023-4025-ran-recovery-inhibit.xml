<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4025 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: bcd0d8e1-aed0-59db-aff2-8c799282c416 -->
  <rule id="433738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4025 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>