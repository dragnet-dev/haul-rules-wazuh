<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2415 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 93f0580b-78d6-5921-be9e-a07bb5290b97 -->
  <rule id="703058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2415 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>