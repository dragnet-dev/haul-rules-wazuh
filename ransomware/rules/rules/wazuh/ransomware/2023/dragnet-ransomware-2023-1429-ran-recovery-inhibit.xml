<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1429 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 1ccba186-ab39-50c8-ba86-ea554ff4dc12 -->
  <rule id="379461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1429 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>