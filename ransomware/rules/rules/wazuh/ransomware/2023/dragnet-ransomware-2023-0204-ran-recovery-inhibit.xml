<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0204 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 7cbe09ab-c056-5d41-bfba-f3b593cbb427 -->
  <rule id="593409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0204 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>