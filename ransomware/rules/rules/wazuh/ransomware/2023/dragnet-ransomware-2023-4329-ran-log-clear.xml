<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4329 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 0b4616ce-eeb0-5aea-8d57-0484ac434a33 -->
  <rule id="133868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4329 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>