<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1883 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 55780dc4-1dcd-52be-8b90-e149340725fc -->
  <rule id="879900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1883 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>