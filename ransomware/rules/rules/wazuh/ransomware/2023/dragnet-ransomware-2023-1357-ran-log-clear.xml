<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1357 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: 32b39b52-c9a4-59eb-88b0-656c62f9f9c8 -->
  <rule id="374355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1357 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>