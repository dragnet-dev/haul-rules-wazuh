<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0284 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cc2e262a-b40d-5252-bbde-69fac6a64825 -->
  <rule id="668626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0284 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>