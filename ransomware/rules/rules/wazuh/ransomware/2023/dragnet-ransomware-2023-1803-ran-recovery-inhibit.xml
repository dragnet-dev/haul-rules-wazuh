<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1803 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: cc85c4ca-c955-5da5-bc71-9b174a0b992b -->
  <rule id="677724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1803 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>