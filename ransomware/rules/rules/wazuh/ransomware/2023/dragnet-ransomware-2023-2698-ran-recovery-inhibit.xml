<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2698 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 65a5213f-97d6-52a1-8b74-854a1a536424 -->
  <rule id="250521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2698 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>