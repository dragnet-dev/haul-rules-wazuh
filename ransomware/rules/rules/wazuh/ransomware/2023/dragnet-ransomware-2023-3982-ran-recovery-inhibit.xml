<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3982 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d1a9d1e4-f993-5621-a5ab-0289b8e6efbc -->
  <rule id="771171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3982 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>