<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5345 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3b2e1f80-b7f2-5275-8574-75fa16d0be52 -->
  <rule id="717791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5345 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>