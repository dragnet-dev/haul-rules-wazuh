<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4623 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 03dd1f00-7610-54b0-8ad7-9cbc9c8b1345 -->
  <rule id="782710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4623 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>