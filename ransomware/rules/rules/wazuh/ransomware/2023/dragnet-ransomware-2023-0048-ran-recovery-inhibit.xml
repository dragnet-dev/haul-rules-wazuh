<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0048 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 045f5da2-85d8-587b-a722-05cd3354c3ae -->
  <rule id="183098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0048 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>