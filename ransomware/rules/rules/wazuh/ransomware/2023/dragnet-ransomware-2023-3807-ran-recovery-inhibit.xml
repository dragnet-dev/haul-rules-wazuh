<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3807 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b0741474-ebef-5a80-9c68-e201a3179b84 -->
  <rule id="307414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3807 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>