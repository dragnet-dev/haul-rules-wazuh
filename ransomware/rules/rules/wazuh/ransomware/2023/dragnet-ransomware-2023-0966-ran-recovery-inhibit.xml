<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0966 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f2eadeb0-3e83-5634-9ba6-930ee2dcc496 -->
  <rule id="221598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0966 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>