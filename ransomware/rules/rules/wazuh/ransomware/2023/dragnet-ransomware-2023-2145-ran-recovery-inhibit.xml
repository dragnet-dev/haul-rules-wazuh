<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2145 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 73abd010-19fd-56be-ad7c-12345838c7b0 -->
  <rule id="417570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2145 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>