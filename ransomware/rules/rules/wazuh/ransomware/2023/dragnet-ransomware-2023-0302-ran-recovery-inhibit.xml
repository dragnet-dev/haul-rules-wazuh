<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0302 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f2596b60-1954-54c7-855a-a1745b4af0c9 -->
  <rule id="741547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0302 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>