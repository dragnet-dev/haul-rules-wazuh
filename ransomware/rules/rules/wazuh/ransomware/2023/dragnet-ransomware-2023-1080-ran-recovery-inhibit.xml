<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1080 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 88d0059f-8a6f-5a70-bfa6-ce6867e7a4f1 -->
  <rule id="621005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1080 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>