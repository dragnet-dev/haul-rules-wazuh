<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0889 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c8ab1d87-5fa9-5f8f-aa9e-7ae7625b12ac -->
  <rule id="870269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0889 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>