<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1119 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: fddb4603-8421-50d8-9ee9-b41d8fe6c6d3 -->
  <rule id="298746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1119 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>