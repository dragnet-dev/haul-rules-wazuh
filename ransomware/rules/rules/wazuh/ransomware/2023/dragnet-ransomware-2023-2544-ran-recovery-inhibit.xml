<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2544 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ea92ada1-cad1-5676-9616-ac66b8dc235e -->
  <rule id="714125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2544 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>