<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3155 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 6dd07a18-dd58-5c1e-b5a6-8761fe7be7b1 -->
  <rule id="211322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3155 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>