<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1056 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 5cb2b12a-d7ed-5756-bdc8-db93ca80e5cc -->
  <rule id="673231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1056 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>