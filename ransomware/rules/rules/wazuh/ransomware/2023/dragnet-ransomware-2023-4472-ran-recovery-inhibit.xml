<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4472 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 509a24a2-d82f-50f9-abcc-df63e6e6e952 -->
  <rule id="546794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4472 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>