<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0901 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 737db8cd-3607-5df2-8aa3-3bdf2d15e8cf -->
  <rule id="188918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0901 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>