<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3771 — Recovery Inhibition (darkrace) | Status: experimental | Sigma ID: fd07df33-90e4-53ac-87c9-6d8bb9fb9be2 -->
  <rule id="278815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3771 — Recovery Inhibition (darkrace)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>