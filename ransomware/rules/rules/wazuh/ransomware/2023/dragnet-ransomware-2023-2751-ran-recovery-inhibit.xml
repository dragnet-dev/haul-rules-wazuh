<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2751 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: a8faebdc-bbf4-5117-956f-e41dd96a6282 -->
  <rule id="942123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2751 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>