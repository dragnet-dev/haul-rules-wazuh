<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1737 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: 10ebcefe-d2d2-5367-a66e-192cfda02cb6 -->
  <rule id="751631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1737 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>