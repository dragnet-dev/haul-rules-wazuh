<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3606 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 8a87db3f-69ec-53a4-8ca0-5d3e02ba0e4c -->
  <rule id="955291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3606 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>