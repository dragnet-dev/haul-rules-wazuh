<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3358 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 72410bf6-3174-51a3-9c62-9245e8437cd2 -->
  <rule id="358571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3358 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>