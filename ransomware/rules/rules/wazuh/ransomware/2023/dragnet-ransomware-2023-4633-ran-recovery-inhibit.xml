<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4633 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 0af5bed5-ff3a-58c8-964b-57eb2ef1777b -->
  <rule id="991533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4633 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>