<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4132 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1585d154-c2cf-56d5-a1cb-5494a9a173bd -->
  <rule id="837315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4132 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>