<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0668 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 6fdabb00-5e63-5b56-a212-a42dd7896821 -->
  <rule id="230491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0668 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>