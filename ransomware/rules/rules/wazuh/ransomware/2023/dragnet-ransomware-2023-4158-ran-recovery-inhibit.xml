<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4158 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e98182d0-0292-5dab-84c2-b4d6dd32cdf8 -->
  <rule id="698182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4158 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>