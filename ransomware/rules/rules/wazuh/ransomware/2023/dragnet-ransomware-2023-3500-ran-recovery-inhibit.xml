<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3500 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: abef8779-fa23-5287-9558-6cecd29eff12 -->
  <rule id="901587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3500 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>