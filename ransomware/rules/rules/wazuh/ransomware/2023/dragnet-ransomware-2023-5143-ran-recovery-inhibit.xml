<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5143 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4b07945f-ab43-5da3-84f1-6bedf5d2762f -->
  <rule id="407945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5143 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>