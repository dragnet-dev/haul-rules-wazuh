<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3117 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: bf5e086d-eea1-5329-80eb-b7ce6311242e -->
  <rule id="465408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3117 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>