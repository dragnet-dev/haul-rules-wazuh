<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3364 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: 5267e632-f3bd-57ce-aa4b-2e97ce0d24a1 -->
  <rule id="428663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3364 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>