<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0548 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6cb540d3-f87d-5d39-b997-8ea03a69d790 -->
  <rule id="939540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0548 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>