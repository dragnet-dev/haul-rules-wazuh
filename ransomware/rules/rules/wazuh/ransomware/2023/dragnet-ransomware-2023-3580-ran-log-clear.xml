<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3580 — Event Log Clearing (0mega) | Status: deprecated | Sigma ID: 452389b4-b38c-54cf-82d5-406e361512da -->
  <rule id="138235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3580 — Event Log Clearing (0mega)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>