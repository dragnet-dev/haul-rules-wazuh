<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2211 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: cad34a71-459c-51b8-a413-e93212bab0d6 -->
  <rule id="792554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2211 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>