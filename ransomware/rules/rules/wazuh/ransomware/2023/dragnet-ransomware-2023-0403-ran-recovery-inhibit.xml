<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0403 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f3e5c15b-46ff-5a35-bcff-429dba8213f9 -->
  <rule id="440121" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0403 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>