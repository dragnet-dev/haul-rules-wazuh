<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0017 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 7f14b876-6516-5705-8dc4-9d38a340afd7 -->
  <rule id="334358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0017 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>