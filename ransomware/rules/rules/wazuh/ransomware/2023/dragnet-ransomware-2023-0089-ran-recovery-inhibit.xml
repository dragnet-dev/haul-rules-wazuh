<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0089 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e815c14b-9617-54c4-8621-6a5672253d87 -->
  <rule id="670521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0089 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>