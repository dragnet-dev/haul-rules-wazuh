<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4277 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 70b05ce9-e615-578a-a692-2c60a931bdb0 -->
  <rule id="109692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4277 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>