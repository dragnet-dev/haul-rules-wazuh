<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4376 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: fddfadee-13c6-57b0-b1c5-26789ed9b3b8 -->
  <rule id="239866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4376 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>