<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0271 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: dbe37b43-eb56-5bd5-bbf0-b917b8f33e44 -->
  <rule id="329403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0271 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>