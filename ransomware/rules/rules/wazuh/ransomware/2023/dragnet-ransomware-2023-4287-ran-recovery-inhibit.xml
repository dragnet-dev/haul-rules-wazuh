<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4287 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 6c4542c5-e337-5799-bb03-20314e1a610d -->
  <rule id="284542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4287 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>