<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4311 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 622b1df2-4c64-52e7-8fbf-680d4f65bd0b -->
  <rule id="794109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4311 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>