<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5210 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 54a26bb7-65d3-5cf0-8e82-a516a7d58a11 -->
  <rule id="598827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5210 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>