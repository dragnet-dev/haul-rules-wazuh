<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2542 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a47d134d-1fd1-5618-9402-5a05b060a013 -->
  <rule id="876513" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2542 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>