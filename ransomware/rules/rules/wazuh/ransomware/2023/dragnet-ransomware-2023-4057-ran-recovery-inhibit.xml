<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4057 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7be11e51-5d62-5fa9-9f15-92c90a8f143f -->
  <rule id="571390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4057 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>