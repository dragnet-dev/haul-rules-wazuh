<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0342 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e28e080f-eb21-50dd-bcd9-9d63441613a7 -->
  <rule id="586208" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0342 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>