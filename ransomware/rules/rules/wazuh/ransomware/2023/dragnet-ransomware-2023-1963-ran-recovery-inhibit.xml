<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1963 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ebe4e660-7a9b-52cb-830f-410261a7971c -->
  <rule id="739186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1963 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>