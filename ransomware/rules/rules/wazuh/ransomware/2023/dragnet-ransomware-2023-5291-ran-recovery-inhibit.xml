<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5291 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 14bfa69d-5d02-516a-a8d9-0bcf4297f6f8 -->
  <rule id="741069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5291 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>