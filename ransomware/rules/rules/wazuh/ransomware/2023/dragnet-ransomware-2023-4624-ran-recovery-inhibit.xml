<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4624 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f52be908-2f3a-58f3-bd95-4b33b01a1f0d -->
  <rule id="475029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4624 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>