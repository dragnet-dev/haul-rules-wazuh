<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5012 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 82263115-e3d3-5f7a-aa80-aa4a860fb033 -->
  <rule id="226311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5012 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>