<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4045 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 70926a04-2969-580d-99ee-7944d1835713 -->
  <rule id="334826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4045 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>