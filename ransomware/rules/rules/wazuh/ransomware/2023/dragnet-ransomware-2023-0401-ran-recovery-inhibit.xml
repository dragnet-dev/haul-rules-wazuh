<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0401 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 051a0b12-e9f0-5c74-b238-978b1f4bf846 -->
  <rule id="521711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0401 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>