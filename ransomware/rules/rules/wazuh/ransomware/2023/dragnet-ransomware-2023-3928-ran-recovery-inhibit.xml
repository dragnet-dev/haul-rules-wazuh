<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3928 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d838f881-3b4c-58aa-af00-d9336cc0c269 -->
  <rule id="514238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3928 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>