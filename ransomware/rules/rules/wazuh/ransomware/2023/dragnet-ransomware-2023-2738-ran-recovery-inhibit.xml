<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2738 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 91fa084e-fbd6-5203-a5d6-a6c377704c62 -->
  <rule id="654608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2738 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>