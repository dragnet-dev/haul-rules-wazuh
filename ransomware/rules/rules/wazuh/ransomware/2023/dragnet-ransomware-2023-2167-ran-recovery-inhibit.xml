<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2167 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: e6b8efee-9008-5b69-87a7-0bafb8aba0ed -->
  <rule id="710607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2167 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>