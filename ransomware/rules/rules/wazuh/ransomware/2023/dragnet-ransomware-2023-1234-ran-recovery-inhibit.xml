<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1234 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6c063144-df64-5853-9b04-671fc376f614 -->
  <rule id="280631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1234 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>