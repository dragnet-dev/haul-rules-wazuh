<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0730 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5f7a2e8f-5312-5412-863c-c785a272ca67 -->
  <rule id="751566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0730 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>