<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0718 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 556664a3-d33d-5337-be91-aae7f784abe3 -->
  <rule id="906634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0718 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
