<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4276 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 0f94778f-56a7-59d7-988b-f1ae45f9e7cf -->
  <rule id="794778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4276 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>