<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2134 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 595b28a0-0162-55e2-b911-4b52d37163f1 -->
  <rule id="950058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2134 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>