<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2666 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: a0fe5cb2-b824-5fb8-a9f4-740bb3a12c27 -->
  <rule id="636732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2666 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>