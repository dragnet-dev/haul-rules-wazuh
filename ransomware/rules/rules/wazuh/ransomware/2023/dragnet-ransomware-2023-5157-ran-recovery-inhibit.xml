<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5157 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0772381c-0a70-57f2-b3fd-95458eed1812 -->
  <rule id="758108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5157 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>