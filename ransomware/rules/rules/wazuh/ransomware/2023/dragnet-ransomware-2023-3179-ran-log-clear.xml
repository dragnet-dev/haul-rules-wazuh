  <rule id="451134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3179 — Event Log Clearing (ransomed)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
