<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4706 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 6e46137d-0eab-5e9d-8384-4510ba2be2bd -->
  <rule id="304613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4706 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>