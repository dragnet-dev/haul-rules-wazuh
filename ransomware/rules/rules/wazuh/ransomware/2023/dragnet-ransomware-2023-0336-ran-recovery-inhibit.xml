<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0336 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b8c038ab-ad55-5ef2-8241-daabd5ff2225 -->
  <rule id="200038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0336 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>