<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2366 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d0a909e2-1115-5c75-9854-3be6c90d32b7 -->
  <rule id="390909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2366 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>