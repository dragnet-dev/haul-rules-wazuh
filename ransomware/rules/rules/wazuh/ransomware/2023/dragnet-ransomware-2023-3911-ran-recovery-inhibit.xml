<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3911 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a3240cf6-6fde-57f9-96aa-3f32655f352b -->
  <rule id="851852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3911 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>