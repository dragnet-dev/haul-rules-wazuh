<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4252 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 96728338-a9f1-5ac9-ba03-4b344eff43f9 -->
  <rule id="772833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4252 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>