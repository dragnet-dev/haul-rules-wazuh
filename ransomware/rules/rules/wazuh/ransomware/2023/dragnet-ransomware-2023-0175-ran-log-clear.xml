<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0175 — Event Log Clearing (noname) | Status: experimental | Sigma ID: 16e28a5c-b7e0-56d1-ba13-2de932eade8b -->
  <rule id="824585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0175 — Event Log Clearing (noname)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>