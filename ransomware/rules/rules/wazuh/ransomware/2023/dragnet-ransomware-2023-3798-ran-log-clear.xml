<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3798 — Event Log Clearing (werewolves) | Status: experimental | Sigma ID: bfc07a9b-c129-5bfa-817e-fe5780de3eb7 -->
  <rule id="508922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3798 — Event Log Clearing (werewolves)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>