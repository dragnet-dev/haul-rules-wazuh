<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1633 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 48c51d69-bd87-5afc-be84-293a5931fcb9 -->
  <rule id="448829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1633 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>