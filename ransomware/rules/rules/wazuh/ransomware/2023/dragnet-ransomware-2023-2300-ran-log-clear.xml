<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2300 — Event Log Clearing (darkpower) | Status: experimental | Sigma ID: 95e8b3d3-a78e-5c80-8f6a-355ef839b9e1 -->
  <rule id="755793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2300 — Event Log Clearing (darkpower)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>