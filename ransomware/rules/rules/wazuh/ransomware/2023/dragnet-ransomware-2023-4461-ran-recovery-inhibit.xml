<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4461 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ae1ba9a7-8868-584c-bd43-fc894bd6ee2b -->
  <rule id="958829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4461 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>