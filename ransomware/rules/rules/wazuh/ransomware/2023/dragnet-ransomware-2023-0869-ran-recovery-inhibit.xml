<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0869 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bb7f371b-5f58-535d-9c2a-4f2c13275438 -->
  <rule id="404737" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0869 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>