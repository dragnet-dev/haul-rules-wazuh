<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0111 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dd529bf7-5cdb-5855-a31b-fd3a85d5c610 -->
  <rule id="944475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0111 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>