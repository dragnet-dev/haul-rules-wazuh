<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3479 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d599afa1-3104-58d1-8225-dbb6c17d1f7b -->
  <rule id="881519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3479 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>