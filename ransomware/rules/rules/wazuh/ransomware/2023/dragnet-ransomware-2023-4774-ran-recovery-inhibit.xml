<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4774 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e01b9ae7-204d-50de-8d9a-da19dee67f9f -->
  <rule id="988474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4774 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
