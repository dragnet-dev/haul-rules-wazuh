<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3729 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 874fbba3-3674-5f22-b476-708f9e678a96 -->
  <rule id="983931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3729 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>