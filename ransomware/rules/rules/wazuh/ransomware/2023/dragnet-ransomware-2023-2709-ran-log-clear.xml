<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2709 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 5a0b11ce-3a08-551d-b9e6-580bf54ef1e2 -->
  <rule id="641111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2709 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>