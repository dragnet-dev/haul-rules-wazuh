<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3630 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7e79077f-d77e-5fab-aad0-8d10f9f9ca94 -->
  <rule id="467907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3630 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>