<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1408 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 01bce5fd-384c-5b2f-bb9c-f11cdb1e9f54 -->
  <rule id="338975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1408 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>