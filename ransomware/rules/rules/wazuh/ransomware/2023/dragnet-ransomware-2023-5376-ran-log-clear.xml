<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5376 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 0d1b8994-e5ec-58ef-89b9-95ab5fcb41e7 -->
  <rule id="407899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5376 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>