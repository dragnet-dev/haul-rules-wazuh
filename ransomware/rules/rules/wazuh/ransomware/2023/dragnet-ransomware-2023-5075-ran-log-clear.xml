<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5075 — Event Log Clearing (rancoz) | Status: experimental | Sigma ID: 2cbae342-99a0-5810-a6a2-02ea7c83842d -->
  <rule id="132143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5075 — Event Log Clearing (rancoz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>