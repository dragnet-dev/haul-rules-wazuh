<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1651 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 89b4d872-0909-535d-8581-05c8bd732606 -->
  <rule id="596778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1651 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>