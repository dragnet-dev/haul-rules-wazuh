<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5264 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a1b963b7-5cc0-51b3-be9c-7c5361983d3a -->
  <rule id="827963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5264 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>