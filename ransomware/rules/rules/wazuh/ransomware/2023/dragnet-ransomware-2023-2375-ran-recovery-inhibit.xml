<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2375 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7441b1a1-ce5c-55ff-82fa-d5c81f0de169 -->
  <rule id="390671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2375 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>