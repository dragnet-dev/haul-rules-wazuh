<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3487 — Event Log Clearing (noescape) | Status: experimental | Sigma ID: 7cee8c6c-4bf0-5ce4-af5f-0f54e7203313 -->
  <rule id="717260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3487 — Event Log Clearing (noescape)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>