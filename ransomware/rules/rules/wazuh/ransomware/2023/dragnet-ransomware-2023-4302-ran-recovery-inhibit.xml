<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4302 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5766453a-bb21-517d-b4b2-20b87030e251 -->
  <rule id="466453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4302 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>