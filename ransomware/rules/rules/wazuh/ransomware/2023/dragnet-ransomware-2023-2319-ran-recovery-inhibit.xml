<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2319 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 0d860bb1-d0ad-5c94-88b6-483771f98671 -->
  <rule id="948347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2319 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>