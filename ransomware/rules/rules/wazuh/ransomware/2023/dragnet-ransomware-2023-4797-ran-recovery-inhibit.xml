<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4797 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 8756ec77-3b93-5ab9-86f3-cdd32282e49e -->
  <rule id="541772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4797 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>