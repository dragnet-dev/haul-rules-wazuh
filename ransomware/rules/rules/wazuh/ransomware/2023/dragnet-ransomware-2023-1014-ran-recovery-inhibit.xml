<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1014 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e341a1b2-13c1-5a5c-a134-c06baab9cf6f -->
  <rule id="594661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1014 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>