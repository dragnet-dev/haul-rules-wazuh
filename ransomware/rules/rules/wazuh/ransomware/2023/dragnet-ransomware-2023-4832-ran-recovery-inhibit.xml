<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4832 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1709e7a2-a694-5c64-b328-df60400860ee -->
  <rule id="877402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4832 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>