<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3145 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: f49b99f2-b07c-5698-8eba-0c1e6943d0f3 -->
  <rule id="779599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3145 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>