<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1908 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2be2405c-d832-59e4-8d27-0afa874898fc -->
  <rule id="822405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1908 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>