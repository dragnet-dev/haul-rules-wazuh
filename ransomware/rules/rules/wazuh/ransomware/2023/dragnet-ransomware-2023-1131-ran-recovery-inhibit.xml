<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1131 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 23764d35-3507-5e5a-94ae-6ef2cfdf5e30 -->
  <rule id="302373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1131 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>