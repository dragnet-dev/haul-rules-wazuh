<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3912 — Recovery Inhibition (play) | Status: experimental | Sigma ID: db33d983-0eed-59b2-8429-80538f3fd321 -->
  <rule id="909419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3912 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>