<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4112 — Recovery Inhibition (medusa) | Status: deprecated | Sigma ID: 5dd2b34f-a727-53ad-a11c-2226b68cd461 -->
  <rule id="702033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4112 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>