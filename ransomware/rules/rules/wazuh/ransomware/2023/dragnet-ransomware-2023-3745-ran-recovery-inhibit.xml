<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3745 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 2ede2313-e15e-57d2-8452-f1b2668bbee4 -->
  <rule id="399823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3745 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>