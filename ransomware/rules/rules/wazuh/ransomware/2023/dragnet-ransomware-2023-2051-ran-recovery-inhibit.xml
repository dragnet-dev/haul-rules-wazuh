<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2051 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 575aafe1-e744-51e0-8074-e4e77b24139c -->
  <rule id="657935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2051 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>