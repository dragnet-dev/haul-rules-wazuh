<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1587 — Event Log Clearing (cactus) | Status: experimental | Sigma ID: f442b5c0-232f-51ae-bbd2-abd12e8ca2ad -->
  <rule id="770835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1587 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>