<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2346 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: c5504e72-b8a0-5f20-8bba-bc259aeec3dc -->
  <rule id="308078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2346 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>