<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3002 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1b61e4a1-b676-556a-9a4b-7389288b2c57 -->
  <rule id="870474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3002 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>