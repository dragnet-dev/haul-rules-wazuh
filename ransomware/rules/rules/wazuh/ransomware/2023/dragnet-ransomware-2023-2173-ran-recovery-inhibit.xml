<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2173 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 59dbacb5-4ea7-59e3-85b6-6dee9e8a3b14 -->
  <rule id="422860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2173 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>