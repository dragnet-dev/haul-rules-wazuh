<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2520 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 0394898c-c9b4-5372-b37a-7c22e961df69 -->
  <rule id="118380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2520 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>