<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1567 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 346e580a-c33a-5ce9-a907-6563b1426e09 -->
  <rule id="250580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1567 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>