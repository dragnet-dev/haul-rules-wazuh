<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3469 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8f22fde5-fb8d-5ca8-b2c4-8c75a5190a83 -->
  <rule id="166685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3469 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>