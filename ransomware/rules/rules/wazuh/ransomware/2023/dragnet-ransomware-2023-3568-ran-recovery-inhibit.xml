<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3568 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: cf2de6e2-4612-5bce-a842-6e52238f4b67 -->
  <rule id="906546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3568 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>