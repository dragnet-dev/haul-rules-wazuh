<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2798 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 56f8f8d8-ceb5-5001-96e9-98b14140c072 -->
  <rule id="659038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2798 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>