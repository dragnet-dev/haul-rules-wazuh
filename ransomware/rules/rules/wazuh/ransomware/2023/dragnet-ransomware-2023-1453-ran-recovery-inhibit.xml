<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1453 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 70e72f30-b44d-5af5-9aa6-9bafd889de53 -->
  <rule id="115567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1453 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>