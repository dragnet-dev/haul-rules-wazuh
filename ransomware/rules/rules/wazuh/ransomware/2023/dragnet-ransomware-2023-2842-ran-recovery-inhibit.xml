<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2842 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: f44176f2-f33f-5cb6-899e-a42905d41425 -->
  <rule id="744176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2842 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>