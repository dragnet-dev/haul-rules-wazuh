<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4306 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ca12eae2-9de4-56be-853e-7977767b96ad -->
  <rule id="774506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4306 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>