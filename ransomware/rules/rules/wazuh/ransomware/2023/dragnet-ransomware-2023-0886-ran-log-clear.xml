<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0886 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 42be1f2c-36d5-57bb-b49d-fd56b9f95412 -->
  <rule id="950751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0886 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>