<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1336 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 8b8083b3-5b5c-5278-8a6d-f08cbf7fd22a -->
  <rule id="598083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1336 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>