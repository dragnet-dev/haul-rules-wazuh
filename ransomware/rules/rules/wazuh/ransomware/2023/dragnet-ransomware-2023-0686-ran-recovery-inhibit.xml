<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0686 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 161bcafd-2caf-543f-81b6-d5edceb0b23c -->
  <rule id="799599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0686 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>