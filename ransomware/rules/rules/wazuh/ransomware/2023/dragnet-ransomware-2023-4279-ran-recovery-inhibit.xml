<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4279 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 948f3d1b-19cc-5db8-ae85-7e7544e31e4e -->
  <rule id="729341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4279 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>