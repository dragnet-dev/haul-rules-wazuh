<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4122 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 4ce93660-46d7-55a6-a057-d0afdd670433 -->
  <rule id="430936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4122 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>