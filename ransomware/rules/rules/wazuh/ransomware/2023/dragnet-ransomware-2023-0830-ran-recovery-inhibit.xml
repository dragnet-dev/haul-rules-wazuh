<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0830 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 63a292d6-168c-5cbd-94bd-55ae0bcba3b8 -->
  <rule id="218292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0830 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>