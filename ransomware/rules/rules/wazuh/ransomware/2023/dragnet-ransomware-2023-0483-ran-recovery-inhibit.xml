<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0483 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 1353aa1e-ac7c-5bdc-8d18-4aeb3e27319a -->
  <rule id="865381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0483 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>