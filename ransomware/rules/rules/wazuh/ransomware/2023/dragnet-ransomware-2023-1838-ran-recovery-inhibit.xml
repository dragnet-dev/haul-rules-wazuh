<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1838 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6d73b937-a8e1-57e7-aee6-3b330c6968dd -->
  <rule id="955799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1838 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>