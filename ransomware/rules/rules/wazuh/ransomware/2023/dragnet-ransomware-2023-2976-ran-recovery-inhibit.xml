<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2976 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 89c4b2ad-ea6e-5f2b-9279-ef670741e0ca -->
  <rule id="598352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2976 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>