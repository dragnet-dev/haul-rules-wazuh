<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0250 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f5b02c2e-19be-5f92-af34-ac778f8a1c1c -->
  <rule id="485644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0250 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>