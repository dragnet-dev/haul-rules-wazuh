<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3374 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8697f78f-1d42-5a62-94f4-9600f01128d1 -->
  <rule id="591677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3374 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>