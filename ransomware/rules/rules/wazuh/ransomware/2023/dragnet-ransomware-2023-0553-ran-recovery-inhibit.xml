<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0553 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f0040526-5943-57a7-9320-0d8b0b2638d9 -->
  <rule id="700405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0553 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>