<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2717 — Event Log Clearing (cyclops) | Status: deprecated | Sigma ID: 68a75a48-6b9f-542e-9c3f-e2ce4122d2d8 -->
  <rule id="958010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2717 — Event Log Clearing (cyclops)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>