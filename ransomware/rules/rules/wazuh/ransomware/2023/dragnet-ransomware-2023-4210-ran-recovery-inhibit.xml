<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4210 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dd72792e-ab74-57ec-9c1a-c7dec7574946 -->
  <rule id="517279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4210 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>