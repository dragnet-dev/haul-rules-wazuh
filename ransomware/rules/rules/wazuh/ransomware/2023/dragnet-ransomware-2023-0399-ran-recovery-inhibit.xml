<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0399 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 47af86a5-47c0-540a-8f18-0932d803672d -->
  <rule id="420786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0399 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>