<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5286 — Shadow Copy Deletion (ransomhouse) | Status: deprecated | Sigma ID: 2bf7b0d8-b2d6-5b51-9d6f-731f60f98925 -->
  <rule id="326030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5286 — Shadow Copy Deletion (ransomhouse)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>