<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5259 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6327531c-f85d-5a48-9fac-d4a52d62ad6e -->
  <rule id="127531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5259 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>