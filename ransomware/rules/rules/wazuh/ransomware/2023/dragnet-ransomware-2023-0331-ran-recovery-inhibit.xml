<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0331 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 54754da5-850d-5589-8211-ccf6b3bdc4c0 -->
  <rule id="617242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0331 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>