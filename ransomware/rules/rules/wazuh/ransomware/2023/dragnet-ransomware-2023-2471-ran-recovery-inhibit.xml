<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2471 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f645e187-c0bc-5b1f-9437-f7991ba3dc0a -->
  <rule id="803341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2471 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>