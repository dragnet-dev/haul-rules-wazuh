<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3448 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 73d341a3-86ac-52ca-bc7b-ff455a5616ce -->
  <rule id="381341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3448 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>