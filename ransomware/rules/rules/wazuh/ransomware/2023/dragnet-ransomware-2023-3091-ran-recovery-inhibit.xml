<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3091 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a77ce485-d07d-5429-a901-0c6ecc135100 -->
  <rule id="159184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3091 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>