<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5092 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: db7f6b9f-d21d-5e45-ad04-e5130d3e603b -->
  <rule id="326827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5092 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>