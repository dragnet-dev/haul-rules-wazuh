<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0724 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a8878b39-5936-586d-9352-adccd19770c3 -->
  <rule id="942059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0724 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>