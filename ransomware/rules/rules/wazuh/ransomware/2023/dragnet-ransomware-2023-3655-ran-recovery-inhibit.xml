<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3655 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: 671da738-5294-5cfa-99da-b84229ca1abf -->
  <rule id="919947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3655 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
