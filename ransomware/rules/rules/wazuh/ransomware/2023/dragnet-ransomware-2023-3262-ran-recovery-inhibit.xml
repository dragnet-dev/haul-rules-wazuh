<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3262 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 655d8daf-5970-51df-af1c-ea5464b8160d -->
  <rule id="879021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3262 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>