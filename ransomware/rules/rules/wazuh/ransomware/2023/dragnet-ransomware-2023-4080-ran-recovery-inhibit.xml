<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4080 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e6e7ba56-1c5f-51de-8050-61849e3f4d5d -->
  <rule id="717978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4080 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>