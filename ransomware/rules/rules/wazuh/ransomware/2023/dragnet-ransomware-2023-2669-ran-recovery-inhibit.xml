<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2669 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a01bd658-b3c5-569d-8db1-d23d8289baf9 -->
  <rule id="864456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2669 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>