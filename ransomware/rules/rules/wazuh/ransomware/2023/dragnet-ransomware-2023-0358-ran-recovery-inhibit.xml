<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0358 — Recovery Inhibition (noname) | Status: experimental | Sigma ID: 6fe82bc1-44a0-5155-abe1-f7064d6d27e5 -->
  <rule id="265323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0358 — Recovery Inhibition (noname)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>