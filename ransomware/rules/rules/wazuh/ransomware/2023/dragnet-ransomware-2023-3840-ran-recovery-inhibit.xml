<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3840 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: cb0b1488-c772-5bcc-bcfb-4b5f7d224679 -->
  <rule id="649114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3840 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>