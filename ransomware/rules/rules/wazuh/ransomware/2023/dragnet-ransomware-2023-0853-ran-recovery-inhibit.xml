<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0853 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: f9ecde15-7de8-53cc-a20a-f0a247ac9c58 -->
  <rule id="680862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0853 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>