<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2433 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8ad27b51-454d-59e2-be5a-9c9f8fd74eb0 -->
  <rule id="954043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2433 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>