<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4838 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5bcc7e8d-cde3-5ac3-add7-177b8e3685dd -->
  <rule id="260126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4838 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>