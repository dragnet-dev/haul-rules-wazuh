<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1903 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 9c625be4-1b92-5531-8773-77beef8f6375 -->
  <rule id="806011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1903 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>