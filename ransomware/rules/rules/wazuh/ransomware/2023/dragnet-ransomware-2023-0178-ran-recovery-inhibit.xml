<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0178 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: ae8d14ce-1bdc-5b9b-8ea3-16c1c47e1a31 -->
  <rule id="198114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0178 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>