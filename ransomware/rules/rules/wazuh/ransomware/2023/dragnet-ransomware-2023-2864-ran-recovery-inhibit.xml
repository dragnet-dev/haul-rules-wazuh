<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2864 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: bb8c2b82-9274-5334-8f6b-2b44ef188cbc -->
  <rule id="409643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2864 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>