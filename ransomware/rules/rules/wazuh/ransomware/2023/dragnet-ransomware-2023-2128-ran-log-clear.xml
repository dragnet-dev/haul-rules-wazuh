<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2128 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 4a9e0ff0-1ca5-5ed6-99ae-e6abf40116ba -->
  <rule id="219695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2128 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>