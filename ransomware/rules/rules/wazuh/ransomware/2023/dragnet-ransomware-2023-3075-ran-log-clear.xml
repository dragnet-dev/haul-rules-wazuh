<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3075 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 85818ab4-09e6-54b0-9dc5-95a00b3d459a -->
  <rule id="573098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3075 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>