<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2253 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0e4b2f93-60d4-5c58-a69b-74883605ccb6 -->
  <rule id="204479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2253 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>