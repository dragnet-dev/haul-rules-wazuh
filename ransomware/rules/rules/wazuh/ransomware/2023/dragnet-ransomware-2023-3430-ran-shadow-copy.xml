<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3430 — Shadow Copy Deletion (rhysida) | Status: experimental | Sigma ID: b224a0b6-891b-563c-8f52-39e71b6abb8a -->
  <rule id="995940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3430 — Shadow Copy Deletion (rhysida)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>