<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5351 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: e02e62d6-aef2-5e0e-96f1-24b07fdcf0a1 -->
  <rule id="544662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5351 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>