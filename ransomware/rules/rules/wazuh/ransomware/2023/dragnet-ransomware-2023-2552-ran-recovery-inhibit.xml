<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2552 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: bddb6c08-1cc3-5f85-bf77-04135edd175c -->
  <rule id="676588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2552 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>