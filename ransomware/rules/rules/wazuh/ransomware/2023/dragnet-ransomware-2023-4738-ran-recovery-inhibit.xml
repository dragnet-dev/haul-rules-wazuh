<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4738 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8fc2dc80-690a-50cc-a870-d7bf0830c20b -->
  <rule id="588732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4738 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>