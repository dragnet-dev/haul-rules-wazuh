<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0354 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bc7a8bf2-0610-51e9-83d7-7fd7152dcfdf -->
  <rule id="432459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0354 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>