<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0353 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8a20c2d3-a548-5831-8534-97c9175ef227 -->
  <rule id="511322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0353 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>