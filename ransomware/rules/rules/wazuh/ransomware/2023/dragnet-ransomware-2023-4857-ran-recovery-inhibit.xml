<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4857 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5d20ff5f-d986-5dbf-91b7-103e169dc47a -->
  <rule id="686175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4857 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>