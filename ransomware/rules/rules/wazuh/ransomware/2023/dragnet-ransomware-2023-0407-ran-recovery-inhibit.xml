<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0407 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 38ec8eec-a560-5078-9dc7-6b3d83a1dda7 -->
  <rule id="794382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0407 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>