<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4465 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 59bfce5f-fc9c-5f71-8450-1caeb3f81368 -->
  <rule id="415726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4465 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>