<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4351 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 22a708e1-8951-5640-981b-40cd47cc4558 -->
  <rule id="503342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4351 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>