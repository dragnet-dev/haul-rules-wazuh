<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4937 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: f52d07cb-0966-5caa-864f-e0aeeecc34cb -->
  <rule id="784507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4937 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>