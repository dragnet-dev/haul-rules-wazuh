<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2470 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: cc2b08bb-ce53-53aa-bebe-7bceab3c46a9 -->
  <rule id="668308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2470 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>