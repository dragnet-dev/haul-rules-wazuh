<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2694 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: b521270a-dc4b-5e71-b5ca-9aaab10d796f -->
  <rule id="352127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2694 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>