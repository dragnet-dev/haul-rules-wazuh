<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2193 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: c249e3e8-0321-532c-8d67-02498b69bec3 -->
  <rule id="259983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2193 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>