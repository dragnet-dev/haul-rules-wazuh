<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2368 — Event Log Clearing (medusa) | Status: deprecated | Sigma ID: 8b38f7d2-c7fe-5756-841c-7439f4bc32c9 -->
  <rule id="530237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2368 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>