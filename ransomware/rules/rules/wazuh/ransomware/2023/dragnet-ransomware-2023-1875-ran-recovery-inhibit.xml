<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1875 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 61101e72-9112-52fb-b71c-31bba91e92d7 -->
  <rule id="876307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1875 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>