<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4257 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 14d9b0a6-d1d8-5dc2-b692-76a8b2bbe700 -->
  <rule id="792010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4257 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>