<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4947 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b5c6f45a-b2a1-5a24-9f2f-f45b65cf5231 -->
  <rule id="364314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4947 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>