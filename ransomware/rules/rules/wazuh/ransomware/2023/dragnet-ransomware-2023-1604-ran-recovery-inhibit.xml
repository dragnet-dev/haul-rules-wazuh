<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1604 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 32164e6e-8a6e-56f3-92a1-5840d38a8f08 -->
  <rule id="746386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1604 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>