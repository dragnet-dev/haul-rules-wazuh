<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2384 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e2f20e3e-fe41-5b16-9727-0e7d4ba09976 -->
  <rule id="159534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2384 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>