<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0774 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e6d0098e-c744-5e23-82da-5c4496ce8996 -->
  <rule id="649009" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0774 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>