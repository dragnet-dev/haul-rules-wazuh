<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3483 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9742b4e8-a6db-51d5-a42d-22e46abc5700 -->
  <rule id="758834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3483 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>