<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3209 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 6f8206d8-8dc8-5328-abc2-1dc953b92233 -->
  <rule id="318206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3209 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>