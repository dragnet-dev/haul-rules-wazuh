<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0339 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: afe15bbd-d977-53d3-bede-a425e4a107ac -->
  <rule id="102651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0339 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>