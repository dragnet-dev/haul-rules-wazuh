<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0423 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 22c4452b-5772-585d-97e9-70128c8b28df -->
  <rule id="144452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0423 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>