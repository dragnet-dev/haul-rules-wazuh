<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0828 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 8e029825-a9f4-5e6e-a86b-f6ad48cc6d6a -->
  <rule id="620298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0828 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>