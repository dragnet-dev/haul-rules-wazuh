<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1963 — Event Log Clearing (clop) | Status: experimental | Sigma ID: d1d1c0fb-0a3f-5c98-985e-c4b3b4dd97f5 -->
  <rule id="774680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1963 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>