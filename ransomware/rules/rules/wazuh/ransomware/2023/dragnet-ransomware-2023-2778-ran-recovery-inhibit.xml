<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2778 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: af67094d-55f7-5fa1-82ce-3b070ec0191b -->
  <rule id="956709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2778 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>