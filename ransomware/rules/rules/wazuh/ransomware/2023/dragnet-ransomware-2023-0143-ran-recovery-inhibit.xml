<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0143 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3e107b6c-3777-55cc-9468-4d41df22af4f -->
  <rule id="137236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0143 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>