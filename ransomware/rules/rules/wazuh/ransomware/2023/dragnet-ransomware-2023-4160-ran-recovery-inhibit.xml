<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4160 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 98569819-06d8-5b29-aec3-db2b8fcc535a -->
  <rule id="956981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4160 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>