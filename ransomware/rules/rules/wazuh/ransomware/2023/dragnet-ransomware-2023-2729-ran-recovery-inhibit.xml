<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2729 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 1666cb47-4c0d-55d0-ab39-e55d0fce349b -->
  <rule id="766994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2729 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>