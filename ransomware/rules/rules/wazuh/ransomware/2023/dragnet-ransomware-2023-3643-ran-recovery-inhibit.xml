<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3643 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 7983509a-c51e-54b6-b912-a8823b4a49bb -->
  <rule id="883509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3643 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>