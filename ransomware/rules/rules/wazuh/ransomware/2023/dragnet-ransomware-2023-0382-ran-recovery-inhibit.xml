<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0382 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c019aa5a-48b6-5b14-97a0-8ffac628377c -->
  <rule id="477034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0382 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>