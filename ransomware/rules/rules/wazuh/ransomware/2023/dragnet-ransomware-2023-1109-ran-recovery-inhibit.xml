<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1109 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ff80f1f9-e55f-5f54-b17d-8e58658ae602 -->
  <rule id="592951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1109 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>