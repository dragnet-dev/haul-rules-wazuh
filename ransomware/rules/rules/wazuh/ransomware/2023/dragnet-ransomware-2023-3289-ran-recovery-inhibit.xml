<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3289 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a6c966b9-d09f-5200-b966-4ba446bbfdc9 -->
  <rule id="908966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3289 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>