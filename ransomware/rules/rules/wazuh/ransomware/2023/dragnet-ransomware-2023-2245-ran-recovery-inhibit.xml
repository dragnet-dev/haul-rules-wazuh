<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2245 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c14b03e6-0deb-5f34-83d6-316d6f12b2e4 -->
  <rule id="243503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2245 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>