<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3263 — Event Log Clearing (play) | Status: deprecated | Sigma ID: 49dfbebe-4d6c-5fa2-a2d8-c28a6e30063d -->
  <rule id="668542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3263 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>