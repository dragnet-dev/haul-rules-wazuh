<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2921 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fcc31d34-d0ca-51a5-8c08-93525e066758 -->
  <rule id="270909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2921 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
