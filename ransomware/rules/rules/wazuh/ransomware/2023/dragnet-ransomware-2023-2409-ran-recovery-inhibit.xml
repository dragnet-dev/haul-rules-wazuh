<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2409 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fa4fa29f-4739-5479-8c3c-88622dc998d3 -->
  <rule id="212742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2409 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>