<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1997 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 996d3841-1f1d-5fe3-a4be-3424d10b20fd -->
  <rule id="794938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1997 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>