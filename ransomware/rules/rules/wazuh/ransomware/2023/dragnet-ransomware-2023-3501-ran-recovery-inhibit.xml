<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3501 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 13fa2877-f45c-5791-b1c4-4bccd08d684f -->
  <rule id="978287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3501 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>