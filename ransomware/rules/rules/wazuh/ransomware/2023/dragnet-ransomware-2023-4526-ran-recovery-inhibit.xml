<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4526 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 12798616-eb49-536d-9209-7f4b7a20302d -->
  <rule id="479861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4526 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>