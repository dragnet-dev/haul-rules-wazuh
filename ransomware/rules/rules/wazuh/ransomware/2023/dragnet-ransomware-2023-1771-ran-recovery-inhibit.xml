<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1771 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: dc039e2d-a71a-5664-acac-b6734c9dbf46 -->
  <rule id="920638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1771 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>