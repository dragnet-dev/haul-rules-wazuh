<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2790 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 1ec87404-baa8-5a62-a574-9ab84ae35245 -->
  <rule id="528740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2790 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>