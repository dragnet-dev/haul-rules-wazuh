<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2212 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: c36f23ac-6cfb-513a-9b67-84e9ca064680 -->
  <rule id="279123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2212 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>