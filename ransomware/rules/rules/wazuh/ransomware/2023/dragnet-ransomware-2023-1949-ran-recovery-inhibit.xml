<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1949 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 1aa919f4-385e-5c16-94f8-75154810dffc -->
  <rule id="630719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1949 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>