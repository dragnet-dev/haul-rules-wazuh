<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3118 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ff1235e5-c578-511d-a2ff-c8917ae728a5 -->
  <rule id="851235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3118 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>