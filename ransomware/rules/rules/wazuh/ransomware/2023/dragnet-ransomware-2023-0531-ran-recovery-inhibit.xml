<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0531 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e23cebb0-e51f-5b7b-b989-a2ee90400d24 -->
  <rule id="531915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0531 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>