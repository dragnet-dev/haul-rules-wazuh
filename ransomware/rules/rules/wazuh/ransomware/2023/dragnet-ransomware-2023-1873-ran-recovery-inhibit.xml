<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1873 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 0721fc0e-2f42-5e71-b8bc-6d6ab13452cf -->
  <rule id="148280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1873 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>