<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3804 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c585ac42-ef6d-5b24-85b8-be8038a225c1 -->
  <rule id="621932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3804 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>