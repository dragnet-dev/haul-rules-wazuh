<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2999 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 27790e48-96e8-5201-b320-203f8c89fd0d -->
  <rule id="946544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2999 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>