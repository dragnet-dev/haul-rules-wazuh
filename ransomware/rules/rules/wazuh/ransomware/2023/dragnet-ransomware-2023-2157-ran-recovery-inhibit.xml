<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2157 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f65c9a57-19ac-5446-b2ec-fdbbb7dc7d82 -->
  <rule id="508474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2157 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>