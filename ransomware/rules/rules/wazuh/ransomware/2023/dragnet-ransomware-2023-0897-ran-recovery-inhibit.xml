<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0897 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d0a5af60-9136-52c7-a5f2-89ac0bc6e5e3 -->
  <rule id="951855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0897 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>