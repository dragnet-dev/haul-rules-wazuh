<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0573 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 2b0bb3fa-a1ef-5300-b9fc-743843189080 -->
  <rule id="302673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0573 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>