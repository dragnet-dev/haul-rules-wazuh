<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1552 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: aa730ef8-e39d-5419-99b4-8aed4d8d8f3d -->
  <rule id="131694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1552 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>