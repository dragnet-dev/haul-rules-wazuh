<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2020 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 38e020fd-f6a8-5305-bf76-c620ceeeba4b -->
  <rule id="152335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2020 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>