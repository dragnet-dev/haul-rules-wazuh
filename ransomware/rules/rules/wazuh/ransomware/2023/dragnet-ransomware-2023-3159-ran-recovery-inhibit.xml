<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3159 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6e1cef10-5756-5769-91dc-e13f360462d5 -->
  <rule id="113007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3159 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>