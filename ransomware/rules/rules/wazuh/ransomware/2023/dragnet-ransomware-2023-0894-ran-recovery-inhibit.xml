<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0894 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 808ee407-f7c6-53b3-a055-5ec8994f849a -->
  <rule id="370864" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0894 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>