<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2887 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5e3ddf11-a652-5985-b1a5-efea3b2fa077 -->
  <rule id="366079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2887 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>