<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3089 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 26d04914-6648-557b-b124-1e4a11223e76 -->
  <rule id="790491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3089 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>