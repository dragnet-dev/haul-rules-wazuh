<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4378 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3bd081e9-1b0f-5913-9441-844e9ac38c84 -->
  <rule id="113310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4378 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>