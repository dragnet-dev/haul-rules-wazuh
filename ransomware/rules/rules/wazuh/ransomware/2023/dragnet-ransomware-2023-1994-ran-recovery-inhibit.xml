<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1994 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f1ec9a82-a647-5f31-afd6-83ff8c448d78 -->
  <rule id="922874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1994 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>