<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1952 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: c7ab6401-2b5f-554d-be48-418f69a32894 -->
  <rule id="668364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1952 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>