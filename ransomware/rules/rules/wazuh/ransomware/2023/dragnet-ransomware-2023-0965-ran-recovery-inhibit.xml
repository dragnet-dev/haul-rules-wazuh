<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0965 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: e289d5e4-59ae-5249-9be8-ad86c4fd61dc -->
  <rule id="586375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0965 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>