<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2808 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 5f266cb3-586f-5a5d-91c7-08fefc48f3a9 -->
  <rule id="724268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2808 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>