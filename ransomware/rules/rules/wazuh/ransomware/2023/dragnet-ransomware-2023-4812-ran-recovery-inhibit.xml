<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4812 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0f802a1e-910d-5d6a-8e26-b5b3d163583a -->
  <rule id="828421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4812 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>