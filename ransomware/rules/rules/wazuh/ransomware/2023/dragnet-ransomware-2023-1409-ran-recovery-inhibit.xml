<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1409 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 7cf266f1-3815-5221-ad28-ae667837b00c -->
  <rule id="299266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1409 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>