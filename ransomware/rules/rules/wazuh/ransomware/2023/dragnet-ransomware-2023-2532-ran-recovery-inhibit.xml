<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2532 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 703d27d4-3054-5432-bb9a-0a825161af7d -->
  <rule id="326127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2532 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>