<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3201 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a23feca9-f38d-57c4-9340-2e4c369901fb -->
  <rule id="694284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3201 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>