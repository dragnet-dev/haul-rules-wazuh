<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0690 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 3aad02a2-c918-5ea2-9ec1-6bb16c82663b -->
  <rule id="702102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0690 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>