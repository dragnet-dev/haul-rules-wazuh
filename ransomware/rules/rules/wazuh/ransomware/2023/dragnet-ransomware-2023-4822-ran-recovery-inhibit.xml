<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4822 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9e3e683c-a54e-5f32-ab6b-01b42f267239 -->
  <rule id="834268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4822 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>