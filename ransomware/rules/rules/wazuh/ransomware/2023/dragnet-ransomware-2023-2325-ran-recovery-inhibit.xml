<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2325 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 0123fe3b-2b01-5b67-af8a-cf1973d4920b -->
  <rule id="678779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2325 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>