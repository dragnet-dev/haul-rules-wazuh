<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0237 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5a037cba-5f9d-58dd-8870-66efc6a35908 -->
  <rule id="640604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0237 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>