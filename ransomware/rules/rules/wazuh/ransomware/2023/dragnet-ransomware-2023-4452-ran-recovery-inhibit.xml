<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4452 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 1199dacc-59ce-50bf-853a-d053f58e21f3 -->
  <rule id="514604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4452 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>