<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1009 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4b677719-d7b2-5222-9aa1-4ba11402622d -->
  <rule id="467771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1009 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>