<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2670 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1c58320a-7f1d-5cfd-8bed-d6f49e91965a -->
  <rule id="258320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2670 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>