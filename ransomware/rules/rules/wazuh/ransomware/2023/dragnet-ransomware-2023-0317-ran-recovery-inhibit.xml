<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0317 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eacc01de-9f8a-52e5-ad28-f2e49ad92810 -->
  <rule id="710801" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0317 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>