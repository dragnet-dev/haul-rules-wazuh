<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2517 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 55d87687-dc4c-581e-abc2-a3890141d6f3 -->
  <rule id="938768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2517 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>