<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4130 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e579f0b1-e464-5b68-8fe0-e3af78135e5d -->
  <rule id="632790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4130 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>