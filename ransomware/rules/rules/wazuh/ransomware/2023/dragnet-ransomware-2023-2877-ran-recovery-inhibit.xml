<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2877 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: fe0a5ad1-fe8f-5b70-98b8-765c7b04b05f -->
  <rule id="304090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2877 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>