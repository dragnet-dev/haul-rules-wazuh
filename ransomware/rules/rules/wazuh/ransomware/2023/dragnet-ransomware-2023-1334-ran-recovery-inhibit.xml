<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1334 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4e76d2f1-21fa-5459-8cc8-0f9c72f06619 -->
  <rule id="460292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1334 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>