<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4787 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 0b46c733-4b2e-5272-b981-310cdb8229c7 -->
  <rule id="134873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4787 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>