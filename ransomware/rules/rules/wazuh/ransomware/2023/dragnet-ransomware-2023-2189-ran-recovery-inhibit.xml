<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2189 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 77f1b88d-2174-53c7-b205-28a33e5c9748 -->
  <rule id="295478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2189 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>