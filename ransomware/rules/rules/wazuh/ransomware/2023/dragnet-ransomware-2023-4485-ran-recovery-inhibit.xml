<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4485 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: f5c307d4-643e-56c2-a313-04d96e654559 -->
  <rule id="792307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4485 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>