<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2867 — Event Log Clearing (malas) | Status: experimental | Sigma ID: 07d3dd5f-697a-59e3-b3fc-ea6bb8fa06b1 -->
  <rule id="609895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2867 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>