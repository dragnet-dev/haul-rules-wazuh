<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4436 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5677d52a-5c0d-517e-84ca-f3f5e5d112b8 -->
  <rule id="184552" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4436 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>