<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4486 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 758a4a14-1eb1-5066-8234-85ba8f9d5785 -->
  <rule id="242154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4486 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>