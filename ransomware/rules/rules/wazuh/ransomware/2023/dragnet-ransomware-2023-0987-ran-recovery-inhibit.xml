<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0987 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 8afa70f2-acc7-5bf6-abea-e1ae5ed0fc7c -->
  <rule id="957870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0987 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>