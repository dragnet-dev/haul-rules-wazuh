<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3227 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 186462cf-86e5-5851-a83c-a23ea8eaa1b7 -->
  <rule id="383404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3227 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>