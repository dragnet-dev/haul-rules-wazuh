<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4072 — Recovery Inhibition (play) | Status: experimental | Sigma ID: aec980b0-4412-5ead-b8a1-a97f4a724a63 -->
  <rule id="196980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4072 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>