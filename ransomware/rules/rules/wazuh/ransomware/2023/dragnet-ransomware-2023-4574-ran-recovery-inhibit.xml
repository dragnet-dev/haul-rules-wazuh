<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4574 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fd375fa1-e5e5-5917-b846-3ca3cc5bac4b -->
  <rule id="554015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4574 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>