<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4439 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 9bb0fb29-cb69-522e-92cc-eb39403ed55e -->
  <rule id="177211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4439 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>