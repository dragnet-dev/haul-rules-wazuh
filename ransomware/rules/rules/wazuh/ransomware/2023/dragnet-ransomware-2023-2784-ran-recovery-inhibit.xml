<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2784 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 0fe77856-eb39-51b7-9f5d-427fa5ff2509 -->
  <rule id="847785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2784 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>