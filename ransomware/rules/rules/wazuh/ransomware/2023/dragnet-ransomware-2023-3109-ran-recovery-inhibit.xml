<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3109 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6782dec7-8d53-5e5b-b250-04b9a53de711 -->
  <rule id="936414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3109 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>