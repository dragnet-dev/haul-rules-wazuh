<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5123 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fae062eb-fcaa-5986-bfd6-c5c6d9c69c16 -->
  <rule id="514062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5123 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>