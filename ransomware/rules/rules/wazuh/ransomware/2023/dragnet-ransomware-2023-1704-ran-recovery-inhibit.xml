<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1704 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 2a319a78-3528-5861-95d6-4f26cae2301b -->
  <rule id="571147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1704 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>