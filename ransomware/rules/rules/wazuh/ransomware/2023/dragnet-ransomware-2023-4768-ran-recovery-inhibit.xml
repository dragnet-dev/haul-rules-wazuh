<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4768 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 62d37649-98e2-5fd9-8c29-3e8a304dba29 -->
  <rule id="205376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4768 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>