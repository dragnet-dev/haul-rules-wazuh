<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4716 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ff0c5a0f-757a-5a27-a292-8af4c45180e2 -->
  <rule id="330010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4716 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
