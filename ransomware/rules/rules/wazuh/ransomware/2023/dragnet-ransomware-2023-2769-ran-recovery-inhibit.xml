<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2769 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 2a12bfa0-87f3-5684-96b8-fc0f84b8f89a -->
  <rule id="278463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2769 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>