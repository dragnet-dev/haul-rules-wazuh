<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3134 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b73e5b54-1e85-51f7-83a0-0130f082b4ea -->
  <rule id="405211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3134 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>