<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2827 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 99809e72-2b69-583a-96b4-5f06f7903caf -->
  <rule id="796958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2827 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>