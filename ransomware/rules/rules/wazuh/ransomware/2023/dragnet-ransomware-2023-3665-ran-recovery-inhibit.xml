<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3665 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 196afa66-fea6-587c-84c1-5069709d25d6 -->
  <rule id="956266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3665 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>