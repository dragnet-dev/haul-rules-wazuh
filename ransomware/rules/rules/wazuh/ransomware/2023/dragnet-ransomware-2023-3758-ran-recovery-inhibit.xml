<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3758 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 36312f94-2343-5861-b7c3-baa03bce92bf -->
  <rule id="510079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3758 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>