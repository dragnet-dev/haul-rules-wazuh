<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4660 — Recovery Inhibition (cuba) | Status: experimental | Sigma ID: 6f12fea5-5c78-545b-8c4f-9fddd1faedcc -->
  <rule id="244926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4660 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>