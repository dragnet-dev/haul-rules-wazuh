<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1449 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1b91c73e-c32e-5ed3-8a94-02509ce2b4bc -->
  <rule id="966873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1449 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>