<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0495 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: cdd35fdf-f41c-588b-8e87-2c6c0e21d745 -->
  <rule id="869375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0495 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>