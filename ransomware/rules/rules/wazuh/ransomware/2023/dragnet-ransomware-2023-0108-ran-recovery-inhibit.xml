<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0108 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6e5bf689-8dfc-56a3-b68b-e1c438ed816b -->
  <rule id="230716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0108 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>