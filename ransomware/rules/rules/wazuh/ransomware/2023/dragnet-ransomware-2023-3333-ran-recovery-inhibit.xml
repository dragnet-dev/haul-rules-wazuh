<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3333 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 17504452-ea1a-5dad-bac6-79dc89574049 -->
  <rule id="950445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3333 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>