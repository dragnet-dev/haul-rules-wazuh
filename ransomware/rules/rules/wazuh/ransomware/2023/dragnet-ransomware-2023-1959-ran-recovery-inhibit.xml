<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1959 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a25dc691-d833-5945-9dcd-eb35096555cd -->
  <rule id="926206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1959 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>