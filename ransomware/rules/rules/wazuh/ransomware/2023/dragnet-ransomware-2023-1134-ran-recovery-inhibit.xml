<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1134 — Recovery Inhibition (raznatovic) | Status: experimental | Sigma ID: b4f3104d-40ea-58b8-8ad1-ef34eb341baf -->
  <rule id="139310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1134 — Recovery Inhibition (raznatovic)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>