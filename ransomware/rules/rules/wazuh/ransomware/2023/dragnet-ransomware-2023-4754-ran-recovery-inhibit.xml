<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4754 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e0201518-204a-5e48-94a1-53c188f3bd95 -->
  <rule id="602015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4754 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>