<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0465 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 381e0829-29c6-58c8-85b0-ffb65f39a6e9 -->
  <rule id="810082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0465 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>