<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2693 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 86662dae-4187-5015-8755-98cfe995169a -->
  <rule id="586605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2693 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>