<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1154 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b4659d4f-eb4b-5869-b691-b637a9b8755e -->
  <rule id="134557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1154 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>