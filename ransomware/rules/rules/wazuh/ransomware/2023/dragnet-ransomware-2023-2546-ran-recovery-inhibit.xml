<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2546 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7d0fd2fc-dd35-5c20-b7cc-295bd8565e1d -->
  <rule id="602532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2546 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>