<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3127 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 20abc215-a28c-5a7b-94ed-099eebe75ded -->
  <rule id="466821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3127 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>