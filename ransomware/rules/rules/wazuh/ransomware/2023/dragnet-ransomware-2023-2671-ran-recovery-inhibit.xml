<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2671 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 13859e42-ba4a-5628-abc6-28756a44ede0 -->
  <rule id="517584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2671 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>