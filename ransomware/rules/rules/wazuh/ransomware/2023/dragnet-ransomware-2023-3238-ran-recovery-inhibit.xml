<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3238 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d63c38e7-5c69-5224-b1dd-65ea45f7e7d1 -->
  <rule id="482038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3238 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>