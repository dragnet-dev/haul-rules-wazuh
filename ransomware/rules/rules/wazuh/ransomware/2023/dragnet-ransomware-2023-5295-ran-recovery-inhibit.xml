<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5295 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 858f6391-5adf-57e4-a14b-270fc639c295 -->
  <rule id="574363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5295 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>