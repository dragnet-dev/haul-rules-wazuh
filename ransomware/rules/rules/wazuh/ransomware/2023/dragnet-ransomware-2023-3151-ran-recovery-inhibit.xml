<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3151 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: e40f5b50-420c-5593-b1b9-a4607d44c2b9 -->
  <rule id="188891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3151 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>