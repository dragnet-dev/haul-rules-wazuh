<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3330 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4ade9589-e4ca-5dce-850a-23c0a3f1fa8d -->
  <rule id="216695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3330 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>