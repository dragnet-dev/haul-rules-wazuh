<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1779 — Event Log Clearing (raznatovic) | Status: experimental | Sigma ID: d48f7bbb-b9d1-5f59-81ca-e85994821d12 -->
  <rule id="853403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1779 — Event Log Clearing (raznatovic)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>