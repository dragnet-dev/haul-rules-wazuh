<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3638 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 633574bc-5933-5584-98f5-fe0e87719f99 -->
  <rule id="337195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3638 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>