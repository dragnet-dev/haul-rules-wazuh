<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1846 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ab4d75ac-5d91-57d8-99b1-7fabc19620fa -->
  <rule id="143775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1846 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>