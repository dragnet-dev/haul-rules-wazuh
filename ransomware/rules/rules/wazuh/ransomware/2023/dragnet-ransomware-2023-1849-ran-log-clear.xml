<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1849 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: b8a853ab-f2a3-5aa0-abdc-fddf71729f1f -->
  <rule id="198853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1849 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>