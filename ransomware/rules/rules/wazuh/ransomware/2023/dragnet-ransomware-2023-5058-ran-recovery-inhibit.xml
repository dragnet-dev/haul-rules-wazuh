<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5058 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4e78b8dd-93cf-552a-8841-d7c265086242 -->
  <rule id="460598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5058 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>