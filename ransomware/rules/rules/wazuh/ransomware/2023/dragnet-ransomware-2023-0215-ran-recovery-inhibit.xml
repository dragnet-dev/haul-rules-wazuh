<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0215 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1ea0a386-cceb-5215-8fff-4ed49cb66277 -->
  <rule id="741038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0215 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>