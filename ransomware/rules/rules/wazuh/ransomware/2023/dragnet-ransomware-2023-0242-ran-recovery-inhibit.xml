<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0242 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: ce78fab0-2992-5931-92e7-11782aafe45d -->
  <rule id="893818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0242 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>