<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4830 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cb70ecc2-01b5-597e-b536-88bb13870103 -->
  <rule id="814956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4830 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
