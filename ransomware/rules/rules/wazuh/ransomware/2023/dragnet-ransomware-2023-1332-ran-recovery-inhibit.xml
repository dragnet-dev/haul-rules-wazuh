<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1332 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0edd2cf3-217f-5ef8-ad6f-753151f2626a -->
  <rule id="841519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1332 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>