<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4136 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 4200fe49-dd8e-5e07-b36b-a606df4fec80 -->
  <rule id="275454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4136 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>