<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1328 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: ee729324-0067-5959-9b6f-b168ef9adc00 -->
  <rule id="687293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1328 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>