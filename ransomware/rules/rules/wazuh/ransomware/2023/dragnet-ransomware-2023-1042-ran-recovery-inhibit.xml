<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1042 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 50a5863f-d005-5164-a4b4-0ed8b9eba14b -->
  <rule id="105863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1042 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>