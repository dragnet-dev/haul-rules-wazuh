<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1287 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 315d922e-29e8-5c9e-85e8-009afb4b7c92 -->
  <rule id="653922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1287 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>