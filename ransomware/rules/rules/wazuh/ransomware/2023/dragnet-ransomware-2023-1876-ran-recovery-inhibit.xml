<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1876 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1d64f865-1ad3-5246-9c78-df39c75f80ae -->
  <rule id="343986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1876 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>