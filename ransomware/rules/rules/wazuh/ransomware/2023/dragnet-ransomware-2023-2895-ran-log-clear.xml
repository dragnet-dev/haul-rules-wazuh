<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2895 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: 8abf727f-6b91-5a59-b1f3-7d2ff2ca5161 -->
  <rule id="951972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2895 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>