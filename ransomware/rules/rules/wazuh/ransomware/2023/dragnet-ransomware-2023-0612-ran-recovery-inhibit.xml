<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0612 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 91906441-63bb-5219-aa4b-1ff0c96ada42 -->
  <rule id="290644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0612 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>