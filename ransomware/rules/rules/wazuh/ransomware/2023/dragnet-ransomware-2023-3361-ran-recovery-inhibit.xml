<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3361 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 76133d29-7bea-5763-b833-d34049a0d433 -->
  <rule id="418141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3361 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>