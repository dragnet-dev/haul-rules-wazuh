<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4617 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cb9f1490-2328-5f5c-b008-1e95931327ab -->
  <rule id="663914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4617 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>