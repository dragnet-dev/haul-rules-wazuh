<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0570 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: addd8882-2c54-5938-86b1-116ece32ce30 -->
  <rule id="950988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0570 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>