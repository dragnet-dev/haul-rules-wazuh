<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2712 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: afb3b0c4-73a4-58b4-adad-a71f1afda4ee -->
  <rule id="998190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2712 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>