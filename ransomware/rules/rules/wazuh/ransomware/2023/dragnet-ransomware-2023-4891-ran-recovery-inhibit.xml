<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4891 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 10805e17-08e7-5b43-9724-09ee7f344721 -->
  <rule id="928941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4891 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>