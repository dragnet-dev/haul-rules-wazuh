<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4360 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 04fc3f95-355a-5426-818b-2d99fea37c8a -->
  <rule id="342239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4360 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>