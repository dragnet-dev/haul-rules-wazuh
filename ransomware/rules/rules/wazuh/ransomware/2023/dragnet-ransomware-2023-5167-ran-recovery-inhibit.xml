<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5167 — Recovery Inhibition (darkrace) | Status: experimental | Sigma ID: 5e35ea68-7b8d-5450-b5b5-f848922aa8aa -->
  <rule id="715594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5167 — Recovery Inhibition (darkrace)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>