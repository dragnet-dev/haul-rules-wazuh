<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4014 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: c79b1211-855f-5f5a-8f9b-0810cbeb4a26 -->
  <rule id="347512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4014 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>