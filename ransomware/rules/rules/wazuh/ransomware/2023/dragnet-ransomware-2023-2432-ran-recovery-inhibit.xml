<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2432 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: cb7fd485-c24d-500b-9337-a6cbcf8759be -->
  <rule id="817254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2432 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>