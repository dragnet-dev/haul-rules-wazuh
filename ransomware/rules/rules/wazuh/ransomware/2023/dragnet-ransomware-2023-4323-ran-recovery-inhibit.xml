<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4323 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: a7b3e813-e33c-5248-b16f-fd9a373a7579 -->
  <rule id="157428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4323 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>