<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0691 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7355652a-8b12-5058-bc40-5e899d8e8ed1 -->
  <rule id="255652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0691 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>