  <rule id="842094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3940 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
