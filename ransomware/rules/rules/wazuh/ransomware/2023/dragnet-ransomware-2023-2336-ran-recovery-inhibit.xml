<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2336 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b48613fc-0b7a-5d8b-b280-c4ff1eef19a5 -->
  <rule id="348613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2336 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>