<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1654 — Event Log Clearing (cryptnet) | Status: experimental | Sigma ID: 1f9c54d0-03d6-59ba-9f06-8ed73df66e6b -->
  <rule id="186477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1654 — Event Log Clearing (cryptnet)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>