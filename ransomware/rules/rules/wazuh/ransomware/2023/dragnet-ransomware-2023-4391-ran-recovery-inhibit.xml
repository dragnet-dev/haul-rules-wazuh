<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4391 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: c8011dd6-a1bd-5382-b3fc-b976db9a83bd -->
  <rule id="348189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4391 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>