<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1413 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eb5ae2f0-a8bc-5e21-bbc8-a585c60efecf -->
  <rule id="730542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1413 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>