<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1769 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 473b0633-e52e-5eb2-9e44-e5e0ee80fc35 -->
  <rule id="479063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1769 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>