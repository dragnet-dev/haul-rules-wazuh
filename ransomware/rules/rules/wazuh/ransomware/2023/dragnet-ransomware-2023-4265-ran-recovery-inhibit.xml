<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4265 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: bd69fa8a-5a06-528d-8db9-0b2409877813 -->
  <rule id="456314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4265 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>