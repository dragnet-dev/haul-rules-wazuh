<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2278 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 062724a8-8674-5981-8b79-2f6c486b0e9b -->
  <rule id="203594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2278 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>