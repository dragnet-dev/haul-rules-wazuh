<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3650 — Event Log Clearing (clop) | Status: experimental | Sigma ID: f07aba1b-54b7-5954-9bad-b6f8ad3d5ca9 -->
  <rule id="875418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3650 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>