<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5331 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 4d4954ed-7aa7-5211-83cd-3dc891cfbc1d -->
  <rule id="799278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5331 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>