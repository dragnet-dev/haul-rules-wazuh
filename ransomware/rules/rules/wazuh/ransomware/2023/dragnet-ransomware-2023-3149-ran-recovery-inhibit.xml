<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3149 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d238a51e-467a-54b2-ac7f-7c6804f08518 -->
  <rule id="418185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3149 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>