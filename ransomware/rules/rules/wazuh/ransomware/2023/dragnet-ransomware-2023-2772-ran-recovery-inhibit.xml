<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2772 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 75edbcc1-6703-52bc-ad70-df3fb6cbe8b1 -->
  <rule id="576060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2772 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>