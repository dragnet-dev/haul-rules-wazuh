<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1030 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 391e37ae-7658-58be-9569-7a81a61ed753 -->
  <rule id="232602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1030 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>