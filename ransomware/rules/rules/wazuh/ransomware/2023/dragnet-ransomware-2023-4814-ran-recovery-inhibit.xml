<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4814 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 43e50166-0b2f-5ac1-ad3a-e5d6a827e28d -->
  <rule id="825016" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4814 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>