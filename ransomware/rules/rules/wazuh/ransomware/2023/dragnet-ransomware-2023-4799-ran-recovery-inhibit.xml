<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4799 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c58a880-05cb-5676-a597-6dc735f325c6 -->
  <rule id="293388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4799 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>