<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5102 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ab3f0cad-5c34-5f12-858d-c34b17b512a1 -->
  <rule id="887692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5102 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>