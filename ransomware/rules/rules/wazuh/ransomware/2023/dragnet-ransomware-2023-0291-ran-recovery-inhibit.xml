<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0291 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: bd70eb6a-da7c-570c-a45b-d362dec40d8f -->
  <rule id="456555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0291 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>