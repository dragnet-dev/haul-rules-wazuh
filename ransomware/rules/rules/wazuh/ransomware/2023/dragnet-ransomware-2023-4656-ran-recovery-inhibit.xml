<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4656 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a38d0c18-ae64-538d-9596-ce058b519a0c -->
  <rule id="959372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4656 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>