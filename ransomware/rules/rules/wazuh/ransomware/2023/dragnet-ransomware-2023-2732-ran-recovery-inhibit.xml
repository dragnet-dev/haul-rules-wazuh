<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2732 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 94ea4d4b-6dfc-5f0e-9936-7c6f0fb3ae13 -->
  <rule id="387757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2732 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>