<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2221 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f437bbdb-15a3-51e9-aaa8-7d3bbc0490be -->
  <rule id="452059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2221 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>