<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2774 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 7227504c-e66c-5674-b99d-0eea8f0d4c7c -->
  <rule id="127504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2774 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>