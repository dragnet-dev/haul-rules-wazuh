<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0167 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 9b1ed7f3-ff93-5744-9015-a1a9968a4617 -->
  <rule id="472937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0167 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>