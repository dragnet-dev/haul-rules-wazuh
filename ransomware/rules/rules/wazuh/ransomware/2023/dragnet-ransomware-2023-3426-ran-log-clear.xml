<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3426 — Event Log Clearing (play) | Status: experimental | Sigma ID: 4a0d4173-ecc4-5f9c-b4b5-e7a032a52f90 -->
  <rule id="385341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3426 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>