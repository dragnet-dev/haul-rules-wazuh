<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1684 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e5b5258f-213a-5b81-b803-24f8fdf00c42 -->
  <rule id="631525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1684 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>