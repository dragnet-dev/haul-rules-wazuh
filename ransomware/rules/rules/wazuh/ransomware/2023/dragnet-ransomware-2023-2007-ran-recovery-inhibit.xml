<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2007 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 020c1a9b-6b28-55fc-b923-291176a45c46 -->
  <rule id="503515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2007 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>