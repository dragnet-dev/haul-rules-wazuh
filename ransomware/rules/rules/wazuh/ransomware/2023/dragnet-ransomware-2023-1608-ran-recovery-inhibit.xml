<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1608 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 945ae568-50e2-5afb-8467-2a6016a78889 -->
  <rule id="720945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1608 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>