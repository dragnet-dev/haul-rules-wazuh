<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3125 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f8e79347-c739-5a4d-af02-0c19457173cc -->
  <rule id="842793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3125 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>