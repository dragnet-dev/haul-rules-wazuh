<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1977 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cebbe717-8f5e-537b-860d-6dfe79ba86c6 -->
  <rule id="467827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1977 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>