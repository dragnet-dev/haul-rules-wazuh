<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0759 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e01edb34-cf5c-5ca7-bb68-cbce2b2eb885 -->
  <rule id="442299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0759 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>