<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0149 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e8fd5c64-fac7-53a0-980e-8885acd5a327 -->
  <rule id="802652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0149 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>