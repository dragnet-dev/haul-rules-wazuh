<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1631 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a6307465-4bd5-5393-a203-173434f57c5e -->
  <rule id="263074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1631 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>