<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5197 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e2103bb8-429e-59b2-95c1-c82ea0fa761c -->
  <rule id="573659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5197 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>