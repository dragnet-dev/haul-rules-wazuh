<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3180 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 793f5ac8-39b7-5668-9788-e54be980c6e9 -->
  <rule id="332570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3180 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>