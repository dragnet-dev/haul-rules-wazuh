<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1747 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 459bdd74-792c-562a-b1d0-3c08500a7594 -->
  <rule id="183101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1747 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>