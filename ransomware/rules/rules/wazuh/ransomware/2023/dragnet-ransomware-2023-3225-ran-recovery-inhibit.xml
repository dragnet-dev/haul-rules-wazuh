<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3225 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 5fa77ff4-83d8-5984-a7ec-3458975e45ef -->
  <rule id="749247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3225 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
