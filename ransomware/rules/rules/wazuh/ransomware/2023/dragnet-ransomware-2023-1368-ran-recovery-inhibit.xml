<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1368 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c35526a3-847b-5ce4-917f-282bac7dc172 -->
  <rule id="435526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1368 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>