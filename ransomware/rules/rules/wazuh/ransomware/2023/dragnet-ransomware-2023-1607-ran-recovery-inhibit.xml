<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1607 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7cdbd773-6fb0-5812-95d8-3ec502d6fa11 -->
  <rule id="714217" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1607 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>