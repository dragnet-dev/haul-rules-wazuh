<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2965 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: fa2dae9b-6071-56f0-8364-d6ca73c8c516 -->
  <rule id="451694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2965 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>