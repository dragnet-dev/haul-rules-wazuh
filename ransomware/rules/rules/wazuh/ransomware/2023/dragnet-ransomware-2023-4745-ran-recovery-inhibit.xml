<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4745 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 11e9e33a-e2a2-5d1a-b83f-5709ae651b64 -->
  <rule id="455833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4745 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>