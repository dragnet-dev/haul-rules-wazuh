<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3634 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: ecc22397-d54f-51a5-b389-20718e1fb29b -->
  <rule id="288223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3634 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>