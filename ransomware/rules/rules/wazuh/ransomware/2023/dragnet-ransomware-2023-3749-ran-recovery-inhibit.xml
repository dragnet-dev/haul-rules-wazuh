<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3749 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a366995d-e4b6-55fb-8e2e-2f613aa19433 -->
  <rule id="236699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3749 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>