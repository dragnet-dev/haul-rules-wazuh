<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2059 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: a29e63d3-9e61-5af0-981d-241a3fbbf2f2 -->
  <rule id="847863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2059 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>