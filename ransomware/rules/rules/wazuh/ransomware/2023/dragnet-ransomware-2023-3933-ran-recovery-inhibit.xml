<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3933 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 139b2aa9-b196-50d6-872b-e04e9b3be0d0 -->
  <rule id="422282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3933 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>