<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1075 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 57ad786f-6ef2-5942-8079-83f8e78f413c -->
  <rule id="676578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1075 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>