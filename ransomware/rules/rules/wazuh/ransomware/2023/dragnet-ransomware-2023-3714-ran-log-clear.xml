<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3714 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: f5a927c9-7e0d-5f2d-8c36-4dfb5417aa8e -->
  <rule id="790927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3714 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>