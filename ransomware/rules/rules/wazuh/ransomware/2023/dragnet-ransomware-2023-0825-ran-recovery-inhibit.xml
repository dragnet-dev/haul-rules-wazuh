<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0825 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b5adad00-8b65-5efc-bf5c-6f4d59d52052 -->
  <rule id="481101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0825 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>