<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4572 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 6cf34869-f98d-5b8f-a6f3-be53430473b9 -->
  <rule id="943348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4572 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>