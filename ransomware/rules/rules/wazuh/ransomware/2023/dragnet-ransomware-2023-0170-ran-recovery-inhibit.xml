<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0170 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1059b8b2-79fa-5366-a1db-d0d5980904a8 -->
  <rule id="112939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0170 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>