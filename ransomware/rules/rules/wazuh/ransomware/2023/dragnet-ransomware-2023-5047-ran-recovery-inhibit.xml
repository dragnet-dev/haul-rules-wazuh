<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5047 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 6504e877-b464-55a8-823c-483b05d7abac -->
  <rule id="240788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5047 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>