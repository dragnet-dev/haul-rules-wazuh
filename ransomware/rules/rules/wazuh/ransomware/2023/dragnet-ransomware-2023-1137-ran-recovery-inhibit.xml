<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1137 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 26aab650-9bc1-597d-be9f-99203ca2fd1e -->
  <rule id="292276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1137 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>