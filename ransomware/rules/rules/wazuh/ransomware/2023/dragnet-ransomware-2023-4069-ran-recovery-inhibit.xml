<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4069 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: b37b87da-8679-53a2-a542-a9eb1aad2f91 -->
  <rule id="120387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4069 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>