<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0160 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2c44e5e0-edcd-5d8e-8687-78fc653bdf3d -->
  <rule id="678974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0160 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>