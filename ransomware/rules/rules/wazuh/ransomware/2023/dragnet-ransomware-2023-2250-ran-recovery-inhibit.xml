<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2250 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5af55708-0627-5b96-b631-bc5291c08a1f -->
  <rule id="655557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2250 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>