<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0092 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 5ed2cafc-4e79-503f-8638-ab1b2613419a -->
  <rule id="384234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0092 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>