<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2622 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 76da56b5-a4ae-5e3a-afb7-2feda0bbdb38 -->
  <rule id="267456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2622 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>