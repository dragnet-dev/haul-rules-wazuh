<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4270 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 5c8b1db8-337d-52c9-bef6-9ba3e27e9c8d -->
  <rule id="677469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4270 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>