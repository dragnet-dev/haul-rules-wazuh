<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5004 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 828eb02f-3489-5e18-bbcb-6fe63a68124d -->
  <rule id="422030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5004 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>