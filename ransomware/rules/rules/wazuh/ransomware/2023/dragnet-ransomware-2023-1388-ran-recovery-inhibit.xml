<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1388 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dd3de4a2-c78b-5c25-b816-bfd598082e95 -->
  <rule id="367504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1388 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>