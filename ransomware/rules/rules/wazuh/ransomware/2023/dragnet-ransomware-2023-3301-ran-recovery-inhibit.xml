<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3301 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6b176386-6109-54b3-ab99-929d772caea0 -->
  <rule id="271763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3301 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>