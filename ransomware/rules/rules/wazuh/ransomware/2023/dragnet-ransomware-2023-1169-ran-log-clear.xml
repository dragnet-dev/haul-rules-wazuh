<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1169 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 77d7b73e-9195-59ec-a5fb-4c85da4b5772 -->
  <rule id="293237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1169 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>