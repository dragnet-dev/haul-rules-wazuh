<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3449 — Event Log Clearing (qilin) | Status: deprecated | Sigma ID: e06534b9-4a23-5de0-a1e5-a0136f8ef8b6 -->
  <rule id="606534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3449 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>