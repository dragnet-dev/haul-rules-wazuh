<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1712 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 244681b2-4083-53c2-bc98-4aea94e3e796 -->
  <rule id="414907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1712 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>