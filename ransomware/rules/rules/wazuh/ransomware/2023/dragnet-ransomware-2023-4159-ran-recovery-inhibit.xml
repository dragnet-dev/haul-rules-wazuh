<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4159 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d8a61f7a-1c57-5374-a427-06db81803015 -->
  <rule id="949791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4159 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>