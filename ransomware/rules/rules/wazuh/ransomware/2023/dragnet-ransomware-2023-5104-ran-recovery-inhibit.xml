<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5104 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 41e5ceec-1be3-5711-a2d2-d589fae38114 -->
  <rule id="916686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5104 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>