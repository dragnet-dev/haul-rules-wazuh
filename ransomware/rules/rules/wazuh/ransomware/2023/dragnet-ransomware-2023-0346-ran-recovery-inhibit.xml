<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0346 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3c3f666e-6e63-544e-b278-218a7d3fd091 -->
  <rule id="763666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0346 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>