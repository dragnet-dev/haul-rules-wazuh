<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5228 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 14f298b5-1804-5761-a3d6-a872f9bb027f -->
  <rule id="328779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5228 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>