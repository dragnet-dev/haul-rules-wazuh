<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1965 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 013c51e2-89d4-55af-a034-f79e425c19cc -->
  <rule id="928302" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1965 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
