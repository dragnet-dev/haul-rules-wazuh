<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4237 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: 4246da9f-7d4e-58e6-b85f-a5c425ce1cd6 -->
  <rule id="287194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4237 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>