<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0685 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 85da745c-1af2-59b9-8c00-a855de68b171 -->
  <rule id="497874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0685 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>