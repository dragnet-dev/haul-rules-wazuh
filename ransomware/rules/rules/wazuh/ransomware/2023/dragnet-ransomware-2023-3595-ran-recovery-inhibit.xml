<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3595 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a12a6f56-6fa7-5463-9bd9-01ee7cd2ba60 -->
  <rule id="892431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3595 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
