<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1973 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 0e16450f-900f-5025-af73-e809ba789559 -->
  <rule id="616450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1973 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>