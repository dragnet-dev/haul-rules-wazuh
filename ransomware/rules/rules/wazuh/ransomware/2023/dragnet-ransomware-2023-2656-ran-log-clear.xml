<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2656 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 2ccd687e-453d-571e-b9e6-bd57ea75ccef -->
  <rule id="346968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2656 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>