<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4980 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 36cee208-f2a6-5e2c-a9eb-266bf4d6805f -->
  <rule id="707662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4980 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>