<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0734 — Event Log Clearing (ranstreet) | Status: deprecated | Sigma ID: d64bd530-0019-5465-a5c8-03441b71dfc3 -->
  <rule id="893735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0734 — Event Log Clearing (ranstreet)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>