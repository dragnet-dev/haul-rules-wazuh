<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4116 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1f85f9a6-aea1-58e6-8792-cebc33c425b0 -->
  <rule id="156154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4116 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>