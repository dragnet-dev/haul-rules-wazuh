<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2872 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 3683524f-fa04-561f-8350-cc97babf0ed3 -->
  <rule id="183524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2872 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>