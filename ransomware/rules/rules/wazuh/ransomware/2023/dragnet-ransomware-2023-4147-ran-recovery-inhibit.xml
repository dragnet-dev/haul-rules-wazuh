<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4147 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ac63a9c7-19b5-5ae8-b44f-2a55cea4bed4 -->
  <rule id="162189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4147 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>