<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2727 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5b719353-a785-591f-a2f8-4897729b62eb -->
  <rule id="271935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2727 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>