<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1306 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9630e738-3b6d-505a-845e-538bb2f0a6eb -->
  <rule id="740947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1306 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>