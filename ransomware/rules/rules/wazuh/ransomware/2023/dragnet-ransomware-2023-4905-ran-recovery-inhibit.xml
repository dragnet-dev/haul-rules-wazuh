<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4905 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5a1026fa-350e-53b9-b3c6-af6642d8ecf4 -->
  <rule id="116431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4905 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>