<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2025 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 0da8daa7-f971-5e91-912d-3c2dcbea6dd3 -->
  <rule id="965546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2025 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>