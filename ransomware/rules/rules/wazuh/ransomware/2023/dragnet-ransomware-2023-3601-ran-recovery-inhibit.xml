<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3601 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: dd152ebe-012e-5ef8-9145-799a7fe3cc2a -->
  <rule id="938446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3601 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>