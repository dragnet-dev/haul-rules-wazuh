<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0415 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4475f2ff-9d13-5d99-978e-45cb25889353 -->
  <rule id="758447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0415 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>