<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4511 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 5068471f-1274-5153-a4ac-fd30986f356a -->
  <rule id="668471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4511 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>