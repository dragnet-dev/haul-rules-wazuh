<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1854 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 93f1b185-915f-5173-a7ec-7ab7b035d1c4 -->
  <rule id="705071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1854 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>