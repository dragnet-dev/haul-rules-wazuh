<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5053 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 63539d31-5c26-57dc-950f-4e80b4ca4108 -->
  <rule id="216637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5053 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>