<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5289 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 677da95e-7436-593c-8a44-299e5a16ddc7 -->
  <rule id="935309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5289 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>