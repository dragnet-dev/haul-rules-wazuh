<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2525 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1c756d4d-e107-57f3-bc8c-653df601b738 -->
  <rule id="201094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2525 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>