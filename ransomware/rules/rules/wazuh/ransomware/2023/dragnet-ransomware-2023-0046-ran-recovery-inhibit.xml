<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0046 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3b5f994f-de43-579a-a164-cf2faeca1a82 -->
  <rule id="635994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0046 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>