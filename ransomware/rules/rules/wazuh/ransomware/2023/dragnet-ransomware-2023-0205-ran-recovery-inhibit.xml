<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0205 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: aa65ec79-cf3c-506a-a30f-8a7cb52f2291 -->
  <rule id="868876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0205 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
