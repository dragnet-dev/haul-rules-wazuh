<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3090 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 5acf04ca-6658-58fa-bd28-abb6350cd85d -->
  <rule id="624704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3090 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>