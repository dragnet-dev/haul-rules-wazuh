<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1486 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b9ad3f0b-65b5-5ffd-bde0-20352207637b -->
  <rule id="501983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1486 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>