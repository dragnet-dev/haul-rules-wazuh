<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4505 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: c3c87fb0-73f7-5929-9e2a-b5134bdfd183 -->
  <rule id="569407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4505 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>