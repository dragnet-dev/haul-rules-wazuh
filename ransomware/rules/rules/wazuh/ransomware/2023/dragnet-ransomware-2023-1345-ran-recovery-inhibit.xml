<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1345 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 84a99928-3341-523d-b56e-c2d3f2ede28e -->
  <rule id="554999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1345 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>