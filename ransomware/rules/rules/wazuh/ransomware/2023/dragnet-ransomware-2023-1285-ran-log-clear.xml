<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1285 — Event Log Clearing (cryptnet) | Status: experimental | Sigma ID: 62cd0e5c-f824-5ecc-8c22-746aa6f2f5c6 -->
  <rule id="872334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1285 — Event Log Clearing (cryptnet)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>