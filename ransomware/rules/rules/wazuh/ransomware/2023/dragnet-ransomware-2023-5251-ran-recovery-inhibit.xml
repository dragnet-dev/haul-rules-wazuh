<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5251 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 2698abac-3cc4-5d83-8de8-3c90709dbf6f -->
  <rule id="353754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5251 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>