<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2054 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0e5dbed0-44eb-502d-ae37-c2c559824192 -->
  <rule id="659021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2054 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>