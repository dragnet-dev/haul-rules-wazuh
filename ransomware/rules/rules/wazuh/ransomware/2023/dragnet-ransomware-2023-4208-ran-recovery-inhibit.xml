<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4208 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 86f222ea-64f7-5001-8875-30db26cc7641 -->
  <rule id="591222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4208 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>