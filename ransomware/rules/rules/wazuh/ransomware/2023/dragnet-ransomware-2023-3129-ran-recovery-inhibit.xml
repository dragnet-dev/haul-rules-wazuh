<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3129 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 2b49345c-67d9-5768-96e6-a445afd4cc93 -->
  <rule id="849345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3129 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>