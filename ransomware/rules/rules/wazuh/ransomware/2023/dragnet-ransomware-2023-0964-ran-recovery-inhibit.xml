<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0964 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 56c95f09-3d20-5ed5-b5aa-d08d98a6b6a4 -->
  <rule id="654335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0964 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>