<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2754 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 89e35db4-f162-5c98-9b7a-bf77a6a6623f -->
  <rule id="601373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2754 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>