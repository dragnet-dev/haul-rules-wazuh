<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3369 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a7a6b679-c51d-564a-b31a-aec5ea121012 -->
  <rule id="156276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3369 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>