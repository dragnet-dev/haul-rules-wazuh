<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1272 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ffbafc70-b501-5805-a41d-5c6ad1e4ce5b -->
  <rule id="247471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1272 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>