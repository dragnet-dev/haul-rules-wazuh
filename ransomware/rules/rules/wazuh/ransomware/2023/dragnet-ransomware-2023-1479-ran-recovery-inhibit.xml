<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1479 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dc11a1a9-b56a-56b9-93b9-7f781275232b -->
  <rule id="921861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1479 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>