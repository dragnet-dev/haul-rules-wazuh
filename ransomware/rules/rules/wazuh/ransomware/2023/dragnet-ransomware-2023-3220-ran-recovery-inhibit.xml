<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3220 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bce4968c-831a-5e8b-9540-ff74bb1fae52 -->
  <rule id="422496" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3220 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>