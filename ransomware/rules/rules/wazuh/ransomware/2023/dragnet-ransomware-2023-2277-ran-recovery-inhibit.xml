<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2277 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 85312162-8d25-59ca-975d-66abecd56a69 -->
  <rule id="531216" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2277 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>