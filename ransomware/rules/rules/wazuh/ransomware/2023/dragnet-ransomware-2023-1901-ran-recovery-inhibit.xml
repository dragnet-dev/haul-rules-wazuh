<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1901 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5adbd21f-6715-5f43-932d-217e20e95c51 -->
  <rule id="221572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1901 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>