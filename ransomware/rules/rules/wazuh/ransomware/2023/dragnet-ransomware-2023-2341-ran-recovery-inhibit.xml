<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2341 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7432efd9-5db1-5f98-a09f-7cf4e02c75f3 -->
  <rule id="202831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2341 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>