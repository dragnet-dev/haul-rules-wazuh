<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4791 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 95cae279-bc8c-5038-8417-bcef794f06b2 -->
  <rule id="423662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4791 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>