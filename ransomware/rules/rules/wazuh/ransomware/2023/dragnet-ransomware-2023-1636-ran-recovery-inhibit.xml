<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1636 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 96cae56c-67b5-51d6-a660-af26202fcfe8 -->
  <rule id="464625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1636 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>