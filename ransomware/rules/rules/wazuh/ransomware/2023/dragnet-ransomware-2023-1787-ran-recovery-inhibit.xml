<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1787 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e67f8bad-4f9a-579e-958a-d76670817a98 -->
  <rule id="258059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1787 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>