  <rule id="965087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2252 — Recovery Inhibition (ciphbit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
