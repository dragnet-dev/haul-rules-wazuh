<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0673 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b7232502-0e71-5a32-9377-ad7998f4ada0 -->
  <rule id="372325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0673 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>