<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3897 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 4a62d90b-1068-5ea9-937e-344611f6efb5 -->
  <rule id="394059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3897 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>