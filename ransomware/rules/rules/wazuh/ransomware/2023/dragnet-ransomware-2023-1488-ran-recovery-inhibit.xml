<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1488 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 48e9729a-6203-5d01-92f0-407795923465 -->
  <rule id="729729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1488 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>