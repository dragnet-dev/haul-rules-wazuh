<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4492 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 9b5e7ebf-249d-53af-aa45-d81c1142bc27 -->
  <rule id="483166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4492 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>