<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3575 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 8d47c950-8500-5e58-8a6d-327d737ef4a1 -->
  <rule id="563649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3575 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>