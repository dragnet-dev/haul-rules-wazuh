<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1569 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e3a38dea-7c99-57ea-ae75-1fe2cff1cb1c -->
  <rule id="177421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1569 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>