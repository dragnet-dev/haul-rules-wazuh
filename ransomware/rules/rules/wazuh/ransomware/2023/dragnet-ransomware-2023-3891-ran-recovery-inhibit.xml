<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3891 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: b7111fdb-2ea7-54e9-a704-084a6574db79 -->
  <rule id="173791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3891 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>