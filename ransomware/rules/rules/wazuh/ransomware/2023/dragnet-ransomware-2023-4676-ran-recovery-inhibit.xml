<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4676 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 64858946-8d0f-507e-abda-af9f558fa765 -->
  <rule id="285894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4676 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>