<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3437 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fa397a67-3fc3-56dc-8f1f-cd1b351fd993 -->
  <rule id="506362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3437 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>