<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4155 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 27ebde08-b6d4-5c90-bc13-89d93c9c2691 -->
  <rule id="129854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4155 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>