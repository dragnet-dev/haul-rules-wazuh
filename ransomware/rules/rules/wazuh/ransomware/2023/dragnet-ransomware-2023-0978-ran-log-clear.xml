<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0978 — Event Log Clearing (clop) | Status: experimental | Sigma ID: d68385bf-ea0d-5a79-8df0-dc4e0f1d4ea6 -->
  <rule id="568385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0978 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>