<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3680 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4dcaceaa-598c-5c75-93d0-1c2e0f7998c7 -->
  <rule id="698190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3680 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>