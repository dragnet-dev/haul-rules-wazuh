<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5279 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 513b9bfc-2fac-5a4b-b50f-1cb38e4282d5 -->
  <rule id="515195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5279 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>