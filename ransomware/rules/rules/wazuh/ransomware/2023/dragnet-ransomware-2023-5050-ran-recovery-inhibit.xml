<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5050 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c141ff9a-b6dc-55c2-bbbd-8320205a5b0e -->
  <rule id="508351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5050 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>