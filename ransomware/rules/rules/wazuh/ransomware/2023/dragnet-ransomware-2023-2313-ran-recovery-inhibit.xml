<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2313 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: acbcb112-7789-508b-a37a-ddaa7cddebf4 -->
  <rule id="875311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2313 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>