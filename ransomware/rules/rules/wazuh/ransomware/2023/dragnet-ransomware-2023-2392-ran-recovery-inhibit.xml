<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2392 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 5b6a3095-55fc-592f-918c-e040312d3da9 -->
  <rule id="666630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2392 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>