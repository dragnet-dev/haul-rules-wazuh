<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2483 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: a2055a36-fb42-5bb8-b79b-4e60c3975a87 -->
  <rule id="832890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2483 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>