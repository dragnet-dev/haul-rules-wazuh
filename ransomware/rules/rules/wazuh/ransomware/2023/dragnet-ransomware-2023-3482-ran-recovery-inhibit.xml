<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3482 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 3c9f9e98-efd2-5d3e-b8b4-057bd26ec287 -->
  <rule id="761598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3482 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>