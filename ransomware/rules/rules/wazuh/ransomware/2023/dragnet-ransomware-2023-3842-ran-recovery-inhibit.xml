<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3842 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 78d7c012-7c19-52fd-ad3b-ff8ddf67a22b -->
  <rule id="318840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3842 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>