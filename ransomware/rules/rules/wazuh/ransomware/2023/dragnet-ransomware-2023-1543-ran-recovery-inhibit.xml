<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1543 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9917b4cb-a7b6-5e13-a607-bbbab29719d5 -->
  <rule id="786834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1543 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>