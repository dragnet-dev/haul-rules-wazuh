<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0625 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 53582555-1663-5931-8d89-5bfb0981afa1 -->
  <rule id="958255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0625 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>