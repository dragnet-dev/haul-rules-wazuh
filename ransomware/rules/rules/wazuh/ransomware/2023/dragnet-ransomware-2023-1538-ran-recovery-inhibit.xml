<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1538 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 25db012a-de0a-592c-9878-46966a86a2b3 -->
  <rule id="419012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1538 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>