<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4168 — Event Log Clearing (noescape) | Status: experimental | Sigma ID: 1a4ceff4-b15d-5a3b-bbfc-e552af2b02b9 -->
  <rule id="284655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4168 — Event Log Clearing (noescape)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>