<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2595 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c2c77961-8237-5c13-acec-6011522650c7 -->
  <rule id="264779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2595 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>