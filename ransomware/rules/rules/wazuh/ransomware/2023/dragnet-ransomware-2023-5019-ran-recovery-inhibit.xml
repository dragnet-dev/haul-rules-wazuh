<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5019 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 50545693-df42-598a-9a70-f8a2f3ca36b7 -->
  <rule id="654569" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5019 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>