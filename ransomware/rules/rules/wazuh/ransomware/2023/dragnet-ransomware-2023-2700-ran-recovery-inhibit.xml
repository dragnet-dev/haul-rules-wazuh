<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2700 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: daa013ea-c21c-50ce-9103-49cd984927e6 -->
  <rule id="898013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2700 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>