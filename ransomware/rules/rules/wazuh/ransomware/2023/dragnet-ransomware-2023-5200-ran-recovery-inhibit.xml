<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5200 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1b8dc9ab-e93c-584f-80cd-a32bfdda0371 -->
  <rule id="722234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5200 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>