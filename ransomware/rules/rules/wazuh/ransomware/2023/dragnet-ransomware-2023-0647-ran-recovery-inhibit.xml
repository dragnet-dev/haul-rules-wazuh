<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0647 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e0b852fa-9239-50b4-9611-8d11aadc0659 -->
  <rule id="551852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0647 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>