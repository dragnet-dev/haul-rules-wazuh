<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2350 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 35658963-8ca4-5858-985b-b578bc115988 -->
  <rule id="965896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2350 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>