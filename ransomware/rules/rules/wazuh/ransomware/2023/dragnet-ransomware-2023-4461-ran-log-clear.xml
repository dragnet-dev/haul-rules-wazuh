<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4461 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 49f4db94-5acc-5d16-b3d4-2d3d9ab242a1 -->
  <rule id="346683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4461 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>