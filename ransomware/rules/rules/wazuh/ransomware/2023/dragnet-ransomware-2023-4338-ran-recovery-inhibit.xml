<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4338 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: be81652e-5dcc-5ee9-bdc2-d61e775618e8 -->
  <rule id="208165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4338 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>