<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3414 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 68b81ffe-bb8c-5dd7-b8e9-65d7dccb4d90 -->
  <rule id="959711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3414 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>