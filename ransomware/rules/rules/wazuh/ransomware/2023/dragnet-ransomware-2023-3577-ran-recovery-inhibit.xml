<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3577 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a533f1bd-1371-54ca-9f2a-7b4461e285c3 -->
  <rule id="885431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3577 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>