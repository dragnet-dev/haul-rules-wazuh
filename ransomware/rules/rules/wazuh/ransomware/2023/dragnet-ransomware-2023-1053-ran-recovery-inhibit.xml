<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1053 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 4026af55-bc24-5782-a6a9-07396fb492b7 -->
  <rule id="230831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1053 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>