<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3202 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3300ace4-51e2-57f3-8027-3728b55f3027 -->
  <rule id="119566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3202 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>