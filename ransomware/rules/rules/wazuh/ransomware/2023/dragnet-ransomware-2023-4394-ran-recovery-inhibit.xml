<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4394 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f58cd86a-85b1-5ee3-803e-4386628aacae -->
  <rule id="490538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4394 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>