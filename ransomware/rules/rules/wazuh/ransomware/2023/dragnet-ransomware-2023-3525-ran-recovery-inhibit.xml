<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3525 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5ad11d25-3bbc-539f-bd6c-6a9008b22f6e -->
  <rule id="624989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3525 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>