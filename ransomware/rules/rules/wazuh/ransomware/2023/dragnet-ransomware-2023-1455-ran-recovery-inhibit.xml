<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1455 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8d408cf6-453a-5f06-b20c-e7c21800ad16 -->
  <rule id="562540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1455 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>