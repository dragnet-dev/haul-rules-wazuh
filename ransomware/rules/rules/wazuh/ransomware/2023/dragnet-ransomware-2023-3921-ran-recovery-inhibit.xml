<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3921 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0d7d7d9f-26eb-5539-843a-543a087179c2 -->
  <rule id="929259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3921 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>