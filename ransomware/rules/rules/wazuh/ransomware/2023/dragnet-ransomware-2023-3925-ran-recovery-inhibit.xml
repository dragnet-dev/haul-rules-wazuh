<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3925 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 796a9761-723c-5a29-829e-090549bcb5fe -->
  <rule id="474697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3925 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>