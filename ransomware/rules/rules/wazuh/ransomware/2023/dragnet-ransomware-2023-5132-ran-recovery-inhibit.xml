<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5132 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cc77786e-645f-5db8-9fbe-a1e73dbe7f78 -->
  <rule id="347778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5132 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>