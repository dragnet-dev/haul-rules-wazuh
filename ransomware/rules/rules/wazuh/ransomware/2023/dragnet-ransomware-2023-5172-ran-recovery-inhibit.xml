<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5172 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: f216a87e-7fab-549e-b58f-21db5f8a1b8e -->
  <rule id="734668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5172 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>