<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3621 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 45c4295f-6028-5faa-a1a1-56a9f46bff1c -->
  <rule id="224295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3621 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>