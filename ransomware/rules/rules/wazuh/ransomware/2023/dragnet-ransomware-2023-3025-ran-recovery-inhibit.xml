<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3025 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b26a2f3c-c1cc-5466-8f7a-b899d69529d4 -->
  <rule id="284207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3025 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>