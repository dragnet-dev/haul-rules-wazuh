<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3854 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a7900792-07fa-5db9-aa08-ee6baf2ac0d5 -->
  <rule id="279007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3854 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>