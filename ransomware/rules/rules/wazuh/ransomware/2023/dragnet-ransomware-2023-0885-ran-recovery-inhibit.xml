<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0885 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1f4cb0a4-90aa-5087-8fc3-a901b9298dfc -->
  <rule id="393930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0885 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>