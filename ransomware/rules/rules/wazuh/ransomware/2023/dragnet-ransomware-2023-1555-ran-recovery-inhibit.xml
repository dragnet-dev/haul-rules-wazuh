<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1555 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 22c79fbe-e913-5cca-9459-1936f5763cf0 -->
  <rule id="438875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1555 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>