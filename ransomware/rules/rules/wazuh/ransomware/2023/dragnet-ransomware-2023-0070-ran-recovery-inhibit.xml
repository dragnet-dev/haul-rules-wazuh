<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0070 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5e3836f8-05c6-5284-b112-647f047a0dae -->
  <rule id="801391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0070 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>