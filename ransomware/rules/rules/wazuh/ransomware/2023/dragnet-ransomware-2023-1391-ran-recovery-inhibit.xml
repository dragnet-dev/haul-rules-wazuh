<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1391 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: aabed882-8c67-59d8-a4b1-43de7a18f534 -->
  <rule id="793738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1391 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>