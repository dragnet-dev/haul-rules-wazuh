<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3041 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: 7a89309e-7b9d-5aff-8dd2-526eb45c7f92 -->
  <rule id="428930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3041 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>