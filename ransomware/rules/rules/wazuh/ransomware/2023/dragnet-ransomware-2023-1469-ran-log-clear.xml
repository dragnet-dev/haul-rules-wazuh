<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1469 — Event Log Clearing (qilin) | Status: deprecated | Sigma ID: 2aee6441-d3c1-5e5c-9d3c-22a247b04f06 -->
  <rule id="299064" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1469 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>