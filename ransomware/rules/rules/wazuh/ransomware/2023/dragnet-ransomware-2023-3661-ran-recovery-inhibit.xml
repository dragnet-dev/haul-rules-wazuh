<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3661 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7b024667-365f-50ce-a575-8ee99f702a15 -->
  <rule id="430246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3661 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>