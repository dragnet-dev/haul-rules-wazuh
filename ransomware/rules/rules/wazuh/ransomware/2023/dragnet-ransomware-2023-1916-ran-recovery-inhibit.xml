<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1916 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a0b889bc-b43f-55f5-a16e-9bf7948127ca -->
  <rule id="811889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1916 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>