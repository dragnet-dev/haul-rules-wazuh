<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4813 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f703c422-135f-5a9c-88c7-731415e1dcbb -->
  <rule id="812604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4813 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>