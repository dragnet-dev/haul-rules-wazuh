<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1748 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 50d71cd6-166b-5546-974e-35d77103cfda -->
  <rule id="501948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1748 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>