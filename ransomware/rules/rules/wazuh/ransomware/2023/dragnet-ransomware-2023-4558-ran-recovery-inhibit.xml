<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4558 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b1d60d20-3205-5a60-8e71-59bea79f3c38 -->
  <rule id="263373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4558 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>