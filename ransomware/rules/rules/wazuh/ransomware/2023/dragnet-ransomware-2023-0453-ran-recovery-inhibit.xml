<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0453 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1622d265-bd60-5e8e-93ec-ac6154f3d142 -->
  <rule id="896526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0453 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>