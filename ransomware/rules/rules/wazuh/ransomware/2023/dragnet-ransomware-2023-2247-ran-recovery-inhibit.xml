<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2247 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 188f5482-6e80-52a8-8462-da03f9b8639d -->
  <rule id="423548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2247 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>