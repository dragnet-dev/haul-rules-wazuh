<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3843 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: aa11e9fe-cce7-589c-b466-e38e821f4744 -->
  <rule id="121909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3843 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>