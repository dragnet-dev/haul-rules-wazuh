<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4007 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 2dd1ac0d-9b38-5836-899b-0f23f4dd1dba -->
  <rule id="176908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4007 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>