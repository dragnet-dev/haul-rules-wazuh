<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3801 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d271dc86-6c3b-598a-8e39-2b4701f88d71 -->
  <rule id="797596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3801 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>