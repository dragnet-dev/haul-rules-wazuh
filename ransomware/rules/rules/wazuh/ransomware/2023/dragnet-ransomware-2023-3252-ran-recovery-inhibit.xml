<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3252 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 00570466-8373-5119-886b-67bcd2dce1db -->
  <rule id="404668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3252 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>