<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4457 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2ee4a2eb-acbf-5290-a054-20516a3c00bd -->
  <rule id="400742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4457 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>