<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2539 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: de1abfd7-db3c-5247-ac4d-4895fdcac564 -->
  <rule id="199967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2539 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>