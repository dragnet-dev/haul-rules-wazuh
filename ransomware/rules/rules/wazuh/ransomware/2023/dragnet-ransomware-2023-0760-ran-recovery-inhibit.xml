<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0760 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1ae1d8f2-ca59-5536-8a02-4f54cde8dab2 -->
  <rule id="312783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0760 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>