<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3602 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: fcd69f94-eee9-5249-9013-30da0ad8cfc3 -->
  <rule id="273119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3602 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>