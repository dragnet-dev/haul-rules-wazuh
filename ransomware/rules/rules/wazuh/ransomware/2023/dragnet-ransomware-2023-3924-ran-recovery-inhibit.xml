<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3924 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 66497c56-488c-5651-b25d-1028c9e50c09 -->
  <rule id="263964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3924 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>