<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0432 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 6a6e50e3-e28e-5763-8559-b094bdb65ee9 -->
  <rule id="907050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0432 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>