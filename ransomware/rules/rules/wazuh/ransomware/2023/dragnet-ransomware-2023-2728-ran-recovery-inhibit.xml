<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2728 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 564c0612-530f-5cb0-90bf-a9787d605a61 -->
  <rule id="136061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2728 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>