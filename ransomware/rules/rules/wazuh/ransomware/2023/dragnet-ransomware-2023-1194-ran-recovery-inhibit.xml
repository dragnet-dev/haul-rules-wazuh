<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1194 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f08e6766-ecb8-537a-825f-85f2d550fc95 -->
  <rule id="714267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1194 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>