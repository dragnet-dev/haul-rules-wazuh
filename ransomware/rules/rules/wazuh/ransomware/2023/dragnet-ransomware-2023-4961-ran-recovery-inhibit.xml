<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4961 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b08264f4-b905-55d0-9c1c-65facbf26dea -->
  <rule id="308264" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4961 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>