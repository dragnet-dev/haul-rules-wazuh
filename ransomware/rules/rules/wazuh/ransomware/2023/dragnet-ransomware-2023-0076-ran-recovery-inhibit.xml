<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0076 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 17a9a813-2196-5986-85e7-f79b8037b9e7 -->
  <rule id="127481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0076 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>