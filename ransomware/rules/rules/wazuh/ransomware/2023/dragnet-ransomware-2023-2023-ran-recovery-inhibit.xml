<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2023 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 258b519c-c8aa-5b89-9e6b-222f23d9f881 -->
  <rule id="639519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2023 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>