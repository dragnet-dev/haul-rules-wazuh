<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3810 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 94a9d334-1310-5ef2-a3e0-b6d483e0c550 -->
  <rule id="723973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3810 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>