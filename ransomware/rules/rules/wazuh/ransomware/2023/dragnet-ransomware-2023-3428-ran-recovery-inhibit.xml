<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3428 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ae6809c6-3091-54f1-b6ef-18aaa09a3f62 -->
  <rule id="946809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3428 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>