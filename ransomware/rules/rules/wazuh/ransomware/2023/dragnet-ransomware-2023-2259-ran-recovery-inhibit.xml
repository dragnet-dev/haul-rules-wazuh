<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2259 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 1d556de9-86b4-578d-ba71-373ebe2d68d4 -->
  <rule id="466558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2259 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>