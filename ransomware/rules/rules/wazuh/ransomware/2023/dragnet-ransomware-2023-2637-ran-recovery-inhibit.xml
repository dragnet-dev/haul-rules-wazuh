<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2637 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 81a9a477-f461-5b6f-a782-da13b01297c8 -->
  <rule id="391144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2637 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>