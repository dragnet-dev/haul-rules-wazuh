<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0543 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 11a678a5-9607-5d09-98c1-4c26427fe0b1 -->
  <rule id="386858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0543 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>