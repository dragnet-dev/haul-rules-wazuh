<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4006 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 39a4f90e-4eb1-547a-8949-2b946c6fae3c -->
  <rule id="215199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4006 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>