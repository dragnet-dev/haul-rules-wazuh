<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0787 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 94b5b883-efb5-5b4d-a044-7d8b08167644 -->
  <rule id="724918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0787 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>