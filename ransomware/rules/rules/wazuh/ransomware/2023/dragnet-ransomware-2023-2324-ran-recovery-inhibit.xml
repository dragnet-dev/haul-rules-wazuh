<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2324 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e921dfa1-8f19-5f10-abe6-b7a86268ba65 -->
  <rule id="319999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2324 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>