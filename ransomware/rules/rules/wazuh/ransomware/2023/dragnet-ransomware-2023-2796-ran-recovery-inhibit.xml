<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2796 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 202f286e-24f9-5032-8643-44144bad96f9 -->
  <rule id="647286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2796 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>