<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1380 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a4a1a1ca-1cec-5850-be2c-d43479da664a -->
  <rule id="978661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1380 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>