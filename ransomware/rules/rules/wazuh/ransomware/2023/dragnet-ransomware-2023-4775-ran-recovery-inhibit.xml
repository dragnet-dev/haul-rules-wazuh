<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4775 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c0f73ea2-9686-56e0-a21b-e75f5e040611 -->
  <rule id="497182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4775 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>