<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4559 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 24b4f8a1-e38f-5314-8286-4068c54b5f24 -->
  <rule id="324778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4559 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>