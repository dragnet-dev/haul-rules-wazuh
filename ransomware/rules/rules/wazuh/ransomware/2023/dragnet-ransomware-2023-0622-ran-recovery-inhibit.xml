<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0622 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 5c2bfad8-7b93-5d14-8892-8e99f0f98d66 -->
  <rule id="279578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0622 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>