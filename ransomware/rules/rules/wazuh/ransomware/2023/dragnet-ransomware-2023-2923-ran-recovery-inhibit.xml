<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2923 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 7f306f47-6c02-578d-b456-86eef1644d6d -->
  <rule id="336911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2923 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>