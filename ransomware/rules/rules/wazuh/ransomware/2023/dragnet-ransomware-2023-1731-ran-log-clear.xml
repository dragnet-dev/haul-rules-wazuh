<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1731 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 4d659764-92b4-5aaf-a8ce-2fc90a9c6418 -->
  <rule id="665976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1731 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>