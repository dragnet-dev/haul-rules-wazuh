<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0921 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 8ed2691d-dbde-512f-b01f-19daaa4ba4bb -->
  <rule id="585269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0921 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
