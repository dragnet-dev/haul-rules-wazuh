<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3589 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: e0291318-50fe-576a-8fb8-ef9a47d2c106 -->
  <rule id="602913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3589 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>