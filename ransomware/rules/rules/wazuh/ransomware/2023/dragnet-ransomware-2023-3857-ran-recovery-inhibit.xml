<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3857 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2d93ae41-d7e3-5801-b841-3729091747a9 -->
  <rule id="375982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3857 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>