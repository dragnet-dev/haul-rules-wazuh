<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5339 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c780b62f-c50f-5c60-af88-00355e7aea00 -->
  <rule id="344916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5339 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>