<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2764 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 8423934a-3c4c-5784-b4b7-1362c0c8cce8 -->
  <rule id="423934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2764 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>