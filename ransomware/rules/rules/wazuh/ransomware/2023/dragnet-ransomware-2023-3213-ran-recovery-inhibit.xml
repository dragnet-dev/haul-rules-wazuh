<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3213 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 0f7ba65f-c46f-5c54-b0be-461385e064ef -->
  <rule id="537865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3213 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>