<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3829 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1a132e27-2dd7-5ce2-a791-36f83e014f84 -->
  <rule id="681262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3829 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>