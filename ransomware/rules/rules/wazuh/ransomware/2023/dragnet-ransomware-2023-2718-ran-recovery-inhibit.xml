<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2718 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0da2fcae-4a40-550a-b981-e3bd1cf5ee9d -->
  <rule id="941514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2718 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>