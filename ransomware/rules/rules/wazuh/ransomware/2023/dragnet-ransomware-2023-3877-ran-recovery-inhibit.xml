<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3877 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9386e875-add8-5f2c-a780-f517e30299bc -->
  <rule id="701908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3877 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>