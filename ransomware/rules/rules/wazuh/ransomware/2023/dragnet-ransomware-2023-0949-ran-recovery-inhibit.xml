<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0949 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4506f7b4-9e6c-5ceb-9094-e305e377125a -->
  <rule id="837883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0949 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>