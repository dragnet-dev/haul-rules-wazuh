<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4353 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3edb03d3-4bda-5143-b6cc-c53a285ac3df -->
  <rule id="809103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4353 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>