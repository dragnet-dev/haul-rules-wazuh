<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0982 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1c8dc29c-b170-52d6-b181-25439bbb0e16 -->
  <rule id="294829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0982 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>