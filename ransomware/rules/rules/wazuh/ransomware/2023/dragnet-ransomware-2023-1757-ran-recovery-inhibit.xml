<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1757 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f540a1be-bcea-57ae-ad18-3f15a91c1c94 -->
  <rule id="786501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1757 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>