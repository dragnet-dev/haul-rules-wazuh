<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0162 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: d56f2648-6389-563e-a63c-9682464de011 -->
  <rule id="471126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0162 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>