<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3007 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d6c537f0-80a2-577a-947d-60d2d53e78ed -->
  <rule id="488537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3007 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>