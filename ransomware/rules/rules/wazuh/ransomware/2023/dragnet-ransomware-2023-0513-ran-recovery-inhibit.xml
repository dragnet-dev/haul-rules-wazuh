<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0513 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 63cbe282-186a-5e04-b6d2-9da9bb7d897e -->
  <rule id="913102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0513 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>