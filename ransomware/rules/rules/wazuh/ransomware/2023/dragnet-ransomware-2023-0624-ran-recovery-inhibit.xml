<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0624 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5a37d185-2678-5236-9a55-ee2fef5d794d -->
  <rule id="646051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0624 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>