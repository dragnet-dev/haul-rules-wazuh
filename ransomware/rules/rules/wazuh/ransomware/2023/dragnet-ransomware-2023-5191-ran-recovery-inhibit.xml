<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5191 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: a7359160-4f71-5780-90d3-2086e1079fab -->
  <rule id="273591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5191 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>