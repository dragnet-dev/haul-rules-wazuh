<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0104 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 35b74184-44d0-55f3-a022-55237bc7097d -->
  <rule id="417418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0104 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>