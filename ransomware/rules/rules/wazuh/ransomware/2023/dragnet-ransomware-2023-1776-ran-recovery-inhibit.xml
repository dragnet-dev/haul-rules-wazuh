<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1776 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1f33b24a-20fb-5434-80e9-618ab662b3af -->
  <rule id="613924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1776 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>