<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2762 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 6cf3e226-0e02-5a52-9350-070de7f4c69b -->
  <rule id="189422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2762 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>