<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0412 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: 3f5e0077-1e92-55a3-bd55-f1fc64778ff6 -->
  <rule id="217400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0412 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>