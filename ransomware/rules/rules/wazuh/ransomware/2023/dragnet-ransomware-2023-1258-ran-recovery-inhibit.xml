<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1258 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f670b6eb-dc7f-5e7e-bb8c-71a3e75ea73f -->
  <rule id="807316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1258 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>