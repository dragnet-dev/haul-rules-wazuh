<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4091 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 64fd32ec-3ecb-5b38-9cab-e3d1b9c54434 -->
  <rule id="863732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4091 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
