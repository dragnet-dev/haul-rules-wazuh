<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3539 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: a161e4b8-a569-599f-af6b-5d7dd3c2c6d3 -->
  <rule id="825904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3539 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>