<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3183 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b03900ac-32fc-5f6b-b5e6-8be0aa9b2ff1 -->
  <rule id="303900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3183 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>