<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5006 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 0f69ab36-691b-5230-89d4-035c00e199f5 -->
  <rule id="518353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5006 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>