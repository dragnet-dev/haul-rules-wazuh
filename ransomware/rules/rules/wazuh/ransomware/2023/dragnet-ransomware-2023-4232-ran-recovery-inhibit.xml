<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4232 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2a4a375b-c4fe-50f9-91b2-3794df37e8e9 -->
  <rule id="594375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4232 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>