<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3832 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 16773fbc-7263-50f7-b61a-330f09b02f41 -->
  <rule id="794139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3832 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>