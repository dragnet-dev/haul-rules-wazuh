<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4408 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1f43f9c3-4ef4-542a-92bb-def24f2e193c -->
  <rule id="948636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4408 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>