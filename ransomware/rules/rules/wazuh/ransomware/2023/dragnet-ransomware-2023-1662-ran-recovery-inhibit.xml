<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1662 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6471dde6-0be2-5503-99aa-331b0b9d6d19 -->
  <rule id="856797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1662 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>