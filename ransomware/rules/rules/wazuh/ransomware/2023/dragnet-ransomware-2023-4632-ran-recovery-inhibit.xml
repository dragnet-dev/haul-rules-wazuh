<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4632 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 05283907-b9be-5937-9f05-65b4de593f29 -->
  <rule id="883907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4632 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>