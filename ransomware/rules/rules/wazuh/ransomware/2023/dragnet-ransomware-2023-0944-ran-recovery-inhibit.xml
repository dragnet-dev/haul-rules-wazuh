<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0944 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 5325160d-4df7-5389-b73d-1b17e7f429a0 -->
  <rule id="925160" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0944 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>