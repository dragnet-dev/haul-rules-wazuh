<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2040 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3c75ec72-345e-5268-a7a1-ae28d000c1a0 -->
  <rule id="755436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2040 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>