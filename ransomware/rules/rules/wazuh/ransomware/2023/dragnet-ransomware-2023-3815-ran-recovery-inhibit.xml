<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3815 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 21b27c77-de0d-5306-9c4a-f34932d2e170 -->
  <rule id="256447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3815 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>