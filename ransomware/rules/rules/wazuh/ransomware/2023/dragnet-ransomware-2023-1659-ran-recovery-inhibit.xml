<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1659 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f61a053d-c464-5fe1-9143-0340415b9a81 -->
  <rule id="798605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1659 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>