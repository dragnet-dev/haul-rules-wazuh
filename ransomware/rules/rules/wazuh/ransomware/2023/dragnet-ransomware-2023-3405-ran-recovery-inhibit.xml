<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3405 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4bc21d2f-cb90-5f85-b4e0-6ae73e3f9907 -->
  <rule id="239549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3405 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>