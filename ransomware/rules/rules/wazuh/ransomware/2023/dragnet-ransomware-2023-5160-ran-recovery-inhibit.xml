<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5160 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9980d948-37a6-5101-94d0-2d4aa6c26928 -->
  <rule id="796939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5160 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>