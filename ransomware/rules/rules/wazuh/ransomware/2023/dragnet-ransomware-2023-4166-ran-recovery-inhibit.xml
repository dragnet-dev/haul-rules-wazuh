<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4166 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 04457fd4-a67f-591b-a83b-738cbac8f9e5 -->
  <rule id="341245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4166 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>