<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0142 — Event Log Clearing (ryuk) | Status: deprecated | Sigma ID: 3b1adcd7-fcc1-58e2-ad0e-e79fd0ca2a22 -->
  <rule id="723516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0142 — Event Log Clearing (ryuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>