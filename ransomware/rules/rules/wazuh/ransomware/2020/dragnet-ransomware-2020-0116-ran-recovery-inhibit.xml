<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0116 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: dbd9725a-295a-53a4-ab6b-2c35a0ce4af8 -->
  <rule id="917972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0116 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>