<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0049 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 0513c2d0-93cf-5233-a037-199126f5f51b -->
  <rule id="515245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0049 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>