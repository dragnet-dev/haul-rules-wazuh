<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0231 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 9a37b94b-bce7-59c5-9a4a-a432d52ad4f0 -->
  <rule id="770039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0231 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>