<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0176 — Recovery Inhibition (maze) | Status: deprecated | Sigma ID: 9c4cb7cb-fcc4-5c47-80c5-cf34e434504d -->
  <rule id="505877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0176 — Recovery Inhibition (maze)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
