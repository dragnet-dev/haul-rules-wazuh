<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0143 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: 0374771b-67d3-5bd9-b58b-e033caabcf51 -->
  <rule id="696347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0143 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
