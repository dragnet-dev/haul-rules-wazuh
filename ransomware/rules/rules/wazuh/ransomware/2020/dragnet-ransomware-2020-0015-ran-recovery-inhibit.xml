<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0015 — Recovery Inhibition (maze) | Status: deprecated | Sigma ID: db428ee6-f330-5d42-a19b-f51b4be1f3e4 -->
  <rule id="910862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0015 — Recovery Inhibition (maze)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>