<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0054 — Event Log Clearing (netwalker) | Status: deprecated | Sigma ID: 9e737b87-1429-5699-af1e-8a2ccba7baf0 -->
  <rule id="839803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0054 — Event Log Clearing (netwalker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>