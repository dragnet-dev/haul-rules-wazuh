<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0179 — Recovery Inhibition (wastedlocker) | Status: deprecated | Sigma ID: 8c6a146b-be30-58c4-a78c-9ed18c720353 -->
  <rule id="550614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0179 — Recovery Inhibition (wastedlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>