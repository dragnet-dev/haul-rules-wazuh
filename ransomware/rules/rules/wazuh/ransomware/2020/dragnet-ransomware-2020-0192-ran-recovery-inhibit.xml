<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0192 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 187f722b-e242-5b9a-9dba-fbde662e22d4 -->
  <rule id="407722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0192 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>