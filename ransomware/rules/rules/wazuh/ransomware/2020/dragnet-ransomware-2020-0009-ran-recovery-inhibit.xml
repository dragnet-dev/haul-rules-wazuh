<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0009 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: 8195388c-5d17-5787-afd6-5a3c648ad086 -->
  <rule id="195388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0009 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>