<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0193 — Event Log Clearing (hades) | Status: deprecated | Sigma ID: c308454c-2496-5d03-8194-0c155acca757 -->
  <rule id="430845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0193 — Event Log Clearing (hades)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>