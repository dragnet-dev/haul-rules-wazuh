<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0003 — Shadow Copy Deletion (dispossessor) | Status: experimental | Sigma ID: 10c4e658-1ee5-5a7e-9e49-858cd90b8e4c -->
  <rule id="159865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0003 — Shadow Copy Deletion (dispossessor)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>