<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0228 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: f3ab473c-2c3b-5833-9532-6833170d7e1e -->
  <rule id="433947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0228 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>