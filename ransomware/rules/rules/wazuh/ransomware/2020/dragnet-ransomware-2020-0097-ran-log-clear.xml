<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0097 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: fa78b5d6-a4ae-59e3-ad1a-35f9a880501f -->
  <rule id="512595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0097 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>