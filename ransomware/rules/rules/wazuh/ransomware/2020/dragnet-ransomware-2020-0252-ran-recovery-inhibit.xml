<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0252 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 99615255-56c5-5059-9a6c-a22092fe0afb -->
  <rule id="161525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0252 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>