<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0031 — Recovery Inhibition (agelocker) | Status: deprecated | Sigma ID: 18849ee0-c2f5-52ab-940d-7b4b91c2b817 -->
  <rule id="425582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0031 — Recovery Inhibition (agelocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>