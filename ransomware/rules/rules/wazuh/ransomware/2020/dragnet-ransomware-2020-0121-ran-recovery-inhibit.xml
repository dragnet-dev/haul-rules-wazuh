  <rule id="869853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0121 — Recovery Inhibition (egregor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
