<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0216 — Recovery Inhibition (coldlock) | Status: deprecated | Sigma ID: 46ebca86-f182-5bc2-a028-e9492bd2bb5c -->
  <rule id="475018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0216 — Recovery Inhibition (coldlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>