<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0219 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: aba708f2-9211-56f6-a832-9654765ef84c -->
  <rule id="146708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0219 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>