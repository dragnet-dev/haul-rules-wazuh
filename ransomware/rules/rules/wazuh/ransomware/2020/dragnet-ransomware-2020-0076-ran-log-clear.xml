<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0076 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 52df1a25-bbd6-5ec3-a884-8ae31c8fa478 -->
  <rule id="465626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0076 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>