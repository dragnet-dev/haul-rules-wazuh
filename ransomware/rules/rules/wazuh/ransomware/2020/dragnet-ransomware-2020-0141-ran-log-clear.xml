<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0141 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: 2737648e-c40e-58d3-a7e0-1b2d929ff7e1 -->
  <rule id="137648" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0141 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>