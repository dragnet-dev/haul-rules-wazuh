<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0183 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: 773ae415-3e1f-51ee-9e34-1e1d07a500df -->
  <rule id="280624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0183 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>