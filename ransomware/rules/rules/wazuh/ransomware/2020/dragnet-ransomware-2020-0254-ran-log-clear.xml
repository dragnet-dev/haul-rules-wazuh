<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0254 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 7b5c3e1c-f475-5d47-911c-3e9965e3cda3 -->
  <rule id="563582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0254 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>