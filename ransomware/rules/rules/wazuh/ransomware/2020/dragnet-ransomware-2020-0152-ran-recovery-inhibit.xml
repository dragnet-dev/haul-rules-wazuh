<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0152 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: d0ed461a-39e6-5b89-b553-314be043dc52 -->
  <rule id="751746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0152 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>