<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0248 — Event Log Clearing (pay2key) | Status: deprecated | Sigma ID: 80cbe969-678c-5714-8b41-87132387c341 -->
  <rule id="709429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0248 — Event Log Clearing (pay2key)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>