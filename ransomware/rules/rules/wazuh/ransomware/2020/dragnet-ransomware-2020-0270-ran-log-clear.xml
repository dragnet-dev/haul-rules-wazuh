<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0270 — Event Log Clearing (egregor) | Status: deprecated | Sigma ID: b642e23f-1c3c-5408-ac46-674b6d71c676 -->
  <rule id="162862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0270 — Event Log Clearing (egregor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>