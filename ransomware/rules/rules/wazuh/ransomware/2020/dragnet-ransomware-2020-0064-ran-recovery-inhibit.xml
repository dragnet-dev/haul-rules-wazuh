  <rule id="357333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0064 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>