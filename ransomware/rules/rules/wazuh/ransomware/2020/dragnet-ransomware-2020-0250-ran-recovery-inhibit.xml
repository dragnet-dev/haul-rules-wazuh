<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0250 — Recovery Inhibition (doppelpaymer) | Status: deprecated | Sigma ID: 365ccf60-4965-5928-8e1a-386eacc002a3 -->
  <rule id="698319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0250 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>