<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0130 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 16147162-95ef-5dfe-951e-2b007e7f4b7f -->
  <rule id="814716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0130 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>