<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0249 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 4cc71cad-b2ca-5967-8906-c4ca38bf08a6 -->
  <rule id="265948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0249 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>