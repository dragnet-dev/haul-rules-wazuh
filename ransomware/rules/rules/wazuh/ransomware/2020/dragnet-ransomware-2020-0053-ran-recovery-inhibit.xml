<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0053 — Recovery Inhibition (clop) | Status: deprecated | Sigma ID: 05486601-dc3a-520c-9db0-262e18c5a7b2 -->
  <rule id="186601" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0053 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
