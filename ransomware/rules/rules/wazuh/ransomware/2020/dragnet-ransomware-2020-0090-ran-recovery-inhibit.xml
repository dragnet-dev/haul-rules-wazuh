<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0090 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7e3d49d5-1d0e-5fc6-9f2e-70227fd53f28 -->
  <rule id="322149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0090 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>