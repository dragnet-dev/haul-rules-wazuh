<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0235 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d12891e1-592c-51ca-821f-1fb0ff858bb9 -->
  <rule id="512891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0235 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>