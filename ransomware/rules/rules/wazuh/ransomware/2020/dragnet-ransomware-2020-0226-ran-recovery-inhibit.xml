<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0226 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 9e965f50-0d55-5d18-b674-0c95e4623904 -->
  <rule id="843455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0226 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>