<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0213 — Recovery Inhibition (wastedlocker) | Status: deprecated | Sigma ID: 62652ac0-c74b-57ae-b454-f145640be59b -->
  <rule id="202442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0213 — Recovery Inhibition (wastedlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>