<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0233 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: c8de8acf-963c-56f2-bdab-fc9ae6509c22 -->
  <rule id="878538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0233 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>