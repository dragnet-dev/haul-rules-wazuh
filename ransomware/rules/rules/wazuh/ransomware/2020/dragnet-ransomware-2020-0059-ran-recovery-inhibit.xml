<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0059 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: 7be22d76-c693-5fbc-998a-4d6e9d6f1ce4 -->
  <rule id="571565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0059 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>