<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0038 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: 767582e7-a786-55d6-aace-a8460fa4d6b1 -->
  <rule id="681326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0038 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>