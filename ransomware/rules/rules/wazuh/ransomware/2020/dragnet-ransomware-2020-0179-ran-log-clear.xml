<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0179 — Event Log Clearing (wastedlocker) | Status: deprecated | Sigma ID: 0ed84c5a-437d-565f-8f43-b8bb747d683b -->
  <rule id="305565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0179 — Event Log Clearing (wastedlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>