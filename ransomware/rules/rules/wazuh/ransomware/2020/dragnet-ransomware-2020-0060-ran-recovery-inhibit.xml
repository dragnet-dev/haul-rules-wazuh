<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0060 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: b18ef4c6-713c-5853-afcf-adead01e53d5 -->
  <rule id="264474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0060 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>