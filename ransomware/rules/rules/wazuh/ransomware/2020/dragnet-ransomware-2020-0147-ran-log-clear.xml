<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0147 — Event Log Clearing (coldlock) | Status: deprecated | Sigma ID: 1414e5e8-b733-5060-92ba-8c4a2e21aff4 -->
  <rule id="122174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0147 — Event Log Clearing (coldlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>