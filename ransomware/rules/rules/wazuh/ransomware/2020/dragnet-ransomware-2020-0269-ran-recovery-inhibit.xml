<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0269 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: a1d4ee6b-8de1-57b3-8ed2-b6fb3b215be7 -->
  <rule id="671502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0269 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>