<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0229 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 0c014a75-d357-5239-8b03-20227f16adf5 -->
  <rule id="222347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0229 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>