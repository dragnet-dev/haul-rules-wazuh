<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0110 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 261e353b-5a80-5a5b-b2ae-f1356b64e5c6 -->
  <rule id="690353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0110 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>