<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0132 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: 515e0d75-7b21-5e1d-9d03-8ed1fdbc0e6a -->
  <rule id="520653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0132 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>