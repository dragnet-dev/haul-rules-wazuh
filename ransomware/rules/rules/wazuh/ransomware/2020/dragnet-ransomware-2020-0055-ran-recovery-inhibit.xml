<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0055 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c344f837-df5a-5bb9-ae56-a8dc3aa6be48 -->
  <rule id="275198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0055 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>