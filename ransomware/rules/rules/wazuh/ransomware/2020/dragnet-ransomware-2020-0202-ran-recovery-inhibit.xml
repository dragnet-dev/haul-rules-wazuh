<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0202 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 23ee7890-5ebe-54a0-9aed-29a75a48ac30 -->
  <rule id="826789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0202 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>