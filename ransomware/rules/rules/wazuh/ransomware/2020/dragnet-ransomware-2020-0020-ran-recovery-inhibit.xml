<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0020 — Recovery Inhibition (doppelpaymer) | Status: deprecated | Sigma ID: 4eca7bee-0a45-5d3d-991a-d450c262633e -->
  <rule id="627323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0020 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>