<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0077 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: 6d2e37b7-28ec-5c25-9bc1-61d755ea5223 -->
  <rule id="948637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0077 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>