<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0258 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 36422343-9a0b-525f-98d5-1de8db4ebf80 -->
  <rule id="142234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0258 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>