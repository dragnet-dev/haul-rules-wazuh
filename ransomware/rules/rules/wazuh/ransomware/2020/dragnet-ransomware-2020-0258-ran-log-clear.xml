<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0258 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 2ebb3d35-bc46-5d81-997e-4c33c8308d57 -->
  <rule id="214141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0258 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>