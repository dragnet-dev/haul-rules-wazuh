<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0211 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 7037dc97-218b-5cd4-9067-c37ea2c23688 -->
  <rule id="101692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0211 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>