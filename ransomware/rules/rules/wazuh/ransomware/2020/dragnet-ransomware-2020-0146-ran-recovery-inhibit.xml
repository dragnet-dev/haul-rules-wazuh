<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0146 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: f363804c-85de-53f3-984e-c09d34c62cae -->
  <rule id="736380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0146 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>