<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0199 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: 5521711d-044b-5578-8069-163c2adfd1ca -->
  <rule id="221711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0199 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>