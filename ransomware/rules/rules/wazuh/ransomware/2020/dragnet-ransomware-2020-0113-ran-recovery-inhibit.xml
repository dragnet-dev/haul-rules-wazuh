<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0113 — Recovery Inhibition (doppelpaymer) | Status: deprecated | Sigma ID: 337fc107-464a-530b-8f0e-0499f0c25483 -->
  <rule id="652410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0113 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>