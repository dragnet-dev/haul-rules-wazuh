<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0133 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: ca25a36c-a09c-5ded-8cd5-c444b4be3b0a -->
  <rule id="636103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0133 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>