<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0149 — Event Log Clearing (maze) | Status: deprecated | Sigma ID: 2c7de47c-2bb5-5125-ac72-cb5e68fb0dcd -->
  <rule id="346544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0149 — Event Log Clearing (maze)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>