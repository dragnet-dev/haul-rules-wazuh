<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0071 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 104580c3-a57e-5f13-b01c-f077bb21de5d -->
  <rule id="873292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0071 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>