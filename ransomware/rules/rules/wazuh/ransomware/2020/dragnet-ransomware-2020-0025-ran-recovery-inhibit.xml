<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0025 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 49d83223-d900-5dc3-bd6c-a14c6db2ec0b -->
  <rule id="878322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0025 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>