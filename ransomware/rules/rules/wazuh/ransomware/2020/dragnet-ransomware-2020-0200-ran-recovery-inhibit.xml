<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0200 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: 81e9e5d5-6550-583b-b7f2-ec903c7d34cf -->
  <rule id="397585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0200 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>