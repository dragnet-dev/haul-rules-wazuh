<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0011 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: b04e2242-9dd2-5ed0-959f-4cb6b0f9a877 -->
  <rule id="967822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0011 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>