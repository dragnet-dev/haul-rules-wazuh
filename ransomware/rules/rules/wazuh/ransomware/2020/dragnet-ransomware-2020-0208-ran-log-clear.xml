<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0208 — Event Log Clearing (ryuk) | Status: deprecated | Sigma ID: aed9dd87-8cbd-5d23-ba17-1c9536f95eb7 -->
  <rule id="962845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0208 — Event Log Clearing (ryuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>