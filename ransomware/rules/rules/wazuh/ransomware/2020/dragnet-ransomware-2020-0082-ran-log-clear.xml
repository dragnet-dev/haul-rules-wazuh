<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0082 — Event Log Clearing (maze) | Status: deprecated | Sigma ID: b71e4e02-9dfc-57a7-9cf7-85b2a23370a5 -->
  <rule id="400078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0082 — Event Log Clearing (maze)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>