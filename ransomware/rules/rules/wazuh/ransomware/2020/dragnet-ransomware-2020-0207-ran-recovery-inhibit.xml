<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0207 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: c690a9b8-9b2a-52ed-b617-9abc1ae2eb64 -->
  <rule id="330509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0207 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>