<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0056 — Recovery Inhibition (coldlock) | Status: deprecated | Sigma ID: 314b6f48-74c2-50ba-9355-aa1c65213877 -->
  <rule id="957114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0056 — Recovery Inhibition (coldlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>