<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0038 — Event Log Clearing (netwalker) | Status: deprecated | Sigma ID: 7244ef5e-5572-5f34-848a-e3a385f46b06 -->
  <rule id="154703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0038 — Event Log Clearing (netwalker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>