<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0241 — Recovery Inhibition (nefilim) | Status: deprecated | Sigma ID: f2087c80-062b-5379-a43b-991b9ec85ea5 -->
  <rule id="733404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0241 — Recovery Inhibition (nefilim)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
