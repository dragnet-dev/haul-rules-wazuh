<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0169 — Event Log Clearing (egregor) | Status: deprecated | Sigma ID: b2585b26-1da9-515f-a823-9764fd14298c -->
  <rule id="101371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0169 — Event Log Clearing (egregor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>