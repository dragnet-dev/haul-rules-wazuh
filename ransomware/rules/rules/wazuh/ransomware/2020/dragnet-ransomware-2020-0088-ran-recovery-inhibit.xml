<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0088 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 84e7982f-2fed-5b99-baca-72219d896d80 -->
  <rule id="558798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0088 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>