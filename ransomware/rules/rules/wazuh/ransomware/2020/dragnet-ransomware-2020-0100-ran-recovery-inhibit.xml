<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0100 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: 98a6eed4-a892-55ea-b918-a9db265e2818 -->
  <rule id="541454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0100 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
