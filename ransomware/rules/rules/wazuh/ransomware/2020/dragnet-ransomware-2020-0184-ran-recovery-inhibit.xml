  <rule id="102860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0184 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
