<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0178 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 0d9c6666-13f2-5729-b996-dc8e4e0dc47a -->
  <rule id="536666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0178 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>