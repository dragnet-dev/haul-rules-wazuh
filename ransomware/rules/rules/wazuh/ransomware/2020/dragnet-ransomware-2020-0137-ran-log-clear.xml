<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0137 — Event Log Clearing (prolock) | Status: deprecated | Sigma ID: 346e8f41-e1cc-5831-a9c4-270947d577d3 -->
  <rule id="881434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0137 — Event Log Clearing (prolock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>