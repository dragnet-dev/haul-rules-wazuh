<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0246 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: 5d447a58-ab6e-54fe-8ea7-91636674e1a9 -->
  <rule id="695162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0246 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>