<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0094 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: e3484318-f869-5458-a357-9f7ba7408385 -->
  <rule id="634843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0094 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>