<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0057 — Event Log Clearing (maze) | Status: deprecated | Sigma ID: 6a1f25ee-a74b-5792-b08e-bedb75c1d0a2 -->
  <rule id="899125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0057 — Event Log Clearing (maze)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>