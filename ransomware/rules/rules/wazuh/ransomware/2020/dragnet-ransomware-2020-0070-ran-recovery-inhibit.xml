<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0070 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: ef91f48e-69db-507a-940b-de00b53922ab -->
  <rule id="338714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0070 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>