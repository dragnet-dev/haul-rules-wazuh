<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0013 — Recovery Inhibition (doppelpaymer) | Status: deprecated | Sigma ID: d55708b9-28a6-55e0-91db-e8534aba80fa -->
  <rule id="555708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0013 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>