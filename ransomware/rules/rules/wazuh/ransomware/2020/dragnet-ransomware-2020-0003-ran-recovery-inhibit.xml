<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0003 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 43d343ca-9ba3-5941-984a-0980516f8643 -->
  <rule id="521500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0003 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>