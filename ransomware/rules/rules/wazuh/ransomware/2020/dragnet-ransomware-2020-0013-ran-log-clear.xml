<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0013 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: 8afa32d4-cb02-5747-b1bc-f711bb79a9cb -->
  <rule id="957832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0013 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>