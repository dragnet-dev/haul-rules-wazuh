<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0078 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: 13893c76-ea07-55d9-8000-db3d6c71fe3a -->
  <rule id="523007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0078 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
