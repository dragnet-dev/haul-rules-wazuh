<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0138 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: f3be04f5-2fd1-55c9-abab-99307d9aaca4 -->
  <rule id="435804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0138 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>