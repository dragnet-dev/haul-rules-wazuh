<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0265 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: 627b6a5d-fb41-5b29-93ae-72091079586c -->
  <rule id="806986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0265 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
