<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0068 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c16522c2-f101-55cc-ba2f-bcff4084c024 -->
  <rule id="416522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0068 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>