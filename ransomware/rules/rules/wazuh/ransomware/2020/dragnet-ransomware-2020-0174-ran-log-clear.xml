<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0174 — Event Log Clearing (sekhmet) | Status: deprecated | Sigma ID: d1df3634-9e2b-55ba-93b7-d7a777e9c988 -->
  <rule id="775936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0174 — Event Log Clearing (sekhmet)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>