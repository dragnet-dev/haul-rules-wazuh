<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0048 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 67289af1-3aa8-57d6-af22-bbd866473ea3 -->
  <rule id="276634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0048 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>