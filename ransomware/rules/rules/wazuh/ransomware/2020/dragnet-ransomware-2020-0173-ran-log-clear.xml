<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0173 — Event Log Clearing (maze) | Status: deprecated | Sigma ID: 883cf5a1-443f-5d0b-98f8-d3854ac63dd4 -->
  <rule id="562555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0173 — Event Log Clearing (maze)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>