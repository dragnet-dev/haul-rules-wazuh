<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0191 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 781a3003-86b8-583f-bc31-83fa22fcc906 -->
  <rule id="450630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0191 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>