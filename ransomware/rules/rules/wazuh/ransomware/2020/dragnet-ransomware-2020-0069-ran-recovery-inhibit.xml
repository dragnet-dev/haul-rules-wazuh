<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0069 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: af61f410-ff6e-5767-9fe1-db223774e283 -->
  <rule id="209914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0069 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>