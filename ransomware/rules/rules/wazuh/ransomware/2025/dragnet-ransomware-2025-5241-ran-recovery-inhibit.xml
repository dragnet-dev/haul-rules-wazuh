<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5241 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3014348c-25f0-5a93-9bb1-6145509cfdcc -->
  <rule id="414348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5241 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>