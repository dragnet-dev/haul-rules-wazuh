<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4516 — Event Log Clearing (radiant) | Status: deprecated | Sigma ID: d98e6e2e-8a2a-5bbd-895f-cad357d492b6 -->
  <rule id="981230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4516 — Event Log Clearing (radiant)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>