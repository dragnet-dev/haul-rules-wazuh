<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5206 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 51fe7f6d-dfd3-585a-8fb3-42cd6c52e1be -->
  <rule id="429727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5206 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>