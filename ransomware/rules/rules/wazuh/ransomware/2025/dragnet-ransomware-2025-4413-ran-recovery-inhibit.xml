<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4413 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d1a4a164-8b1c-5b7d-a12a-3f78bc6ba7cf -->
  <rule id="770341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4413 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>