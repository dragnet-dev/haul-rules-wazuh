<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5844 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 1f2ff2bd-56d6-5f65-8869-40a37b8b2c97 -->
  <rule id="320363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5844 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>