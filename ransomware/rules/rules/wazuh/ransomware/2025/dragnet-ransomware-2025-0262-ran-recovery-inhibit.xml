<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0262 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: acc28129-df40-5356-afae-0e25d3f54c0e -->
  <rule id="164281" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0262 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>