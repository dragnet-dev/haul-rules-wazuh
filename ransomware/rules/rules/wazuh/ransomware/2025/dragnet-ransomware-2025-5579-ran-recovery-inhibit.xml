<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5579 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a0177aa0-673e-5ae2-8630-41806f7a07ab -->
  <rule id="802842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5579 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>