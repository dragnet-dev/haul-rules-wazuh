<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4177 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 09ef8f48-8c79-5366-8784-105c105693fb -->
  <rule id="570234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4177 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>