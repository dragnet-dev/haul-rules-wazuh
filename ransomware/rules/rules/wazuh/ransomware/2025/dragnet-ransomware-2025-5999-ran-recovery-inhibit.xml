<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5999 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 70ad9203-2136-597d-a03a-d0384c1d5197 -->
  <rule id="109392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5999 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>