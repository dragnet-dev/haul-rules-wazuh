<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0287 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eb8a2520-a0a0-5924-bff7-8e9f982eabe4 -->
  <rule id="273825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0287 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>