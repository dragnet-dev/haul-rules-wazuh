<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3896 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 23a4d18c-6fe9-5f77-bbd4-1a3c446f52f5 -->
  <rule id="755718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3896 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>