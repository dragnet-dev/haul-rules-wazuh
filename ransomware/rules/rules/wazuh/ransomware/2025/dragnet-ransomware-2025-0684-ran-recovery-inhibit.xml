<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0684 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b40fb925-7091-5265-9dcd-556e677b7099 -->
  <rule id="320919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0684 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>