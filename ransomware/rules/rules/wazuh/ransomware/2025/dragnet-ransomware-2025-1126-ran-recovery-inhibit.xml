<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1126 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 79327bf4-ce8f-512c-b503-6bd9287ca7a3 -->
  <rule id="469243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1126 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>