<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6235 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 21beb3a1-a740-5f4d-b26d-1849071843bc -->
  <rule id="850778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6235 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
