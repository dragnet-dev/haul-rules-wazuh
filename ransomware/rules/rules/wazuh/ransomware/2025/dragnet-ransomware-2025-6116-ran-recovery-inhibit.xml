<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6116 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ef30e9d7-4edf-5e08-bd6b-11680fc1214f -->
  <rule id="328949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6116 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>