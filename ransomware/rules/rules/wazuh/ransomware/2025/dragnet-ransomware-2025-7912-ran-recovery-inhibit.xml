<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7912 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: e16f979e-2d12-5716-89ae-d87882fb9cb1 -->
  <rule id="567197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7912 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>