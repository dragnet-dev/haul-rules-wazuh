<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3971 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 48132b10-e59c-5845-936e-c803e92802d1 -->
  <rule id="601231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3971 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>