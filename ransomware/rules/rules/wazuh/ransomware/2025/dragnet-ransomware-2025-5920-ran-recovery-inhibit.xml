<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5920 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 8cb258fc-07c1-5f35-a5dc-7a7a1e332765 -->
  <rule id="551258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5920 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>