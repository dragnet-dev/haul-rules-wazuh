<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7512 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: dede2c0a-f28d-503a-916c-75041fddf7d8 -->
  <rule id="228684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7512 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>