<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7785 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 5a17ce6b-f069-53fe-9368-ecf4a345dee3 -->
  <rule id="608558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7785 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>