<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1977 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: c12d090c-663e-5c8c-be9c-115a9d2d85c6 -->
  <rule id="240509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1977 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>