<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4746 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: beba05c9-6656-57e1-aeb2-1444ced4ea47 -->
  <rule id="482605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4746 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>