<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2145 — Event Log Clearing (trinity) | Status: experimental | Sigma ID: 39e2a67e-6c17-5000-a37c-b90e3bab87b4 -->
  <rule id="221226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2145 — Event Log Clearing (trinity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>