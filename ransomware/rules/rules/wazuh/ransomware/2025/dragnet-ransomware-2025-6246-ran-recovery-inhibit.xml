<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6246 — Recovery Inhibition (tridentlocker) | Status: experimental | Sigma ID: a026e03c-6405-59fa-ad02-8d1c44541cb0 -->
  <rule id="804300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6246 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>