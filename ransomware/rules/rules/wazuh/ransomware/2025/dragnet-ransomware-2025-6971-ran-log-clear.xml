<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6971 — Event Log Clearing (securotrop) | Status: experimental | Sigma ID: bffe21d1-8d2e-5a04-8d80-ac1d070b6284 -->
  <rule id="515021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6971 — Event Log Clearing (securotrop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>