<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7533 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: faede4ae-18e4-5480-9f26-fafa84db4552 -->
  <rule id="227806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7533 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>