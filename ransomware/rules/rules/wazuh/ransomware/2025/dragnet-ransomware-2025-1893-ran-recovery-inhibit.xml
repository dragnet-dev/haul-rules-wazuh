<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1893 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 988b7950-7838-59d1-b5d4-583abedad4d3 -->
  <rule id="781979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1893 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>