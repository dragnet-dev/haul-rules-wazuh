<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0623 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: da686f67-987f-527a-93f0-3632706f8d85 -->
  <rule id="898991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0623 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>