<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4421 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2e3c28b9-737a-572e-9568-6700f6796c9c -->
  <rule id="272459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4421 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>