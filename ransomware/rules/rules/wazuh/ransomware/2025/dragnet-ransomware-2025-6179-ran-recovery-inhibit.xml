<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6179 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b2865c66-f3b9-5a1e-9a00-42224abcdf78 -->
  <rule id="105852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6179 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>