<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4884 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bbfaa80e-aef5-5c13-bfeb-d5cdaa7a72ad -->
  <rule id="599628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4884 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>