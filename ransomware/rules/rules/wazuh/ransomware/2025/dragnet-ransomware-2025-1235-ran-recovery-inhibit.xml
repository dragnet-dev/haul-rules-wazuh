<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1235 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: af023338-7669-5875-a05b-da491407419f -->
  <rule id="950233" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1235 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>