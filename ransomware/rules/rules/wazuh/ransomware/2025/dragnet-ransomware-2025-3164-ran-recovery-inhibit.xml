<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3164 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: df42a242-a219-51d8-bd11-8c9f3ba1c9c5 -->
  <rule id="974822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3164 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>