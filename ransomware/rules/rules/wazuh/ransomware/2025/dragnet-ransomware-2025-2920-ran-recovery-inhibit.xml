<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2920 — Recovery Inhibition (play) | Status: experimental | Sigma ID: abe9a162-d00d-54e9-8e01-74e93ddabae7 -->
  <rule id="901541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2920 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>