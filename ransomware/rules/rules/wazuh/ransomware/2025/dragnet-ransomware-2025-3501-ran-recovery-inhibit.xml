<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3501 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 9de2e376-2fa3-5a0a-b559-e72bc56d37f9 -->
  <rule id="542063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3501 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>