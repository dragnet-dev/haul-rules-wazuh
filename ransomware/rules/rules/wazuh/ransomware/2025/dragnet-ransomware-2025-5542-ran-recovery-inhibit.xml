<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5542 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 085522bf-b57b-51f0-b7cc-c21664f056fb -->
  <rule id="568363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5542 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>