<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5695 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 741570aa-8562-5412-b32e-dedb70a46113 -->
  <rule id="265130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5695 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>