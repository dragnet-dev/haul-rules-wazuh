<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5056 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e4262d4b-9dc4-5eba-8ecf-898922a6b9fe -->
  <rule id="608205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5056 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>