<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6651 — Recovery Inhibition (qilin) | Status: test | Sigma ID: e45cc85d-2274-541c-ba3d-e46674ab2073 -->
  <rule id="201248" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6651 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>