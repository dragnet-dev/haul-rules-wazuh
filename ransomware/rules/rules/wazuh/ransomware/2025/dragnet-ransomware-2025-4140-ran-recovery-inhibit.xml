<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4140 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c1e49454-0c60-569e-b78f-8b5a5eabee69 -->
  <rule id="250494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4140 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>