<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6768 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f9225e73-2efe-5740-8de7-a35eccdf05f8 -->
  <rule id="847614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6768 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>