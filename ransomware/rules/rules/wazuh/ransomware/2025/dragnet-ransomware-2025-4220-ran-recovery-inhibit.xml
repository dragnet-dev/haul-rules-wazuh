<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4220 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4cbb46f4-7c4a-5365-89f3-ef4095a985ed -->
  <rule id="264346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4220 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>