<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2389 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 96417d61-e148-57f5-b4be-566f0eb16caa -->
  <rule id="742685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2389 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>