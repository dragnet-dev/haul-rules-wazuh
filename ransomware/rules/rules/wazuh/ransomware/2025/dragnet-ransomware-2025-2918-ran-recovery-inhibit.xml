<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2918 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: c565f332-0752-5921-bdc6-c0eebc90b15d -->
  <rule id="310553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2918 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>