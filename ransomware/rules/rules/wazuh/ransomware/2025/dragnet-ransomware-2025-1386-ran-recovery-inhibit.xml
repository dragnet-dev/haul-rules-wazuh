<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1386 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 5e175068-fdd6-5dac-aff8-23899acc00bc -->
  <rule id="517506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1386 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>