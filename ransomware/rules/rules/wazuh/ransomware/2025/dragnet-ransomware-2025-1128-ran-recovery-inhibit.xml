<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1128 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 737e833c-c521-5359-a533-071de9492e8d -->
  <rule id="380683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1128 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>