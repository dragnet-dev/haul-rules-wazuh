<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7497 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9336e77d-e309-5dec-bfea-1d8ff814e0c6 -->
  <rule id="693907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7497 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>