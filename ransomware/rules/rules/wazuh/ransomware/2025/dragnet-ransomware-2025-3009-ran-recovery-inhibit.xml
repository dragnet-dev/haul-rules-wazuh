<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3009 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0335b282-9edb-586a-830d-e78560fab3b2 -->
  <rule id="971282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3009 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>