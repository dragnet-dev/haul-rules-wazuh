<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1748 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 094b98e1-9914-59a8-a3dc-b0b02339a2b3 -->
  <rule id="725582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1748 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>