<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7522 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 9c68fff4-8e87-5527-a964-162a1ad1b0eb -->
  <rule id="511263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7522 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>