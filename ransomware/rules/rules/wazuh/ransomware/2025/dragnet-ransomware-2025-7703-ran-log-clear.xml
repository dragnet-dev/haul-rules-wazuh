<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7703 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: e5ed48ee-b8bc-53d3-8ac9-2d2a228d24b1 -->
  <rule id="235748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7703 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>