<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2849 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f135bd6e-fc31-50c1-8a2c-13871063fa9f -->
  <rule id="374749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2849 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>