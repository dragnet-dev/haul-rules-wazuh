<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3247 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: dbb54e64-dffd-5952-9556-4e9d935de242 -->
  <rule id="324878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3247 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>