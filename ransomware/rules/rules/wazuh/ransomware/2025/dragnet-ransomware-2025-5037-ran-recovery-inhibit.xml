<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5037 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 97a9eabb-5822-553b-ae70-7026a423fd7b -->
  <rule id="501258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5037 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>