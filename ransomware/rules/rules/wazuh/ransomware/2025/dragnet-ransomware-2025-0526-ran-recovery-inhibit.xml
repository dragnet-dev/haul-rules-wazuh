<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0526 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6c4fadc8-85eb-5a27-bf55-bc52a2c333a7 -->
  <rule id="944077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0526 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>