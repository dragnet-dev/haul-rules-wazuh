<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6564 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 6d41b41a-ef4d-5a3e-af5e-3c8609ab2fb9 -->
  <rule id="950674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6564 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>