  <rule id="258333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2160 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
