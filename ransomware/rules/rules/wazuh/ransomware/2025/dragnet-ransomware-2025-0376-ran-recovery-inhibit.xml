<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0376 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 6b8dae54-e49f-5f3f-bb2d-a35388354489 -->
  <rule id="918990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0376 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>