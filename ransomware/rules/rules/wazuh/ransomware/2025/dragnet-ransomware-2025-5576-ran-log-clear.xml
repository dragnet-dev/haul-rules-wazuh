<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5576 — Event Log Clearing (interlock) | Status: experimental | Sigma ID: 9617bd99-1383-5bf7-886e-e6ddd9c0fbf9 -->
  <rule id="762141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5576 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>