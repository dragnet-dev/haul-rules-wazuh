<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6822 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6d7decda-7bd4-5991-8c94-935b0be91f90 -->
  <rule id="996876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6822 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
