<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1502 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fe1043f8-0cf7-5df6-8d32-ee0ba39d22cd -->
  <rule id="841043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1502 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>