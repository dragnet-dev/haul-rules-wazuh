<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4736 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 7fb71d13-7b1e-5d2e-8ec7-13e909734bfb -->
  <rule id="669949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4736 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>