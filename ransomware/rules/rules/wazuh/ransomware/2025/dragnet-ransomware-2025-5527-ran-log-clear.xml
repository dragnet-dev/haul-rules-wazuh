<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5527 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: 8e607a2f-12ad-5cc5-a5f5-1b88792eb274 -->
  <rule id="581722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5527 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>