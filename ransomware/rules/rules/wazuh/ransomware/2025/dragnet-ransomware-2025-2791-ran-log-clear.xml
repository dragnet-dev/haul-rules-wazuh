<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2791 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: 0473dc9b-47f0-5e29-ae73-47e41c5b4e8c -->
  <rule id="413089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2791 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>