<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2738 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 34f046b0-93b4-5831-936a-b1af0b2ec3ce -->
  <rule id="944747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2738 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>