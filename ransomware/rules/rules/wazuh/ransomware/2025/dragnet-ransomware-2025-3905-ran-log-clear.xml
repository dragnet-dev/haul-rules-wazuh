<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3905 — Event Log Clearing (flocker) | Status: experimental | Sigma ID: 2d0cef17-d3f4-5ecc-88f3-14fe3b9fa12b -->
  <rule id="146511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3905 — Event Log Clearing (flocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>