<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6863 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6112fc63-2b11-5b12-a23c-0689d66efc55 -->
  <rule id="764924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6863 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>