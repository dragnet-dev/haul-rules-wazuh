<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1147 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a121b452-7053-5e13-adf5-24e7ced88770 -->
  <rule id="819474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1147 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>