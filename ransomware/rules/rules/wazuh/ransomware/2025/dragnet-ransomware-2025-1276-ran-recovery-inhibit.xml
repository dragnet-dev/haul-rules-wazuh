<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1276 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: f655b7d2-380c-58ca-a102-f2183774c945 -->
  <rule id="804917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1276 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>