<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1656 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2de4ac7f-84e8-5c33-a4da-7475fa4498f3 -->
  <rule id="180236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1656 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>