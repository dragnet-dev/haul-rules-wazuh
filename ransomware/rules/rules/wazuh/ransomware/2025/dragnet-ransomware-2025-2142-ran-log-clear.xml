<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2142 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 1d9344e9-f06b-51f0-8c97-9f5e858d1b82 -->
  <rule id="389518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2142 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>