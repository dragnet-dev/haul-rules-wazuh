<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6361 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 63e9b6a8-a36a-5445-b245-e82795e09ee5 -->
  <rule id="836756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6361 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>