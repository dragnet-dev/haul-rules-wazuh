<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3299 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5284045c-7214-5090-9990-afb87eeea22b -->
  <rule id="884045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3299 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>