<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2658 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 82e4b8e7-d1b9-5a5c-aad8-e7f9173457cb -->
  <rule id="422358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2658 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>