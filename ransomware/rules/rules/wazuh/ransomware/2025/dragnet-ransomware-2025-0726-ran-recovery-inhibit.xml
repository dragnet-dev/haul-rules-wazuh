<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0726 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: a5b4812a-e9f5-50eb-8f64-cd3aad5bdcfc -->
  <rule id="891481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0726 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>