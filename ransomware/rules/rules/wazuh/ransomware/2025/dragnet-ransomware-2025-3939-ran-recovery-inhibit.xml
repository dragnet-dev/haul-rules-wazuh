<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3939 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b9bfab26-8d6f-5e6a-81ce-2db526309a25 -->
  <rule id="747851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3939 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>