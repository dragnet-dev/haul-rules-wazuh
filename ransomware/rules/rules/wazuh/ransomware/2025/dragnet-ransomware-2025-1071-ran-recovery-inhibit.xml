<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1071 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 6594f6ca-4d2a-513d-a01b-075b20cf7f03 -->
  <rule id="255196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1071 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>