<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3017 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 913b5e65-f0bb-5522-ace2-7b844a743d77 -->
  <rule id="639134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3017 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>