<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4875 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5ee5b103-5683-528d-8db4-93a7eb4466c0 -->
  <rule id="729711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4875 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>