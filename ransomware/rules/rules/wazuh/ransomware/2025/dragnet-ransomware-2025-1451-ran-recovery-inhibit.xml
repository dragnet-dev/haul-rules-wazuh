<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1451 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2c4f5ef3-ceda-55ad-9e36-421c4b37a593 -->
  <rule id="339134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1451 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>