<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5745 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 90717c3e-a10b-55b9-8310-fdd4ffc1f758 -->
  <rule id="651484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5745 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>