<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2118 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 0525fa28-1078-51f2-9d96-b1a16e12c6f4 -->
  <rule id="546502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2118 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>