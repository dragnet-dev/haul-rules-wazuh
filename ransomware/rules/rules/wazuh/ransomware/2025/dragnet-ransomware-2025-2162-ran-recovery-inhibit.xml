<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2162 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 107cf262-075a-5e96-a69d-23ecf8a30903 -->
  <rule id="159926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2162 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>