<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7297 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 510682a9-f802-5a37-a0f7-1521363e5602 -->
  <rule id="170922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7297 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>