<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4584 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 316f25cf-3eba-5b47-9938-35ec800d380b -->
  <rule id="114012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4584 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>