<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7806 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 6f5686a2-cfbd-5bbd-b036-cd5a35a06541 -->
  <rule id="315686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7806 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>