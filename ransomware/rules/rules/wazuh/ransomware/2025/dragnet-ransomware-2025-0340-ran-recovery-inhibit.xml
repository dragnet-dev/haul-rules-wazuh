<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0340 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b87ed3e2-198f-5b01-a045-d0d0c79aa889 -->
  <rule id="441093" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0340 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>