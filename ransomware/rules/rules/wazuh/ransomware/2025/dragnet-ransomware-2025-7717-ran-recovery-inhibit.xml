<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7717 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 2721da61-4fb9-5d70-9d64-3e5586c55819 -->
  <rule id="767946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7717 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>