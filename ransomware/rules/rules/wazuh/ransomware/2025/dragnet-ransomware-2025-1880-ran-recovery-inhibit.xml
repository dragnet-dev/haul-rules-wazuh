<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1880 — Recovery Inhibition (d4rk4rmy) | Status: experimental | Sigma ID: e0ba9017-03ce-529c-9354-705cfb3f2c9e -->
  <rule id="102690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1880 — Recovery Inhibition (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>