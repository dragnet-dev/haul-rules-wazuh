<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5721 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 37d1ae1c-3f0f-5f72-8e09-88c4f2d44593 -->
  <rule id="749230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5721 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>