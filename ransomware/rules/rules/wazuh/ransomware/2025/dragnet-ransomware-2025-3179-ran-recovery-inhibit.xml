<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3179 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: beb3280c-88ae-5c19-8b6b-b34ba813ed6f -->
  <rule id="451328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3179 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>