<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7919 — Recovery Inhibition (J) | Status: experimental | Sigma ID: d0e66817-0c0f-504d-aa7f-560351402f94 -->
  <rule id="394668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7919 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
