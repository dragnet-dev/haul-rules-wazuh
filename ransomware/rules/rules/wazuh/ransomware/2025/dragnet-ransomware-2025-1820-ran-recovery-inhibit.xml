<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1820 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 0f77b980-221b-5641-b006-4982b412264c -->
  <rule id="824398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1820 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
