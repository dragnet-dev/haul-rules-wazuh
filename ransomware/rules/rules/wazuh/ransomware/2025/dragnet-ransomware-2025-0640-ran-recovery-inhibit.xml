<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0640 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 6edb1816-06d3-5025-8ab8-47000aeb674f -->
  <rule id="237918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0640 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>