<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4422 — Event Log Clearing (handala) | Status: experimental | Sigma ID: 21790d86-0d1a-52e9-9dd3-0b582dcfb929 -->
  <rule id="886538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4422 — Event Log Clearing (handala)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>