<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4208 — Recovery Inhibition (warlock) | Status: deprecated | Sigma ID: ab5e4863-b3cd-5aaa-89d5-9283920fdf92 -->
  <rule id="145448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4208 — Recovery Inhibition (warlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
