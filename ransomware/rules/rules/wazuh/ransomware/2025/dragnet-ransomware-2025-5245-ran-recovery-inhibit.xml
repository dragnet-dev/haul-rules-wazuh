<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5245 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 86f092ac-a58b-55fe-979d-1701d45a9e57 -->
  <rule id="591092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5245 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>