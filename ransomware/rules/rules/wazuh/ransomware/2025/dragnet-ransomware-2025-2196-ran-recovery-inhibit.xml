<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2196 — Recovery Inhibition (genesis) | Status: experimental | Sigma ID: 31b99abf-1e1b-5bfc-87ce-2c9ed5606282 -->
  <rule id="504715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2196 — Recovery Inhibition (genesis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
