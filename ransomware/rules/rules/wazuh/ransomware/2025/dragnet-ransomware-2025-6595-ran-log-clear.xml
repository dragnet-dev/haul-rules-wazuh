<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6595 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: f3d210cc-7756-5bb0-9ce9-5a1a51d9b3b5 -->
  <rule id="761210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6595 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>