<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7215 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: f52d309c-ba4c-5523-926b-dcabebb959a3 -->
  <rule id="784530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7215 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>