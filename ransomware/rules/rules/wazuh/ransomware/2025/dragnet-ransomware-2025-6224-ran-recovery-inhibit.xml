<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6224 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: c7b0ac2d-c981-5a2a-b3bf-7af3799a54d5 -->
  <rule id="830252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6224 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>