<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1804 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ae9aaa59-eca7-5f16-9a4f-b481d874375d -->
  <rule id="966634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1804 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>