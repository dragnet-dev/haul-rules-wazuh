<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7082 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 53824a1c-090a-5b6c-b2ef-4be8878af54c -->
  <rule id="611941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7082 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>