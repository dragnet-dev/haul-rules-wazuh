<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4695 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1a838e4e-6c67-5176-8840-cb97969caeb6 -->
  <rule id="794224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4695 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>