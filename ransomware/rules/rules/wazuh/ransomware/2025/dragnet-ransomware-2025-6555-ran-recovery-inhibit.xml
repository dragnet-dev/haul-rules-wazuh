<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6555 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: dea421a3-3f41-54b1-8296-85f5ec8e569a -->
  <rule id="962421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6555 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>