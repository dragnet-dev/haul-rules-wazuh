<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2603 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 4ca46e15-c90f-55a3-bead-bff003ed2b4a -->
  <rule id="262350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2603 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>