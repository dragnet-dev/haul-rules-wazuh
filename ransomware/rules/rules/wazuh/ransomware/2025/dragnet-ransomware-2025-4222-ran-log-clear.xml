<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4222 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 84db67b6-af0d-53a8-b3e3-f1f2e802a3b3 -->
  <rule id="472367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4222 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>