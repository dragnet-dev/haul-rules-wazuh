<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1080 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f1781f16-2970-5851-bc0c-fbdf14e95f0d -->
  <rule id="728511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1080 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>