<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3170 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: c21a8dc9-e60b-5ae5-bf62-573215d7e39e -->
  <rule id="527501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3170 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>