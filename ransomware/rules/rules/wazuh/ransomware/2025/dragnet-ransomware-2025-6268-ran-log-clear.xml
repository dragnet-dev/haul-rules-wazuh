<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6268 — Event Log Clearing (teamxxx) | Status: experimental | Sigma ID: cccb40b0-f480-56ab-ad7d-396e4091e12d -->
  <rule id="842740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6268 — Event Log Clearing (teamxxx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>