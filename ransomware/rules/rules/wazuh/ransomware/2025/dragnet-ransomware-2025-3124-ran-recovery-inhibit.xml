<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3124 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f5e31176-3b57-5dd5-8d04-11a45c9f65b4 -->
  <rule id="794311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3124 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>