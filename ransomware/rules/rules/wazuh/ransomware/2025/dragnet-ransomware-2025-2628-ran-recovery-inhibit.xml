<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2628 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c605cda5-9448-5d82-8029-79beb36b55ec -->
  <rule id="627085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2628 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>