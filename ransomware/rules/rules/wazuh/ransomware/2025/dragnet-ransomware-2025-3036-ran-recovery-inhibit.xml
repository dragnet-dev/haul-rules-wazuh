<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3036 — Recovery Inhibition (qilin) | Status: test | Sigma ID: fd005a42-26f8-50ec-b5ac-5a365231d589 -->
  <rule id="548090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3036 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
