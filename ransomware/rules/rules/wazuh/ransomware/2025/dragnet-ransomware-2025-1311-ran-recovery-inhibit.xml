<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1311 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: cc5c4152-1ded-5488-bba1-489460264041 -->
  <rule id="673241" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1311 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>