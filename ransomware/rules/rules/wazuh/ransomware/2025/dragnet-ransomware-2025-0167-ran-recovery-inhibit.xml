<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0167 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c5f1f918-c3c9-5bff-9eb7-35ea9835a383 -->
  <rule id="624319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0167 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>