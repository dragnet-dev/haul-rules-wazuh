<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5017 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 003b4fee-6e6a-5cef-8261-ef78d20b4cef -->
  <rule id="737102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5017 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>