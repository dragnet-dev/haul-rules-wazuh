<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2845 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 4ef0288d-e463-5591-8749-aea9ce98cce4 -->
  <rule id="463028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2845 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>