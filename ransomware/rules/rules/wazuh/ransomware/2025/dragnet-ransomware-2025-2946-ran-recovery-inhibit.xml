<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2946 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 23baecbf-ecf0-51ce-b5fe-212eaba83fc8 -->
  <rule id="755180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2946 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>