<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6635 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: a383abb3-cd95-5efc-a74f-a518757a1cb3 -->
  <rule id="958219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6635 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>