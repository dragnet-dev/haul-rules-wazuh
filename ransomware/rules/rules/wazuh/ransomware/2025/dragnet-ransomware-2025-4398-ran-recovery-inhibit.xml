<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4398 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: 4e54cd19-1fa5-5904-aa34-b57e21d4cc03 -->
  <rule id="310829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4398 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>