<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7319 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 9d47ca58-f2d3-55cf-a618-7ef11ffde321 -->
  <rule id="531434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7319 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>