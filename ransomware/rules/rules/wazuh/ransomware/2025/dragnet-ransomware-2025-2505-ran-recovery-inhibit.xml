<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2505 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6024cd9a-553b-53ff-a447-fcfe11cf118c -->
  <rule id="742349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2505 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>