<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1424 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 58391e68-c367-5cd7-8760-47791681088d -->
  <rule id="442706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1424 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>