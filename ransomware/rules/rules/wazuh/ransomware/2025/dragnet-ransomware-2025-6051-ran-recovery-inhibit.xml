<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6051 — Recovery Inhibition (insomnia) | Status: experimental | Sigma ID: ade38824-c2ee-59dd-a522-80eb309aa8df -->
  <rule id="182388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6051 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>