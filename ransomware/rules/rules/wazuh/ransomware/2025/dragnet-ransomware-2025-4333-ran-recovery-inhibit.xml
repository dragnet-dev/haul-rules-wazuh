<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4333 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d4fc1150-c970-5a32-bb18-d8a74c1226da -->
  <rule id="855611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4333 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>