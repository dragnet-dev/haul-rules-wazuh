<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4207 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3274591a-2731-5829-8949-16e55db731a5 -->
  <rule id="674591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4207 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>