<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1081 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 42ac12d5-ee25-5a53-9824-b0c00467af2e -->
  <rule id="292412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1081 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>