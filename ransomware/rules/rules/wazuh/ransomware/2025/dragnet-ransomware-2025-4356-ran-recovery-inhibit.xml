<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4356 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8038502b-9705-53d0-88ae-248295add1cb -->
  <rule id="938502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4356 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>