<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5903 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 00f60605-32de-55f8-a8e0-7427bc0639b3 -->
  <rule id="760605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5903 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>