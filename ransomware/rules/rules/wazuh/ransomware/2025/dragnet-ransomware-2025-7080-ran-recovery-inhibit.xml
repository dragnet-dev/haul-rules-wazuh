<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7080 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d315838b-9b66-5d20-9a99-3405e30df9b0 -->
  <rule id="531583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7080 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>