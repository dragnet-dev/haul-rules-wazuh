<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2816 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5ac6ee7b-9243-52db-9996-d115c5b312ce -->
  <rule id="218894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2816 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>