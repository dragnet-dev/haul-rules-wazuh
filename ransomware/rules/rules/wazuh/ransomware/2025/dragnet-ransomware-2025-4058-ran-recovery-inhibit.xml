<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4058 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 388514b5-a98a-5114-86c0-23739c8396c5 -->
  <rule id="916235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4058 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>