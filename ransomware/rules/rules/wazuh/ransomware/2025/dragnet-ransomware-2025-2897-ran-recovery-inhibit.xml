<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2897 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 493e9ba1-2c77-5e01-99be-f63326ad2ad4 -->
  <rule id="464475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2897 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>