<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7909 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: fd2a6092-231d-512e-882d-db31a62cc06c -->
  <rule id="552260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7909 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>