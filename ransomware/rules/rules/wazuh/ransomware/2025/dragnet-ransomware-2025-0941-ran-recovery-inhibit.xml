<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0941 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: c28c1726-d293-595c-9452-0075918172ba -->
  <rule id="266017" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0941 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>