<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4633 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c41fdfdf-65bd-5619-8cb9-3e418d5f2002 -->
  <rule id="687199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4633 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>