<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7448 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 3c0115cf-bf1c-5b9d-b848-34d4dc4d8b6d -->
  <rule id="701852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7448 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>