<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1389 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 9e7b7e1f-1b17-5dd0-85ff-9143913081e9 -->
  <rule id="564606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1389 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>