<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3342 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 76e7eae5-2158-53b7-995c-5f7d2ebc3aed -->
  <rule id="550826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3342 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>