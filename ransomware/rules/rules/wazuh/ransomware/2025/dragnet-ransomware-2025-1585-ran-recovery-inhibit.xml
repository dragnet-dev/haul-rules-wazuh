<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1585 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6e55649c-d487-530a-b7b9-5b9c07b0963d -->
  <rule id="305564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1585 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>