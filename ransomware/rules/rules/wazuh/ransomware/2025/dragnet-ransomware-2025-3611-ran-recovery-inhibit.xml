<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3611 — Recovery Inhibition (bert) | Status: experimental | Sigma ID: 6191bbd8-44f0-5cf2-a16e-14c83e99121b -->
  <rule id="785083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3611 — Recovery Inhibition (bert)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>