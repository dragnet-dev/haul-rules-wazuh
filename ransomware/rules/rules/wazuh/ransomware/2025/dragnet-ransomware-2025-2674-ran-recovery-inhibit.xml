<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2674 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2b373e6d-ed49-5cb6-8e97-68d44d5f3ee2 -->
  <rule id="739826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2674 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>