<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5345 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8a9e9d6b-e17c-522c-a5d4-4e09540149ea -->
  <rule id="958237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5345 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>