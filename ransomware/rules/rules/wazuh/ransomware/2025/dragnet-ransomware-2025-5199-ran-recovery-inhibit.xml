<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5199 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 108f14b3-0484-5d7c-a086-5fc45ac5a8f6 -->
  <rule id="189035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5199 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>