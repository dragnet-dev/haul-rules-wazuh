<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6725 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: afeaa448-7cd3-5c69-a8e9-65f784fc20b5 -->
  <rule id="105544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6725 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>