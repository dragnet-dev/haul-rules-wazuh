<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7314 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a8934ef0-9191-5229-8a8f-499abddd5b3c -->
  <rule id="942958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7314 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>