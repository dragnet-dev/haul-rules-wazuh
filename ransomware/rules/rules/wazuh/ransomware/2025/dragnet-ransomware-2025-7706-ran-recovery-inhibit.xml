<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7706 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 506c30e5-1b48-5418-bbbe-201c1ac449fe -->
  <rule id="473294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7706 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>