<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6078 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 647d8452-e797-5e03-b2b0-4bcc45b429e8 -->
  <rule id="236584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6078 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>