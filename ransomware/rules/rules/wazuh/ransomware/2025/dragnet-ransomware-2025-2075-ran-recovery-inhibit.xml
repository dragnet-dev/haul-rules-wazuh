<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2075 — Recovery Inhibition (qilin) | Status: test | Sigma ID: ea5d84ed-5b78-5a0e-ba48-6eacaf709491 -->
  <rule id="253384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2075 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>