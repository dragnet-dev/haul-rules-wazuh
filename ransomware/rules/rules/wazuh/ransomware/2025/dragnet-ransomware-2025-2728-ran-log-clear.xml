<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2728 — Event Log Clearing (lunalock) | Status: experimental | Sigma ID: e1bc316e-e696-5f01-9e19-7fac7daed91d -->
  <rule id="128431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2728 — Event Log Clearing (lunalock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>