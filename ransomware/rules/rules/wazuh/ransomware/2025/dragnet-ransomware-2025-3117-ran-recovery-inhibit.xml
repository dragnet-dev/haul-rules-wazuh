<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3117 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 2791511a-e4bb-5e31-b5ca-907525758c6b -->
  <rule id="191511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3117 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>