<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6429 — Recovery Inhibition (skira) | Status: experimental | Sigma ID: 49533f92-38e7-528e-80e1-34185de8329f -->
  <rule id="825439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6429 — Recovery Inhibition (skira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>