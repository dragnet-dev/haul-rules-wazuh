<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6527 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 07b16372-6ef6-51f8-b584-4a22b4584840 -->
  <rule id="431637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6527 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>