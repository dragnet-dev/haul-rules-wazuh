<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1505 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ef24708c-e181-55e9-b00f-3c16f8416e26 -->
  <rule id="692470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1505 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>