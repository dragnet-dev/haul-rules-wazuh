<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3946 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: fa55cf4c-7cbb-528c-8e9f-6eb5c6e0ef70 -->
  <rule id="214287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3946 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>