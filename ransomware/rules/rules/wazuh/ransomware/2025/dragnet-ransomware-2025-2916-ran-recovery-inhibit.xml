<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2916 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 075dd396-e2f6-5185-a4dc-c97992d71cab -->
  <rule id="242139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2916 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>