<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3093 — Recovery Inhibition (insomnia) | Status: experimental | Sigma ID: a4a53bf0-01cc-5186-80c5-dd7cb7bd59e3 -->
  <rule id="979259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3093 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>