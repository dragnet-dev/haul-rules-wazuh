<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7298 — Recovery Inhibition (qilin) | Status: test | Sigma ID: e06c66cc-6c30-5184-806c-e1749a265747 -->
  <rule id="550866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7298 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>