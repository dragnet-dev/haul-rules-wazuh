<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3746 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9abf578e-7403-5937-9359-d877ee89549a -->
  <rule id="461557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3746 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>