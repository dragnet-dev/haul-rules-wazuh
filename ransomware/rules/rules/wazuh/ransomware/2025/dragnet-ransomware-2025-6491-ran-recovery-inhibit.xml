<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6491 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 7004e7cc-1501-57d3-bace-9049d2830e35 -->
  <rule id="320787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6491 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>