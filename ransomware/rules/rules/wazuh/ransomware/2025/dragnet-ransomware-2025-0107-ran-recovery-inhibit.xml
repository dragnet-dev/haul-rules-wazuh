<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0107 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: c27036e6-9bfc-5e3f-a09b-c4e375031731 -->
  <rule id="427036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0107 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>