<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5333 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 95cbddc4-4a04-5bf8-809b-7bb019013e67 -->
  <rule id="978109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5333 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>