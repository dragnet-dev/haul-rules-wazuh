<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5700 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 026385b7-f2dc-5b82-9206-90996561270a -->
  <rule id="721717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5700 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>