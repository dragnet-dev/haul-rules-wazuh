<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7686 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 7e1af19e-ee83-55ca-add2-9eae06c6788e -->
  <rule id="629911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7686 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>