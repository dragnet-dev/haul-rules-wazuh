<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5052 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 744ad327-16f2-5a03-9cf8-580e98eb2a35 -->
  <rule id="206373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5052 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>