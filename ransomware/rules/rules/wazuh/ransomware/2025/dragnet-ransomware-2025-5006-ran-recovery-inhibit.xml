<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5006 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 4b65abef-8920-562c-a063-8a791d09f5ca -->
  <rule id="236811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5006 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>