<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3862 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 2084aa0f-ba4f-53d7-a817-8e062aa8d990 -->
  <rule id="936740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3862 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>