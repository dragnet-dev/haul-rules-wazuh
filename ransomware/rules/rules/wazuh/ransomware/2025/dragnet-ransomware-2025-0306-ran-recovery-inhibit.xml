<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0306 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 2ea373ce-ef6b-5193-b10f-bba9ad18c5b5 -->
  <rule id="341980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0306 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>