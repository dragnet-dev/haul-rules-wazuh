<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1006 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 53555180-83d1-58b1-b4cc-309353625b54 -->
  <rule id="955518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1006 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
