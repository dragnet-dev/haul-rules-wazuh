<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2611 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: e7b98666-7f33-5a51-be1f-1fa26c8b1ace -->
  <rule id="663986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2611 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>