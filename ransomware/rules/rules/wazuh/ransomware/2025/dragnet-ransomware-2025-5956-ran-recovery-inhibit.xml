<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5956 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e8ee5edd-8e82-5bb5-b932-b32a61ec3a4a -->
  <rule id="800254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5956 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>