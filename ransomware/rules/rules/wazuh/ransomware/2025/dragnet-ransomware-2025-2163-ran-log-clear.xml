<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2163 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 0aa59a05-43b1-5ccc-b65b-af9f48ed4ba4 -->
  <rule id="129540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2163 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>