<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3142 — Event Log Clearing (radar) | Status: experimental | Sigma ID: eb03b38b-079e-57c6-8639-64c4b25ebba3 -->
  <rule id="260593" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3142 — Event Log Clearing (radar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>