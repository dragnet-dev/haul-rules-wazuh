<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4735 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 08193915-134b-5fff-af45-21c86816baca -->
  <rule id="193915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4735 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>