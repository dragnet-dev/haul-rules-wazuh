<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7290 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 76c6bbe5-d3c0-5109-bd47-f3fdb516aee8 -->
  <rule id="545403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7290 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>