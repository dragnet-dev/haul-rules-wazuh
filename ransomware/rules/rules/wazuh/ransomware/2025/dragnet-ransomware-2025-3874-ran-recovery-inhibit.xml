<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3874 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 1713fc6e-884c-59d8-acb8-f469c6c03866 -->
  <rule id="887806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3874 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>