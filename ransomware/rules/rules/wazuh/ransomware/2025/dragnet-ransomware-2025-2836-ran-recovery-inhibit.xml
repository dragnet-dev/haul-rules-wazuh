<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2836 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b987c142-e8b2-52da-9b3d-625ef34b66d6 -->
  <rule id="218041" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2836 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>