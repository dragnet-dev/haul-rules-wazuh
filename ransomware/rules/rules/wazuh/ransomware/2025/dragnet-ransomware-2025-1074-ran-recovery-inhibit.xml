<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1074 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5379bb12-7a21-52f1-a12a-a8f6648adae2 -->
  <rule id="577211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1074 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>