<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3084 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 18a5a4da-cb42-528f-9002-6280f7cda1f1 -->
  <rule id="543277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3084 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>