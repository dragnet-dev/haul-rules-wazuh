<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0569 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a6a82710-f76a-5fcc-92ef-0f6d6169a7fc -->
  <rule id="906827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0569 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>