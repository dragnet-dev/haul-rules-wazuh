<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1280 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: cd57585a-5fe6-5e2f-9e17-8fd0622763d7 -->
  <rule id="355758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1280 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>