<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5131 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 66034a27-fa8c-53e2-b770-7bdd9fa11132 -->
  <rule id="256554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5131 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>