<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7625 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: e2b2d157-37a2-521e-a1a6-65f8ed80f1f7 -->
  <rule id="153251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7625 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>