<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7372 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 630b2e93-b23c-5938-bad4-652934be0417 -->
  <rule id="814606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7372 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>