<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6869 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 4195a6d2-ba7b-5dee-84a8-e91f9e05caa4 -->
  <rule id="940909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6869 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>