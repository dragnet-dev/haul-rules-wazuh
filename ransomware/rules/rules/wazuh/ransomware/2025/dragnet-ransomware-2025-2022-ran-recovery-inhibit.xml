<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2022 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1b2b6792-3e86-514f-8664-8bfab56e5d02 -->
  <rule id="863679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2022 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>