<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7550 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 82abdf87-db07-56ee-9e4a-5182615c1140 -->
  <rule id="117951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7550 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>