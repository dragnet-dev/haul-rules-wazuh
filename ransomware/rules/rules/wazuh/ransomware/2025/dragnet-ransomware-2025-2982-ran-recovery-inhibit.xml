<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2982 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5789d13b-47f0-586d-8451-a02afd41cf9f -->
  <rule id="363713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2982 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>