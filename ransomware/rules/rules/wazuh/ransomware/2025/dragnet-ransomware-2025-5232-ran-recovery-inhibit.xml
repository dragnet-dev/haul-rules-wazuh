<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5232 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: c9f462bd-40e3-5203-94d1-1bd1252882e6 -->
  <rule id="379462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5232 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>