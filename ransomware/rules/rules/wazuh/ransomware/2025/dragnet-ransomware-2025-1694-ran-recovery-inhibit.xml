<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1694 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 939362a4-b01b-5884-b2de-d16b207ab7b6 -->
  <rule id="729802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1694 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>