<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3579 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: eb534083-0180-5f2b-a64f-cad0c0f25011 -->
  <rule id="655340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3579 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>