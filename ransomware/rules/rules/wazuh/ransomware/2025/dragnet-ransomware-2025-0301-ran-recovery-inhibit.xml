<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0301 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 82c4916e-54a8-574b-a31a-c147470b1094 -->
  <rule id="524491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0301 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>