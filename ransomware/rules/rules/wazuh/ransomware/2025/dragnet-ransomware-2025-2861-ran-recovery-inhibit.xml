<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2861 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 142603cd-ba9a-5695-a876-2be6cc7bfe58 -->
  <rule id="581660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2861 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>