<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4698 — Recovery Inhibition (qilin) | Status: test | Sigma ID: f3ec7e8e-3336-5319-a130-48afbfd8eccf -->
  <rule id="104766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4698 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>