<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4874 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 3990c710-9da4-5b5b-b539-cf002134664c -->
  <rule id="185271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4874 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>