<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3303 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 2768bcf2-b9a9-5aab-83f7-5a2518130326 -->
  <rule id="640751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3303 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>