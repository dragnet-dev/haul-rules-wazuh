<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7335 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 974c0cf2-0bcc-5869-8361-a9ff8aca2c3c -->
  <rule id="795372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7335 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>