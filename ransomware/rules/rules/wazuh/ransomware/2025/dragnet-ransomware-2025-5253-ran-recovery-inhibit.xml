<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5253 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ceaceb75-27f7-571e-9703-a4531682ce21 -->
  <rule id="144683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5253 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>