<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6931 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: e62e2237-d17e-5910-bc45-d53f593bba0a -->
  <rule id="640622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6931 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>