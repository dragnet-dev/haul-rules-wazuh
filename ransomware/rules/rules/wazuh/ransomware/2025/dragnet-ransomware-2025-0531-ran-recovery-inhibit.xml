<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0531 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a0cb24d9-a038-5c40-bedf-86189eb4a617 -->
  <rule id="880324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0531 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>