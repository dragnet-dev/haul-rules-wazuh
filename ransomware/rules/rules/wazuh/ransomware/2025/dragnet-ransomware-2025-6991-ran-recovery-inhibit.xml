  <rule id="206824" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6991 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
