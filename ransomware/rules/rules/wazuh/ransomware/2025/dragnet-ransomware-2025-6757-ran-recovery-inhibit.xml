<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6757 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 366d75c0-266a-5b40-b553-6a85824a4049 -->
  <rule id="491612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6757 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>