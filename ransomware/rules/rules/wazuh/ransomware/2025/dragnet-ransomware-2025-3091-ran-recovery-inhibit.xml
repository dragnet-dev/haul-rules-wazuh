<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3091 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: edfe8253-1d26-53b5-87a1-4c5536970760 -->
  <rule id="792682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3091 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>