<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1338 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0b63ec59-2c5b-5808-bdd3-952b1c4dd229 -->
  <rule id="379645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1338 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>