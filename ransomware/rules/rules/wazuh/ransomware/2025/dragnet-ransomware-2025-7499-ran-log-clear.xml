<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7499 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 1d32e5f7-cbf6-5318-b88c-6828ee1fbdcb -->
  <rule id="408255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7499 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>