<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2705 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 824f69aa-3ee5-5fed-96b0-ecda963c9cc6 -->
  <rule id="519969" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2705 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>