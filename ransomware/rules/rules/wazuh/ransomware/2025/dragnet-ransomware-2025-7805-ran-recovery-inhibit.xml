<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7805 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 8c25d845-c4c3-57c0-8117-18425cb5bade -->
  <rule id="544138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7805 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>