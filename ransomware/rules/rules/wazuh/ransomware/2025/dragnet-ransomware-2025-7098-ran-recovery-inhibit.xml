<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7098 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 4a002684-ad46-529c-8c26-bf5b46d44504 -->
  <rule id="300268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7098 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>