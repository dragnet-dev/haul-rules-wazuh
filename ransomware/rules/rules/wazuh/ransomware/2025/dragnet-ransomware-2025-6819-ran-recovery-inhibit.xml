<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6819 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 57a42b35-2a0a-5c3f-b1fb-4c1a32a06daa -->
  <rule id="675883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6819 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>