<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6359 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 5cc682f4-aa1d-56fa-935c-350326a6a74c -->
  <rule id="684682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6359 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>