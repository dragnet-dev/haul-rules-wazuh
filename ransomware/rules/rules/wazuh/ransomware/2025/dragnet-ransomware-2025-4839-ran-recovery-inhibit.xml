<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4839 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 117ce427-eb93-5438-a581-16a6b7ce846d -->
  <rule id="415842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4839 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>