<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0153 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 2ec99979-f317-5976-b5e5-88b8d600edd3 -->
  <rule id="389997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0153 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>