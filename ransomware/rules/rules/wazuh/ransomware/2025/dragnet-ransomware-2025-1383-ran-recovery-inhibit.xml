<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1383 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 980d2003-2b9c-534c-ba08-e01471628809 -->
  <rule id="769320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1383 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>