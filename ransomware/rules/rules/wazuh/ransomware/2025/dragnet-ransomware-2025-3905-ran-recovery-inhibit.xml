<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3905 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 89ad9a8c-79f5-5a53-acce-959c0e637ca2 -->
  <rule id="173274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3905 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>