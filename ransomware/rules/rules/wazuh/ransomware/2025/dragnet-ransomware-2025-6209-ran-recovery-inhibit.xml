<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6209 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3feb50c1-e5ca-56cd-98e7-05c11466bce3 -->
  <rule id="836350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6209 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>