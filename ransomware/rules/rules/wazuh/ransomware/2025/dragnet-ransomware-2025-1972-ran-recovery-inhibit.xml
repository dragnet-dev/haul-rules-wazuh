<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1972 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 18434579-a945-59f5-b5fd-3b537f042ef0 -->
  <rule id="143457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1972 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>