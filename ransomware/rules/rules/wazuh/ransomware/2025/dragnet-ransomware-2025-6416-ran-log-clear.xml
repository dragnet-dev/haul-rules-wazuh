<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6416 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: fa1fdaa1-a4eb-5e5e-92ae-ad0533b2cef3 -->
  <rule id="448154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6416 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>