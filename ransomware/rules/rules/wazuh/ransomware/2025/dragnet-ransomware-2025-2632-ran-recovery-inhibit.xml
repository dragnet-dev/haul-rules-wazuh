<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2632 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: c6dca7fa-c3ad-5669-ad35-87651ac7bf24 -->
  <rule id="796267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2632 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>