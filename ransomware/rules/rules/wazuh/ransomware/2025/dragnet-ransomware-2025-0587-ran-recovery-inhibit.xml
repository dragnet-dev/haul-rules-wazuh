<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0587 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: dc9ea52a-e46d-595e-a029-e6f1c0490b46 -->
  <rule id="357385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0587 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>