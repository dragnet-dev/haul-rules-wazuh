<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6733 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8cc430f3-e50c-512b-8231-3715ace896da -->
  <rule id="552430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6733 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>