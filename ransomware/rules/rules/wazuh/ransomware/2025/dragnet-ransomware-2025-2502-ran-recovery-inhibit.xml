<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2502 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 9a66911a-464f-5d1c-baf6-29c493c4f6e8 -->
  <rule id="746691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2502 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>