<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1708 — Recovery Inhibition (yurei) | Status: experimental | Sigma ID: 85afb05c-a697-57d2-a615-13f2802e0c5a -->
  <rule id="909710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1708 — Recovery Inhibition (yurei)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>