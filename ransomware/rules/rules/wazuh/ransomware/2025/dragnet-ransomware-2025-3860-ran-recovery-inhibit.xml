<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3860 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: bcbd686b-d7fd-568d-8386-6192e4363dc7 -->
  <rule id="431768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3860 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>