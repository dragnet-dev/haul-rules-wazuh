<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2645 — Event Log Clearing (fog) | Status: experimental | Sigma ID: 6465a1dc-7655-5b7a-b1e4-d2da3d6ef672 -->
  <rule id="234501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2645 — Event Log Clearing (fog)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>