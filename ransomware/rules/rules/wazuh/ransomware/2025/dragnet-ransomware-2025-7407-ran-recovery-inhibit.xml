<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7407 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 47552bd4-bc58-5f7a-ab03-7ea075aba477 -->
  <rule id="573501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7407 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>