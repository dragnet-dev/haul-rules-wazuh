<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1890 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 4fa4c1ab-f89d-5794-8cc1-7e7272c32182 -->
  <rule id="339161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1890 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>