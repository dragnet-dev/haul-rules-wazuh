<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3979 — Event Log Clearing (VanHelsing) | Status: experimental | Sigma ID: a3b5eb6c-a454-5b8b-9a41-ecec19dfc71f -->
  <rule id="748555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3979 — Event Log Clearing (VanHelsing)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>