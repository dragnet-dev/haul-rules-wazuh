<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3666 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 65044031-0d09-508b-8d1d-f2541209d61c -->
  <rule id="304403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3666 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>