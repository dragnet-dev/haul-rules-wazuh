<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1872 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 248c2376-d535-50ef-bcdb-554910926efc -->
  <rule id="480237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1872 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>