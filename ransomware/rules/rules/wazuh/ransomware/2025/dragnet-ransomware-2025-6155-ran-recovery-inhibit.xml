<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6155 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6a17de2c-bf4c-5157-a865-640c61cd3d8d -->
  <rule id="118174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6155 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>