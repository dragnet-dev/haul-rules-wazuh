<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0207 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f7af4856-62a5-5406-b49a-92f7448fa45e -->
  <rule id="536748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0207 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>