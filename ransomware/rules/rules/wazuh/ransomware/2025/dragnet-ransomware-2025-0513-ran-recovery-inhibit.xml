<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0513 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5a158ba4-d630-54c9-bed1-e374ca7405f6 -->
  <rule id="642539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0513 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>