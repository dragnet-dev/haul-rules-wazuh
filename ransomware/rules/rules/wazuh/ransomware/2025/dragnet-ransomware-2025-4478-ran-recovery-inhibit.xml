<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4478 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 10571291-a558-50d8-b430-8a2bc82396fd -->
  <rule id="257129" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4478 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>