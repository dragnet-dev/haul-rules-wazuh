<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1265 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: 96045015-74c9-5cf9-a2fb-fbfe30f9df4c -->
  <rule id="704501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1265 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>