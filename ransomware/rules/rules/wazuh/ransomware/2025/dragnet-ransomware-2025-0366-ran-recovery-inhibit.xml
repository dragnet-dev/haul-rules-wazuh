<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0366 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: f6f93b1a-c138-5af8-bcad-9a69b0ab9416 -->
  <rule id="519099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0366 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>