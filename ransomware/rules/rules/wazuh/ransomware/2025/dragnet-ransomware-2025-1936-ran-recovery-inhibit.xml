<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1936 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 94c00766-6ec2-5326-8d4b-9520f5fd159d -->
  <rule id="716007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1936 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>