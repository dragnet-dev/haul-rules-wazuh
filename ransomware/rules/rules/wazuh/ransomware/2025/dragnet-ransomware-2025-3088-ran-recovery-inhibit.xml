<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3088 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 50b54812-ab36-5d52-b9a4-a0c257802216 -->
  <rule id="115481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3088 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>