<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4251 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: b6dfbadb-6d07-592e-984f-e574c4baaba7 -->
  <rule id="559450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4251 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>