<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7779 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 2f3e9360-6a53-5293-b490-9a80da82cc5b -->
  <rule id="482936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7779 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>