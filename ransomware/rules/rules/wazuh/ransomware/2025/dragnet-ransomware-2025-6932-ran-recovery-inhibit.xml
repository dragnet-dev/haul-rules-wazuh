<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6932 — Recovery Inhibition (radar) | Status: experimental | Sigma ID: cc8d6d11-d47b-58dd-8eef-f1af8598ee23 -->
  <rule id="845069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6932 — Recovery Inhibition (radar)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>