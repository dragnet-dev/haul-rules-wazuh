<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6227 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6e529465-ce0d-5757-a87d-898f1d5f6ff6 -->
  <rule id="305294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6227 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>