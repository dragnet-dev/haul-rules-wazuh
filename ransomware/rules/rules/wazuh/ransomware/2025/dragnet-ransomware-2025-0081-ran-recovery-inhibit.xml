<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0081 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 08a03692-81d1-5127-a98d-44ea6a7bc997 -->
  <rule id="580369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0081 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>