<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2256 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2ec35e7d-e2e1-5606-8798-fa0699f35cdc -->
  <rule id="397374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2256 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>