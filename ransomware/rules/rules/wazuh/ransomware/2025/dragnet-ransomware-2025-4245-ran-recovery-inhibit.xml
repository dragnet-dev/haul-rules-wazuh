<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4245 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b8a42883-49d5-5c86-8217-c548aae625d2 -->
  <rule id="198428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4245 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>