<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1369 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 05a1fbc5-c002-50d2-bc34-17251d2b7d57 -->
  <rule id="194524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1369 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>