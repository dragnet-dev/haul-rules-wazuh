<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7496 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 4e0cc03b-4bf3-5d56-b798-4bd2eb838b74 -->
  <rule id="298840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7496 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>