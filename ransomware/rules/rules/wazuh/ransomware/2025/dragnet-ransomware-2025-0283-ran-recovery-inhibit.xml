<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0283 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: f248f4b2-313f-5c41-a64a-0accc4399a59 -->
  <rule id="739834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0283 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>