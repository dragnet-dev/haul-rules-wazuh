<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4076 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 2e3ed784-a01d-5af2-bd48-9e1caf9aa6c7 -->
  <rule id="387657" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4076 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>