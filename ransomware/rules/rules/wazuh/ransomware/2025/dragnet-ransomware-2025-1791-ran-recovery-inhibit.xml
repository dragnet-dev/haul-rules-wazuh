<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1791 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 875b6a8b-2abe-584e-a420-95da2762fca8 -->
  <rule id="541866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1791 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>