<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1813 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 32476722-306b-5383-a218-03ed39cd0473 -->
  <rule id="647672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1813 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>