<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3876 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 2b2d579f-54e6-5f11-86cc-1477c4f6dd4c -->
  <rule id="725579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3876 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>