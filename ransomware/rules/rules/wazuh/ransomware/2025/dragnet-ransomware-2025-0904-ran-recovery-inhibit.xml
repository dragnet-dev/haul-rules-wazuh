<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0904 — Recovery Inhibition (gunra) | Status: test | Sigma ID: 45092781-4f3b-5e85-8c7f-d13b54ccf139 -->
  <rule id="109278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0904 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>