<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6379 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 6b267322-e2de-56d8-a96f-10c7fa90e418 -->
  <rule id="272673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6379 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>