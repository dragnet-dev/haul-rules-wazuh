<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2323 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 46acbf11-643d-5618-a521-ac96c3a0a845 -->
  <rule id="458879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2323 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>