<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6118 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c9daf96c-cc02-53f9-b04a-d26582c4389a -->
  <rule id="918879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6118 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>