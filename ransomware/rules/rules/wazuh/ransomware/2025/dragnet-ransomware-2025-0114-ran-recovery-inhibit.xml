<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0114 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 388a7689-0c3e-54f9-9c68-d45d6c95429d -->
  <rule id="918768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0114 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>