<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1367 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: c73a1bec-ec71-5632-9388-a37dd8744912 -->
  <rule id="660507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1367 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>