<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5596 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ae90f9d7-3118-5816-af88-e6d5956ad3c6 -->
  <rule id="198559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5596 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>