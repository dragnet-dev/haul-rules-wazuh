<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1189 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 1e13fe3e-6475-582b-8dbe-3eb9eafba90c -->
  <rule id="615823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1189 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>