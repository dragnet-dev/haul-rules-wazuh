<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7397 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 762e8f00-6b5a-5bd2-bdfa-4220b5063984 -->
  <rule id="253103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7397 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>