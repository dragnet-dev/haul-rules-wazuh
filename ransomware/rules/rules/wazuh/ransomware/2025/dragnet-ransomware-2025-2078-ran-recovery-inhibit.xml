<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2078 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 60539224-4b00-5ddd-864f-0c856b1fa05e -->
  <rule id="753922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2078 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>