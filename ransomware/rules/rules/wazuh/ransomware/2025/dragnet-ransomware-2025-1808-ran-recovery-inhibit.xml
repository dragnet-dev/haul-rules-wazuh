<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1808 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: ce209ad3-1dc3-5c03-a2b1-396a87a96cbf -->
  <rule id="699354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1808 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>