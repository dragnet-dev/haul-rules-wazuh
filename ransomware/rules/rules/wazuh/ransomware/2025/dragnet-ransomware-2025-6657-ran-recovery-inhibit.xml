<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6657 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2f8bb78c-04da-5db3-8ff7-29ecdcfaae8f -->
  <rule id="425557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6657 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>