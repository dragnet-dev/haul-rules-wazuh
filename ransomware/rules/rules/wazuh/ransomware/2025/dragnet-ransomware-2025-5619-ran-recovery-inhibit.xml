<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5619 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 3ec1e130-01ff-5986-9321-57f80eb8ab88 -->
  <rule id="806701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5619 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>