<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0158 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: bf6fc4a0-7ff8-5113-9f6e-39239e7ed700 -->
  <rule id="507484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0158 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>