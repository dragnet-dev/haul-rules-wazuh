<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1602 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: beddfd25-c65a-5531-85c7-734095de7d57 -->
  <rule id="908669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1602 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>