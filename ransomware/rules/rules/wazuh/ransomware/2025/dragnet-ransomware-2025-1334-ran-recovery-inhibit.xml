<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1334 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7570e489-8afe-5e7c-baed-d02ff465b808 -->
  <rule id="411344" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1334 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>