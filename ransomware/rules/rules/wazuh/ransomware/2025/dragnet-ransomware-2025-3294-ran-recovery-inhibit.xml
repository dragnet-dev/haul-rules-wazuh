<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3294 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 388c5efd-b731-56ed-b470-218101ee5f00 -->
  <rule id="724719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3294 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>