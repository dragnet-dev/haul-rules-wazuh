<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3919 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: cc377d8e-ead3-5982-b87d-38733a1465b8 -->
  <rule id="670045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3919 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>