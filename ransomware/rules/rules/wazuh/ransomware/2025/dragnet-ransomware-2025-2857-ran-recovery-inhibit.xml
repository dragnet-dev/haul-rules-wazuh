<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2857 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 63fd8b9f-794e-5d12-865b-d72346157a81 -->
  <rule id="921099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2857 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>