<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5809 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 434476cf-5398-5a3e-8fff-64bcf03b9a62 -->
  <rule id="751628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5809 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>