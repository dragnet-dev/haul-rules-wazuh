<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3126 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9b96a9c7-7706-51d8-b382-f4495f6879d1 -->
  <rule id="795469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3126 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>