<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3443 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 13eafd17-57cb-5a62-aea9-3270098790a9 -->
  <rule id="221251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3443 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>