<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0224 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: cb0c5f45-3743-5a6b-a2df-ab103faebb48 -->
  <rule id="798815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0224 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>