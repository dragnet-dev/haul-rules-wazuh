<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3604 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 605e3035-413d-5fde-ad1b-60d5536f3bdb -->
  <rule id="794303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3604 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>