<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4945 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 69d85388-40e1-5da4-882d-5ba52f434fb3 -->
  <rule id="317853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4945 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
