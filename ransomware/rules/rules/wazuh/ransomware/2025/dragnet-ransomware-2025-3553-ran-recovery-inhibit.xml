<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3553 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 00dfb0c8-40ff-59c4-a677-4a150a054385 -->
  <rule id="426528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3553 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>