<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7901 — Recovery Inhibition (everest) | Status: test | Sigma ID: d2d0147a-13d5-5a14-994c-1806e8823761 -->
  <rule id="425014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7901 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>