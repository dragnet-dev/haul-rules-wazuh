<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1101 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a487a5d4-6558-5c0e-bf35-8ff96f81debd -->
  <rule id="878025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1101 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>