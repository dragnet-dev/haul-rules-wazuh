<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5103 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1fa0bd0f-a019-50dc-bfe5-59565fcf51fc -->
  <rule id="495549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5103 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>