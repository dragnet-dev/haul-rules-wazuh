<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2145 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: 2f655ebd-42d6-58de-bfd6-274671c00502 -->
  <rule id="599915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2145 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>