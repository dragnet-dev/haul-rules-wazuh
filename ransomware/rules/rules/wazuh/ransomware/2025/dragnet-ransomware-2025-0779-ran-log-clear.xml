<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0779 — Event Log Clearing (kairos) | Status: deprecated | Sigma ID: 0a0308aa-ca9b-5e0c-a7b7-41beb496afb0 -->
  <rule id="804938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0779 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>