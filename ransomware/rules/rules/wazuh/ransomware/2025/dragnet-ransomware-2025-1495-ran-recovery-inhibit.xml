<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1495 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: a028d4ec-c22c-5af9-9e7b-584e66bf21d1 -->
  <rule id="804614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1495 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>