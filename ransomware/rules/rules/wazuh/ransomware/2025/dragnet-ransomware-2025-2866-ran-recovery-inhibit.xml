<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2866 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 30985142-1bf3-50e4-b625-4975d7b03fd3 -->
  <rule id="498514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2866 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>