<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0735 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e1b48fed-d2da-592e-94be-1cdc5a1a43c9 -->
  <rule id="127983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0735 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>