<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1223 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 82b04e10-9d1d-59cd-93bd-674d4d82d86a -->
  <rule id="416878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1223 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>