<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4814 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f5524474-6fc3-5621-8605-0bca1ef67322 -->
  <rule id="755244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4814 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>