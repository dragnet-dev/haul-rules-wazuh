<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4679 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 5f09d4ac-6c99-56b3-9e6a-aed0e2c2fcfc -->
  <rule id="721574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4679 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>