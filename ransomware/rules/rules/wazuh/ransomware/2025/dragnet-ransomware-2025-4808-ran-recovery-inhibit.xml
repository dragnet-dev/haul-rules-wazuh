<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4808 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: f35b3890-ddbd-5ff4-acfe-851129932d82 -->
  <rule id="757138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4808 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>