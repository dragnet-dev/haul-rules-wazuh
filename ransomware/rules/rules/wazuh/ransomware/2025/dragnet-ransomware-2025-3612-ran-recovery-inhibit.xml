<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3612 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 9e6aac37-82a0-524c-9c1f-9dcb6cf440db -->
  <rule id="298988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3612 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>