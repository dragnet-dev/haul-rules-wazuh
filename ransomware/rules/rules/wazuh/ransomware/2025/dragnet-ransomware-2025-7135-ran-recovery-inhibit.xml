<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7135 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: ab2052e0-573e-5829-ac73-9ae1918cff53 -->
  <rule id="912052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7135 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>