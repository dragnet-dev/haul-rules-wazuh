<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7371 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 55559045-ae9c-53a0-a118-6d78746a3480 -->
  <rule id="255904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7371 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>