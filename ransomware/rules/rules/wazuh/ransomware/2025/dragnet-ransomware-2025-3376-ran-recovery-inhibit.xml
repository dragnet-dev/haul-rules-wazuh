<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3376 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 8c314e56-9a34-500b-9b36-8fa7b4051252 -->
  <rule id="545038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3376 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
