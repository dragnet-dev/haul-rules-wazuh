<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0205 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: c26329b0-ae40-5d32-9827-1f88aa499c57 -->
  <rule id="426329" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0205 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>