<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0234 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5c696c23-99d4-5e08-85a9-160bc00d0fd8 -->
  <rule id="683148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0234 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>