<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2132 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 3cff8315-d4cf-5b64-9ec2-eb4b10fe9bbb -->
  <rule id="761583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2132 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>