<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6988 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 2aef7e78-6291-5856-88fe-e9072785d6cc -->
  <rule id="958686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6988 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>