<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5270 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 30ef2296-df06-54c5-b519-6a788fe4f97e -->
  <rule id="819229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5270 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>