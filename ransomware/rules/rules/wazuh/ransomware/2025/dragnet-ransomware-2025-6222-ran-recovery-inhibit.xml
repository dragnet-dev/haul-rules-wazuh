<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6222 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: ffe9e9d3-58ce-5e2b-b4ba-aec94c693139 -->
  <rule id="351989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6222 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>