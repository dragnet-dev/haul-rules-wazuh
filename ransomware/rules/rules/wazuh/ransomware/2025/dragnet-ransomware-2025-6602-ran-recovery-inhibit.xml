<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6602 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 5b7e411a-e29f-5fc8-81bd-505f7b392bc3 -->
  <rule id="668641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6602 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>