<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2293 — Shadow Copy Deletion (SilentRansomGroup) | Status: deprecated | Sigma ID: 4498d4a4-800d-53cb-9afb-1135d9176aeb -->
  <rule id="817034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2293 — Shadow Copy Deletion (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>