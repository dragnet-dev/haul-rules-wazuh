<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0217 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: f474bf7c-b393-579b-a5a3-9e4d5fee2130 -->
  <rule id="461535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0217 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>