<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4136 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: c679b404-a226-5128-9aff-3c40acaf9417 -->
  <rule id="328754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4136 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>