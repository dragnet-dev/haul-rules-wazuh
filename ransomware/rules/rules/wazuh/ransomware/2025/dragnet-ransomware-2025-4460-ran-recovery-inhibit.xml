<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4460 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 775ecfc6-8fce-534f-935c-d5efbcac071a -->
  <rule id="578191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4460 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>