<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7176 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 0202b5fe-cbf8-545c-935f-bfeaeb68bb5f -->
  <rule id="303614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7176 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>