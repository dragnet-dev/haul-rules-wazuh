<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3679 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: fb63e770-5b21-5ec7-b472-7ff82525d41e -->
  <rule id="526227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3679 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>