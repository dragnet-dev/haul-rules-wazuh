<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5715 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: ccd9f25f-31dc-5475-9680-1c76a6ba13aa -->
  <rule id="844792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5715 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>