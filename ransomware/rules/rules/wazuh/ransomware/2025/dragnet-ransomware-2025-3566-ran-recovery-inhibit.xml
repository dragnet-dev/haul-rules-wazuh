<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3566 — Recovery Inhibition (lynx) | Status: test | Sigma ID: c2c8be40-7723-58a5-9d8e-ef32de12e891 -->
  <rule id="630078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3566 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>