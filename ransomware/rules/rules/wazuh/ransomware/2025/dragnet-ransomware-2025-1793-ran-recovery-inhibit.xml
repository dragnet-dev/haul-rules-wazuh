<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1793 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 655d8155-197b-50cd-b67b-e4faf707167f -->
  <rule id="249381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1793 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>