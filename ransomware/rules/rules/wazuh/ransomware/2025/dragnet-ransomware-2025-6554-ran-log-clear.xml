<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6554 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: eb3b9a98-f5c9-5dea-8d6b-1080c8a63194 -->
  <rule id="725594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6554 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>