<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4712 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: f9810b9e-6ae1-5e2e-807a-de7fa8fa0fbd -->
  <rule id="856971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4712 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>