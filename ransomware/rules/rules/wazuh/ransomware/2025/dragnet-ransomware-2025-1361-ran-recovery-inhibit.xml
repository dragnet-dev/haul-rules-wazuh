<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1361 — Recovery Inhibition (hellcat) | Status: deprecated | Sigma ID: 167f34b8-edcc-5679-8801-45e4883ba4fb -->
  <rule id="799755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1361 — Recovery Inhibition (hellcat)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>