<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6195 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 325e458d-a52a-53d1-a9d9-479e193126b2 -->
  <rule id="814458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6195 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>