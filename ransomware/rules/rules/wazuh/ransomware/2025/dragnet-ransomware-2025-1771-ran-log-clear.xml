<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1771 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 6fedb426-0d61-550c-bc0c-2b4edb91f9d4 -->
  <rule id="184594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1771 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>