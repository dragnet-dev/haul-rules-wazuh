<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5312 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: ad5998d4-d3fc-50ea-aeb4-c9c4b91eb190 -->
  <rule id="935998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5312 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>