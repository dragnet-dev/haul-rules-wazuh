<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6640 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 0fa5a16c-7bb2-51bc-975c-ac174aa976c1 -->
  <rule id="509016" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6640 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>