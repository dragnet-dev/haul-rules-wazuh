<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2149 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 47d96bbf-a034-5bcc-90c7-b3b832a3f6bb -->
  <rule id="425547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2149 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>