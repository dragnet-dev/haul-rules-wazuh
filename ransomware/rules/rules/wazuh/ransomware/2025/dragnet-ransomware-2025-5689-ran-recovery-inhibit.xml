<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5689 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a6fdfece-6631-5a1e-aa4e-3ffcbb370846 -->
  <rule id="811838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5689 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>