<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6254 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f76455fd-190b-5ef8-9816-ea7f56140a9c -->
  <rule id="776455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6254 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>