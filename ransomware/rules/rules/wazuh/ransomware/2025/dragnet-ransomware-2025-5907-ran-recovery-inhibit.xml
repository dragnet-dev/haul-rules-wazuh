<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5907 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b4dcc252-889d-506d-9f99-2e9209b9548a -->
  <rule id="304762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5907 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>