<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1293 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2e206643-65d5-5573-b695-63ed7bff796c -->
  <rule id="220664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1293 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>