<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4803 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d4503e13-0de1-5709-9c6d-25c518dd1e46 -->
  <rule id="452062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4803 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>