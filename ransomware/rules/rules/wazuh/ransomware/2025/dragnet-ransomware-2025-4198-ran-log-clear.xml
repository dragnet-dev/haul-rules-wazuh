<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4198 — Event Log Clearing (nova) | Status: test | Sigma ID: 1f474700-cd13-5c2f-8445-55cc7b439410 -->
  <rule id="547470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4198 — Event Log Clearing (nova)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>