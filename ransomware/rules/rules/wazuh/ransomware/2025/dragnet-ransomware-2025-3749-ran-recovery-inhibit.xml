<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3749 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4b22537b-d49f-5579-acc3-48dd45c51076 -->
  <rule id="422537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3749 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>