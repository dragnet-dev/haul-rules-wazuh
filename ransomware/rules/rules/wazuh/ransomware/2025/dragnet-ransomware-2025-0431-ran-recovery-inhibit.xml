<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0431 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 31db92c6-fb66-5957-bb5d-2b464ae6bd1e -->
  <rule id="549484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0431 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>