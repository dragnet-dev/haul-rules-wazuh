<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3843 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c45e80e5-b446-5618-b4d6-bf8e05754b11 -->
  <rule id="293480" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3843 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>