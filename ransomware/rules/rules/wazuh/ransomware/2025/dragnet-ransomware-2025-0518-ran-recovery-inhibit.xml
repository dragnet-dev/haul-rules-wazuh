<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0518 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b4efc213-6acd-571d-9ee5-2a0226cfbf8a -->
  <rule id="307802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0518 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>