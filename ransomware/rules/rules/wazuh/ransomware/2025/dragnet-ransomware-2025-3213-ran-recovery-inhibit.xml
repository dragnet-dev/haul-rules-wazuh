<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3213 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bdeedb72-1ce2-5a0d-b01b-abee9aee1da5 -->
  <rule id="847451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3213 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>