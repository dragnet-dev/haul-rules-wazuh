<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3337 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 86acca1f-5855-5647-9d71-cfcbc667c0a7 -->
  <rule id="380330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3337 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>