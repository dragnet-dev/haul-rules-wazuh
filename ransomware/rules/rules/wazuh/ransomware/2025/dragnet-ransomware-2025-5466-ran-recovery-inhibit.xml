<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5466 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 63d7da85-6c7b-55a0-a59c-bcb2d707d358 -->
  <rule id="915770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5466 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>