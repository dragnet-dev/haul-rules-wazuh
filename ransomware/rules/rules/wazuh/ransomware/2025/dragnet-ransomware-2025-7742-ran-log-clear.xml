<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7742 — Event Log Clearing (crazyhunter) | Status: experimental | Sigma ID: c307cae9-51a8-5c60-af65-488eec254618 -->
  <rule id="550794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7742 — Event Log Clearing (crazyhunter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>