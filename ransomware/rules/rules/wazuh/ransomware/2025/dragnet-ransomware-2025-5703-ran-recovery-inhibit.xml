<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5703 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 960d215e-73f8-580f-8cec-60c61f4ce3ad -->
  <rule id="737321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5703 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>