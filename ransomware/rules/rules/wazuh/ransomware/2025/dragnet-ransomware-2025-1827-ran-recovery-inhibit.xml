<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1827 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 22e3430a-4129-544b-9725-5666c2e185e3 -->
  <rule id="163430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1827 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>