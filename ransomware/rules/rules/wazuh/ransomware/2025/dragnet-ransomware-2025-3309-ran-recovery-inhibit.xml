<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3309 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d55fa557-7fcc-5599-9888-4d48d9791cb3 -->
  <rule id="871305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3309 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>