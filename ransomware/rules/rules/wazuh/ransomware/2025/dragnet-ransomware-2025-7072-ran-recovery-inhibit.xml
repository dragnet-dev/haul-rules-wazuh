<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7072 — Recovery Inhibition (cicada3301) | Status: experimental | Sigma ID: aaaeb648-8369-5302-92ef-05d11029ad6a -->
  <rule id="791156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7072 — Recovery Inhibition (cicada3301)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>