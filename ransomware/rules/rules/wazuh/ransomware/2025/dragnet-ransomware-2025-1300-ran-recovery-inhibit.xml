<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1300 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 14810422-deae-58c2-b166-54f7b6c1a1c4 -->
  <rule id="681042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1300 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>