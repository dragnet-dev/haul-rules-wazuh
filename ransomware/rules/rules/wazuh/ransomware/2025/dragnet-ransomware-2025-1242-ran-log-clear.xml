<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1242 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 4b53eb5b-ff60-5647-97ef-2e63b97b2a6a -->
  <rule id="233803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1242 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>