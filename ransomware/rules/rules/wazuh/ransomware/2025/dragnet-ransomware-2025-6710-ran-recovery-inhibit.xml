<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6710 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6fad6f28-2148-532e-bbe0-e046cacad7b7 -->
  <rule id="174351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6710 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>