<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6688 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 2788be23-4f54-5732-ae40-6466e5b7ae10 -->
  <rule id="939182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6688 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>