<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6895 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 12482efc-3cb1-526f-81d7-cf565134d977 -->
  <rule id="595631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6895 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>