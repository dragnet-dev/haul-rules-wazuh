<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6237 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1ecb7558-ca02-5fba-8d0d-0dba34cd37c4 -->
  <rule id="783755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6237 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>