<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1718 — Event Log Clearing (bert) | Status: experimental | Sigma ID: 9bf6bad9-9b4e-5945-add9-40b84e4b2bb8 -->
  <rule id="188922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1718 — Event Log Clearing (bert)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>