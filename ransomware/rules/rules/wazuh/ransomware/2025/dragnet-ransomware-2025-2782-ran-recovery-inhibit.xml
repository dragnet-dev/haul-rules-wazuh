<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2782 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1eda6297-410d-5920-913b-5d85b383ee24 -->
  <rule id="798629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2782 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>