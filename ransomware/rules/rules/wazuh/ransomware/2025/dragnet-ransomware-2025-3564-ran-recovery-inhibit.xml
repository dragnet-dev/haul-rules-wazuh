<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3564 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c67cf8f7-4a48-56af-b9b0-2a10cf4999fb -->
  <rule id="645598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3564 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>