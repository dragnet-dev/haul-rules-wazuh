<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2143 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 77d90964-1195-5584-b90e-049fae9fafc0 -->
  <rule id="445909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2143 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>