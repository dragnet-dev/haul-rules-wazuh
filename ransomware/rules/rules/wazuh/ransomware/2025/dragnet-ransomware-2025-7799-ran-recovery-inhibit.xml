<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7799 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 76b5731f-7116-503a-856e-6b2163af013e -->
  <rule id="427573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7799 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>