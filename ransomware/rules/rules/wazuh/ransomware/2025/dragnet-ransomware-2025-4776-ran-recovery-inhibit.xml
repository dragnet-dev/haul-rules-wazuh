<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4776 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: ca6496d8-b21e-51a8-8f7d-4d5f07f1820c -->
  <rule id="326496" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4776 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>