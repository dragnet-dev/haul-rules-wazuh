<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4320 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: bdb7b479-4425-5862-bb93-8151cbf1bcfc -->
  <rule id="457234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4320 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>