<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4277 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b8ce755c-c14a-53b6-8e3c-556a6abad89f -->
  <rule id="441475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4277 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>