<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6316 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e138adff-a92e-58ee-b2e0-d9750ec3285b -->
  <rule id="119501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6316 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>