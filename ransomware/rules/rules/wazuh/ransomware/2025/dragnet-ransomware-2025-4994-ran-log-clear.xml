<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4994 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: e1a3a1e7-7449-5bee-b2ba-8bff25580efc -->
  <rule id="126181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4994 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>