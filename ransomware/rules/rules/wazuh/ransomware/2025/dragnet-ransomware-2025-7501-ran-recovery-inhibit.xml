<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7501 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: efcef29d-56ed-57ec-93d7-3bb757ebdb2c -->
  <rule id="922552" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7501 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>