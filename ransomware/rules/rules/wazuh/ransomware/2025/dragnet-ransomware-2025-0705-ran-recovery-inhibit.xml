<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0705 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b58f9f95-4bf6-5219-a953-fae4131844ca -->
  <rule id="367039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0705 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>