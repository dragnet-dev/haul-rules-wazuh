<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2519 — Recovery Inhibition (rebornvc) | Status: deprecated | Sigma ID: 3106cf6e-def3-5d83-9b78-f312783ee348 -->
  <rule id="853436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2519 — Recovery Inhibition (rebornvc)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>