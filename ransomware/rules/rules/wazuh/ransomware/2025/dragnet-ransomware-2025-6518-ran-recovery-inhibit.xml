<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6518 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 010e10cf-fd93-5e46-842b-955983d39860 -->
  <rule id="957167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6518 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>