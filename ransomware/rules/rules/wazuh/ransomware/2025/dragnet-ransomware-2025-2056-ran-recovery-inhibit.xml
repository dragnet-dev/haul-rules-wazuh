<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2056 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8e266976-489f-57bd-90e1-1086cfb6d92a -->
  <rule id="622669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2056 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>