<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2696 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: d7a0ba1a-e683-5aeb-8d40-18084f3e3c82 -->
  <rule id="337306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2696 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>