<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4472 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a63a04d6-cbb5-5ace-8961-d47f062a76c9 -->
  <rule id="901804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4472 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>