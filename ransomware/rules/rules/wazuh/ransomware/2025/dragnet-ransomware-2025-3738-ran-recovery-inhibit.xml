<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3738 — Recovery Inhibition (play) | Status: experimental | Sigma ID: edf70b74-da5b-5543-b1ce-59648aa8be87 -->
  <rule id="792331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3738 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
