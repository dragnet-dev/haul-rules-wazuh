<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4304 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 99c8ede7-401b-5425-88a0-e2af351735f2 -->
  <rule id="588045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4304 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>