<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7355 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8868dc8d-5e2b-580f-a7ee-ba5c1abee7b5 -->
  <rule id="570428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7355 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>