<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2326 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: e78d8e8e-563d-5274-b733-19f39d37f199 -->
  <rule id="285902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2326 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>