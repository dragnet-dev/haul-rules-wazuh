<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3135 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c99ddc16-73eb-52c7-ad54-bddff39b40c1 -->
  <rule id="924252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3135 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>