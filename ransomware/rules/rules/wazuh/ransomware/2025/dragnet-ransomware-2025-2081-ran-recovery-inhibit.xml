<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2081 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 485a779b-5b31-5aa7-8e5d-5abf15dd13ac -->
  <rule id="670779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2081 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>