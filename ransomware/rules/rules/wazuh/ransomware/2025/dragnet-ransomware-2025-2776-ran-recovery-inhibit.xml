<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2776 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 71f4747e-a052-5c38-9969-23fd96a281d0 -->
  <rule id="351474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2776 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>