<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1062 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bb48abb2-63b5-5339-9c9c-5c1e46fe6618 -->
  <rule id="399659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1062 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>