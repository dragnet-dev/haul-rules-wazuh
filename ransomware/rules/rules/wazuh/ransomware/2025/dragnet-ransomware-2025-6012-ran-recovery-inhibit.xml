<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6012 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: afe0db3d-6bff-5449-b0b6-dee3fb4a8f90 -->
  <rule id="104059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6012 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>