<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7026 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: f97fb36a-8414-5e6f-bad1-0bd982a95ed6 -->
  <rule id="590833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7026 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>