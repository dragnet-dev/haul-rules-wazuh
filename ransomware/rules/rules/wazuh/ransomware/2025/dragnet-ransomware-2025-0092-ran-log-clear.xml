<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0092 — Event Log Clearing (kryptos) | Status: deprecated | Sigma ID: 3577c7c2-d277-5152-9875-26b0a431684b -->
  <rule id="259164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0092 — Event Log Clearing (kryptos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>