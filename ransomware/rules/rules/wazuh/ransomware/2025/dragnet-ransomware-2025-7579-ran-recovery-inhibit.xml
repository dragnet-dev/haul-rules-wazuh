<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7579 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 19d8b3cc-5f99-5cee-adee-d9a413b7ae1a -->
  <rule id="137500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7579 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>