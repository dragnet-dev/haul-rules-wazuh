<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2841 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: f139c9cd-965c-5aa8-9f4a-8ff2d8d32a7f -->
  <rule id="722369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2841 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>