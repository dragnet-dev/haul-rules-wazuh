<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5516 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2e1932d0-5e0c-5eb0-b255-2ead49a2615c -->
  <rule id="290925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5516 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>