<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3594 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: c7fb4a36-e77e-5b3b-b1a3-1245453e213a -->
  <rule id="842154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3594 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>