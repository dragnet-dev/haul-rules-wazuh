<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0841 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: fdd66e6c-c030-5ae3-adbf-6556d2417141 -->
  <rule id="298670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0841 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>