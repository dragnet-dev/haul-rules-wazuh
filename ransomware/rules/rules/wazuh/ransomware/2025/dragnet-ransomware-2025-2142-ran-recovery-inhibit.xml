<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2142 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 74a79466-ad08-5c7c-8b89-6bc837c557b4 -->
  <rule id="394794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2142 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>