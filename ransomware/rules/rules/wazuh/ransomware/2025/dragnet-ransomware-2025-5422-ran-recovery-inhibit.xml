<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5422 — Recovery Inhibition (arkana) | Status: experimental | Sigma ID: 118267ab-df6c-5155-8de1-1a5c9d885ad9 -->
  <rule id="192282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5422 — Recovery Inhibition (arkana)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>