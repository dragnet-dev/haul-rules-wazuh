<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3095 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: e75676bd-05e4-5b04-a688-18d2b372aa13 -->
  <rule id="675676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3095 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>