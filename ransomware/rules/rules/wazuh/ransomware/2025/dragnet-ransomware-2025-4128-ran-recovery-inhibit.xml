<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4128 — Recovery Inhibition (tengu) | Status: experimental | Sigma ID: fcdbf277-6b90-511a-86a6-df4992351724 -->
  <rule id="235711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4128 — Recovery Inhibition (tengu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>