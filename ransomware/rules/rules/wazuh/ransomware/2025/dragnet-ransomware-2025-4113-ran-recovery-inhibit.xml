<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4113 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1d7245d8-fd4c-560b-8f0a-f35069d29424 -->
  <rule id="355933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4113 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>