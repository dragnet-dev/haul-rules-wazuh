<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2381 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 53a2cd1d-ac27-5e3e-aa6f-9815e294a128 -->
  <rule id="497197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2381 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>