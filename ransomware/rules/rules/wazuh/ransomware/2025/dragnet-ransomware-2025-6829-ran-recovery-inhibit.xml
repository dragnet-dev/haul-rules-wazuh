<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6829 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a5acc401-95ea-5ef8-a59e-18e01a708ff9 -->
  <rule id="828444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6829 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>