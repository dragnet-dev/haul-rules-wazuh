<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0072 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 803e3178-05ef-5614-a60f-518ec718de0b -->
  <rule id="486231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0072 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>