<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2693 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: dafdc5e3-63d6-5d12-af21-a3b871d30baa -->
  <rule id="969885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2693 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>