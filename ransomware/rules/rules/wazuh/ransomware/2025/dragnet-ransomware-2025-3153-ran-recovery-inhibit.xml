<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3153 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: e92cfe5f-808c-5672-b029-789605538fdb -->
  <rule id="814558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3153 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>