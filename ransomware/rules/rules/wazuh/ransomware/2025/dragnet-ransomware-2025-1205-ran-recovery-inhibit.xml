<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1205 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 32d657d3-06f2-55aa-a925-05da682e099a -->
  <rule id="410525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1205 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>