<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3892 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 1945b040-5e74-5788-b8f6-f263d13225ff -->
  <rule id="513104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3892 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>