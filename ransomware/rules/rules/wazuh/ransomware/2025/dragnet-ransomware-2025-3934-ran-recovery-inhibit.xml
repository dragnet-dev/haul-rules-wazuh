<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3934 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 8fba79d1-9e3b-5cab-956e-edea5f4bd021 -->
  <rule id="179479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3934 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>