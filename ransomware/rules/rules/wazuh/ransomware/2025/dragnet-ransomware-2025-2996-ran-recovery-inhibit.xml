<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2996 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 506f4dc8-1bf9-58f9-a968-d2bee86af345 -->
  <rule id="497837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2996 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>