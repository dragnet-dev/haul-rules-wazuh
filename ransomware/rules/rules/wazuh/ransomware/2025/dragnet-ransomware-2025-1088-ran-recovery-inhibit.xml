<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1088 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9a4be24a-111a-5eb8-a6ca-6a1a34da023c -->
  <rule id="454542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1088 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>