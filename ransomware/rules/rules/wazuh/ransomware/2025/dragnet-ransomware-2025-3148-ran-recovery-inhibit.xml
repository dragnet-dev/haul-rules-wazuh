<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3148 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: c83072b8-b983-51f8-8471-8bae8159bbda -->
  <rule id="483072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3148 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>