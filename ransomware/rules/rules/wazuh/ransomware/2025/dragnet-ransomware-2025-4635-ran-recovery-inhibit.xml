<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4635 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 6b955ec9-28cf-5cc8-89b7-945ccdd0cd87 -->
  <rule id="927294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4635 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>