<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7440 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 72e71c8f-d4e8-526c-b1ef-844b8f9b647c -->
  <rule id="166748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7440 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>