<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3143 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 9ff8c445-a18b-5479-b675-0b6734b5511f -->
  <rule id="595804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3143 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
