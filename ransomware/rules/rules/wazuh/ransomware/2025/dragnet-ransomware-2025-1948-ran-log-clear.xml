<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1948 — Event Log Clearing (securotrop) | Status: experimental | Sigma ID: b266a0cc-3db6-579d-bc4f-cb1cd3d288fc -->
  <rule id="102660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1948 — Event Log Clearing (securotrop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>