<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6041 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 81206ce5-83ec-5e27-bc60-ee01b59bb37c -->
  <rule id="499308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6041 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
