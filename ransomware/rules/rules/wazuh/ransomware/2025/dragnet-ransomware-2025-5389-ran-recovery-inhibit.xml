<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5389 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: acbd6eb5-12ea-5daf-86ee-48b71a50d688 -->
  <rule id="875470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5389 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>