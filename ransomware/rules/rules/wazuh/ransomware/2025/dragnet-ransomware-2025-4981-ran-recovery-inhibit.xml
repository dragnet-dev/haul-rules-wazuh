<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4981 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: e20476b7-d739-568d-9346-a63948ae5750 -->
  <rule id="620476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4981 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>