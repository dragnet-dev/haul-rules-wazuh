<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4910 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 21415210-ac98-5ed3-9104-84769906feb6 -->
  <rule id="441521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4910 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>