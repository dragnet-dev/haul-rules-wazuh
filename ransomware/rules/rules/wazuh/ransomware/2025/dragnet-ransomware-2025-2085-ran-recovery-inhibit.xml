<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2085 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b4838ffe-da05-5f25-bd71-5c7f5ec6e084 -->
  <rule id="137423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2085 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>