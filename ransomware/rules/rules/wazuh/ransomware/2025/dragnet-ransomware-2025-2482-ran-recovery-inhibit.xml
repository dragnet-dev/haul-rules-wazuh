<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2482 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: c86ab678-d40f-58ef-bb49-78799c062ae6 -->
  <rule id="693876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2482 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>