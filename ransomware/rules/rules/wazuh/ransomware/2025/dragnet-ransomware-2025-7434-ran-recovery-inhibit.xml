<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7434 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1f2205ec-a97e-5812-8ad4-b7a5c2ff4b69 -->
  <rule id="595294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7434 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>