<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0901 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f9b072b3-ab7e-50fb-b3d6-c28f3a02b05a -->
  <rule id="855072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0901 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>