<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4762 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 7d6c3ccf-69c8-5a72-8ad7-3b7c7e440106 -->
  <rule id="617340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4762 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>