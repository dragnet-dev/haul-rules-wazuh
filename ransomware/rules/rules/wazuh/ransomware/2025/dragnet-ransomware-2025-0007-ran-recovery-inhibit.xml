<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0007 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 439870c7-5d2c-5de4-97d1-f174ce294496 -->
  <rule id="837932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0007 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>