<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1577 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 8355e1d6-2ed1-57c3-994f-2bc1b47205e1 -->
  <rule id="536941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1577 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>