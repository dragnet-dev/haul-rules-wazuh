<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0959 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 27e19527-50c6-577b-9958-795e815f0d81 -->
  <rule id="961952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0959 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>