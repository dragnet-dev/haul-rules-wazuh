<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7439 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5eaaa3c3-2d29-52d1-894e-4bc20af556df -->
  <rule id="377543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7439 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>