<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5521 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 0f3f644e-0213-5eb0-b96f-b1feb4c21c97 -->
  <rule id="763644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5521 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>