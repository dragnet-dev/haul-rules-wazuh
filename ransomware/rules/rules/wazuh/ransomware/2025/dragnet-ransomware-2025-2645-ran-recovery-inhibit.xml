<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2645 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 5cf3c907-2db4-5ed7-9aa6-1c58b81ac846 -->
  <rule id="679809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2645 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>