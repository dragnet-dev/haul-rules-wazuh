<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1538 — Recovery Inhibition (direwolf) | Status: test | Sigma ID: 7094ab7d-adc6-5c86-a10a-0733617c0404 -->
  <rule id="116235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1538 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>