<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6102 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: dd219b43-2167-556d-8e8d-7ff2677d975f -->
  <rule id="939515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6102 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>