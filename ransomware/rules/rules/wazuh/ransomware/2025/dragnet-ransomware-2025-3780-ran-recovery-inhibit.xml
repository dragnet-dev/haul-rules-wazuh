<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3780 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 776b23f0-ecca-52d5-b178-f9974c2246d4 -->
  <rule id="442723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3780 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>