<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2735 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: fbbb899e-9e75-52b9-aa39-c1a35f903e04 -->
  <rule id="244389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2735 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>