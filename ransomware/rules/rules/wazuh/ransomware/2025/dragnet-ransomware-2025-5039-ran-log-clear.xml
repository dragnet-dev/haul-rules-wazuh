<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5039 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 1fd517cf-0c3e-5b0a-9b13-2411f9e37d96 -->
  <rule id="152284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5039 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>