<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2377 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6794bb3b-7f01-56be-a4a7-5ca000c22442 -->
  <rule id="939451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2377 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>