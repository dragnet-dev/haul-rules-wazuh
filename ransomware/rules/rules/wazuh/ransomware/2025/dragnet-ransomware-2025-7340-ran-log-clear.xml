<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7340 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 0a1cd9f9-36af-5f6d-a7fe-38e480abca73 -->
  <rule id="669919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7340 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>