<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1592 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c83947b9-5bbb-5979-9952-3e9cd0eca0e6 -->
  <rule id="483947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1592 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>