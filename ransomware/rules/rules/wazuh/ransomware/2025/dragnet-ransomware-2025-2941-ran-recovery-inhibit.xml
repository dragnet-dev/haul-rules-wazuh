<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2941 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 13162bb3-e890-5c6c-b07c-5b92f0e976ad -->
  <rule id="769659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2941 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>