<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4626 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 32c5e46f-5083-5f97-ab71-b5562945b3ab -->
  <rule id="393446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4626 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>