<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3454 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 239258c4-4314-549e-9b4d-3ea96f85d7ea -->
  <rule id="328140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3454 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>