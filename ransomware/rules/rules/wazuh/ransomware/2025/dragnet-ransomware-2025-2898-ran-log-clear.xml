<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2898 — Event Log Clearing (devman) | Status: deprecated | Sigma ID: 7311a256-3512-568a-9fcc-c6370bd71f91 -->
  <rule id="369862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2898 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>