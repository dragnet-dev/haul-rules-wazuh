<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3199 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 9903bc8b-5a29-5639-bb9c-b6acaee11c35 -->
  <rule id="835356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3199 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>