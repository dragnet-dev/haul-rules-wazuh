<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7158 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: eb7235c1-383c-5b61-b3ac-98344c9de8a7 -->
  <rule id="657235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7158 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>