<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6531 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d1714745-0351-5723-a77b-8c78ea007ec4 -->
  <rule id="517147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6531 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>