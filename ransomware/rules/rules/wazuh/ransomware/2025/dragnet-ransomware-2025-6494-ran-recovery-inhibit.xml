<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6494 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: dc8c567c-fad3-5f8c-bfb7-ad2e644fa16b -->
  <rule id="934056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6494 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>