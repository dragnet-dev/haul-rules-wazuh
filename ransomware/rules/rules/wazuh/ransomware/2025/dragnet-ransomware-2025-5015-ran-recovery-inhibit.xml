<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5015 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a2498e92-472b-5365-a5f7-b14a7c2dfdd5 -->
  <rule id="839982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5015 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>