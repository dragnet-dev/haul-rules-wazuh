<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3333 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 626df993-b298-574b-bd3f-372722aa01d6 -->
  <rule id="804799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3333 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>