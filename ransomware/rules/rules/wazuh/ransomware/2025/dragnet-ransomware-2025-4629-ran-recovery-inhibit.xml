<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4629 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4059918f-e0e7-53ea-89b3-85a39ea9f397 -->
  <rule id="559918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4629 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
