<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3183 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 239f5b57-d3cf-508f-9ad9-0ff9fbdec92a -->
  <rule id="843315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3183 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>