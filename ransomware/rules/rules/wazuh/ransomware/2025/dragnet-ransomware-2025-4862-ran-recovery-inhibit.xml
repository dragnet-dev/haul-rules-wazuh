<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4862 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 9b643414-5480-54b6-99e5-1531520820d8 -->
  <rule id="756434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4862 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>