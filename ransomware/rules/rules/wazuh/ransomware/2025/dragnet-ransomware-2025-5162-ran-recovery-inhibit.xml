<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5162 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 55a0de32-09ef-5526-92fc-2dc32b2be1ed -->
  <rule id="578622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5162 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>