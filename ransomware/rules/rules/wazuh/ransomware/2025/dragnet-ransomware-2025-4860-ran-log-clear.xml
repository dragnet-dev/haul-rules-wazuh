<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4860 — Event Log Clearing (play) | Status: experimental | Sigma ID: 449b47ec-07c4-52c1-9ddb-5f4bca4a3fa5 -->
  <rule id="812766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4860 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>