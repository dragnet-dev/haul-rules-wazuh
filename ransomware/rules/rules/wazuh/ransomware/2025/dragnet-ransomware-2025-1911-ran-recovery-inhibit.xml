<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1911 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3274f071-c827-5977-8eea-6a617d9ecb8c -->
  <rule id="839907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1911 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>