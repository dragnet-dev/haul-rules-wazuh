<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7389 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 5080ae8a-5f21-5389-8846-eca436f49f05 -->
  <rule id="500654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7389 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>