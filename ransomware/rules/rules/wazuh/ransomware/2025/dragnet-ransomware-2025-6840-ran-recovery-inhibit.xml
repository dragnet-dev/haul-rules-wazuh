<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6840 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: ead994a1-2435-59a6-b8ae-a1336e4fb8c4 -->
  <rule id="257994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6840 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>