<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5724 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 0691c178-b4f7-55bd-bc0c-218dafff90fd -->
  <rule id="306817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5724 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>