<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1111 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a01a0cfc-47f7-5967-80e5-a955679a9e27 -->
  <rule id="864172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1111 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>