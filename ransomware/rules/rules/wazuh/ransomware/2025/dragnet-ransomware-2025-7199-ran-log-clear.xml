<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7199 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 72dd05a7-3c0a-5371-af15-01c995a9cb44 -->
  <rule id="165305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7199 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>