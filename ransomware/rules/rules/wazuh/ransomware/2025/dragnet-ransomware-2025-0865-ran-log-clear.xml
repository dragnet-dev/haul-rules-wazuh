<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0865 — Event Log Clearing (handala) | Status: experimental | Sigma ID: 994b09bd-fab0-5b69-a86d-0e9b7a940a30 -->
  <rule id="791509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0865 — Event Log Clearing (handala)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>