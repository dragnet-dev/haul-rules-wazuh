<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4447 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 89253996-2e32-5710-b50c-439e90ff8ba5 -->
  <rule id="925399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4447 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>