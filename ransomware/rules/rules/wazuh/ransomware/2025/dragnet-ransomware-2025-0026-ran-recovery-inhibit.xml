<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0026 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d09c97c4-abf7-5adf-b745-6fe7d5b730df -->
  <rule id="395697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0026 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>