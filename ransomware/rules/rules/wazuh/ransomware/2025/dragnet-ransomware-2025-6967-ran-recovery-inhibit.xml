<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6967 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: beb0030a-d2ab-5c43-a22f-86b4c10074a1 -->
  <rule id="451003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6967 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>