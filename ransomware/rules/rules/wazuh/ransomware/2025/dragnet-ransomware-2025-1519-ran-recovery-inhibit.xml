<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1519 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: ad23f410-2ebb-50df-9d66-c900435ed644 -->
  <rule id="171834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1519 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>