<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4821 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4621a935-a347-5647-a4ad-ec94ec478901 -->
  <rule id="294693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4821 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>