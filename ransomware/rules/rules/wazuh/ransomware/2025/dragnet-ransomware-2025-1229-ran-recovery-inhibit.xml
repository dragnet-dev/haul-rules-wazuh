<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1229 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e779d31f-ea18-5f28-8ba1-05155d9909bb -->
  <rule id="664773" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1229 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>