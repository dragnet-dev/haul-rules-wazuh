<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6177 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 440f5f3d-7691-5b04-abfc-88048f8f43c8 -->
  <rule id="328895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6177 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>