<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2192 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 77d4e5ae-7d17-5373-a406-18a793edf19f -->
  <rule id="292785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2192 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>