<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5952 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 868173c3-393d-5a65-b81b-05b3f2594403 -->
  <rule id="490780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5952 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>