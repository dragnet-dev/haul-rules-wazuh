<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4666 — Event Log Clearing (genesis) | Status: experimental | Sigma ID: f3dc0de8-9b3d-5d39-8a0a-b820a4af9f43 -->
  <rule id="102093" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4666 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>