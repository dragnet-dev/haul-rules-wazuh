<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7579 — Event Log Clearing (chaos) | Status: experimental | Sigma ID: 36b3ca4f-7caf-5844-a266-fe8ce65f0471 -->
  <rule id="703690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7579 — Event Log Clearing (chaos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>