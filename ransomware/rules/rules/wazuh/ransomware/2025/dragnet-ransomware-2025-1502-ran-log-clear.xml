<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1502 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 0e632dac-a1b4-52f5-bb53-338387b5c8c9 -->
  <rule id="246010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1502 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>