<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5326 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 1df5220d-1158-5733-abc9-913ca6ef59c5 -->
  <rule id="395220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5326 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>