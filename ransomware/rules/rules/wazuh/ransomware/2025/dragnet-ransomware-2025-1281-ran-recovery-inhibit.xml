<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1281 — Recovery Inhibition (radiant) | Status: experimental | Sigma ID: 9603b654-1c85-5fb5-a979-5811b4d41a5a -->
  <rule id="736596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1281 — Recovery Inhibition (radiant)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>