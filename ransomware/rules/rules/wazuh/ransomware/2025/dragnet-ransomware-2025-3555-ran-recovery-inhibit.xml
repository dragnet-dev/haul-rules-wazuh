<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3555 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3d9f623b-a7db-5cd8-9e55-2e3b54e91bc0 -->
  <rule id="119623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3555 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>