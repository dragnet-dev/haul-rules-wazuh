<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5973 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 0b9a41b3-ff8f-583a-b3fb-5ed5bbe2a1ce -->
  <rule id="463067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5973 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>