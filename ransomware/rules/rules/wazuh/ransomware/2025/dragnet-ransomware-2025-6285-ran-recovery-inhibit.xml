<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6285 — Recovery Inhibition (tridentlocker) | Status: experimental | Sigma ID: 625615e1-39b4-5018-8567-10207d42c5b5 -->
  <rule id="209854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6285 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>