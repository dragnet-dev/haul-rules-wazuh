<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7662 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 4684e25a-893b-51fb-94ff-e0e0a7cd4b09 -->
  <rule id="395825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7662 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>