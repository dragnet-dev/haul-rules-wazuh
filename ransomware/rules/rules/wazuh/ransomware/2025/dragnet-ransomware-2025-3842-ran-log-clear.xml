<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3842 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 9c1ffdcc-c0d8-5a7b-b87a-e29c6a29318b -->
  <rule id="197949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3842 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>