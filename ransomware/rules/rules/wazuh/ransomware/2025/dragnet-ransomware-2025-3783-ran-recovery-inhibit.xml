<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3783 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 2ea0ef1c-4aa7-5f5b-be9e-5fc73a144457 -->
  <rule id="209999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3783 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>