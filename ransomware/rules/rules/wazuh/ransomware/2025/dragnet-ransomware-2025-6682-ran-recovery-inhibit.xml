<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6682 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 021c42de-c091-5b51-80c9-f5a8f5b5a62e -->
  <rule id="919774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6682 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>