<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0972 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a6dbd8c8-3332-501b-ba46-ec0cc50c068e -->
  <rule id="876938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0972 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>