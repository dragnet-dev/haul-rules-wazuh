<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1721 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8c25ef97-8f92-5095-b919-c031dc53ba33 -->
  <rule id="990639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1721 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>