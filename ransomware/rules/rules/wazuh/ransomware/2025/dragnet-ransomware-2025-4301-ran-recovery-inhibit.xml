<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4301 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 49c3e0ae-13d3-5b23-a83d-f84839bcb962 -->
  <rule id="474220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4301 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>