<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0139 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e134e30a-d3a4-53e2-957d-5a4339dffab7 -->
  <rule id="561583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0139 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>