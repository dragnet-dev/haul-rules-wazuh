<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5045 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 1b8255bc-8d99-5609-b6c8-a86a68de95b5 -->
  <rule id="952091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5045 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>