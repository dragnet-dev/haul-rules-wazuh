<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0642 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 96b42178-e2a4-594e-a4a6-afb00c531f07 -->
  <rule id="747421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0642 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>