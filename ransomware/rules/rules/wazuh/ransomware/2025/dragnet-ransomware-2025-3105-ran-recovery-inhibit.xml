<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3105 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: cfd2e1fb-3aa3-5682-95c9-6ddef27b140a -->
  <rule id="920461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3105 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>