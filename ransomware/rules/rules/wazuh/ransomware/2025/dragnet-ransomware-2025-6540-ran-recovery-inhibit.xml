<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6540 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: f9cbbbde-8ac2-51f9-8d05-edd6b2da139b -->
  <rule id="672379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6540 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>