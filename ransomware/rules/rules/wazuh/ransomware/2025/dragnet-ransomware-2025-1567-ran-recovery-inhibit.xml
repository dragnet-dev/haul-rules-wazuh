<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1567 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bc300bc0-819e-5ed8-9013-85955d5028fc -->
  <rule id="412811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1567 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>