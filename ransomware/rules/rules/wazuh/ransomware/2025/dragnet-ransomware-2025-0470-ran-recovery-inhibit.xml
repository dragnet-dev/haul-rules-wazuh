<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0470 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 6affc09d-1f6f-5133-8ea4-124ad3ec5fdb -->
  <rule id="882680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0470 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>