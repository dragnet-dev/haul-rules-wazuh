<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0729 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: b128b617-7bb4-59c1-bcdf-b2264461702b -->
  <rule id="980596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0729 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>