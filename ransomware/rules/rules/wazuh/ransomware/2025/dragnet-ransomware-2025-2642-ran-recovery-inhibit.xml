<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2642 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: bac31bc3-ab32-5c1c-8ade-a6e52af812d0 -->
  <rule id="381307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2642 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>