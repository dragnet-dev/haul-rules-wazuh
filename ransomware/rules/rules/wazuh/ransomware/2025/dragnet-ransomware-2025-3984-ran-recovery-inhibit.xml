<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3984 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: d8ee21f7-535f-590a-926a-e1f5ea68a292 -->
  <rule id="956621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3984 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>