<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5906 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 42b23598-4a7d-5ffe-aee4-bd1dbebf6fa9 -->
  <rule id="632359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5906 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>