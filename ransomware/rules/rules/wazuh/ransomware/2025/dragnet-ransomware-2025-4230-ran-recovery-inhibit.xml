<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4230 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 24bba930-fdbb-503e-b2e4-c60395689285 -->
  <rule id="213069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4230 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>