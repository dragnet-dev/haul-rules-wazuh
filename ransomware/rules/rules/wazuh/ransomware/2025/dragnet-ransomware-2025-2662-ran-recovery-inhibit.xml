<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2662 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f161128c-ff87-5670-85e9-93de8c5b3e30 -->
  <rule id="716112" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2662 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>