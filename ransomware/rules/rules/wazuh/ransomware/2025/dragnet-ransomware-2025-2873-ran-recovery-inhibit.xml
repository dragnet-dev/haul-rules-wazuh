<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2873 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6f2aabca-02d9-5a2a-899f-f8cad40576df -->
  <rule id="157483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2873 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>