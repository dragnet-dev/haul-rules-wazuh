<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0539 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 63f08f8d-b888-55c3-8b00-bfb73911eb3b -->
  <rule id="836943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0539 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>