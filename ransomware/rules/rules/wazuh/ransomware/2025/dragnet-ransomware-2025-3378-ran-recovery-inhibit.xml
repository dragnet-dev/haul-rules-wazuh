<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3378 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 58c8054d-ac2f-5cdc-affe-39fa5b41da65 -->
  <rule id="508054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3378 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>