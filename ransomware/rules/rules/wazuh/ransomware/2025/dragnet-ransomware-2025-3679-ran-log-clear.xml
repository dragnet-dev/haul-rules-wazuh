<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3679 — Event Log Clearing (ralord) | Status: experimental | Sigma ID: 8eac4677-1041-5fb7-8112-e4e75c9cf3d6 -->
  <rule id="152446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3679 — Event Log Clearing (ralord)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>