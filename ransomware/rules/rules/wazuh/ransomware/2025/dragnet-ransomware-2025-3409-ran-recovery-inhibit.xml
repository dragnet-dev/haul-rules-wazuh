<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3409 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 1812cc33-feb4-5a93-9b7e-22ff36c11720 -->
  <rule id="240763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3409 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>