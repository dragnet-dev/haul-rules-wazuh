<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5282 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: cd68476e-3726-57a5-9aba-17928ba1459e -->
  <rule id="356847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5282 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
