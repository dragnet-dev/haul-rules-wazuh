<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5153 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: a746917a-36fe-54e5-9607-f6ed6ec79e08 -->
  <rule id="274691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5153 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>