<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5218 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 16ebe6ef-bac9-54df-8c86-e1d3716379c4 -->
  <rule id="389710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5218 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>