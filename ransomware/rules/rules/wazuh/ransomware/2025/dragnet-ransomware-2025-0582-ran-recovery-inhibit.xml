<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0582 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 210d6ed8-ba11-52b6-bf37-955222a8f8dd -->
  <rule id="636653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0582 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>