<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0112 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 211c40c9-b589-56b8-9ded-e3a02c1b7de4 -->
  <rule id="121452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0112 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>