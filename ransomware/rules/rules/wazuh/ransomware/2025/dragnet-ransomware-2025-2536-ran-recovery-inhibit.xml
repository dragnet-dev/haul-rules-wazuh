<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2536 — Recovery Inhibition (lynx) | Status: test | Sigma ID: fba0eaa8-79dd-5645-bcd8-460235630031 -->
  <rule id="506794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2536 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>