<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6001 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5d696d7b-435a-5ff7-9ca4-37321565161b -->
  <rule id="699149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6001 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>