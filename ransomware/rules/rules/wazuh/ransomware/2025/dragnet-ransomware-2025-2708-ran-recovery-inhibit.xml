<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2708 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9c2cd154-be8c-5e10-84aa-3b66ba39d569 -->
  <rule id="500771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2708 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>