<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7605 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 48b26ae1-cc06-5a60-a2be-eeabaf7758e1 -->
  <rule id="446826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7605 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>