<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2280 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 0e85abb1-1327-5b5c-b32a-47a9e78aa297 -->
  <rule id="785307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2280 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>