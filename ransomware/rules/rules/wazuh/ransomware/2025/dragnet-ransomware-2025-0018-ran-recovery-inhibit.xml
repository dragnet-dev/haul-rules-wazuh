<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0018 — Recovery Inhibition (radar) | Status: experimental | Sigma ID: 3232a136-5f90-5f5a-91dc-2a7688bee719 -->
  <rule id="772213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0018 — Recovery Inhibition (radar)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>