<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1350 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5ce6a009-a568-5bb3-860d-754c9d995e00 -->
  <rule id="678660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1350 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>