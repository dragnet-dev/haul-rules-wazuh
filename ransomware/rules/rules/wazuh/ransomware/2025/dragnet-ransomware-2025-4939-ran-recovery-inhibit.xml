<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4939 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9caee03a-90ff-55f4-95e4-b31b65b38a6d -->
  <rule id="217740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4939 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>