<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0850 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 69b13e2f-4b98-5f7b-b3e3-65c9ec34728c -->
  <rule id="984222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0850 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>