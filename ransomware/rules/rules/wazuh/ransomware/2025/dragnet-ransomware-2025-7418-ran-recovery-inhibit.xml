<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7418 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 7260324c-2645-58bb-a6f0-2e9da8ac7934 -->
  <rule id="160324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7418 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>