<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6462 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 2b56e88c-bd82-5009-b434-9aa8b7c2f4c2 -->
  <rule id="771088" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6462 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>