<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4346 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 9385cb27-a510-59d5-b6c2-c6f705e5dc2c -->
  <rule id="702763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4346 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>