<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1136 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 4fc3aef8-ace8-587b-b247-c84472dfd3cf -->
  <rule id="667502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1136 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>