<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3238 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: ed837b67-c938-5d37-8d1a-e2d923c2280f -->
  <rule id="305403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3238 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>