<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4246 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 8932a724-2e30-5bd0-83c0-2b0511162c4e -->
  <rule id="629227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4246 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>