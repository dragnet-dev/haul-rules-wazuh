<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6777 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: bdcc1816-2515-5eee-8d15-f3139188af94 -->
  <rule id="458818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6777 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>