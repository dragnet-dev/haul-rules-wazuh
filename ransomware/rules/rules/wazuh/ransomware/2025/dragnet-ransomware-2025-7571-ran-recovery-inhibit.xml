<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7571 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: dd36b53c-eb82-555d-aa6d-26bca1990c94 -->
  <rule id="941875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7571 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>