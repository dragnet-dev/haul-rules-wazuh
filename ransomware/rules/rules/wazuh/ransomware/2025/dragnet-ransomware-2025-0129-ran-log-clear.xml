<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0129 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 988a16d4-8e9a-5a3d-959a-9ee9e602089d -->
  <rule id="781816" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0129 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>