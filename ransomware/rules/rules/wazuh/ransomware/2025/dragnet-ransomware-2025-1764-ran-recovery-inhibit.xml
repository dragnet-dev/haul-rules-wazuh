<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1764 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: b6505f49-3278-5003-a1bc-b7cd70d8326b -->
  <rule id="164095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1764 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>