<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6973 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: cabc1c39-2aee-511b-b9d6-49079b92e9b9 -->
  <rule id="304028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6973 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>