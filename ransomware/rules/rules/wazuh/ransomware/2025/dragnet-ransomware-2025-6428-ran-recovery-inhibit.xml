<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6428 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f24698c7-3133-5ee8-83f8-599ad9f9c8ed -->
  <rule id="724698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6428 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>