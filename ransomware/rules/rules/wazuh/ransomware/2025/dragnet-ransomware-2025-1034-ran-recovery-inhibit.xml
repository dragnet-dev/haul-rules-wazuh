<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1034 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: d10e9c1f-1489-50aa-9419-aa905adfae38 -->
  <rule id="755996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1034 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>