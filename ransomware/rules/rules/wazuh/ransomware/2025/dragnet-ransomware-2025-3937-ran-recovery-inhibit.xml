<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3937 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 6d176860-bf1b-5012-a8ed-c2656146c050 -->
  <rule id="291768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3937 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>