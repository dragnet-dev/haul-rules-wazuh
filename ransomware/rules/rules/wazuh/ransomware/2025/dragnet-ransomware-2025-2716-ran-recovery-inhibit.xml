<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2716 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 3784e475-b198-5b45-a118-10a0e037f6d4 -->
  <rule id="755847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2716 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>