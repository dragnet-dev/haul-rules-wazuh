<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0616 — Event Log Clearing (beast) | Status: experimental | Sigma ID: aeb68862-9048-5eab-b12e-1c1f7d48c047 -->
  <rule id="195688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0616 — Event Log Clearing (beast)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>