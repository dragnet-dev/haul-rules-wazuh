<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6852 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3a56b539-18b5-59f9-892d-cc79ea9250a4 -->
  <rule id="470753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6852 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>