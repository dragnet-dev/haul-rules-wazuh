<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3817 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1ff70068-59ca-5bab-b857-03aee197e637 -->
  <rule id="717006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3817 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>