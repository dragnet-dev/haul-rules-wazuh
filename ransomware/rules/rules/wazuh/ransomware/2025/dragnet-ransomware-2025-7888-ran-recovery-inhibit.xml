<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7888 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f96f91c9-6bc2-5497-abb1-cf42cd5bda2d -->
  <rule id="855191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7888 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>