<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7671 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 25771325-0a8d-5ce8-8ddc-e3f6d9942f61 -->
  <rule id="877132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7671 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>