<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0058 — Recovery Inhibition (qilin) | Status: test | Sigma ID: e04f162b-3f8c-56c6-bcf3-763758a88bee -->
  <rule id="547916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0058 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>