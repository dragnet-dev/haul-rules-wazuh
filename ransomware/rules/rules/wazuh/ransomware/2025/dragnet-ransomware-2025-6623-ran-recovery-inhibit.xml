<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6623 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 52e6047d-5e2f-5b85-ae49-4f8a15cbe60b -->
  <rule id="466047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6623 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>