<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4495 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 817351f1-b461-5055-afc4-b7fb3b9aa85c -->
  <rule id="577631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4495 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>