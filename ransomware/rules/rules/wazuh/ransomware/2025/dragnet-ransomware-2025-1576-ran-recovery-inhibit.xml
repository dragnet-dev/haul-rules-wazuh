<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1576 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 71a09e15-c594-524b-a8db-612c19bb9f37 -->
  <rule id="133758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1576 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>