<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2659 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9f459b96-4616-5b4b-9f2c-689422c8a84e -->
  <rule id="851355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2659 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>