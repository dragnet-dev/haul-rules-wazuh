<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3185 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8401816e-70a8-58f1-8ff1-51ffe285a50e -->
  <rule id="401816" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3185 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>