<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6307 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 1050ecfe-be93-5189-a645-6ec9cc2e6bbe -->
  <rule id="804591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6307 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>