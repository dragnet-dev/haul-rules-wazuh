<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5129 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: eeb05228-be9d-535d-a8b6-2586fccca432 -->
  <rule id="319052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5129 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>