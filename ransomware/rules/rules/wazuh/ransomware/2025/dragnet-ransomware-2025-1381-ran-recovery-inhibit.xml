<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1381 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 877a6159-ecde-5ff4-a692-b58a1d8667e3 -->
  <rule id="604261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1381 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>