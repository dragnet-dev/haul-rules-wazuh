<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6352 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 229150a0-29d4-5293-9849-b2e91dda4b89 -->
  <rule id="166410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6352 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>