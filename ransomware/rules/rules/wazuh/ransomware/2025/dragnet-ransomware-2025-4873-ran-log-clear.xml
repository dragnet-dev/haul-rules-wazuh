<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4873 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: e03f56c7-d34b-5eef-9fe1-6df7b5a3d4c4 -->
  <rule id="546356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4873 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>