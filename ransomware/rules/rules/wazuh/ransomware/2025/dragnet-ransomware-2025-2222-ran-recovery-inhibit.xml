<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2222 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: afc8be70-9295-5b93-a793-631643bf0bce -->
  <rule id="100958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2222 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>