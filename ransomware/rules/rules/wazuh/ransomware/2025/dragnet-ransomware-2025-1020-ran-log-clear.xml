<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1020 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: b664c238-08b1-5388-90e7-36a79a544655 -->
  <rule id="166362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1020 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>