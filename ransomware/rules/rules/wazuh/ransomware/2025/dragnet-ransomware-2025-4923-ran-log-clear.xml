<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4923 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 891c1f81-9bbd-5313-8c95-c9168ba2cd4a -->
  <rule id="582911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4923 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>