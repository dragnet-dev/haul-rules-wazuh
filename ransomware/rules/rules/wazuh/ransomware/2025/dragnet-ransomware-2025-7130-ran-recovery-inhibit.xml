<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7130 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: aea2047f-86ff-5ce5-8fea-3a1737a7a3f8 -->
  <rule id="194204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7130 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>