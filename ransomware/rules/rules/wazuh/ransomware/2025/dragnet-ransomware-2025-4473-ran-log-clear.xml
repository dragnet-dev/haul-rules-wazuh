<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4473 — Event Log Clearing (monti) | Status: experimental | Sigma ID: 3412f6cb-6e54-5ee0-b8c8-5f8d9a316083 -->
  <rule id="737228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4473 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>