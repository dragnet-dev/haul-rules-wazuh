<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6812 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 2aede9bc-d789-5bee-9e02-37d36de683dd -->
  <rule id="958389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6812 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>