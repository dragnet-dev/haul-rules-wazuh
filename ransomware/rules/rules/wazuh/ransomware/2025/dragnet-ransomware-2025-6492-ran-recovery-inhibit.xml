<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6492 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: e13af01a-6aca-57d3-bf7c-b98e846c44db -->
  <rule id="119030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6492 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>