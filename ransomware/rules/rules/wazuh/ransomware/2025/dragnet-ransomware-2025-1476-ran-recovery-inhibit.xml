<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1476 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 36607630-33a9-5e32-a958-99c710735df0 -->
  <rule id="160763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1476 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>