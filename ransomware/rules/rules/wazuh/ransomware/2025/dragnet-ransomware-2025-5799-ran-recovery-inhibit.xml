<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5799 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6457b7da-9466-51c1-8d01-7f0a15c7538b -->
  <rule id="233237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5799 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>