<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0152 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b936b144-07ca-5d8b-8b6b-c75e34dded5c -->
  <rule id="209871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0152 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>