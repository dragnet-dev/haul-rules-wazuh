<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7250 — Event Log Clearing (coinbasecartel) | Status: test | Sigma ID: f0dc579b-34cd-5f7e-8dcc-0491932be399 -->
  <rule id="362057" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7250 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>