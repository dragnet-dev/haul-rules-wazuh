<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1889 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 59790793-646c-5a9e-b3df-76bbdaedc2f6 -->
  <rule id="679079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1889 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>