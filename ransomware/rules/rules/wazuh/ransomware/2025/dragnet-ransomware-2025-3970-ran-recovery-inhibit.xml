<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3970 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: e3499231-de7f-5b05-b0e7-f68917fc6b8a -->
  <rule id="634992" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3970 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>