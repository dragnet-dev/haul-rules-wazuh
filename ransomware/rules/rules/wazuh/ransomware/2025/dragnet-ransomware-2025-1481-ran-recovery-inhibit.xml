<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1481 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 588eb377-f3df-57c0-b5a6-15e2e54248e3 -->
  <rule id="707633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1481 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>