<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0130 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c8e64517-a114-5366-a3ed-9778c3423a73 -->
  <rule id="362645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0130 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>