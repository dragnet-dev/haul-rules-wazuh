<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0497 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c9e28915-808c-5712-9f31-3c9022ce8b47 -->
  <rule id="378289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0497 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>