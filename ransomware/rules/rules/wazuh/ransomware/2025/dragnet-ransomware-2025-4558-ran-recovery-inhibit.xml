<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4558 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ec97bf86-268b-5352-90b2-62d0e733dc0e -->
  <rule id="766623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4558 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>