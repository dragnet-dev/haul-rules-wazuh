<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2362 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: f463754e-7206-5dbd-84b6-49eb21efe300 -->
  <rule id="746375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2362 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>