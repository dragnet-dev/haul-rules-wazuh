<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3197 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 13239625-0450-5dac-a7cd-4c61dd7d445f -->
  <rule id="523962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3197 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>