<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7093 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 98f14c74-5a89-5743-a796-a35de1e4b259 -->
  <rule id="833036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7093 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>