<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7072 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: 4b25e7c3-4ad7-5e45-9f98-03b41c58bc94 -->
  <rule id="404147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7072 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>