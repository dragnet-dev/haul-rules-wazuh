<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5649 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 106602ed-cf55-517a-8dd6-a35a33ab37b7 -->
  <rule id="905646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5649 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>