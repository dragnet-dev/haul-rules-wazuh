<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4799 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: f033b345-a5dd-5bad-97d8-f641885448a3 -->
  <rule id="705393" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4799 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>