<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6887 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6a2529ef-020c-5cea-94dd-1d019c106b75 -->
  <rule id="262529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6887 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>