<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0810 — Event Log Clearing (kawa4096) | Status: deprecated | Sigma ID: fbfbd25c-8db0-5a9c-92bd-425bfec1b584 -->
  <rule id="232125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0810 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>