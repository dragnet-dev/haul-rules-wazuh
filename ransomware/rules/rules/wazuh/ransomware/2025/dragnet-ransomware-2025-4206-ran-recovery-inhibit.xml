<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4206 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: b0b41e5b-87ef-579b-bf39-77bf9036df71 -->
  <rule id="234270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4206 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>