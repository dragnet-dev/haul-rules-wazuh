<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3415 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e6a06577-9f72-56ed-b710-4afb5c37cd39 -->
  <rule id="646065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3415 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>