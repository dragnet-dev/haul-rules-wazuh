<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7729 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5c71a146-3700-50e5-9ff3-7dd7b60edd9f -->
  <rule id="683461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7729 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>