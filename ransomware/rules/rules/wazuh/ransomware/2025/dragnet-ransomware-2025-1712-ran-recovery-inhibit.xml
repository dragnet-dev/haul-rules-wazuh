<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1712 — Recovery Inhibition (VanHelsing) | Status: experimental | Sigma ID: 6d3b710f-5fec-54b3-9ea4-01967868b63f -->
  <rule id="949971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1712 — Recovery Inhibition (VanHelsing)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>