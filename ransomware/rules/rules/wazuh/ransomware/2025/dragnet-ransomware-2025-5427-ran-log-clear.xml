<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5427 — Event Log Clearing (brotherhood) | Status: deprecated | Sigma ID: c2c74b43-5005-5fc9-831a-364ab29cd9ac -->
  <rule id="543595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5427 — Event Log Clearing (brotherhood)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>