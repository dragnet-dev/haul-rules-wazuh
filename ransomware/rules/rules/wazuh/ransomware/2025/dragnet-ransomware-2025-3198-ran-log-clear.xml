<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3198 — Event Log Clearing (arkana) | Status: experimental | Sigma ID: c05d00e5-3e3e-5612-bde1-dba273bea8dc -->
  <rule id="229300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3198 — Event Log Clearing (arkana)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>