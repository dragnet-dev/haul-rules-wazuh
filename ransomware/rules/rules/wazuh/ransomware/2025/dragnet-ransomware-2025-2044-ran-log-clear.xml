<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2044 — Event Log Clearing (global) | Status: deprecated | Sigma ID: 1bb85b4b-7bf7-5fed-9a1e-3af4735ba026 -->
  <rule id="901714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2044 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>