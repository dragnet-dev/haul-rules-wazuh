<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5668 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8c48349a-4b05-513a-bba4-e8927a71ad67 -->
  <rule id="604834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5668 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>