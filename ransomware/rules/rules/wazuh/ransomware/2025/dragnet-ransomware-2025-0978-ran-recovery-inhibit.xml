<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0978 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 347134a4-6fb0-5357-9394-e09e9e404b3e -->
  <rule id="254154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0978 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>