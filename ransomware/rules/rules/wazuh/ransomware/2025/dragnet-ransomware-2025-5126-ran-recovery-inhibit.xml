<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5126 — Recovery Inhibition (spacebears) | Status: test | Sigma ID: 60662e00-1914-5fe7-aa5f-5862c4a226c1 -->
  <rule id="806060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5126 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>