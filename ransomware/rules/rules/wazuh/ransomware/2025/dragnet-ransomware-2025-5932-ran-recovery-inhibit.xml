<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5932 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 55b6fa61-26d4-55a8-b251-40db87428896 -->
  <rule id="582746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5932 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
