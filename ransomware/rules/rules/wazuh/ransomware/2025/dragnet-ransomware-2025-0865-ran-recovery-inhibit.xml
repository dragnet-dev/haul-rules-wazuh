<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0865 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 94d27795-868f-516a-b9b4-653a09f7650c -->
  <rule id="717277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0865 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>