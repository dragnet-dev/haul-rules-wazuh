<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3768 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 18ae9221-62f4-56fb-8972-2ef23b1efd16 -->
  <rule id="382922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3768 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>