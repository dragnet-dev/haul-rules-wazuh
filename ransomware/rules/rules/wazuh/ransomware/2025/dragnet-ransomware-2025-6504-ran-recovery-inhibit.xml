<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6504 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 3cfe28e0-efed-5210-a18b-22f2aea3c4c8 -->
  <rule id="761428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6504 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>