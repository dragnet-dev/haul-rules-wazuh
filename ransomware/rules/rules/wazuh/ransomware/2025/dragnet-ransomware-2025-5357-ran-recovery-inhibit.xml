<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5357 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 93e5b8aa-97b8-5b73-8ae0-ae02ad0e4978 -->
  <rule id="704118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5357 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>