<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5665 — Recovery Inhibition (qilin) | Status: test | Sigma ID: be3e07af-0d28-5c76-a4b0-15d5ea22226b -->
  <rule id="446207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5665 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>