<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2637 — Recovery Inhibition (J) | Status: experimental | Sigma ID: bd5e2647-37a0-564f-9c1e-558b631dc1e3 -->
  <rule id="433426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2637 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>