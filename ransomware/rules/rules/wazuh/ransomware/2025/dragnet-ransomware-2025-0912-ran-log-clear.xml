<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0912 — Event Log Clearing (kryptos) | Status: deprecated | Sigma ID: bf0d9f4d-e772-5d2b-88f6-0b11362c1b7b -->
  <rule id="491839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0912 — Event Log Clearing (kryptos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>