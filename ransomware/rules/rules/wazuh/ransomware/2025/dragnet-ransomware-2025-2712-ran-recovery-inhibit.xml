<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2712 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 4cab10d5-5ee8-5947-b1ee-38f322d2c57a -->
  <rule id="262710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2712 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>