<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5114 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7f41f626-8973-5a8f-8c05-e3a56e70d46e -->
  <rule id="338716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5114 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>