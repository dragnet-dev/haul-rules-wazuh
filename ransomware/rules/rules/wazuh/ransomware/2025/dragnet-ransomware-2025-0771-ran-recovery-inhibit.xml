<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0771 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 95826748-8f33-5ab2-a3e5-33b08ee9d088 -->
  <rule id="682674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0771 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>