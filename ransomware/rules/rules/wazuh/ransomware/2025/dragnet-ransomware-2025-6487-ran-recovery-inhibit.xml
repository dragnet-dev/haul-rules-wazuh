<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6487 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 303f1eb7-55c7-5ec0-ba21-088cffa54392 -->
  <rule id="849771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6487 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>