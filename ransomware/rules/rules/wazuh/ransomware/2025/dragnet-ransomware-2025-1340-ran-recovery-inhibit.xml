<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1340 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: f2c4ec50-0add-5893-abe3-89630408aec8 -->
  <rule id="957900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1340 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>