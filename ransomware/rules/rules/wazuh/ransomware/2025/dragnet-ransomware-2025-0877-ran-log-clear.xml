<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0877 — Event Log Clearing (sinobi) | Status: experimental | Sigma ID: d3cfb6fe-00be-58d5-a4ba-1b4cc8599708 -->
  <rule id="180916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0877 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>