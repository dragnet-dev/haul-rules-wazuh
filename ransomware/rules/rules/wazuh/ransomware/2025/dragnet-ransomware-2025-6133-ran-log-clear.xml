<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6133 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: febde18b-6992-5c8d-b7b6-9c6d32e62fa6 -->
  <rule id="243422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6133 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>