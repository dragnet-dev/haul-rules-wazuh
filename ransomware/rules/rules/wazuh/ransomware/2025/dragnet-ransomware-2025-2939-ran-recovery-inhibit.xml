<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2939 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 236bb329-43cf-5df4-84ac-a0ed4b0fb5b9 -->
  <rule id="760332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2939 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>