<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4686 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 4d829617-3d74-552d-9993-6da6360cb247 -->
  <rule id="682961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4686 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>