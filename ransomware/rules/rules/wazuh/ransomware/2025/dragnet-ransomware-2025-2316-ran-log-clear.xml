<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2316 — Event Log Clearing (blackshrantac) | Status: experimental | Sigma ID: 4149b46a-d101-5e8f-83ce-a574c73cf8f6 -->
  <rule id="439546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2316 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>