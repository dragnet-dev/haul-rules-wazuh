<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5735 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5bae3f47-6113-555b-b4c5-d78edea768af -->
  <rule id="255263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5735 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>