<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0235 — Recovery Inhibition (warlock) | Status: deprecated | Sigma ID: 140aafda-fa00-5311-957a-63f253afd3a5 -->
  <rule id="318813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0235 — Recovery Inhibition (warlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>