<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2513 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: e68cea03-6c3a-502e-8f2b-1db2508f315d -->
  <rule id="716234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2513 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>