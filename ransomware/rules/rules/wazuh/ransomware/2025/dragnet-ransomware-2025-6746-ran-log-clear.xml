<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6746 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 5ca8ce5c-e007-5295-b309-7c80b763d8a0 -->
  <rule id="296174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6746 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>