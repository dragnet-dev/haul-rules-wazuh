<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1181 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: cd9dff5c-a4e3-5129-bab3-31aedbb13d95 -->
  <rule id="437247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1181 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>