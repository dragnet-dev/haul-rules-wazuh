<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0336 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 410a4753-4900-57c0-9c69-4247204d73a6 -->
  <rule id="370475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0336 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>