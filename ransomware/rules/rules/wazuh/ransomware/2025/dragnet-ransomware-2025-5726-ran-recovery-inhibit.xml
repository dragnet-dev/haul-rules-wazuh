<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5726 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 9f3e537e-ec18-533b-97c3-2cf1018622ec -->
  <rule id="850253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5726 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>