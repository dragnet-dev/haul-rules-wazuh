<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1304 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: c2b361d8-ad96-5710-98a0-f80404b67b77 -->
  <rule id="263361" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1304 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>