<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5323 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 416ca82f-2095-55a8-8ab8-3d8d28d715c8 -->
  <rule id="266988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5323 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>