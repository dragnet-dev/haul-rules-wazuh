<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2817 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 042b9890-735d-5d37-8014-eb3b9e4fe0e0 -->
  <rule id="639890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2817 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>