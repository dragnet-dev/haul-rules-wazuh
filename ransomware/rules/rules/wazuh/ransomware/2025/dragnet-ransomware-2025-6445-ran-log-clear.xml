<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6445 — Event Log Clearing (interlock) | Status: experimental | Sigma ID: 7d9c63f8-ee4e-57e4-91f5-38c38c6c6d68 -->
  <rule id="315663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6445 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>