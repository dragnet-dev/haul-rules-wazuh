<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2964 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: bda5f673-eaa4-54b0-9f59-5856c886b790 -->
  <rule id="455356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2964 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>