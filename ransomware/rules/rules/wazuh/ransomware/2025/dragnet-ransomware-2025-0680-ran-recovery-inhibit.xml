<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0680 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4f4d722c-9e20-53e5-8d47-881c3661af1e -->
  <rule id="471772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0680 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>