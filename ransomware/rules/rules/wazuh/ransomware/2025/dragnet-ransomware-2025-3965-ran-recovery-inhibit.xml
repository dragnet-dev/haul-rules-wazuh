<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3965 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e9adaa1a-9ea0-55d2-b350-3a325da4972a -->
  <rule id="909322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3965 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>