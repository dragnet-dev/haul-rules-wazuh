<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4089 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 3fd697c9-77eb-5ae6-9d2c-f2daa30e2b7f -->
  <rule id="221697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4089 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>