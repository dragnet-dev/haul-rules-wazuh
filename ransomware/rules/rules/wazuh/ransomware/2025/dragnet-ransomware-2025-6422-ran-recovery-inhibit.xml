<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6422 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 274d1d28-722b-55ce-bbc2-71ca982b9295 -->
  <rule id="835492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6422 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>