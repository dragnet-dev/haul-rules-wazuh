<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3573 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: fb061496-b319-5abc-965d-4a1f6347e181 -->
  <rule id="810614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3573 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>