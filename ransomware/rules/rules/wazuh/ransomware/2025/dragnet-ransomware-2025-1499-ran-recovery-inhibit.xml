<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1499 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0c3d4cbb-ff09-541b-8853-4528e78b1171 -->
  <rule id="672587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1499 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>