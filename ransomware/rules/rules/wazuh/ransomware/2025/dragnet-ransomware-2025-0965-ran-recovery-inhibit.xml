<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0965 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0d77ab59-faed-5242-afd9-39bbe0c32b79 -->
  <rule id="926835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0965 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>