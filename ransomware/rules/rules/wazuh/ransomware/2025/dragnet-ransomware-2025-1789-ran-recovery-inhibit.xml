<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1789 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a339bbb6-7677-5f9c-a818-dcb778f7d16b -->
  <rule id="946971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1789 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>