<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7035 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 1cf138ed-1909-5e80-b114-8111da74ca13 -->
  <rule id="310222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7035 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>