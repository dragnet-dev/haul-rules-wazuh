<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3524 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6bf9cff0-9b1a-5e81-904b-fe6608a0fb7d -->
  <rule id="923631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3524 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>