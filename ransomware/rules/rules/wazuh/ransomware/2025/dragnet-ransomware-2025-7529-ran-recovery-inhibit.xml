<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7529 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 9ab53460-d2f6-5295-b847-417736035434 -->
  <rule id="775534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7529 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>