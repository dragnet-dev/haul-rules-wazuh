<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5423 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1c22002f-da1d-526d-ac8d-bf74bb245656 -->
  <rule id="222002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5423 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>