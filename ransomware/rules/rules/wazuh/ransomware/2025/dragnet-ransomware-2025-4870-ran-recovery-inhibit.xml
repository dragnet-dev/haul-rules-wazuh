<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4870 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 2c7d2e63-64b1-5337-8b95-9de901f191ee -->
  <rule id="346446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4870 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>