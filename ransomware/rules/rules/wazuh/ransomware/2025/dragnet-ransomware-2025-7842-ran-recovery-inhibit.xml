<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7842 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: 0bfd2c27-57ee-55e9-a5e9-d59f24d2cabf -->
  <rule id="510842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7842 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>