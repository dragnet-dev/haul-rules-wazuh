<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6802 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 80b8c20e-71ae-5d17-94bc-7c883950505e -->
  <rule id="367002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6802 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>