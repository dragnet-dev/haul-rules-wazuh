<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1862 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ebc8606b-1007-595d-80bd-1abe8308b876 -->
  <rule id="272860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1862 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>