<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0664 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 9959b16f-40ff-55dd-adbe-75801e130180 -->
  <rule id="793551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0664 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>