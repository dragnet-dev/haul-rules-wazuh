<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4617 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: bfaead65-fc1a-5b9c-88da-d834e131382c -->
  <rule id="962093" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4617 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>