<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0143 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: cf2024f1-eb17-530e-8ee2-2bc990858c6e -->
  <rule id="372024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0143 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>