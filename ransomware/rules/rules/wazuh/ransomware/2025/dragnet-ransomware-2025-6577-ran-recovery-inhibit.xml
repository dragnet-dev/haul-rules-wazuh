<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6577 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 3cfa3b8c-2eb9-51a1-beb2-b9b158c3a508 -->
  <rule id="797659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6577 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>