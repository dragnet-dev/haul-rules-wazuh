<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1377 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 44855797-af7e-56b2-bf79-3e34eed12f3b -->
  <rule id="985579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1377 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>