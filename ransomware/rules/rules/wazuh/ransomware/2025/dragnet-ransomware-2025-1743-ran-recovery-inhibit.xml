<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1743 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d38e04a7-05a9-5786-996c-4ef1c74a4f24 -->
  <rule id="442204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1743 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>