<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7287 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5a005271-9eb7-5a20-a6c1-c2f2b60d9370 -->
  <rule id="100527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7287 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>