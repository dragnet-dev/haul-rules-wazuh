<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1874 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: b0fe18cc-dc34-5c8a-ad56-c99e050b9153 -->
  <rule id="241418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1874 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>