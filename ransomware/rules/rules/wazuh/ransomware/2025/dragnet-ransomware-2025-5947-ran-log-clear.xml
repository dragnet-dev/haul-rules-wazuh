<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5947 — Event Log Clearing (bert) | Status: experimental | Sigma ID: 2cffa4c2-21b2-5a5a-9e54-946b1f15be89 -->
  <rule id="143144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5947 — Event Log Clearing (bert)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>