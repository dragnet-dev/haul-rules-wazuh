<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6471 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: add3bddd-c822-5a11-8017-4eac02682f58 -->
  <rule id="920317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6471 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>