<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5060 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 10818827-304c-5a62-a921-e9e0c0981c50 -->
  <rule id="281882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5060 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>