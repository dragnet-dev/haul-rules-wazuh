<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1555 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 455e0ea5-b27f-542e-b4f8-5cf0a1edeb1e -->
  <rule id="367054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1555 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>