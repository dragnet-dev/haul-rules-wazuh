<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5055 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 417134e0-f660-546c-8c06-3ce983c36ff1 -->
  <rule id="474158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5055 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>