<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1306 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: a32e8acc-e624-5552-a323-6546aea59412 -->
  <rule id="944298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1306 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>