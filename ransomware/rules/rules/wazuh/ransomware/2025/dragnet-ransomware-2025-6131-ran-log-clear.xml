<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6131 — Event Log Clearing (dunghill) | Status: experimental | Sigma ID: 2bb31156-736e-5f21-9953-f50e61927d28 -->
  <rule id="793115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6131 — Event Log Clearing (dunghill)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>