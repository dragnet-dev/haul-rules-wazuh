<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1475 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 53ca27a5-f1de-58a2-a803-9022916a92b9 -->
  <rule id="577027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1475 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>