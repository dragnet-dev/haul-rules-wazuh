<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4645 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 56c5ac87-623c-56e7-9a6f-0e0737fcb9b4 -->
  <rule id="625932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4645 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>