<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2820 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 39dbd7ee-29e0-59b2-8551-adc9a44ba2b4 -->
  <rule id="832617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2820 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>