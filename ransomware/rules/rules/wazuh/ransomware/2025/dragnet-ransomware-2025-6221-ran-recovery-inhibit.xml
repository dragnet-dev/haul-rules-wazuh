<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6221 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 10ffdb12-cfde-5713-962a-f4a588fd1997 -->
  <rule id="108591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6221 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>