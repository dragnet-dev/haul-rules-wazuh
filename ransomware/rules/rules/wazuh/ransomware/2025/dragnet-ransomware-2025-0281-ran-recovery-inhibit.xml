  <rule id="499549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0281 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
