<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3887 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bf880984-c6d8-55c9-80af-f082702f15d4 -->
  <rule id="218809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3887 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>