<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2950 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 92324263-a4d7-5ceb-bd83-b416335b3c4d -->
  <rule id="332426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2950 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>