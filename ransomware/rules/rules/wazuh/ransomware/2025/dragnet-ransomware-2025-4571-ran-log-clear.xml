<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4571 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: ed893907-e7b7-581d-85f9-0c9e7c16aa29 -->
  <rule id="678939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4571 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>