<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4280 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9aab33e7-74bd-547d-a134-a95704dc0f5c -->
  <rule id="459533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4280 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>