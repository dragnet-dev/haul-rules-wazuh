<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5397 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 663f7f4f-740d-50f4-933c-12ab8176aab1 -->
  <rule id="899807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5397 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>