<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5355 — Event Log Clearing (blackshrantac) | Status: experimental | Sigma ID: 213e227c-bd33-5d4c-9a05-4f4cb9a4faf6 -->
  <rule id="822227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5355 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>