<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5467 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: b77821a1-f33a-582b-a6c6-a4d2c3820051 -->
  <rule id="377821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5467 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>