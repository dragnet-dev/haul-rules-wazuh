<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2101 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6e0b4f10-fb19-51b9-afee-45ac3857a85a -->
  <rule id="217839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2101 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>