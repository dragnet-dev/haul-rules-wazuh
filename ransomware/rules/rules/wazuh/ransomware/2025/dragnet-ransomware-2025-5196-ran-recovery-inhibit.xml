<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5196 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 21101dcc-1de8-5b2c-aa3f-018e0c89ac47 -->
  <rule id="102076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5196 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>