<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4720 — Recovery Inhibition (RunSomeWares) | Status: experimental | Sigma ID: e152cc79-b41e-553a-890a-3857d98cfc1d -->
  <rule id="123116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4720 — Recovery Inhibition (RunSomeWares)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>