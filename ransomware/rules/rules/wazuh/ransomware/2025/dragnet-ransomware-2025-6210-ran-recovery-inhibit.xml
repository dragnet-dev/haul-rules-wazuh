<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6210 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1537ef0c-f696-5f77-85da-0967e07ab3c6 -->
  <rule id="437110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6210 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>