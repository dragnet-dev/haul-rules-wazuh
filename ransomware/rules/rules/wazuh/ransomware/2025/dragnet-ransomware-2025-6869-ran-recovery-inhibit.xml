<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6869 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 692c9962-94bf-506f-8dfb-af6aafd1c715 -->
  <rule id="308499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6869 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
