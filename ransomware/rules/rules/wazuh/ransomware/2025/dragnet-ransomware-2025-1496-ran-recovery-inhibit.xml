<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1496 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 24fc3ab6-0404-5cd1-adea-3456d0f37da9 -->
  <rule id="223418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1496 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>