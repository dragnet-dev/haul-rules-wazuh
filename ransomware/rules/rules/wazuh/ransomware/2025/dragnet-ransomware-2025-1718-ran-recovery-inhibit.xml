<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1718 — Recovery Inhibition (bert) | Status: experimental | Sigma ID: 6fee4fe8-a9e1-51c8-8eb0-b62bdbc4e951 -->
  <rule id="184719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1718 — Recovery Inhibition (bert)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>