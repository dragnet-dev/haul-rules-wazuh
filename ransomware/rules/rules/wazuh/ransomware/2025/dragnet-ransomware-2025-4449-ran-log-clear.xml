<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4449 — Event Log Clearing (kawa4096) | Status: experimental | Sigma ID: a7185542-1c0b-566a-9894-9fa8c5f6f977 -->
  <rule id="271855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4449 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>