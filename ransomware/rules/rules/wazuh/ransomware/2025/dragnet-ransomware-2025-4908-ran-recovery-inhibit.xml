<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4908 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 12cfc0b8-5930-5a21-bbee-18f4784151f2 -->
  <rule id="396171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4908 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>