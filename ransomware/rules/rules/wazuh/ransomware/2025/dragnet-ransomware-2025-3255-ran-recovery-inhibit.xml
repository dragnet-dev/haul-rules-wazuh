<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3255 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 41fdec2b-f339-5840-a1ac-dfb9bc3a0a76 -->
  <rule id="151980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3255 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>