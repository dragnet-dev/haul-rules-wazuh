<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4412 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7c2bf436-b73f-574e-a2af-296442a5d00b -->
  <rule id="581434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4412 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>