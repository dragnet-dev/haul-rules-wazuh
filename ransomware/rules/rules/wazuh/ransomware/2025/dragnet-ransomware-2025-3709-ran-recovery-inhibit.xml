<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3709 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8b7aa285-9668-56aa-9005-65d3e127d3fb -->
  <rule id="978022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3709 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>