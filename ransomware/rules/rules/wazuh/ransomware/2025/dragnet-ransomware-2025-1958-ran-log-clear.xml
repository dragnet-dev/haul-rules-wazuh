<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1958 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: b01ffde0-17bd-5bd3-82fd-8d20b43c02f1 -->
  <rule id="113789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1958 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>