<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4166 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6a6c24c8-30eb-59f0-807b-c89a8171664f -->
  <rule id="906824" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4166 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>