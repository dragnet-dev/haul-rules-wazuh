<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3663 — Event Log Clearing (global) | Status: experimental | Sigma ID: 7caf7404-3858-56ba-b11a-f3ecdfcd5183 -->
  <rule id="591974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3663 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>