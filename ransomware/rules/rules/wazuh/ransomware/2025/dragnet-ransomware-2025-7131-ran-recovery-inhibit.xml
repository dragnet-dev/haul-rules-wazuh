<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7131 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: fbef14e4-c8a2-599c-891c-140053996845 -->
  <rule id="249514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7131 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>