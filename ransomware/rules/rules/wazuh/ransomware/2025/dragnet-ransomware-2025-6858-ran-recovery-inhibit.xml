<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6858 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 70646426-f513-58ba-b599-64ee44334948 -->
  <rule id="864642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6858 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>