<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6482 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 8bb3535c-44d7-5692-b028-057b076e6699 -->
  <rule id="535353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6482 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>