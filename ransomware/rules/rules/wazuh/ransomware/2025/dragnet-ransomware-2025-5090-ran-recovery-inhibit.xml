<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5090 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: d2787428-2fc4-542c-aceb-ea827f5722da -->
  <rule id="527874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5090 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>