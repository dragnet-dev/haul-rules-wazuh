<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3836 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0136f4c2-2865-5b0b-a1fc-8ea2fcae6fc9 -->
  <rule id="906362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3836 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>