<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5457 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: dd637c12-72a5-556a-a986-b79b2c9c30b1 -->
  <rule id="946204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5457 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>