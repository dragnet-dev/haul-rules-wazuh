<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5915 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: c18ea596-022a-5f1c-96ee-24ae1e20415f -->
  <rule id="520425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5915 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>