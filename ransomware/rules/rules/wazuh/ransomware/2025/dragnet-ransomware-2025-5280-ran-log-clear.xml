<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5280 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: a027d4e1-dc2d-5b59-8ba9-6f9dbac1d04f -->
  <rule id="804454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5280 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>