<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7531 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c03914e7-8175-51bc-b6fa-4d1a698aa433 -->
  <rule id="403914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7531 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>