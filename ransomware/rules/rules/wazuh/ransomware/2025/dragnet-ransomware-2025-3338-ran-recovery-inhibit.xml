<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3338 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 2eee3d18-12bf-5b3a-8ba4-f7b47b350739 -->
  <rule id="222301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3338 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>