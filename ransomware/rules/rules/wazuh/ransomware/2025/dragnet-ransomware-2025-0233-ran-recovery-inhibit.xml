<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0233 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: c14f993c-62a9-500a-8e02-6f5e59b6a1df -->
  <rule id="243999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0233 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>