  <rule id="997501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2913 — Event Log Clearing (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
