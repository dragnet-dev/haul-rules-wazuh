<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3903 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: d57ba082-5197-5558-bdf3-9cec3cfe0dd4 -->
  <rule id="875780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3903 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>