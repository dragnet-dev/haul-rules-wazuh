<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0592 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6e47ad53-0e35-5459-9598-0899000c451b -->
  <rule id="228205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0592 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>