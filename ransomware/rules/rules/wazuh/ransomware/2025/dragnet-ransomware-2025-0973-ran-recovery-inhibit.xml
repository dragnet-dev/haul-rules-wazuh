<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0973 — Recovery Inhibition (play) | Status: experimental | Sigma ID: afe6ebf2-e2f9-52e3-a831-0d67cbe250f1 -->
  <rule id="105611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0973 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>