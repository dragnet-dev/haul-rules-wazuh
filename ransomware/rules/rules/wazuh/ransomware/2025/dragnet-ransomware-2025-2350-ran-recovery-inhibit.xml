<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2350 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7d956701-4ed8-5af3-b284-66a8b346e26b -->
  <rule id="459567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2350 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>