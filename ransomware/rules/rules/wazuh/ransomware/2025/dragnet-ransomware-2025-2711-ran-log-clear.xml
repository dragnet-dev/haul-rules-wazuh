<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2711 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 7e7bc41c-c5bb-5e48-8d3a-4975c7bd5349 -->
  <rule id="645404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2711 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>