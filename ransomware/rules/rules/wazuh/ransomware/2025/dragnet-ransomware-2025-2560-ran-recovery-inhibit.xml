<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2560 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: 85c0f8e8-3e55-55b2-9a3c-525eecd16fa2 -->
  <rule id="495358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2560 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>