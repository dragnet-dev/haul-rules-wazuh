<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3587 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 44d50d91-0cab-572b-b5a4-53093e836b21 -->
  <rule id="348013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3587 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>