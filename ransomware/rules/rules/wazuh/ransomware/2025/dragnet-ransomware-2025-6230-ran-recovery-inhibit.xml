<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6230 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 98f23bf7-9a4f-538b-8c13-be562e32e806 -->
  <rule id="833179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6230 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>