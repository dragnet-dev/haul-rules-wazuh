<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3924 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: 4330908d-0915-5af2-88a4-797d7aba0bd7 -->
  <rule id="830908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3924 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>