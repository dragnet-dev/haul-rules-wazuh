<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0434 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b45ffe9d-bd50-5e57-a4e6-e20f7c041ac6 -->
  <rule id="294014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0434 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>