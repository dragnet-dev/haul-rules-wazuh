<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2053 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: caef6af4-171c-5eab-98af-52bf31ef8b25 -->
  <rule id="312266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2053 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>