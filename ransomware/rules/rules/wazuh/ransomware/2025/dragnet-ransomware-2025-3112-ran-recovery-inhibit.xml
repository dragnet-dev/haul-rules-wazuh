<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3112 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: cadb78b0-8946-5b52-ad36-f0827eb5175d -->
  <rule id="793178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3112 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>