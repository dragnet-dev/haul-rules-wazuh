<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2676 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 5e182dea-6612-5d6c-b319-913ede71bb53 -->
  <rule id="706925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2676 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>