<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4389 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 119b5b05-0f1f-5c62-a79c-2e655c4e5d61 -->
  <rule id="464910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4389 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>