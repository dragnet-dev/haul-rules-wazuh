<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3457 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1d1db5e9-f459-54f2-85ee-a7996dcb4829 -->
  <rule id="354494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3457 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>