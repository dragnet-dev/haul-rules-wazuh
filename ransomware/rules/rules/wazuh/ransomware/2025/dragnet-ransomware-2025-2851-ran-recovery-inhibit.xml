<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2851 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0f917eb9-aa37-5257-8e49-7647708beefa -->
  <rule id="574987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2851 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>