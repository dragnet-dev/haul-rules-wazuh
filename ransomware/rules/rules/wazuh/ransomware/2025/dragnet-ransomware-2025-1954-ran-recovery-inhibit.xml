<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1954 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: dc1dbdf5-a362-5659-a7e3-f5172e4c31f1 -->
  <rule id="118813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1954 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>