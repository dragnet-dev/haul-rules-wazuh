<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4634 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 507338ef-9cd8-5653-bf39-d14da76fcff9 -->
  <rule id="117422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4634 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>