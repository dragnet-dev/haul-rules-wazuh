<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6831 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 62e0697a-17a0-5936-b8b8-385c9470c83c -->
  <rule id="206069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6831 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
