<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3632 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2a22fd11-0272-5535-b044-aa50486a3a3f -->
  <rule id="281085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3632 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>