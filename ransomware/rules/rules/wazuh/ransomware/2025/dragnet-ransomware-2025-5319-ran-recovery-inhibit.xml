<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5319 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a9bbe094-ecf4-5224-b708-c3e3883527c5 -->
  <rule id="994700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5319 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>