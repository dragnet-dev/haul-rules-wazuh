<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3353 — Event Log Clearing (everest) | Status: experimental | Sigma ID: b1426e65-e7b0-5ac3-83ca-8da6e0a3e5b7 -->
  <rule id="982830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3353 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>