<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5682 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fcef2c96-dc06-5b89-89df-a5760344d575 -->
  <rule id="560204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5682 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>