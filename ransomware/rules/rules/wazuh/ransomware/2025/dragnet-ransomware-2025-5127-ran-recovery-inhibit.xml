<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5127 — Recovery Inhibition (warlock) | Status: deprecated | Sigma ID: 501fda5f-60d9-5e06-b22a-379f682bd8ca -->
  <rule id="356154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5127 — Recovery Inhibition (warlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
