<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4266 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 77f8e9c7-cde0-56dd-ad3d-1b45e878c1a0 -->
  <rule id="296629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4266 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>