<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6896 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 81e2cacd-d6eb-5201-8b7c-f525a1d79beb -->
  <rule id="754314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6896 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>