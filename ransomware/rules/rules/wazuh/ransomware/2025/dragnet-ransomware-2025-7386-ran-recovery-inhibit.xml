<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7386 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 0955d6c5-f266-5f09-abdb-5eba56b6a98b -->
  <rule id="746988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7386 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>