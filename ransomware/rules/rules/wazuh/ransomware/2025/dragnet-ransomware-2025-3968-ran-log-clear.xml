<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3968 — Event Log Clearing (pear) | Status: experimental | Sigma ID: ec66aa0f-a08b-5ec7-b1dd-3a52039f1e63 -->
  <rule id="758666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3968 — Event Log Clearing (pear)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>