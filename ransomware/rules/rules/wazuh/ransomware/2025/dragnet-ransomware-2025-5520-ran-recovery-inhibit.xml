<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5520 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4cfc4195-67d4-5588-9889-0bcd77c9bcc7 -->
  <rule id="270841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5520 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>