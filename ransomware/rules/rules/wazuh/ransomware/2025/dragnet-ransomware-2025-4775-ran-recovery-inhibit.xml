<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4775 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: f9d1a8c5-66cc-5b72-bb7f-75d7dbe74f9a -->
  <rule id="591468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4775 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>