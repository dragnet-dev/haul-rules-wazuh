<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6250 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: a38b480a-1921-577c-8961-a0ce77c26270 -->
  <rule id="861948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6250 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>