<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1681 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 0842b7b8-cba3-526b-8fcb-4ab8a8f537a9 -->
  <rule id="457403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1681 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>