<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5044 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: a6cedbaa-26c5-50c8-8372-89a5857c6a99 -->
  <rule id="799771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5044 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>