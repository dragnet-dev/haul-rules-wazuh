<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1870 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: acba7349-5205-5088-a273-b602719d40b4 -->
  <rule id="921873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1870 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>