<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1105 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4562f443-8e0c-5e3e-8cc1-7a26b9e63211 -->
  <rule id="200744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1105 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>