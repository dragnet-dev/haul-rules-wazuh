<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5749 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4364eac6-720b-55bd-be70-ea9c4424a5fe -->
  <rule id="317418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5749 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>