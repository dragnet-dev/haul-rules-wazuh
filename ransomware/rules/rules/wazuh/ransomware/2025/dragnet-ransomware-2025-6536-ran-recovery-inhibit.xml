<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6536 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f1ea2383-fc17-5af5-8e3d-164ae5c0c240 -->
  <rule id="389023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6536 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>