<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4276 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 103380af-6144-5baf-a20b-025a4ce8e860 -->
  <rule id="854090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4276 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>