<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7279 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 77240efc-1390-5ba1-a6fb-6cf126e25c8e -->
  <rule id="435854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7279 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
