<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7762 — Recovery Inhibition (minteye) | Status: deprecated | Sigma ID: 4852173f-5bb1-5267-9566-7a7cab28a698 -->
  <rule id="452173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7762 — Recovery Inhibition (minteye)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>