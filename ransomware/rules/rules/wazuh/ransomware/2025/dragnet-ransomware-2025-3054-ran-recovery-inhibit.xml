<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3054 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8e62fab0-f1f5-564a-8f10-9fe1e945be39 -->
  <rule id="151322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3054 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>