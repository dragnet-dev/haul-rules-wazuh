<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2576 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 62bc3edc-af09-5e96-8d6f-3ca827927c42 -->
  <rule id="869662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2576 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>