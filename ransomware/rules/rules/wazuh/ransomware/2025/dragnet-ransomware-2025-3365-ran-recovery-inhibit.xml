<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3365 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: cbf77bcb-f815-59b6-80d9-b7e8839acf30 -->
  <rule id="822043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3365 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>