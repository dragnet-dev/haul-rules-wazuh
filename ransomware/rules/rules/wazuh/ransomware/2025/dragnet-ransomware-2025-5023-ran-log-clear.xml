<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5023 — Event Log Clearing (radar) | Status: deprecated | Sigma ID: c5a946a1-dd30-5f52-b103-d9a642e65712 -->
  <rule id="310946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5023 — Event Log Clearing (radar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>