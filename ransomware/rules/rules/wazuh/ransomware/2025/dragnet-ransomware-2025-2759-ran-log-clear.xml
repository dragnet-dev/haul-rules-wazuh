<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2759 — Event Log Clearing (shinyhunters) | Status: experimental | Sigma ID: 7e12e549-e3d4-5c89-ae9c-1f4d01dd59f3 -->
  <rule id="318065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2759 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>