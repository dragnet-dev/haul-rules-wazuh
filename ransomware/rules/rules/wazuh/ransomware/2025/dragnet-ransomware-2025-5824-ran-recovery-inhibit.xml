<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5824 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: f09390d4-318d-5f58-b2af-12b7f883fbdd -->
  <rule id="709390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5824 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>