<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1153 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: b28d24ef-2d54-5878-b911-c0595c55cd5b -->
  <rule id="106124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1153 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>