<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2133 — Recovery Inhibition (pear) | Status: test | Sigma ID: b272712a-dc85-5c54-8c4b-7bdbb83e0507 -->
  <rule id="327271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2133 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>