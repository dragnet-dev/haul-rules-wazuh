<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7429 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: cf4149ff-387a-5aed-8e1e-c3a0dcf37dbb -->
  <rule id="374149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7429 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>