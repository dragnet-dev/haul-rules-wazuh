<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5422 — Event Log Clearing (arkana) | Status: experimental | Sigma ID: 60aaa18e-bc72-5a22-9e23-c893a7ade08e -->
  <rule id="784901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5422 — Event Log Clearing (arkana)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>