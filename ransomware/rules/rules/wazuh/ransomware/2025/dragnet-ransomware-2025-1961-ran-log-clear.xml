<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1961 — Event Log Clearing (direwolf) | Status: experimental | Sigma ID: bf3bdc2b-6c04-5d52-9fe6-e6b845ff8ddc -->
  <rule id="738684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1961 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>