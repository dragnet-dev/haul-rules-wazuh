<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3768 — Event Log Clearing (direwolf) | Status: experimental | Sigma ID: 1cf7e22e-8f3b-5203-8bf1-36a6b814c49c -->
  <rule id="320622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3768 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>