<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2186 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: dc67f98c-312d-58aa-a0d1-dec72e6000c2 -->
  <rule id="930879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2186 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>