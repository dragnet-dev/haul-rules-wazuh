<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1565 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 495529ac-265e-5933-afc1-3260b1ac57c1 -->
  <rule id="828474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1565 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>