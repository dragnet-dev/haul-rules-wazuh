<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5364 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c7fbf171-ce55-576a-93cd-6e54642976f1 -->
  <rule id="842231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5364 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>