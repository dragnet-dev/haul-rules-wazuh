<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1021 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 233bd74e-f17e-5ea7-b96a-38b63b51fbc1 -->
  <rule id="683774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1021 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>