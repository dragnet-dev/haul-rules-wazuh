<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7420 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 9979fc7a-321b-50bd-b3f8-62188064cafc -->
  <rule id="854876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7420 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>