<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4056 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 34217433-474a-58d9-8b8b-b229058e631e -->
  <rule id="821743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4056 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>