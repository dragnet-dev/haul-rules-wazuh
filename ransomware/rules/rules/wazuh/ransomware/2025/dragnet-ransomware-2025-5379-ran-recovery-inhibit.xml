<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5379 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 14b856d2-8cb4-5469-bb9f-237f52ef4540 -->
  <rule id="273709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5379 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>