<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3306 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 92e00a7e-e1d7-5835-927e-f0facb6c8442 -->
  <rule id="677610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3306 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>