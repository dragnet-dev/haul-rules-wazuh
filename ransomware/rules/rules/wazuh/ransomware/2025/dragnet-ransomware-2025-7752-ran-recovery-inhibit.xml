<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7752 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: d40ba968-80ae-5d55-ba61-94c00441ac68 -->
  <rule id="832269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7752 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>