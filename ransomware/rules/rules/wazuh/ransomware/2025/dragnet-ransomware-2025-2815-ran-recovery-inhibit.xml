<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2815 — Recovery Inhibition (warlock) | Status: experimental | Sigma ID: 3c2ce7a3-121b-57d8-ba8f-6aa64c406960 -->
  <rule id="743187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2815 — Recovery Inhibition (warlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>