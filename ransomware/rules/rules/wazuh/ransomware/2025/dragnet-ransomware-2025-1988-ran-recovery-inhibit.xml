<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1988 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: c0c2683c-f07e-5716-b0f2-a4c6f74ed28d -->
  <rule id="232268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1988 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>