<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3680 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6fd0db5b-87de-58a0-9a49-ce1fdd959042 -->
  <rule id="180059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3680 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>