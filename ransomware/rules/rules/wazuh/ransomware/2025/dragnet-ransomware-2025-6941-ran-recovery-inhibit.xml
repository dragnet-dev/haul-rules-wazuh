<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6941 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 684c0710-f6fb-5ceb-bd70-852c3305dbb1 -->
  <rule id="295607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6941 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>