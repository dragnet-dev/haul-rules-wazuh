<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0651 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1e5618b2-e768-5c1c-8d41-3211d18b8bfe -->
  <rule id="489899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0651 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>