<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5885 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 56a20d11-0128-5663-b127-a783ca6c8db7 -->
  <rule id="649933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5885 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>