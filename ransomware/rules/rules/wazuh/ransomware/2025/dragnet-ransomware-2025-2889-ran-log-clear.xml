<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2889 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 7be555f7-ce0d-5c12-98ed-b5928b05f9f6 -->
  <rule id="282555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2889 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>