<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0769 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 9e8adfd8-bbbb-52a1-99b2-ee768b7a1ec7 -->
  <rule id="307231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0769 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>