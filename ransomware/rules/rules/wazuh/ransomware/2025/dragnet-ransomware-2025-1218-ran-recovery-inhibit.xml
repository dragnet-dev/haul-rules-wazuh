<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1218 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7ed05562-5b57-5989-bacc-c26fabe1ad5f -->
  <rule id="329055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1218 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>