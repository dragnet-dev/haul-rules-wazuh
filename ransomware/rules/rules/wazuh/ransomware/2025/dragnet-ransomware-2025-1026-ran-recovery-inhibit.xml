<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1026 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 4776401e-d512-5a40-bbee-3535821c7db5 -->
  <rule id="376401" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1026 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>