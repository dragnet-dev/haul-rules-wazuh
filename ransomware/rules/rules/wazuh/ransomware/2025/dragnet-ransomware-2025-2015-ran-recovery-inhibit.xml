<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2015 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: c2cbdefe-af53-5bec-b43f-693f5baf467f -->
  <rule id="947582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2015 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>