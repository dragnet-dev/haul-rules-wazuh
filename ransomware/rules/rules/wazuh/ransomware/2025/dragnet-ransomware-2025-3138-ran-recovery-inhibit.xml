<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3138 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cac8f1f1-3393-53b4-a7f8-b6e86da8d680 -->
  <rule id="791831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3138 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>