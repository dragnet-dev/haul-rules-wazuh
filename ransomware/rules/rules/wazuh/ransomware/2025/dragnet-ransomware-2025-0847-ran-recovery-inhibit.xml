<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0847 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 1fa4d9c7-ba55-5832-910a-c0e9e443f9a7 -->
  <rule id="466076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0847 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>