<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3305 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: e98b4ec8-861a-5995-b58e-7961ebb2606a -->
  <rule id="336718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3305 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>