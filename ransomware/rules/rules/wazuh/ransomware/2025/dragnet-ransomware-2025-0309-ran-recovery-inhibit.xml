<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0309 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 2f06ef55-fb98-5a5a-ad22-fbcb43e23d7e -->
  <rule id="404975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0309 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>