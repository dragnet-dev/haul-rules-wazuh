<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7342 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7ab42882-c5e8-5e96-a7fb-82b3f19a26ac -->
  <rule id="263428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7342 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>