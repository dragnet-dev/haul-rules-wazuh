<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7701 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 61450550-d79c-5e55-8837-b678b0681429 -->
  <rule id="845055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7701 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>