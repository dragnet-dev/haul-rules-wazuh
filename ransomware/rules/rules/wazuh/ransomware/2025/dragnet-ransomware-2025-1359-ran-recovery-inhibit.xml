<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1359 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: e28d1d29-9c39-5f93-896b-2421b174c9fc -->
  <rule id="157789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1359 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>