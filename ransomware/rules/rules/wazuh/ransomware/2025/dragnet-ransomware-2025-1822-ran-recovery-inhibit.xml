<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1822 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: dfd75724-ca2a-5e95-869a-a147d9c06c56 -->
  <rule id="981757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1822 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>