<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6950 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cae15786-6d9d-50e2-bb9f-074ddbcd2fb8 -->
  <rule id="646157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6950 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>