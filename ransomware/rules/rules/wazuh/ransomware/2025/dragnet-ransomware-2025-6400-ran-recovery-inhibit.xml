<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6400 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 9182537e-1073-5b68-943d-1bf7b6ff7bed -->
  <rule id="282537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6400 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>