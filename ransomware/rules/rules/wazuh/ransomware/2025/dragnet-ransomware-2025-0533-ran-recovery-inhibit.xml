<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0533 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: dff7ed90-cdfd-551f-b64f-d1a9bc9411f9 -->
  <rule id="274509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0533 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>