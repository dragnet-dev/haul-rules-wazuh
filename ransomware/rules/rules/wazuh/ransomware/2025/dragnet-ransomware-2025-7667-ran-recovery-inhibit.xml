<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7667 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 1515786a-d3af-59c2-9527-3de676f81111 -->
  <rule id="715786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7667 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>