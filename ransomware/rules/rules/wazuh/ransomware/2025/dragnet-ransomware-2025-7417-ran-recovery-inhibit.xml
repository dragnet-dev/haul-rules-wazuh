<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7417 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 3a685688-74fb-5cf7-8b0e-8738d5077238 -->
  <rule id="568568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7417 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>