<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6092 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9e891f11-b90a-589b-be4c-3179a023bd8a -->
  <rule id="842271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6092 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>