<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3297 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c1147058-e63c-54be-ad8a-097cca0ae663 -->
  <rule id="411470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3297 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>