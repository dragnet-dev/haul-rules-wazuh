<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0080 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fd6d14b3-181d-52e0-8345-18dbf1363034 -->
  <rule id="558914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0080 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
