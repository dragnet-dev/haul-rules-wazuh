<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2954 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e48f827d-48dc-5784-b5de-f4461993c609 -->
  <rule id="618382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2954 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>