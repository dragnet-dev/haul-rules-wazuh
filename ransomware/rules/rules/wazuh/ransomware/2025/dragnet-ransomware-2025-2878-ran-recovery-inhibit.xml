<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2878 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e7a3ada8-edb6-53fc-b845-47647b6a7eb8 -->
  <rule id="747661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2878 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>