<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3665 — Recovery Inhibition (nasirsecurity) | Status: experimental | Sigma ID: 948daa22-a6ab-5711-8849-9b4e0ca54b84 -->
  <rule id="386506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3665 — Recovery Inhibition (nasirsecurity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>