<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0450 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 330f4c3d-add1-5fcf-9365-e96cff263ed0 -->
  <rule id="472763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0450 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>