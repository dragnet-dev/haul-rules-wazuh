<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7265 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: cb0c2f8f-d1da-5d9f-a8df-e103f73ad3c6 -->
  <rule id="798767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7265 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>