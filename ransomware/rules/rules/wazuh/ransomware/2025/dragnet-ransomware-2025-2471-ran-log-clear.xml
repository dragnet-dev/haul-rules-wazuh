<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2471 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: f5d4b7c2-13f1-5b42-bdf5-c63ab6642752 -->
  <rule id="489557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2471 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>