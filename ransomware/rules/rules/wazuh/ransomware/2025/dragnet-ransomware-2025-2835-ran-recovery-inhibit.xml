<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2835 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3a71ce9e-cecd-5b4e-9746-40e6bd587837 -->
  <rule id="703182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2835 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>