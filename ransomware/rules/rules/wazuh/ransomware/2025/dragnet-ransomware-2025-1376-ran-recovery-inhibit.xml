  <rule id="850146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1376 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
