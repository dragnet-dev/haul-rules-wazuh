<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1528 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: ccbafeae-1d62-5432-be90-066a24076215 -->
  <rule id="917214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1528 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>