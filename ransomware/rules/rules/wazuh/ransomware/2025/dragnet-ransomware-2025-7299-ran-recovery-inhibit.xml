<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7299 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 822806c9-58ad-551c-8854-6ae3da1a9105 -->
  <rule id="664908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7299 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>