<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4221 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 8dc8a507-ea27-5c93-84d8-489db8390106 -->
  <rule id="130185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4221 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>