<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1247 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5fdf3cdc-436c-52b9-9c0c-46a4dec59017 -->
  <rule id="426940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1247 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>