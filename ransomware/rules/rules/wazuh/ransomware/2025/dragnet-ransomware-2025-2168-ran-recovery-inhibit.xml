<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2168 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: dff9b32a-39c0-55a0-a796-1a4f9e353013 -->
  <rule id="434353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2168 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>