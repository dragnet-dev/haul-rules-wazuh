<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3148 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: e64d41d2-e719-5fe7-a3b6-cf7e1ce5e8b4 -->
  <rule id="643741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3148 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>