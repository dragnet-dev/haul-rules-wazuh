<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1633 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: c32aa35e-f760-568d-a083-e07608af9f7a -->
  <rule id="555623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1633 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>