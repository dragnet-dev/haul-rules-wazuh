<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0174 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ef334121-567f-535c-89c0-32f31da2029e -->
  <rule id="693341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0174 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>