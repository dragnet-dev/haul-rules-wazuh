<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0589 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 5d70f27e-21a7-550c-add1-8bd25070e808 -->
  <rule id="699352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0589 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>