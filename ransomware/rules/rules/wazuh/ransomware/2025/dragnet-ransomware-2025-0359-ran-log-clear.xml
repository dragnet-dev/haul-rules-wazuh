<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0359 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 08a1dbeb-32af-5eff-b0d5-83ed6b431afc -->
  <rule id="360094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0359 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>