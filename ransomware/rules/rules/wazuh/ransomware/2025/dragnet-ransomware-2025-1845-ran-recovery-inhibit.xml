<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1845 — Recovery Inhibition (brotherhood) | Status: experimental | Sigma ID: e587af93-748e-5724-8ba9-9a327cb3280c -->
  <rule id="234447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1845 — Recovery Inhibition (brotherhood)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
