<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5054 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 019f159d-1fcc-5a75-bc74-83d1088a13ed -->
  <rule id="706557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5054 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>