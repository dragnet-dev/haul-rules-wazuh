<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0546 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5fc30e63-ce23-500f-b117-64b80710d938 -->
  <rule id="751694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0546 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>