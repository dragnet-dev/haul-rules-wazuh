<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4858 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: 2a1dad46-6aef-5dee-a581-093ba4c70123 -->
  <rule id="927917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4858 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>