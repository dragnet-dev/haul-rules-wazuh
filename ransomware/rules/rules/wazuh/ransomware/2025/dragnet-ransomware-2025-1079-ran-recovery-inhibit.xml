<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1079 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 9f4ff082-3e19-5fbe-b6e3-7c9ae9d1d8e5 -->
  <rule id="583190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1079 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>