<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2175 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: a6695c4b-26f7-53a7-af8a-274d05fba243 -->
  <rule id="907132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2175 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>