<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2825 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5126757e-eaa6-5e9a-8e09-b387f8dd76a1 -->
  <rule id="726757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2825 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>