<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0311 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: bc67a72a-3882-5f63-9d21-0ac3884b6b82 -->
  <rule id="418827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0311 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>