<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7095 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f95d9e22-7257-5233-ab46-c8b86383817e -->
  <rule id="585438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7095 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
