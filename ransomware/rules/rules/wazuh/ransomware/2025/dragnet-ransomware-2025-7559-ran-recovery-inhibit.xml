<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7559 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2734d0bd-a983-5793-916b-f65596ec5c64 -->
  <rule id="801131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7559 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>