<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3683 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 6b2fecff-32ad-50d7-8b3c-ee26d4f783b1 -->
  <rule id="894988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3683 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>