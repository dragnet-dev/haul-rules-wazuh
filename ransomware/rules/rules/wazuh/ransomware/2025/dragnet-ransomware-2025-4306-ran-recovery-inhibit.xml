<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4306 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8796b33c-18f7-5508-875c-6ed7572fbc3d -->
  <rule id="607473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4306 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>