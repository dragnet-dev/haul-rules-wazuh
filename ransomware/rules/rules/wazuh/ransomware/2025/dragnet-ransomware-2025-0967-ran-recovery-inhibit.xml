<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0967 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 0369ff6b-2b02-5536-aa76-37a3a7a4445b -->
  <rule id="855147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0967 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>