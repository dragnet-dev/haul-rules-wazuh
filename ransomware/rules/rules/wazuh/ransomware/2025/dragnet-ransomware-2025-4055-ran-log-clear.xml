<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4055 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: c3bfdd6d-cd67-59a0-b30d-ce9e53a93cbd -->
  <rule id="110045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4055 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>