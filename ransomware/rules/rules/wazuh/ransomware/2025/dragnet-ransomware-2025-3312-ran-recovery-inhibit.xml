<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3312 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e05db718-7ab1-5533-9e2d-a480672642d5 -->
  <rule id="998997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3312 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>