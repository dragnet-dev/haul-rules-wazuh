<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5555 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d98a92fa-b933-5119-8666-61e030393aa7 -->
  <rule id="537892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5555 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>