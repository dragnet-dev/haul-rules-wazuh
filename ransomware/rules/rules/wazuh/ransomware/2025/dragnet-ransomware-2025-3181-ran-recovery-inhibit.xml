<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3181 — Recovery Inhibition (bert) | Status: experimental | Sigma ID: 930a0906-9e23-58e4-a8a3-9588a33be6b1 -->
  <rule id="689009" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3181 — Recovery Inhibition (bert)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>