<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1224 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9285a7f2-5b36-5eca-8777-800f859eb5e4 -->
  <rule id="685707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1224 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>