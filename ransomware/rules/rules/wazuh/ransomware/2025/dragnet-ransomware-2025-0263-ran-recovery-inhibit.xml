<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0263 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2e4d3506-9933-58df-b0c0-1b7c7ba08758 -->
  <rule id="337350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0263 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>