<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7332 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 4d980fe5-074c-577b-8c67-e30bb58066a8 -->
  <rule id="447695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7332 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>