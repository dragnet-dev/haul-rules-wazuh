<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6410 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 53fbf080-af54-5ad2-9dc4-505ae5389891 -->
  <rule id="511190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6410 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>