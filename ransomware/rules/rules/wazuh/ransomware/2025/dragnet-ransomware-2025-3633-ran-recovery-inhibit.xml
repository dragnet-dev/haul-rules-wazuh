<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3633 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: aa8fda3c-3765-5212-8c0f-c1d70e1bc6a9 -->
  <rule id="800026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3633 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>