<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4414 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: d53b8d4f-27bd-5548-a4ac-0e9da3b6fd20 -->
  <rule id="865581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4414 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>