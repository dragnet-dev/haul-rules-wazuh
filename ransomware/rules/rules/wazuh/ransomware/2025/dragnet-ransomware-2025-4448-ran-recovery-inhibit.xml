<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4448 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 2551d5ed-0e02-5d39-8fd3-1053c1047a2f -->
  <rule id="332734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4448 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>