<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5875 — Recovery Inhibition (silent) | Status: experimental | Sigma ID: a95cea51-1e10-5eee-a886-b496f3a8ab4b -->
  <rule id="988426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5875 — Recovery Inhibition (silent)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>