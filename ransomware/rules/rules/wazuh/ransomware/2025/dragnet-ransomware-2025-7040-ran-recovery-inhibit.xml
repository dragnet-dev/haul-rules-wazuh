<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7040 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 821ee66f-a40a-58dc-8074-ba59ebdcc4d8 -->
  <rule id="404146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7040 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>