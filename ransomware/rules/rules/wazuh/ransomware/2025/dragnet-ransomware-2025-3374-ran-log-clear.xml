<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3374 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 8e43f946-f4d6-53d0-89dc-9fefaee78e54 -->
  <rule id="579039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3374 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>