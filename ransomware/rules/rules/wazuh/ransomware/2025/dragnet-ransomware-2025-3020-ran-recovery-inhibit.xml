<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3020 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: c9b54e1a-6f80-5f9a-a5bd-6930f52118cb -->
  <rule id="720878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3020 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>