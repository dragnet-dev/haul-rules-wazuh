<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2388 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b7dc24d3-fcf4-5eee-82ab-b063a332e349 -->
  <rule id="417224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2388 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>