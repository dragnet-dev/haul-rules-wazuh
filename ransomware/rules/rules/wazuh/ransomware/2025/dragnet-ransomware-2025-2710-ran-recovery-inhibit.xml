<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2710 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 506be6fd-60b9-5df3-95ab-edbdbfc17702 -->
  <rule id="497266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2710 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>