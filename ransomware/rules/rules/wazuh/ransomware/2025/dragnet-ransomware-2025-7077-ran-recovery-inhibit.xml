<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7077 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b1c0ae09-20b5-5713-a15a-7c0e20cb4433 -->
  <rule id="177454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7077 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>