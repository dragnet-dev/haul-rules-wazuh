<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2375 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 060fc0d0-f1a3-5cd2-8adc-0559d1ae99ef -->
  <rule id="797933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2375 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>