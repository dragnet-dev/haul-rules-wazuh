<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7669 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 4bfde1d7-e5b1-5b5b-afba-697ac93ad56b -->
  <rule id="512621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7669 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>