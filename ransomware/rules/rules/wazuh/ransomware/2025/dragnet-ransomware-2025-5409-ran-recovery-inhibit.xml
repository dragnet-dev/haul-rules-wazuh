<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5409 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 76c83774-13d4-537e-be86-e322e7609374 -->
  <rule id="428837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5409 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>