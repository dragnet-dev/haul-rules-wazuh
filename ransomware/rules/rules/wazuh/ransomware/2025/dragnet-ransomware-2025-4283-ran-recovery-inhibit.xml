<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4283 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 35b2eb58-80ee-57c9-b156-f75bb7424602 -->
  <rule id="662507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4283 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>