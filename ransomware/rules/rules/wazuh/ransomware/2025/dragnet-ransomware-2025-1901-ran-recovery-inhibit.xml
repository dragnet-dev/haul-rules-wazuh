<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1901 — Recovery Inhibition (play) | Status: experimental | Sigma ID: db356398-a0e8-5b6f-92b0-ed7e47f4627f -->
  <rule id="493563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1901 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>