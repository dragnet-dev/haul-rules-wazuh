<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3241 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 91eb710b-7522-5170-8e41-69547aecf5ca -->
  <rule id="653171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3241 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>