<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1145 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 822ccb75-2df0-5ced-84b6-fdd60feff8da -->
  <rule id="770187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1145 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>