<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4036 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bbdeb5b0-22ea-5fe0-a53b-3510b6491d16 -->
  <rule id="595155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4036 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>