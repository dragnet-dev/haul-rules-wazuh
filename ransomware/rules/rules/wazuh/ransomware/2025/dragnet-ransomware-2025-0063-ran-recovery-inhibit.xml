<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0063 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f5dffcaf-e132-5740-8943-d1875a6f4c36 -->
  <rule id="415420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0063 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>