<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1851 — Recovery Inhibition (brotherhood) | Status: experimental | Sigma ID: d1d12a79-764d-5f0e-875e-af68d6638524 -->
  <rule id="774602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1851 — Recovery Inhibition (brotherhood)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
