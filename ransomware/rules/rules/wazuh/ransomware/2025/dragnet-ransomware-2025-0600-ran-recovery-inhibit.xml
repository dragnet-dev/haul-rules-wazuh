<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0600 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cab23b05-71b6-5ee9-8e68-e2b56950f741 -->
  <rule id="789179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0600 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>