<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4461 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2df8bda5-dfa8-5025-81e9-cce80b664b8c -->
  <rule id="183837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4461 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>