  <rule id="736138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0380 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
