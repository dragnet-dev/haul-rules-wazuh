<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5994 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: e0302822-f5b1-515b-b3b0-cf201ffaeb52 -->
  <rule id="603028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5994 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>