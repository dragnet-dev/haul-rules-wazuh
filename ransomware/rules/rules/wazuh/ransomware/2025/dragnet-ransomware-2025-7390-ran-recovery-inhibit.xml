<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7390 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 544f6371-03dd-5de1-8518-513a9859a645 -->
  <rule id="719637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7390 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>