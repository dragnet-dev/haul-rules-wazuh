<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6417 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1cc65c69-2395-53b6-a581-301311e7511e -->
  <rule id="270526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6417 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>