<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2893 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: ca763007-a52a-589c-87f3-3efae9036c21 -->
  <rule id="327630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2893 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>