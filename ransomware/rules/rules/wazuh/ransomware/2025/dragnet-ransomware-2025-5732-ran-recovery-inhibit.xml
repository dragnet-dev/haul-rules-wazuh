<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5732 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 996b631e-49ba-5c03-b3de-4cc5de5dd963 -->
  <rule id="794763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5732 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>