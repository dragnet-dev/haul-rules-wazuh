<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2305 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 20b98d1e-f03a-5ffb-8766-16777bc6f841 -->
  <rule id="911811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2305 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>