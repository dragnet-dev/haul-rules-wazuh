<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5560 — Event Log Clearing (dunghill) | Status: experimental | Sigma ID: bbb010d0-0493-5e03-9a24-140991e779d1 -->
  <rule id="403010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5560 — Event Log Clearing (dunghill)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>