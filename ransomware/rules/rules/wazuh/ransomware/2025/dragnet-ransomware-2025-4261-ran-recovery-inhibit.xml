<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4261 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e2b9ac09-f72e-516f-b663-13f64408919f -->
  <rule id="546956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4261 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>