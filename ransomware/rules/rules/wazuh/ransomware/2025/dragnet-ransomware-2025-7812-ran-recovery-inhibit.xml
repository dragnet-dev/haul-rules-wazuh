<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7812 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4ffe2ec8-c512-5c99-88b3-0cd74eece546 -->
  <rule id="676526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7812 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>