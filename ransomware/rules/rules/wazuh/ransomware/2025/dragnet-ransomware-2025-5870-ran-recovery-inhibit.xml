<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5870 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8ab80768-0e93-54d9-b1a2-a90299608522 -->
  <rule id="519807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5870 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>