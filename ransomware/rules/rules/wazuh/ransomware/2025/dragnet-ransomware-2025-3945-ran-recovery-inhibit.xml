<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3945 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 75cc503b-2490-5a58-87b0-fabcc6967e24 -->
  <rule id="240450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3945 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>