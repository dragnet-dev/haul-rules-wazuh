<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6272 — Recovery Inhibition (play) | Status: experimental | Sigma ID: da5a8bc9-89c2-555f-abd6-6fe9a332f0a1 -->
  <rule id="295339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6272 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>