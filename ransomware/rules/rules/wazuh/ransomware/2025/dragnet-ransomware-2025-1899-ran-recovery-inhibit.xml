<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1899 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 646b9bd3-4d9e-5f78-ad99-341b1f76fab8 -->
  <rule id="855675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1899 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>