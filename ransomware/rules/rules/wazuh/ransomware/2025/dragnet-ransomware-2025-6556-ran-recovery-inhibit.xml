<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6556 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cbd69ae2-a08b-5d18-a07d-bddc2670a8ea -->
  <rule id="818714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6556 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>