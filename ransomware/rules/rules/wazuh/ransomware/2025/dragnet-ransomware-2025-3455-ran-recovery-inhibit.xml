<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3455 — Recovery Inhibition (GDLockerSec) | Status: experimental | Sigma ID: eeb7f2a1-1324-51b2-8115-3f3ac2a08b7e -->
  <rule id="811672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3455 — Recovery Inhibition (GDLockerSec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>