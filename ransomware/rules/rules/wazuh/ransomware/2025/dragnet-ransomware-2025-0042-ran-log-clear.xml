<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0042 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 2f3f8a2b-dc16-5143-bf1c-cddd05a7c605 -->
  <rule id="413418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0042 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>