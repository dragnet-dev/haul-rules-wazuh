<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4347 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9e86cb5a-596a-5cba-8552-6c0ae2ddf910 -->
  <rule id="567019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4347 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>