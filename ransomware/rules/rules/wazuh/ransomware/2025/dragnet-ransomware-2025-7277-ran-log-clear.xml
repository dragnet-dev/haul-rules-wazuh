<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7277 — Event Log Clearing (tridentlocker) | Status: experimental | Sigma ID: d8abda4f-c5c6-5457-a4dd-992084c735a4 -->
  <rule id="187962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7277 — Event Log Clearing (tridentlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>