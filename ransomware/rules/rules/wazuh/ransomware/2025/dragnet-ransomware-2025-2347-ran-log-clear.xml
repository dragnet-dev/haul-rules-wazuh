<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2347 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: d0f85315-0d6e-5e47-9fcd-3ed3f9f56e58 -->
  <rule id="395853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2347 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>