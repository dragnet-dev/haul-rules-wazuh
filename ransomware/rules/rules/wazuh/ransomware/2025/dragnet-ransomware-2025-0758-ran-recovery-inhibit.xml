<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0758 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: d57312e1-4875-5d9e-b76c-184a26be9344 -->
  <rule id="557312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0758 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>