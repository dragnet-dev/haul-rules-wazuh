<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0964 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 1233a10e-a909-56a9-ae10-9059280a4b9f -->
  <rule id="273810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0964 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>