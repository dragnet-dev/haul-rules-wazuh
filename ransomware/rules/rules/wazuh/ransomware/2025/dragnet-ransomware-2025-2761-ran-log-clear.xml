<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2761 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 73a96d9c-6e56-5359-8e6c-3e29ac4fce01 -->
  <rule id="186349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2761 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>