<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7607 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 6c7d4f8d-1240-50cb-b23e-62a74a839b5b -->
  <rule id="184879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7607 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>