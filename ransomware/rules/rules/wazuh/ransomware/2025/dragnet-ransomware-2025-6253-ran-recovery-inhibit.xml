<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6253 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 254e2110-fdd3-573e-9017-d18e0c0ffcd9 -->
  <rule id="578211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6253 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>