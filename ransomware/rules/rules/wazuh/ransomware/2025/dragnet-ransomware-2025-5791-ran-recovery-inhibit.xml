<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5791 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 95a76068-1f25-55f9-80b7-1522d55bf1f8 -->
  <rule id="730760" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5791 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>