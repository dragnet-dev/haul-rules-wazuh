<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3100 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b56f133d-901e-5ba2-ba83-3de70bd1b64f -->
  <rule id="151113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3100 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>