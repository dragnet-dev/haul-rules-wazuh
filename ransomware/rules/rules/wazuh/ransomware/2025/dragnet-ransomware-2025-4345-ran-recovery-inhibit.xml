<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4345 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: e55f8bd8-762a-54c4-aac8-3440f279ec6f -->
  <rule id="227339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4345 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>