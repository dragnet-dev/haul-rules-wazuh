<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7861 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: ec95b55a-cc8c-51e2-826c-3e078568ca2d -->
  <rule id="291315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7861 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>