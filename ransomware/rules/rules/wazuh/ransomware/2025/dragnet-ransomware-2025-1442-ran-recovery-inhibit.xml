<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1442 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3e60c51b-b0a1-5f1d-9324-e4d03b3f48f0 -->
  <rule id="201725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1442 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>