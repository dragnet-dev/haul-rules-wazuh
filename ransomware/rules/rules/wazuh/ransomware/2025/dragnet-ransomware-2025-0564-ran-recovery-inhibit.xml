<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0564 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 12f80f12-f10c-5812-933b-f327e59fd853 -->
  <rule id="724951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0564 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>