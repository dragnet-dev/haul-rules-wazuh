<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0568 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 4d2f1322-28a4-5a3e-bb70-b228dbac985f -->
  <rule id="436713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0568 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>