<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2665 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 0e526f48-2982-5077-a498-6a52c7b25492 -->
  <rule id="624314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2665 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>