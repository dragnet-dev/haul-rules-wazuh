<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0820 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 922988d8-b46c-5b11-8bea-167edcec5b9d -->
  <rule id="467821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0820 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>