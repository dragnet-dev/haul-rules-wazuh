<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3808 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: 48b969f3-e542-57c7-8aed-61b0bfd81f0a -->
  <rule id="879519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3808 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>