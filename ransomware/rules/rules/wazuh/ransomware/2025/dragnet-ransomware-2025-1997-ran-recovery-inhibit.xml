<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1997 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: d34985d3-0397-5fcc-b772-704d223b5729 -->
  <rule id="534985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1997 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>