<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0808 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: de772d18-7727-52c8-86d5-4f257cd93007 -->
  <rule id="964365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0808 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>