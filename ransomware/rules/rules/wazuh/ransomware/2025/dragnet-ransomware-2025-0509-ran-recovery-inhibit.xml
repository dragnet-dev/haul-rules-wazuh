<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0509 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 027557b9-0e82-5eff-9a18-fda9ebbeffc5 -->
  <rule id="909239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0509 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>