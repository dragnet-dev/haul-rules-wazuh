<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5999 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: d3e82d8f-24a9-51e2-86e1-a0a2eb3d25ed -->
  <rule id="828525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5999 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>