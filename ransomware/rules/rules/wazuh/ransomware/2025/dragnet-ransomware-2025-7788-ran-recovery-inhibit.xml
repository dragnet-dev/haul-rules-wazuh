<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7788 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f49c4e50-481f-553b-bc3e-1e7c9f1761b8 -->
  <rule id="467438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7788 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>