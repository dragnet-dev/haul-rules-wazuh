<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4654 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: e16a2547-ab7b-5e9a-93d8-25a46808b013 -->
  <rule id="566625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4654 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>