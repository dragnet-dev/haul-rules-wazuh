<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5400 — Recovery Inhibition (lunalock) | Status: experimental | Sigma ID: 4246726b-d364-5268-8fea-8650381f7608 -->
  <rule id="746726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5400 — Recovery Inhibition (lunalock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>