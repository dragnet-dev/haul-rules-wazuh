<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3205 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4275c483-775f-587a-9917-6ba1daa3941b -->
  <rule id="641248" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3205 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>