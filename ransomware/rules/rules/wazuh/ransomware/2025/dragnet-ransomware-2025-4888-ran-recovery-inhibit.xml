<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4888 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: a1a09464-f1ac-5f79-8e4d-0cc55b4865f8 -->
  <rule id="826094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4888 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>