<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3772 — Event Log Clearing (lockbit5) | Status: test | Sigma ID: b3715f22-3e0a-5e6b-b560-cbcbe8a71fa2 -->
  <rule id="119455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3772 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>