<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0590 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8517cf70-047f-5518-a8bc-4606286baaeb -->
  <rule id="480559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0590 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>