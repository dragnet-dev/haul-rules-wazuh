<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2024 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2d4e5164-cca9-5cfb-8523-7586bfca794a -->
  <rule id="178516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2024 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>