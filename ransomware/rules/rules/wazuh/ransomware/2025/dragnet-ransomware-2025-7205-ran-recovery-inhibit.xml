<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7205 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 856559df-0328-52f4-b0c4-830573eccf44 -->
  <rule id="304957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7205 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>