<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6422 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: c3a43ded-d89a-53f0-b96c-9c64b2cae3e3 -->
  <rule id="565501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6422 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>