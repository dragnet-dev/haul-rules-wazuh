<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5818 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e41bcf66-af85-5b7b-80c1-2a37601b9994 -->
  <rule id="605359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5818 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>