<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1307 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 8f2cef6a-90be-558c-b9de-0d2939935df8 -->
  <rule id="568783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1307 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>