<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1064 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 134697a2-7b9a-55a9-80cd-400e5bfebb52 -->
  <rule id="455162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1064 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>