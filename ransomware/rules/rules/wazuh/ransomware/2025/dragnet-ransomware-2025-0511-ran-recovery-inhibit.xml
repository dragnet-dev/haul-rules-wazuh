<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0511 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 7a9f9c86-51e9-5990-9c8f-8a08e1b6d7aa -->
  <rule id="548796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0511 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>