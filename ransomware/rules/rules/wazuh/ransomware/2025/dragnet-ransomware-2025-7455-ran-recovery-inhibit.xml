<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7455 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 4f0b9633-76fd-5cbb-8463-423e423804a4 -->
  <rule id="465196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7455 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>