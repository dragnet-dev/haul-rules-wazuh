<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7003 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: 67c2fd67-287f-5b6a-8d45-e262859d74d3 -->
  <rule id="175805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7003 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>