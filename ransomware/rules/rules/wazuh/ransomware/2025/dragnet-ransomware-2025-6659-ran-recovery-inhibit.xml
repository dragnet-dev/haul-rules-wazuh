<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6659 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7234bd10-493c-5bc0-bed9-0a007a31b896 -->
  <rule id="152093" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6659 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>