<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4757 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 75d6ac14-d16e-5d35-b8d7-849281b3ed0a -->
  <rule id="506988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4757 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>