<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2180 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 53d71983-b54f-502a-b5c5-ff765ddd2059 -->
  <rule id="617198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2180 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>