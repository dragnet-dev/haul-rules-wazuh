<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3521 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: e901d243-b5ff-5095-98b0-31a5296ca125 -->
  <rule id="684292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3521 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>