<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4983 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 13ad481f-2620-50c5-8010-23e2ac4ff2e1 -->
  <rule id="901481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4983 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>