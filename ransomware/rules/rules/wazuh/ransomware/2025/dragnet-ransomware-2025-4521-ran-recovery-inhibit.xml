<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4521 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 12831b39-6d63-59bd-9497-dbf0a5cb6c66 -->
  <rule id="353073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4521 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>