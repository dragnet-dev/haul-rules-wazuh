<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7307 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 2072c42a-b395-5d85-adb2-dbf9cd7c4a28 -->
  <rule id="716442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7307 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>