<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6356 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 459684db-9f1f-5e98-829b-b86d555862d7 -->
  <rule id="254957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6356 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>