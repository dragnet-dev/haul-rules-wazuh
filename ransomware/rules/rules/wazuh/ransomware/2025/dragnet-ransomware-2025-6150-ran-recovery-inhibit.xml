<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6150 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cd9f0715-bf41-5752-8159-065fbc4e4285 -->
  <rule id="695907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6150 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>