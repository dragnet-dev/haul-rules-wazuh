<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6265 — Event Log Clearing (kazu) | Status: experimental | Sigma ID: 8704eaa8-e0f5-535a-8853-95ad2d9f6951 -->
  <rule id="528458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6265 — Event Log Clearing (kazu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>