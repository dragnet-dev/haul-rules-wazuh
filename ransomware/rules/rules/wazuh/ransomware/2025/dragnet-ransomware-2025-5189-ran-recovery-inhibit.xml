<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5189 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: f5ed48c7-6443-5a36-a5ba-b11f44f27d8f -->
  <rule id="491748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5189 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>