<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1628 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6ad57588-7097-5ff6-bbba-9ecdd7aa4b71 -->
  <rule id="909575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1628 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>