<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4717 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3fbf672f-482c-57a3-91d5-0236dc543483 -->
  <rule id="831967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4717 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>