<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5458 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: aad6ccc3-82fe-5c49-85d3-796e603e09d2 -->
  <rule id="798220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5458 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>