<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1444 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 45d09ac9-48a7-590d-80b4-e0db8618be20 -->
  <rule id="372954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1444 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>