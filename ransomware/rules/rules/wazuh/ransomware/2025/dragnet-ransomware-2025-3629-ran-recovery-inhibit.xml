<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3629 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 756e6be4-e916-5f42-b151-6d310de06659 -->
  <rule id="237707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3629 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>