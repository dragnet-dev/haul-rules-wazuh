<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4271 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: d70d98e1-1447-525d-864c-76147c6cc1f1 -->
  <rule id="493398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4271 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>