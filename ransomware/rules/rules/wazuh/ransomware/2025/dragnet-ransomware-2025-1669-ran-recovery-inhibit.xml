<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1669 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f86e9147-d3dc-5e39-86e5-4c96be6ff642 -->
  <rule id="839091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1669 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>