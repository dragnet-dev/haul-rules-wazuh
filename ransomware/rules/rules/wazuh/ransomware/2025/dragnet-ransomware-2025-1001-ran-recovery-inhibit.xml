<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1001 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: bf16feaa-f82a-5168-8a0f-953bcb98ca71 -->
  <rule id="493950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1001 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>