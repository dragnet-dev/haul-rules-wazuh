<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4016 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 46a09980-02ef-591c-9627-9a44b3345950 -->
  <rule id="360998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4016 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>