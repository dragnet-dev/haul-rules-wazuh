<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4302 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 8f59ab4b-0bd2-522e-92d3-7cbe09aee122 -->
  <rule id="176075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4302 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>