<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2191 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: f3f260c3-aa07-5db5-b83b-f81d47db98e1 -->
  <rule id="763260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2191 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>