<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7511 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8de71666-5e32-581c-97d2-f148d3ee4a2f -->
  <rule id="570716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7511 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>