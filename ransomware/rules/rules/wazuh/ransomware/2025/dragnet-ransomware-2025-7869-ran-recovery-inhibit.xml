<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7869 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 1781e7d0-33fd-53d6-b247-4d4ad8c0d6b7 -->
  <rule id="161725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7869 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>