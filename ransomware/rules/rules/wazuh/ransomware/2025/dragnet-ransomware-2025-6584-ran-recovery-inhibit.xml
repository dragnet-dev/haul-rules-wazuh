<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6584 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: fc9bbba5-10aa-5331-a655-64383b5f48a0 -->
  <rule id="561787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6584 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>