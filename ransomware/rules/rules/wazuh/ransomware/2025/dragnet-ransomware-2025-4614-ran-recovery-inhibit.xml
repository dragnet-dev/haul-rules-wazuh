<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4614 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 839b03af-c8ae-5531-8506-7880fb1c0f50 -->
  <rule id="543503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4614 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>