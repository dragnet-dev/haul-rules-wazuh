<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3833 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5361d3b9-51b9-5e23-986c-a4366f46d531 -->
  <rule id="326299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3833 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>