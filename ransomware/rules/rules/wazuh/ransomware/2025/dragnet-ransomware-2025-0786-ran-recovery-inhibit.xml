<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0786 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 82b47345-4bc2-5532-9b3b-412cdb998b84 -->
  <rule id="523473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0786 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>