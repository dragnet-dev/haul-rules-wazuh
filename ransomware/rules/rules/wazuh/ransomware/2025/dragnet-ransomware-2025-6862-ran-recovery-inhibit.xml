<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6862 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 37e235a8-d1b5-5ae2-bd01-0f91a0538fab -->
  <rule id="799770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6862 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>