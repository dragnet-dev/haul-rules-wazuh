<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5859 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8c692852-e799-52d6-b6e6-1a3a5485a77c -->
  <rule id="606928" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5859 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>