<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5292 — Recovery Inhibition (play) | Status: experimental | Sigma ID: da428b0a-b070-5b52-a61a-1fd6dbd05f86 -->
  <rule id="894859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5292 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>