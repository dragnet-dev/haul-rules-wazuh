<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6014 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: de205699-7e08-53a6-8ab2-4ddae43afc9c -->
  <rule id="522056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6014 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>