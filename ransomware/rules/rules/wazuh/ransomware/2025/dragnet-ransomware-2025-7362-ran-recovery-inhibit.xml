<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7362 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 646197d9-dd14-5cf4-8cde-567c1c7601fd -->
  <rule id="539165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7362 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>