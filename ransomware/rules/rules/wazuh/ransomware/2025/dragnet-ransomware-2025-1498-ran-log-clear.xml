<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1498 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: 9d7e006f-ff1b-58cc-9fd1-1e55176eade2 -->
  <rule id="824600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1498 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>