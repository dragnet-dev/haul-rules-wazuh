<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7774 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: f22c472c-816c-530d-879c-654a00552a55 -->
  <rule id="736447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7774 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>