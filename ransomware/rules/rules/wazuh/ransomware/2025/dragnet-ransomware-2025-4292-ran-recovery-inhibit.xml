<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4292 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b1c6f2b2-063e-566c-9563-e824c7f8fccb -->
  <rule id="261912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4292 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>