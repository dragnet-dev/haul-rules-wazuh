<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0104 — Event Log Clearing (interlock) | Status: experimental | Sigma ID: 81e08c65-b7f8-50bc-aa2d-d9895c8a3237 -->
  <rule id="396140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0104 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>