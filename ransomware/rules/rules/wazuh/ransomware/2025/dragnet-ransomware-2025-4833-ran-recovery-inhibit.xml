<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4833 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 69d1e7a7-7ed4-5fb1-86de-f418842f4897 -->
  <rule id="987507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4833 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>