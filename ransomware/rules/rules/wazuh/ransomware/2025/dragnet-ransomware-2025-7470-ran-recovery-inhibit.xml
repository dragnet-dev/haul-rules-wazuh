<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7470 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 540e9e67-eeaf-5077-80d3-a34abe21cacf -->
  <rule id="584798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7470 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>