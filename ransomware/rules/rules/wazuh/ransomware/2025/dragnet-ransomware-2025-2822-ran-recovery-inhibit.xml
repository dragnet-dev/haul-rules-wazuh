<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2822 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 07a42c26-99e3-566a-a398-c7854c81ee2f -->
  <rule id="258842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2822 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>