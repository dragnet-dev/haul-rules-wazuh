<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5027 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 67b6d29e-69a8-5d65-bdda-a0de086afe45 -->
  <rule id="933892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5027 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>