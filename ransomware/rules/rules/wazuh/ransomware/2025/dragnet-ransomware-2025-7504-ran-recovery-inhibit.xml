<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7504 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: cac050bb-6fb0-502d-a835-ebeda1ea542a -->
  <rule id="644050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7504 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>