<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4101 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: a4c139c1-5777-57c4-87cf-b831724d7795 -->
  <rule id="876139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4101 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>