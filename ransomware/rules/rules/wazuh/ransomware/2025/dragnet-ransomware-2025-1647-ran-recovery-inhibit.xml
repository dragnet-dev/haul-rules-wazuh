<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1647 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 33c005b9-7dca-58bb-89af-8e801da3be46 -->
  <rule id="640091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1647 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>