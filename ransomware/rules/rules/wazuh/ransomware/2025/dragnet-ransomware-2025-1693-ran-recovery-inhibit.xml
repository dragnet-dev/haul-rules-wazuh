<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1693 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: bffd6a73-a6ed-5265-be72-1a1e2ed4ac84 -->
  <rule id="763946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1693 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>