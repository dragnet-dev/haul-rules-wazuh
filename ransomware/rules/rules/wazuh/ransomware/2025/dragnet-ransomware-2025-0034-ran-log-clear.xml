<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0034 — Event Log Clearing (global) | Status: deprecated | Sigma ID: 5d101f09-20ae-5625-ae0b-844b333c2701 -->
  <rule id="689631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0034 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>