<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4920 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 74342b6b-0b18-50ee-bcd0-17b795920c53 -->
  <rule id="389483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4920 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>