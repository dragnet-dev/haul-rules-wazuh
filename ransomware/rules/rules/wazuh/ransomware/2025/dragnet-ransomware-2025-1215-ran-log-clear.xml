<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1215 — Event Log Clearing (yurei) | Status: experimental | Sigma ID: 49038d7e-3ada-561b-b70d-60ee132e0209 -->
  <rule id="746217" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1215 — Event Log Clearing (yurei)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>