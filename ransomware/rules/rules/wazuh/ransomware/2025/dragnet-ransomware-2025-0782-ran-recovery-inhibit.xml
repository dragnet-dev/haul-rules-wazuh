<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0782 — Recovery Inhibition (bert) | Status: experimental | Sigma ID: 37fda110-3d27-544a-92fe-d9ffc1628eef -->
  <rule id="756101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0782 — Recovery Inhibition (bert)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>