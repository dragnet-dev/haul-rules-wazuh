<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6429 — Event Log Clearing (skira) | Status: experimental | Sigma ID: 98fe1e69-e020-5c3e-a52b-514e35833453 -->
  <rule id="554750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6429 — Event Log Clearing (skira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>