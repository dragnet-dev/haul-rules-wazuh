<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4114 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 9d32d376-6b2d-5aa1-b2d2-9d3de47474f9 -->
  <rule id="817253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4114 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>