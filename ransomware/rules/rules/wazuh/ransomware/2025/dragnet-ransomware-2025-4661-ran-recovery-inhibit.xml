<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4661 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: ecc8dea4-d6b1-5317-a35e-013533441be2 -->
  <rule id="799550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4661 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>