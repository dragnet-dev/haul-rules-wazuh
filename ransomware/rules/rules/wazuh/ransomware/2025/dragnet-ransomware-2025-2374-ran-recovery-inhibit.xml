<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2374 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d98a7a9b-895b-5926-ac66-a4d286794d0c -->
  <rule id="980602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2374 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>