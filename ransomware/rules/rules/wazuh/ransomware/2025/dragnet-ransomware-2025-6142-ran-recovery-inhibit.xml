<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6142 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 476fd759-2c97-5abd-a8fa-59cdb03d6fd7 -->
  <rule id="421097" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6142 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>