<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0266 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 005409f3-f063-5107-aa02-54fa32b34df2 -->
  <rule id="449503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0266 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>