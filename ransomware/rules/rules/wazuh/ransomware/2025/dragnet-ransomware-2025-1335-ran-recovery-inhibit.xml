<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1335 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 7d57d797-ed34-5575-ad1b-bad012671944 -->
  <rule id="309257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1335 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>