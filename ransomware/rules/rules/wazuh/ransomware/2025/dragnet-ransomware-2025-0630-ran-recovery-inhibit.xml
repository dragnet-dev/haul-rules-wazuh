<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0630 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 08943b18-276d-5102-a245-d70994a430aa -->
  <rule id="630991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0630 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>