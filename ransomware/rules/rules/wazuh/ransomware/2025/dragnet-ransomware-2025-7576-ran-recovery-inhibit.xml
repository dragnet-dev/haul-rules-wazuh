<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7576 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 642c3d99-30d3-50f1-8724-da2160e6ba95 -->
  <rule id="845501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7576 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>