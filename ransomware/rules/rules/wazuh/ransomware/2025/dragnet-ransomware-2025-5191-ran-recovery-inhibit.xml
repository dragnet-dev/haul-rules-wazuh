<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5191 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 75e422ab-2fce-5abe-ac83-37a0abcf7b68 -->
  <rule id="414422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5191 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>