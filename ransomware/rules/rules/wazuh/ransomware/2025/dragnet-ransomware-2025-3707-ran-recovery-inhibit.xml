<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3707 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 0f8be074-60a6-5234-a60e-457bc811655e -->
  <rule id="563807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3707 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>