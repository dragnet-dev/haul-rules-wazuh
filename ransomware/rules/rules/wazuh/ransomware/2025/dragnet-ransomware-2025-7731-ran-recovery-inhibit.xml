<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7731 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 11f8e024-e7d2-56e1-9319-3f237430bdab -->
  <rule id="470202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7731 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>