<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3929 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bbd534de-66ca-50e6-95c0-c84c1c0dc9d6 -->
  <rule id="405534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3929 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>