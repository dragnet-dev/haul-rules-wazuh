<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7324 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 9c1f58b1-0ada-5aa3-a7a6-8ec196f3fd39 -->
  <rule id="799158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7324 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>