<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6369 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 0a06beb9-6832-554b-80a8-5454021afba1 -->
  <rule id="623627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6369 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>