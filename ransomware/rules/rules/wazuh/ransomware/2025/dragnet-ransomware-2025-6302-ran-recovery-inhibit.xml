<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6302 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 438c5335-e80f-5b9b-982e-ca9910666546 -->
  <rule id="820533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6302 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>