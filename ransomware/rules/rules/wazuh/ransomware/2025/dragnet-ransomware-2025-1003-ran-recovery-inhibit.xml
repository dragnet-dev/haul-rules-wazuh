<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1003 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 92592aba-49e7-5d19-bc75-c2eefe8d46eb -->
  <rule id="681482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1003 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>