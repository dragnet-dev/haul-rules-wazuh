<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6287 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: f91d840c-161f-521f-819e-554953aed467 -->
  <rule id="846984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6287 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>