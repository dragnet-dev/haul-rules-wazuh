<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4226 — Recovery Inhibition (qilin) | Status: test | Sigma ID: b6525ea1-4bd9-534d-aaf3-ee3049a0786f -->
  <rule id="164414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4226 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>