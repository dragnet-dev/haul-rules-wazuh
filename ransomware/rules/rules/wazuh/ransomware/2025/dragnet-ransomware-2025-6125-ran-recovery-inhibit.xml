<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6125 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 32bf1bdb-926b-5446-a8a7-7ae40b113298 -->
  <rule id="541307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6125 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>