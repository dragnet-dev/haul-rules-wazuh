<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7415 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: dbbad840-1f84-5429-a743-2022f971111c -->
  <rule id="100138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7415 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>