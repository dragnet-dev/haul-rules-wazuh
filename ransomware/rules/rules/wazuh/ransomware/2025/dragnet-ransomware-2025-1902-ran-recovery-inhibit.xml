<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1902 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 11b25861-d580-5f92-a767-22a54ef91909 -->
  <rule id="172586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1902 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>