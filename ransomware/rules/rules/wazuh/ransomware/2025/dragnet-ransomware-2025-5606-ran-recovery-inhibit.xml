<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5606 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 644a632e-4b75-599c-803f-aa4fe7a3e1f6 -->
  <rule id="231463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5606 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>