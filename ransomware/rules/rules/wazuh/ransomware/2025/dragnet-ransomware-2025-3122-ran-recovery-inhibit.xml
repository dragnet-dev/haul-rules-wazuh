<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3122 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: a5cb96d3-3d02-5738-95e1-8e49858c539b -->
  <rule id="108396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3122 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>