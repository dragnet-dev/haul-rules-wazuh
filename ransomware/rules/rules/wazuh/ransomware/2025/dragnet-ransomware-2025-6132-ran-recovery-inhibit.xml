<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6132 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: cefe655a-c775-5b06-9302-e87d04f4932a -->
  <rule id="899065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6132 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>