<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6784 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: d7213c36-9018-5491-b762-62030b2efdb5 -->
  <rule id="495420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6784 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>