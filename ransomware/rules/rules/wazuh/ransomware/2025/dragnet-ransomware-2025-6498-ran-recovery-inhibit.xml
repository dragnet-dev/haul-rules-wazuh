<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6498 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 84fce6d5-2b84-5ee3-a37e-25cfdeeb3560 -->
  <rule id="881106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6498 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>