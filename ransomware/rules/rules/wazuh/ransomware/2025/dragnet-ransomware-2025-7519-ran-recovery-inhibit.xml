<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7519 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bd90ec8f-f9c4-55ed-ae88-488517d6f96c -->
  <rule id="461676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7519 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>