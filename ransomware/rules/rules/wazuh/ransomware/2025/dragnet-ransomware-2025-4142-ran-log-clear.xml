<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4142 — Event Log Clearing (dragonforce) | Status: test | Sigma ID: 0f4c7a74-4e4e-5a9e-a31f-05bc792910a2 -->
  <rule id="462827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4142 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>