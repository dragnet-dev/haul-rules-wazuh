<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0520 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d924e7e0-effa-5797-819d-401c42e8ef1c -->
  <rule id="527987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0520 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>