<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1013 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1993ef93-73a3-54d7-89dc-410e70ff63cd -->
  <rule id="704479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1013 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>