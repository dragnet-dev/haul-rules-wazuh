<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5938 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 30d2b0f7-4dcd-5e29-8b68-c2072e5a5f2a -->
  <rule id="127695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5938 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>