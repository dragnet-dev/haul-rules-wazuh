<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5320 — Event Log Clearing (datacarry) | Status: deprecated | Sigma ID: c26e4a4b-a3f2-57cb-86ee-784c48ea4d0d -->
  <rule id="540874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5320 — Event Log Clearing (datacarry)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>