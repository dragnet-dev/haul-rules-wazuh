<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7574 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 30c3c6ad-2d22-5435-ab13-c10cafaa82db -->
  <rule id="104906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7574 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>