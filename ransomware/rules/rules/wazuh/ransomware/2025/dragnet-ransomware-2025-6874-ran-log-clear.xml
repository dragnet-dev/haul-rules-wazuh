<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6874 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: 447e5bc2-f705-56e2-ae1e-d6ab7df41a2e -->
  <rule id="346651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6874 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>