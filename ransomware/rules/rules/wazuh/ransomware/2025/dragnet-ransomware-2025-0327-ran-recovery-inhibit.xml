<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0327 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 5325d2ee-0936-54a3-b947-750338d284eb -->
  <rule id="234126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0327 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>