<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5167 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bad11879-188a-54cc-a33a-5d7f70e5f826 -->
  <rule id="389118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5167 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>