<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1122 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: e76cc254-f246-5405-9e2f-8773d64af36f -->
  <rule id="280602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1122 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>