<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1566 — Event Log Clearing (beast) | Status: experimental | Sigma ID: 2c4dfc7b-80f0-5e8c-a972-0dc4a2ce2421 -->
  <rule id="122204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1566 — Event Log Clearing (beast)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>