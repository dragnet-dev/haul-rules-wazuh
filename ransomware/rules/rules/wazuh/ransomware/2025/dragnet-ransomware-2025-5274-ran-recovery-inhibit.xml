<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5274 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bff73b7a-7939-5681-9177-b197b0416d11 -->
  <rule id="514779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5274 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>