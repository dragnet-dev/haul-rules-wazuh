<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1521 — Event Log Clearing (J) | Status: experimental | Sigma ID: 6bc2fa8c-b8fc-522f-a8b5-c2aaaa440498 -->
  <rule id="914202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1521 — Event Log Clearing (J)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>