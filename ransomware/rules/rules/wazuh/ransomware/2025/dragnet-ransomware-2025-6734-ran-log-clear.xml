<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6734 — Event Log Clearing (anubis) | Status: test | Sigma ID: 8e8bdaa7-55d9-52a9-8474-3c6ff8a41218 -->
  <rule id="552122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6734 — Event Log Clearing (anubis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>