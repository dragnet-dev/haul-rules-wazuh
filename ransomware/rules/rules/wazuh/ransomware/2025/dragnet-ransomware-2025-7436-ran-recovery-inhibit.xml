<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7436 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: b4bc727b-96e7-5c45-a480-c77be5a4115e -->
  <rule id="337272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7436 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>