<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6718 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 9882e385-03b3-595d-b7af-c8d78631ff49 -->
  <rule id="781263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6718 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>