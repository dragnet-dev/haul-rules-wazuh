<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4643 — Recovery Inhibition (global) | Status: experimental | Sigma ID: 35ef5abd-2849-5aa4-9583-c88acd2a4d06 -->
  <rule id="671930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4643 — Recovery Inhibition (global)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>