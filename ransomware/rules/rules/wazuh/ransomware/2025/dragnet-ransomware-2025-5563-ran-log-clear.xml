<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5563 — Event Log Clearing (blacknevas) | Status: experimental | Sigma ID: 6a55e651-c24f-5c77-a69d-925e4d6ae628 -->
  <rule id="904946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5563 — Event Log Clearing (blacknevas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>