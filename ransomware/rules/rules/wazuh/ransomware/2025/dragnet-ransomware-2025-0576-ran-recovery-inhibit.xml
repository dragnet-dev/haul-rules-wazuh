<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0576 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9eb0042e-9ef2-50f5-bb80-904e29fc4fb6 -->
  <rule id="839004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0576 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>