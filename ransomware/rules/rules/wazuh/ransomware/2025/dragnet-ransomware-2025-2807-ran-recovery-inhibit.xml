<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2807 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 9f8d761c-bcb9-56cd-958c-5545388e5d47 -->
  <rule id="858176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2807 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
