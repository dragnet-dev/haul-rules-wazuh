<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6839 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2bf86330-8809-5f4c-855e-a8cd20c19718 -->
  <rule id="838633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6839 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>