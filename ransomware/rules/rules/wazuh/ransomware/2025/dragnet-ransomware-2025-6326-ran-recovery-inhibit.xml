<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6326 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 9607308b-1a2c-5825-9961-b2eb8e8328d9 -->
  <rule id="707308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6326 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>