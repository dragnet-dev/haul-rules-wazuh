<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5755 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 17dc3a34-e42f-56be-aa74-ff8030f9d818 -->
  <rule id="215783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5755 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>