<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2726 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: c6fbf7e5-736d-5316-ae61-af650e4d640b -->
  <rule id="801277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2726 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>