<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0258 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: ee96ddfa-717b-5c9d-be3a-da99e344b267 -->
  <rule id="817597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0258 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>