<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5884 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 391bb85b-eff8-55f2-8e8c-362088e645b9 -->
  <rule id="202838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5884 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>