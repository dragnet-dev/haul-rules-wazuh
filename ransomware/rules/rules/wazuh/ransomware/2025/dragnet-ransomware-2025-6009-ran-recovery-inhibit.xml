<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6009 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c1b45ce8-bfbe-58c1-8f64-47a0fe8a8a10 -->
  <rule id="515932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6009 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>