<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0178 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 5e28565a-e13d-5422-ad80-0efad134cb30 -->
  <rule id="528565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0178 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>