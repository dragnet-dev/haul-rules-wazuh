<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2045 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 30dcfbe6-fdec-56a6-93d0-455a8501434d -->
  <rule id="322651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2045 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>