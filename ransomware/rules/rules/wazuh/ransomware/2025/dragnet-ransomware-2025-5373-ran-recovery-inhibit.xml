<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5373 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7c895750-fc6b-554e-9dc5-f26c2645bcfd -->
  <rule id="448957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5373 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>