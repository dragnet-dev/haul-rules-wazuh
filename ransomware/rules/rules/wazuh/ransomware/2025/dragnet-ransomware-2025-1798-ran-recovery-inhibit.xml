<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1798 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 672d5af6-a05c-5248-a939-2b4adc57b3d4 -->
  <rule id="922490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1798 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>