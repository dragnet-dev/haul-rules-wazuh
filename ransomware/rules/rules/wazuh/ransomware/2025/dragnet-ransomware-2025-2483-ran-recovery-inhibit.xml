<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2483 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 5937fb22-fab8-52e9-88c0-a71e3a9556af -->
  <rule id="720123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2483 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>