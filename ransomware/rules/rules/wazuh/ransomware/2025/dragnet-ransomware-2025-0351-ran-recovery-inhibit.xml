<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0351 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: fc03f37e-4547-5091-85ef-50016ca2113c -->
  <rule id="532633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0351 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>