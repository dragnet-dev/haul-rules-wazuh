<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6624 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: 554f5a67-184c-5a82-a317-8b4f8e0ea7d4 -->
  <rule id="620730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6624 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>