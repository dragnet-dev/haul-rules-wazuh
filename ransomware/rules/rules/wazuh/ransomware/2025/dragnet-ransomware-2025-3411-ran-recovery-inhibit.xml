<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3411 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 1579ea06-54f2-5caf-9860-ed79a424714f -->
  <rule id="544580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3411 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>