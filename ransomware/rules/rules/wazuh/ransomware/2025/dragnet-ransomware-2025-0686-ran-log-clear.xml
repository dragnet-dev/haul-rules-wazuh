<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0686 — Event Log Clearing (teamxxx) | Status: experimental | Sigma ID: 1042a1dc-7622-5b97-aaa6-c374bd19bb6a -->
  <rule id="969149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0686 — Event Log Clearing (teamxxx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>