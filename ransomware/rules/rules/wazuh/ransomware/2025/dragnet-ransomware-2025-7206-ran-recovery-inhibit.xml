<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7206 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 68631d6b-fe01-58c2-900c-9b505edf17da -->
  <rule id="298109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7206 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>