<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1780 — Recovery Inhibition (bqtlock) | Status: experimental | Sigma ID: 5f5be3fb-724b-5f6d-afce-724f5415e8f2 -->
  <rule id="746703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1780 — Recovery Inhibition (bqtlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>