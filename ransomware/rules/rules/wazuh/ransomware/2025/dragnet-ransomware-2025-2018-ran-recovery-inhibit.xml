<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2018 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: b2f96f40-fa4b-5875-ae08-6f7b28b9ed4b -->
  <rule id="292751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2018 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>