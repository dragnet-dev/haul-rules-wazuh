<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1127 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 2750f351-a94a-5cf0-8790-bbb886926195 -->
  <rule id="901535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1127 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>