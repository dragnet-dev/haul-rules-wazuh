<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7102 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 3bd4cb18-5c8d-59b0-ac6b-02fe3f891d53 -->
  <rule id="751147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7102 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>