<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3468 — Recovery Inhibition (qilin) | Status: test | Sigma ID: aaadce5b-bd3b-50e9-bdbd-67325e75d311 -->
  <rule id="485614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3468 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>