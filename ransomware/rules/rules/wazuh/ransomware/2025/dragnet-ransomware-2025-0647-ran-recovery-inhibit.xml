<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0647 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: dc7149af-185c-59ff-b8e8-93aedae4c191 -->
  <rule id="507149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0647 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>