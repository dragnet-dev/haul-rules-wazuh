<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6267 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: b356ab2e-3f60-5ac4-861e-d4939189e01f -->
  <rule id="307307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6267 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>