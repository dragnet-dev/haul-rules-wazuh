<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1876 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: d56aba1a-9a0f-521a-bad1-7b99b998c2e1 -->
  <rule id="256922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1876 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>