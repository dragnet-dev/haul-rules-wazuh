<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6924 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b214c1a5-5e91-5124-b0e6-de7477cedbd8 -->
  <rule id="994361" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6924 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>