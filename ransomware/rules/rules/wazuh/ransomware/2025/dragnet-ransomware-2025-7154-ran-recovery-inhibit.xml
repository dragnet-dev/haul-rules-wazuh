<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7154 — Recovery Inhibition (anubis) | Status: test | Sigma ID: 81120e46-06ad-5bd4-b02b-adf0eb5c2791 -->
  <rule id="497934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7154 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
