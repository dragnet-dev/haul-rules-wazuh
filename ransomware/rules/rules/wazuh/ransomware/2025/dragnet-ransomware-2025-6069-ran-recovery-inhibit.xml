<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6069 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 7d926d91-f2a3-55e0-93ff-0a66369d2860 -->
  <rule id="314829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6069 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>