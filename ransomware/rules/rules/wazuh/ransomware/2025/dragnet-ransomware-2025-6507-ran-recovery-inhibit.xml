<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6507 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2cf74e96-17d7-5247-bad7-267da08d172e -->
  <rule id="351598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6507 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>