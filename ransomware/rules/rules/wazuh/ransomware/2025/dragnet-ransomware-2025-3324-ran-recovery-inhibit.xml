<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3324 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f1758aab-7b32-56ab-87f0-d916f8bb7c10 -->
  <rule id="728138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3324 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>