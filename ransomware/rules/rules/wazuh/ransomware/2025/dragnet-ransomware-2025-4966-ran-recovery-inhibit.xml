<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4966 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fcb8bb38-ed72-5292-91dd-670f8afe980a -->
  <rule id="552315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4966 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>