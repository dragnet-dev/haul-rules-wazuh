<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4162 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: ad8851e2-ebca-51b7-9fd6-3067c7a88174 -->
  <rule id="938851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4162 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>