<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5690 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6608ef9e-e06e-5a7e-a5e0-da68aea81346 -->
  <rule id="891887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5690 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>