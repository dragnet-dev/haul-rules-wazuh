<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1294 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 45c0d7fd-5e0e-5606-94e5-3ed3c9992260 -->
  <rule id="371337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1294 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>