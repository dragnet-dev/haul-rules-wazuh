<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0574 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a853c32c-e103-542c-a2ae-b4ad0150994d -->
  <rule id="936603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0574 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>