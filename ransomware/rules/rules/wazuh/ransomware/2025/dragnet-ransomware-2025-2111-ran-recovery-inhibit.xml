<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2111 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0736854e-bf07-51a6-ad7c-0f3fe0b8e090 -->
  <rule id="189678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2111 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>