<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1224 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 41bcf2a3-9f14-55bc-ae91-30a04a61aa49 -->
  <rule id="909592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1224 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>