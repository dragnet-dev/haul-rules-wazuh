<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6539 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 6ed6528f-459d-5886-a59f-1cfde7ac67c0 -->
  <rule id="973652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6539 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>