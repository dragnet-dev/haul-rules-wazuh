<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0228 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 91e48ea7-adc3-5e24-b285-7e9291a91feb -->
  <rule id="652782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0228 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>