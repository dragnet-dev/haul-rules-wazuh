<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6607 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 31a43cb5-78f9-5767-a210-d798de510400 -->
  <rule id="464811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6607 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>