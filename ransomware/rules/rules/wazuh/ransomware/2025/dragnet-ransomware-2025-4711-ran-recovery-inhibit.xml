<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4711 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a2cad4a7-6f6b-5913-baae-5c1bf1cd1c19 -->
  <rule id="710374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4711 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>