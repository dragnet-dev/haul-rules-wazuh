<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3118 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 1bd3003d-b654-515b-870a-f71731450d86 -->
  <rule id="953003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3118 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>