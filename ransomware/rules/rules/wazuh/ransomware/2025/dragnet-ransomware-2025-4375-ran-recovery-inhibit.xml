<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4375 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b6e3b20e-18c9-5625-a15c-fecf9db967eb -->
  <rule id="392592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4375 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>