<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1632 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 07793844-8e2b-5cab-8fb4-a7da9796bde6 -->
  <rule id="693844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1632 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>