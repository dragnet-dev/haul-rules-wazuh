<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7843 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 61772c03-5288-5878-984d-62f351e414ba -->
  <rule id="983640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7843 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>