<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4063 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 529c0b6f-6241-58f4-b9a6-81d6e2cff20b -->
  <rule id="556171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4063 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>