<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5513 — Recovery Inhibition (devman) | Status: test | Sigma ID: cf3a7eb2-d6fa-5e33-a997-dfffddf8f552 -->
  <rule id="908606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5513 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>