<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3733 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 2f9ff84a-3a2a-59e9-bed3-2c7f3f319a19 -->
  <rule id="428798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3733 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>