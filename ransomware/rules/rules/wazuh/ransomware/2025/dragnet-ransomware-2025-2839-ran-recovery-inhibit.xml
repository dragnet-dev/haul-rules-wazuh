<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2839 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 6db0b04b-369c-5718-b2b3-bb7eb5d74605 -->
  <rule id="208110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2839 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
