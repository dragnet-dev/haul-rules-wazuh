<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2850 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 23bf5bde-39bf-5c38-a1df-6b6ab6983dae -->
  <rule id="363709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2850 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>