<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3872 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0d03c8fa-25ef-5647-8e4d-e1b4b5dde52b -->
  <rule id="737743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3872 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>