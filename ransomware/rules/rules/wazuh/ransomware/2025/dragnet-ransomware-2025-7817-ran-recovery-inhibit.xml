<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7817 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 40eadc56-1d84-5f3c-8675-685998d8cca2 -->
  <rule id="981564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7817 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>