<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0310 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: 2750cbd5-5318-50b2-9249-31e34d818343 -->
  <rule id="567261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0310 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>