<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2057 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b9a384de-c45f-50a0-944a-85bdacb7b556 -->
  <rule id="214384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2057 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>