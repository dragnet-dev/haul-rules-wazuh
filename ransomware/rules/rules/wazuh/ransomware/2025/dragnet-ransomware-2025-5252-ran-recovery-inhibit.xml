<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5252 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ff371eb9-ddad-5dbd-9a4b-ac0cf5c52dc4 -->
  <rule id="585950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5252 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>