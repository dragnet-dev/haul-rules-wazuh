<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0257 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a0bfa81f-9019-5376-8398-850a3ec20fee -->
  <rule id="626668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0257 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>