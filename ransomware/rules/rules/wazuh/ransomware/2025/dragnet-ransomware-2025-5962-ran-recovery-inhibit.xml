<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5962 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4c4f3602-15d9-59f9-959f-148a2c21d540 -->
  <rule id="423936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5962 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>