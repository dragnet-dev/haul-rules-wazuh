<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1530 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 8631e54c-c59e-5a87-8a18-3c82e7895eea -->
  <rule id="581105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1530 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>