<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0239 — Recovery Inhibition (incransom) | Status: test | Sigma ID: e41e98af-ff01-5774-8bfa-1caa2cfc176b -->
  <rule id="607098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0239 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>