<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0307 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 9125d3da-3999-5aeb-bd81-54252c19264b -->
  <rule id="660133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0307 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>