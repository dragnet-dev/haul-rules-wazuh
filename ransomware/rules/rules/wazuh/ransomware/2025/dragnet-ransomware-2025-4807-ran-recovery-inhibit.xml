<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4807 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c4e4abbb-0bd1-5df7-a1a5-16700791c2cf -->
  <rule id="716075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4807 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>