<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0876 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 92323f3d-02bb-5c56-86cc-cff6b3d4f5f9 -->
  <rule id="677183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0876 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>