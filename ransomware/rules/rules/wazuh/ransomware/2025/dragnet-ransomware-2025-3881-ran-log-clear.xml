<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3881 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 9f9281e4-f6f0-572e-af11-a5b1527c2bdb -->
  <rule id="799281" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3881 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>