<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3648 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e7391966-49c9-5c31-b17b-643ab5d8e346 -->
  <rule id="673919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3648 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>