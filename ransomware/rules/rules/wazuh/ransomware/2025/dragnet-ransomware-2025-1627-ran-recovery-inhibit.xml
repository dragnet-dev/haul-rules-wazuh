<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1627 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: f006161a-25c0-5413-967d-9859cf21f25f -->
  <rule id="700616" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1627 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>