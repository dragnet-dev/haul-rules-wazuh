<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2638 — Event Log Clearing (J) | Status: experimental | Sigma ID: cb31b288-8edc-5f88-bbe1-25ae9aa1a9d1 -->
  <rule id="653072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2638 — Event Log Clearing (J)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>