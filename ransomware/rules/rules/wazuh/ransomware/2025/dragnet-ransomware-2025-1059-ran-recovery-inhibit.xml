<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1059 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a87d2ce8-a8e7-5401-89fb-60becec96a24 -->
  <rule id="184844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1059 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>