<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1735 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: fb0ebf8e-4f6e-510f-bd21-e636f26b6c23 -->
  <rule id="484735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1735 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>