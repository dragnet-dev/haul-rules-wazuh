<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1941 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: a1e9667c-a21b-593b-b8f8-232e3743d23d -->
  <rule id="830966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1941 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>