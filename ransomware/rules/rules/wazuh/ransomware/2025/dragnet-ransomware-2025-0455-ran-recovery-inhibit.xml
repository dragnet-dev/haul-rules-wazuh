<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0455 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7395e8e9-5ac1-58c0-9dfd-aed6784e1220 -->
  <rule id="383348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0455 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>