<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4264 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 1f193e99-8ace-571d-ae54-12e834f7d57e -->
  <rule id="591029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4264 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>