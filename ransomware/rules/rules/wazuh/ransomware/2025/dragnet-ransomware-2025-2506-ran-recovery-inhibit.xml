<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2506 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 368acf4e-e978-5317-8248-195a73148070 -->
  <rule id="710095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2506 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>