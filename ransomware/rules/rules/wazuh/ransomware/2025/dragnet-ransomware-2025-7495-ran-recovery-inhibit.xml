<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7495 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 23f9b46d-7e08-5000-b74e-8e3f168c5fea -->
  <rule id="843546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7495 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>