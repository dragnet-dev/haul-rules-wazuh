<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3445 — Event Log Clearing (sinobi) | Status: experimental | Sigma ID: c723e9cb-1b8a-59b7-a0a8-620fb3c304f4 -->
  <rule id="335829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3445 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>