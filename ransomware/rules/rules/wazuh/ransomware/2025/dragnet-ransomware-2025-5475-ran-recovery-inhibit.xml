<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5475 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 9eabb13a-8f5c-5bee-80e5-633cb4044751 -->
  <rule id="299151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5475 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>