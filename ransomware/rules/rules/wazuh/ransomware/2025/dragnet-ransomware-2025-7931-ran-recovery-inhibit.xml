<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7931 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: cebe50bd-76c8-5047-b6eb-62f38c0e6ffe -->
  <rule id="892650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7931 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>