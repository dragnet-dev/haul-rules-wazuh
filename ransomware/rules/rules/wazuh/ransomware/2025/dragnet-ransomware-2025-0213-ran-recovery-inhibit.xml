<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0213 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d3597366-ac0d-5d15-a5d9-ea38f7734645 -->
  <rule id="535973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0213 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>