<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5977 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 34b492e5-caf5-5ab8-996b-013952a40b74 -->
  <rule id="887886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5977 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>