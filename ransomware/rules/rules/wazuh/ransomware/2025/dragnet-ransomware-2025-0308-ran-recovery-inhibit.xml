<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0308 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 4d47b616-e6d2-56e1-a96d-5eb19f1c7bdf -->
  <rule id="439636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0308 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>