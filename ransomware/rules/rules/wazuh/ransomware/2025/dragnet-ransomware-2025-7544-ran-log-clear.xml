<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7544 — Event Log Clearing (safepay) | Status: test | Sigma ID: 303dd7c9-8689-5e8b-97de-5d4bac8f483e -->
  <rule id="846364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7544 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>