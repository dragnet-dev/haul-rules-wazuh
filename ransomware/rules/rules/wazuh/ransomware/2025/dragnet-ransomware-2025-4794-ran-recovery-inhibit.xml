<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4794 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: a88d6060-fc78-5a51-ace8-690070cb9e7c -->
  <rule id="942160" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4794 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>