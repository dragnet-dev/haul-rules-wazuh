<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6485 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 9697ad60-d641-5abc-89d6-b773ebfe76c6 -->
  <rule id="782605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6485 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>