<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5766 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 8a5d167e-9862-5926-aeff-a53d10469750 -->
  <rule id="517316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5766 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>