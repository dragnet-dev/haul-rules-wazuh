<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6934 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2f6c2059-e316-52fb-b04c-cfbf439ad7bc -->
  <rule id="528205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6934 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>