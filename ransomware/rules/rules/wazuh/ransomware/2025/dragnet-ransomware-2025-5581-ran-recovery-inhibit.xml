<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5581 — Recovery Inhibition (yurei) | Status: experimental | Sigma ID: ad612a66-4154-5415-841e-2c9a0c1ff91c -->
  <rule id="177802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5581 — Recovery Inhibition (yurei)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>