<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7425 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d0708145-e19d-501e-bb51-528013ac3b4f -->
  <rule id="507081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7425 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>