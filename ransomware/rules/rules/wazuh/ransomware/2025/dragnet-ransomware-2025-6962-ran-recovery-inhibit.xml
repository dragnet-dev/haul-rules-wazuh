<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6962 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b01f7e10-5dd2-575c-ade5-5563c3c289f5 -->
  <rule id="221086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6962 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>