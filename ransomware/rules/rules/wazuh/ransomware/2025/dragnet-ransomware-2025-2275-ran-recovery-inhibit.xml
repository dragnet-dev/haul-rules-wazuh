<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2275 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c66dc4a7-543e-5075-993e-9d73d9b129a1 -->
  <rule id="643164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2275 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>