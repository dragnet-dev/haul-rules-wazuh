<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5476 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2accdc60-bf81-5244-8b61-84a245234073 -->
  <rule id="204956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5476 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>