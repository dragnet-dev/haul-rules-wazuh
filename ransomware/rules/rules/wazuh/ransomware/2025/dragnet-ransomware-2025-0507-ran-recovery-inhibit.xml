<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0507 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 01b54a06-75c6-516a-8c4b-badc5c8ac3d7 -->
  <rule id="907406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0507 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>