<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3288 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 7dc92ce9-8ea1-55b8-962e-9fe9fd8dbdd9 -->
  <rule id="620684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3288 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>