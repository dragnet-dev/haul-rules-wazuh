<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7271 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 4aa57fe5-b148-5364-a4a0-410644b048d4 -->
  <rule id="211327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7271 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>