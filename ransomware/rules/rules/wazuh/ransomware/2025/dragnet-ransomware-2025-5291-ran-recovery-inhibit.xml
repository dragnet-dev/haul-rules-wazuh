<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5291 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 58c32a6e-067c-5ca4-93ad-6233b98604e8 -->
  <rule id="704522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5291 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>