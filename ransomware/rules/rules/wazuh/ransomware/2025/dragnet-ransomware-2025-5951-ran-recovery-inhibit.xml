<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5951 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 5bad7a45-3578-5a6b-92de-f271897f5ead -->
  <rule id="255162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5951 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>