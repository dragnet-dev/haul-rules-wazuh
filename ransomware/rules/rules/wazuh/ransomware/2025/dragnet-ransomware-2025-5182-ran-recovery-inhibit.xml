<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5182 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b95320c6-0198-5c3e-a962-38bd00412f22 -->
  <rule id="395320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5182 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>