<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3472 — Event Log Clearing (arkana) | Status: experimental | Sigma ID: d6ad8c36-484d-5545-95fd-0e4ca27744c8 -->
  <rule id="298380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3472 — Event Log Clearing (arkana)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>