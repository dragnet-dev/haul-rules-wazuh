<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5268 — Event Log Clearing (payoutsking) | Status: deprecated | Sigma ID: 8e4708df-18d2-5266-8519-30eb3f7492a2 -->
  <rule id="624708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5268 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>