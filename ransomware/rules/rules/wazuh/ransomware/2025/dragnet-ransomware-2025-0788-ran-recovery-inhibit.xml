<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0788 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ea2ab276-03d8-5a4d-a3dd-54ad3290f2eb -->
  <rule id="697232" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0788 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>