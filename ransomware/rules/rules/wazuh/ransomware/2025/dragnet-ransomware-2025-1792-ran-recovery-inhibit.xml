<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1792 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7eeaae9a-81e8-5e00-af6f-cf176e9ec167 -->
  <rule id="317614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1792 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>