<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5474 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 6177de7b-0397-5eb6-9b77-a32eb831c304 -->
  <rule id="781534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5474 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>