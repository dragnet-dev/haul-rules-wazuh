<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1914 — Shadow Copy Deletion (blacknevas) | Status: test | Sigma ID: 5a7c9b4c-f21f-5c9e-86c0-ed2bd0d59ff9 -->
  <rule id="623995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1914 — Shadow Copy Deletion (blacknevas)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>