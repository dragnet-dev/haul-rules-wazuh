<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1155 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2d5c09a6-7d09-550a-b34d-386879cb48dd -->
  <rule id="967354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1155 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>