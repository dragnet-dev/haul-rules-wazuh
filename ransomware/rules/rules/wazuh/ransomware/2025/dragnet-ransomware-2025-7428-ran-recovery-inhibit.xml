<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7428 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: dc036a36-e446-5806-b46f-4a9f0c860ec5 -->
  <rule id="920586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7428 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>