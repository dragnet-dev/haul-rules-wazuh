<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0768 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: e840743f-9664-5524-95bd-707896e14b44 -->
  <rule id="684074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0768 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>