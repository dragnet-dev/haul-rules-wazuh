<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5022 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 43f204e5-d582-5967-b3e2-a48e61812be9 -->
  <rule id="551278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5022 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>