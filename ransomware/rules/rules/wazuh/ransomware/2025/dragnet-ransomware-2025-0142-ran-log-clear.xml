<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0142 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: d779f3b6-8c93-5bf6-b8e2-7b4d8e3a92a7 -->
  <rule id="504793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0142 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>