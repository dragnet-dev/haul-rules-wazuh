<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4958 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3bdd080c-4bdb-5966-b9f5-62a6f85eebbb -->
  <rule id="732508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4958 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>