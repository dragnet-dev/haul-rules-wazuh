<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5441 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a738d830-ab50-5653-ad5a-8349aeb9c78f -->
  <rule id="918218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5441 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>