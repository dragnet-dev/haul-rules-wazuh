<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5146 — Event Log Clearing (shinyhunters) | Status: experimental | Sigma ID: 13925d89-7e9b-5bbc-8214-5b14aab9903f -->
  <rule id="528138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5146 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>