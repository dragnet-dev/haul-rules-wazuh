<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3615 — Recovery Inhibition (everest) | Status: test | Sigma ID: c3b912b8-91c9-524d-a603-529d9d55436f -->
  <rule id="279912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3615 — Recovery Inhibition (everest)</description>
