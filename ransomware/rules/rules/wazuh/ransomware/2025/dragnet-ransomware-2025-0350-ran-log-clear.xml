<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0350 — Event Log Clearing (skira) | Status: experimental | Sigma ID: 3e0c9e2b-5735-5f7c-b8d1-ca7d6a5b3fe6 -->
  <rule id="789278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0350 — Event Log Clearing (skira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>