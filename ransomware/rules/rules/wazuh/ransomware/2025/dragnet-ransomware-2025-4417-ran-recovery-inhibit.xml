<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4417 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 153189da-a33a-5efe-a1be-256d6c01b884 -->
  <rule id="751037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4417 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>