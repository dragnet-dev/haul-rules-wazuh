<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0176 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 77c3aeb3-8cdd-5ad7-99ae-7d9b3e9a966f -->
  <rule id="585582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0176 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>