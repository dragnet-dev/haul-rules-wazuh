<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6139 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c0c087d5-f2dd-52fd-86e8-ccd40cb6024a -->
  <rule id="232087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6139 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>