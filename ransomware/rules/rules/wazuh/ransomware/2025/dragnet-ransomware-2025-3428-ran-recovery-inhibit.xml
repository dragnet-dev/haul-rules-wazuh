<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3428 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c6587a16-7e58-5e9b-aeab-409a66266dd4 -->
  <rule id="325402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3428 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>