<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2687 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3504c5db-e076-5be0-9fec-55093c007ea9 -->
  <rule id="972253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2687 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>