<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1068 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 7eb93de0-3ae2-51e8-9b26-6f5c112b795b -->
  <rule id="644701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1068 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>