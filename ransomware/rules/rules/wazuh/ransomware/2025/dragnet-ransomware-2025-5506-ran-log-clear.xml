<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5506 — Event Log Clearing (devman) | Status: test | Sigma ID: 1a72ece7-21d7-5d2f-baed-bee66e1b461f -->
  <rule id="248302" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5506 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>