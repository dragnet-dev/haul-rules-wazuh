<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3259 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 63065894-bf8a-511e-ae4a-866737accb71 -->
  <rule id="106589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3259 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>