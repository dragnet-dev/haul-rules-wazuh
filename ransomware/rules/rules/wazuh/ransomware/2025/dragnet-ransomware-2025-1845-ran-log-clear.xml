<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1845 — Event Log Clearing (brotherhood) | Status: experimental | Sigma ID: 59b7a851-7bbc-5672-b9b5-d2393fc33ae5 -->
  <rule id="729228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1845 — Event Log Clearing (brotherhood)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>