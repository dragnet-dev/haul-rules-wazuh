<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1781 — Recovery Inhibition (bqtlock) | Status: experimental | Sigma ID: 092e3f44-d87d-50ed-b1a7-969220107047 -->
  <rule id="678234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1781 — Recovery Inhibition (bqtlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>