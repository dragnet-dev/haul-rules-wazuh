<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5340 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3ca21e8a-ba04-5ef0-a882-781c5b3b9f29 -->
  <rule id="752350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5340 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>