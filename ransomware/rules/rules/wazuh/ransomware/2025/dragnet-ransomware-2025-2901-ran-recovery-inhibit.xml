<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2901 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 28cf6f05-6766-53c2-afdd-12bd879e53d9 -->
  <rule id="380111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2901 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>