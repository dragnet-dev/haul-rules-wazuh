<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2316 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: a87bb3f9-df37-5199-95e5-071eec781c70 -->
  <rule id="184593" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2316 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>