<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2337 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 298aafe3-4a74-5ea8-8f46-873c0250e532 -->
  <rule id="423343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2337 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>