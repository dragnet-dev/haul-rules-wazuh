<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0806 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6048eb1a-a5e7-5b2c-b4eb-07135663b87d -->
  <rule id="748523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0806 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>