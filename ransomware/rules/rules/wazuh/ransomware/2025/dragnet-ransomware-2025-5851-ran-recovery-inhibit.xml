<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5851 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: d1a5d21b-0e6f-54bb-9036-aa70d4bcf77c -->
  <rule id="770532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5851 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>