<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2123 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 446f7817-ab66-5527-8748-c950a0e16e6f -->
  <rule id="951781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2123 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>