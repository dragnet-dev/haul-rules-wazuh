<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5610 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 880fc88e-81e8-5cc3-9605-bc06c3f137d8 -->
  <rule id="555328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5610 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>