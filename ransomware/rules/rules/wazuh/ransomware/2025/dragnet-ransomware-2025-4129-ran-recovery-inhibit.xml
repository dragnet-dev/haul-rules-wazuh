<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4129 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ca2da284-02a1-5214-92bf-842f105441b3 -->
  <rule id="778502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4129 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>