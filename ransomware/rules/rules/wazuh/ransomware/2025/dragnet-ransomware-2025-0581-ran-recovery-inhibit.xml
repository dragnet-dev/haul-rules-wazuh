<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0581 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: c51080cd-8871-5541-983d-e408e1fda5f8 -->
  <rule id="451080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0581 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>