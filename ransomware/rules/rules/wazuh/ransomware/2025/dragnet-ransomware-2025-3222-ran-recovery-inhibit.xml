<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3222 — Recovery Inhibition (everest) | Status: test | Sigma ID: 464e69ff-bd58-5d94-894d-6c2d9407fe94 -->
  <rule id="301919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3222 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>