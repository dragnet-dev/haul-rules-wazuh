<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5627 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 4a8984ed-596e-59b0-858b-5fdd2941eb61 -->
  <rule id="383758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5627 — Recovery Inhibition (worldleaks)</description>
