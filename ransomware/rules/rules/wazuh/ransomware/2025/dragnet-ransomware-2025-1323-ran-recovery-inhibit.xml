<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1323 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9c09b101-97ca-5f23-aecf-a5d28164838e -->
  <rule id="797551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1323 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>