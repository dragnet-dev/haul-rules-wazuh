<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3694 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a9925981-a8e3-5d3d-be33-aeb360a6c8ad -->
  <rule id="299259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3694 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>