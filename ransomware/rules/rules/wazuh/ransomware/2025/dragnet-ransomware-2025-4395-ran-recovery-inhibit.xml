<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4395 — Recovery Inhibition (devman) | Status: test | Sigma ID: 4027e5db-d57c-5c69-b275-06cae65015a4 -->
  <rule id="511453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4395 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>