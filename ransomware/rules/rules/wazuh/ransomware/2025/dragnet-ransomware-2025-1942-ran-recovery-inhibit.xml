<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1942 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 131c864d-8de7-5bae-9e53-295b39e7ee02 -->
  <rule id="408864" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1942 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>