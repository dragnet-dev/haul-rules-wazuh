<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6388 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: e3b2e54f-11de-5832-a9a4-5bed53338e1e -->
  <rule id="178865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6388 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>