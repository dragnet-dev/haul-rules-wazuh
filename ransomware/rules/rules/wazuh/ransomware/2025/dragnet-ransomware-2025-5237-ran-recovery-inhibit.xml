<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5237 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 0c13631a-bc37-5e52-bee7-5d32699dbc04 -->
  <rule id="413631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5237 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>