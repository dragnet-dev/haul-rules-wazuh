<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7699 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 1e3dd37d-180c-590d-a602-94f56814d244 -->
  <rule id="678937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7699 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>