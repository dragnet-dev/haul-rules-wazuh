<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0847 — Event Log Clearing (underground) | Status: experimental | Sigma ID: e8c308f0-1547-54ea-b6c8-046faee5b6c2 -->
  <rule id="680308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0847 — Event Log Clearing (underground)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>