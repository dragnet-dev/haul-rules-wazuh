<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1031 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ddf2be46-7f9b-5670-ab83-8d345c47bbde -->
  <rule id="191262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1031 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>