<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7578 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5048c6f8-3284-5465-9ce4-c554ac68c74c -->
  <rule id="424911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7578 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>