<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6864 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 43a1af35-bc78-51e8-b215-319d635c5de3 -->
  <rule id="987311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6864 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>