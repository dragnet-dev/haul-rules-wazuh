<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5123 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c79567d0-fc08-53a8-8ae5-a6973f783e14 -->
  <rule id="479567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5123 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>