<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6771 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: dd22a863-0aa0-50a4-817d-0c7830aa0b11 -->
  <rule id="939628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6771 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>