<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5406 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 751b581a-d66b-55a7-8656-9206b2d058a4 -->
  <rule id="402758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5406 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>