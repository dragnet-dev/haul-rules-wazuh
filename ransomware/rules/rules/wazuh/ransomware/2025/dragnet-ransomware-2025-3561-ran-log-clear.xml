<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3561 — Event Log Clearing (interlock) | Status: test | Sigma ID: e303ed50-ad81-5013-8e0e-d4d8352428f7 -->
  <rule id="161805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3561 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>