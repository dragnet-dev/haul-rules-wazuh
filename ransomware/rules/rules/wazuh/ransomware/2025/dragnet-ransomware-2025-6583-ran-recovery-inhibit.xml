<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6583 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a805cf8e-ffc2-5f7b-bd0e-77f7cc77f5f5 -->
  <rule id="166287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6583 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>