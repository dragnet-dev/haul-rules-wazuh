<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5361 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 4f913de9-0613-5580-8da5-194106943f13 -->
  <rule id="478621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5361 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>