<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2178 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: a84d270e-9692-539a-84aa-5954e584765b -->
  <rule id="935727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2178 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>