<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1418 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 8dc15924-bb4c-5a4a-9a2c-3afeb4408496 -->
  <rule id="568159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1418 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>