<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4748 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: 5c439f38-fa53-57d0-b7cb-9d7dfe87d17d -->
  <rule id="679039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4748 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>