<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2245 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 05edb30f-7ffc-5e44-92f8-278d7390a31a -->
  <rule id="728330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2245 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>