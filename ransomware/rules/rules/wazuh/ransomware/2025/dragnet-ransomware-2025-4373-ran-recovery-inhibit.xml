<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4373 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 25fca613-8ad3-5365-ab2e-bdc8a89e336b -->
  <rule id="264426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4373 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>