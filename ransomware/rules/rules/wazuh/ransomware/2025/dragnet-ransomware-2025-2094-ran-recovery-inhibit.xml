<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2094 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 2ae1b43e-c491-5803-9ee9-ab4e992cb488 -->
  <rule id="297874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2094 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>