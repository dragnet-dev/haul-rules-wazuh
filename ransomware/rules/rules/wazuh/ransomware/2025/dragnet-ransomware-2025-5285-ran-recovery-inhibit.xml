<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5285 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 63bc9172-90c2-5bc7-b090-b031b43154ff -->
  <rule id="831691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5285 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>