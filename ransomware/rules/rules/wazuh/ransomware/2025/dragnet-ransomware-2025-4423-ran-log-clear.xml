<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4423 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: 168bc7bb-fb70-54c4-8172-9a5a1e0a76f2 -->
  <rule id="711483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4423 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>