<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7474 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 374780c1-dc5d-5738-aef6-41839b980b7a -->
  <rule id="696492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7474 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>