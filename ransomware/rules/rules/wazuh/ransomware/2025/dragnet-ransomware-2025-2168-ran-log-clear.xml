<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2168 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 7394f8ee-34e4-51c3-a111-10ae2d0217b2 -->
  <rule id="383198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2168 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>