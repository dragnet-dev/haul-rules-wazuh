<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3530 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8199b541-114c-5cfa-b2d3-f472b82fb13c -->
  <rule id="511955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3530 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>