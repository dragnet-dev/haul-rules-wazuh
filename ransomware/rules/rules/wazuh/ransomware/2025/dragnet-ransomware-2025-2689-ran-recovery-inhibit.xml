<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2689 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 46212119-95d5-5ccf-a2c6-df161c25d810 -->
  <rule id="221211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2689 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>