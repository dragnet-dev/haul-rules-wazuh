<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6166 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 591f77e0-90e9-53ef-a902-c3fa824c8ef2 -->
  <rule id="854846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6166 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>