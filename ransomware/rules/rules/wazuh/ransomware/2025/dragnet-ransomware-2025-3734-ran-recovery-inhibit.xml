<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3734 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 545b2097-a712-573a-ab58-b4aaf7bf1616 -->
  <rule id="731209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3734 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>