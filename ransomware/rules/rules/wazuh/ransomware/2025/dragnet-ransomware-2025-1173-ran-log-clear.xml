<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1173 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 17be82cb-adbd-5dd6-acf6-2f50fe4cf6a8 -->
  <rule id="168524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1173 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>