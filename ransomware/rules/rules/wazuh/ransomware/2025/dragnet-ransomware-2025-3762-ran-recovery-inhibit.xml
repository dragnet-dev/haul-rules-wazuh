<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3762 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 68f5117f-959d-58ad-8a22-b726216672c2 -->
  <rule id="303511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3762 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>