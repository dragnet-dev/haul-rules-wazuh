<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0141 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: a962ce32-8e59-55f0-90fa-5bb4b53f5dc2 -->
  <rule id="206478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0141 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>