<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3099 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: a6de4ae4-2a2b-5e48-b7d1-ace2ea0d9e3f -->
  <rule id="877354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3099 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>