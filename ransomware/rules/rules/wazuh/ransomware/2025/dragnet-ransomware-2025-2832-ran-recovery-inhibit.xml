<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2832 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 8330cfa3-95cc-5fd9-9eb1-107893936f50 -->
  <rule id="432687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2832 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>