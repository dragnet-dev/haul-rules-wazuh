<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2549 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e68e8991-3f80-5f2d-a137-4e7c9fa99fb2 -->
  <rule id="650289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2549 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>