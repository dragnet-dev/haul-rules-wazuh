<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1317 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 27975c75-52c1-5786-a681-792072a8d63e -->
  <rule id="976127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1317 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>