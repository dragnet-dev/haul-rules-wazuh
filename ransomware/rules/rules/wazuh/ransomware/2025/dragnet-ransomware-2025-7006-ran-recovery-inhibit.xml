<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7006 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4d08847b-3515-5a94-93f5-cc246c5cedc3 -->
  <rule id="608847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7006 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>