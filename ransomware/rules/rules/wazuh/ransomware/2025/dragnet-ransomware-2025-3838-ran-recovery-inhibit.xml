<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3838 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: b7658e96-9f85-511a-ae98-32e3ffb0613b -->
  <rule id="182542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3838 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
