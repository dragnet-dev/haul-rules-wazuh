<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1206 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ba1d7ae9-d4b8-5645-a71a-33c3e6d91968 -->
  <rule id="366362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1206 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>