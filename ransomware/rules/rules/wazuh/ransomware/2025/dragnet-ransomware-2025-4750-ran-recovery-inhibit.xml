<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4750 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 7e4f03e4-7e9c-5fcb-a120-a98c3d47f146 -->
  <rule id="323903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4750 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>