<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1776 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b81c5120-672a-5b78-b1e3-a9bc2b22716e -->
  <rule id="190851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1776 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>