<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5740 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 90490b45-2b50-5fd5-9320-8b3f7c5725bd -->
  <rule id="647851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5740 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>