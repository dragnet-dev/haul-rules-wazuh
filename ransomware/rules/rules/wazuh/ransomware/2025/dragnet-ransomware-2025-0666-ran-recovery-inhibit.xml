<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0666 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5fd0eb73-bcad-545c-a5a4-6250bac7538d -->
  <rule id="424715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0666 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>