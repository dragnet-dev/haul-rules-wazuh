<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4978 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: fb48872a-9f86-587b-a582-f66d93eac874 -->
  <rule id="814887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4978 — Recovery Inhibition (funksec)</description>
