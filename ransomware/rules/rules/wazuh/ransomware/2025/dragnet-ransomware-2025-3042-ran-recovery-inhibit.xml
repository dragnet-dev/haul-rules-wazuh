<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3042 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: db975d39-49f8-51f7-831f-e173920dca62 -->
  <rule id="919613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3042 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>