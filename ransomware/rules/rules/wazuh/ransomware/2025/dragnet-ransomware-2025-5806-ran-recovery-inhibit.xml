<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5806 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e24d0bc8-490e-506c-baac-14464e21f62d -->
  <rule id="147531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5806 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>