<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6135 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2a369a20-ec56-597a-b8eb-a3ad4b0d7bfe -->
  <rule id="579142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6135 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>