<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6650 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: eab7d530-f492-5527-bf33-9a1c55cb0193 -->
  <rule id="709255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6650 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>