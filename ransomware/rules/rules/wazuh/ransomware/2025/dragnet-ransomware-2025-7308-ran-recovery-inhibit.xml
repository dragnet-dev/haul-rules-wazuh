<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7308 — Recovery Inhibition (qilin) | Status: test | Sigma ID: d4fb8e18-7e5e-53dc-9053-96049e3713b9 -->
  <rule id="228942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7308 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>