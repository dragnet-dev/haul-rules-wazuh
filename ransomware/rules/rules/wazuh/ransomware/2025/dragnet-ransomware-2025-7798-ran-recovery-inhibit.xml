<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7798 — Recovery Inhibition (morpheus) | Status: deprecated | Sigma ID: 16bd41b9-52ea-5125-9073-f9ae740478a8 -->
  <rule id="656667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7798 — Recovery Inhibition (morpheus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
