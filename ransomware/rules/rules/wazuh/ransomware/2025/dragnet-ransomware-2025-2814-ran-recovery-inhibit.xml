<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2814 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: e71deef1-6811-54d1-a6a7-58de9c640f30 -->
  <rule id="728782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2814 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>