<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3429 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: f9c746f0-ab02-57af-ac34-0e276032532b -->
  <rule id="856746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3429 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>