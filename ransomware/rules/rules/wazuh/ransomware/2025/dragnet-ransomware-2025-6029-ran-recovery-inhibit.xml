<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6029 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1637859c-295f-56af-8623-6606e53bd52a -->
  <rule id="837859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6029 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>