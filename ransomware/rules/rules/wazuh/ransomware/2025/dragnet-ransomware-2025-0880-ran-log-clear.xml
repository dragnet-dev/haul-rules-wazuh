<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0880 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: f93d9d13-5a79-583c-b348-5b1de5bf226d -->
  <rule id="580317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0880 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>