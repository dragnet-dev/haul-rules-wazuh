<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0423 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 308cbc7e-4654-5c38-aa34-90e9df5560a9 -->
  <rule id="464828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0423 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>