<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0926 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 74aa3b7c-f9dc-534e-8d88-968a09290d02 -->
  <rule id="458299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0926 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>