<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6560 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: bf8edd54-b94f-5a56-8d06-395bc6e2b508 -->
  <rule id="759933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6560 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>