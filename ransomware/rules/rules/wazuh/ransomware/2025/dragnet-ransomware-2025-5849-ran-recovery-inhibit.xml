<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5849 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 4802c919-e9ee-50df-bfff-57ee01161449 -->
  <rule id="584491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5849 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>