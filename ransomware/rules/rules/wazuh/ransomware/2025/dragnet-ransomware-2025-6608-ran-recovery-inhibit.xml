<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6608 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2aae483b-738c-5fb5-896b-e868a8abb930 -->
  <rule id="292648" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6608 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>