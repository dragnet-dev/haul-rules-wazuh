<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0237 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ce34597a-4ca4-5f5c-b9f6-1d8e2d891320 -->
  <rule id="363459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0237 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>