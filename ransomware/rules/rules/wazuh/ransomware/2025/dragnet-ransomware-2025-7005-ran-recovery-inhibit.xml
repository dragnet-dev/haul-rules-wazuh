<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7005 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: e3ef1320-24e0-524a-91f5-0e44f9dd9c74 -->
  <rule id="184713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7005 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>