<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5646 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 81a1b2dd-4d02-50aa-8fb0-cedb2102da19 -->
  <rule id="389872" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5646 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>