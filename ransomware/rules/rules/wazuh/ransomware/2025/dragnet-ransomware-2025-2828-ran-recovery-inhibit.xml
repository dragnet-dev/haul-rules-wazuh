<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2828 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6ff5201e-ff88-5360-96d2-1492e8b9c7d1 -->
  <rule id="991520" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2828 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>