<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1828 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: f05cfcbf-31da-56c0-9802-e2e40a287e80 -->
  <rule id="867804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1828 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>