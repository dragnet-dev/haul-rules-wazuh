<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3209 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 3b25d2d4-94ab-52d3-add4-acdca823c890 -->
  <rule id="870125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3209 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>