<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0832 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a70d0783-4911-556b-8641-724485dfcf41 -->
  <rule id="913307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0832 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>