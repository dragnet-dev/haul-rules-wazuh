<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3856 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7f1cdeba-b183-5052-aaa5-7b46e40eb53c -->
  <rule id="809310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3856 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>