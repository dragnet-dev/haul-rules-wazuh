<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5086 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 99736628-d825-5822-95e8-3f09ea7e3d8d -->
  <rule id="173662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5086 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>