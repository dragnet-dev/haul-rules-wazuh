<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2775 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 85f45820-1185-58aa-8aeb-02f38e804063 -->
  <rule id="575458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2775 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>