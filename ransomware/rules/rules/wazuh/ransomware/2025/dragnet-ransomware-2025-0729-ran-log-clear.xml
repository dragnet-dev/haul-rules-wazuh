<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0729 — Event Log Clearing (cactus) | Status: experimental | Sigma ID: 02e56d3f-d6ba-5dbc-b97d-9b8ea9284cd8 -->
  <rule id="321503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0729 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>