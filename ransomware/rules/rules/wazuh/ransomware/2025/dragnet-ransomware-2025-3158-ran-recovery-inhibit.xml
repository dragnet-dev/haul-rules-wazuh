<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3158 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 62948b62-dfaa-504a-b6e9-5af16ff068ce -->
  <rule id="207179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3158 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>