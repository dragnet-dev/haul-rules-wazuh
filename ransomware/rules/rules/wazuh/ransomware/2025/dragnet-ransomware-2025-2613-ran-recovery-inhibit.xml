<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2613 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 208fad7d-3412-5fe6-9ae0-edec466df4d3 -->
  <rule id="559817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2613 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>