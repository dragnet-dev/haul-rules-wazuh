<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2013 — Recovery Inhibition (spacebears) | Status: test | Sigma ID: a402c904-32a7-5c6a-9fbe-f33ba80792f2 -->
  <rule id="864449" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2013 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>