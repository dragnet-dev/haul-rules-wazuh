<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1185 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fe16a074-6039-5de9-985d-8e24a3b7bca7 -->
  <rule id="566660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1185 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>