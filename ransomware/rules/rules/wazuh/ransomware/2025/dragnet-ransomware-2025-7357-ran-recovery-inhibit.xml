<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7357 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 26935a87-e2c7-58e8-9857-b196be2cbdae -->
  <rule id="809708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7357 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>