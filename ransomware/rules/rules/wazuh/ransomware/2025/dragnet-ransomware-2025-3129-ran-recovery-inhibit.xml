<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3129 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: eda8a9f1-5009-5731-8978-1bcc6b8192d5 -->
  <rule id="784589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3129 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>