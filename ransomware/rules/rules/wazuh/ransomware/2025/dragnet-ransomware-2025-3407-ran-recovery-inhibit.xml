<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3407 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: dc6b643c-d781-5fbb-80e8-4a21fd2b9624 -->
  <rule id="930764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3407 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>