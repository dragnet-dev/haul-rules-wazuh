<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5614 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 756062e5-c961-541e-acb6-2a3ceb2c978e -->
  <rule id="497006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5614 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>