<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0928 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: a799e6fa-08f9-5e89-8017-ad50d1b0b1f6 -->
  <rule id="927986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0928 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>