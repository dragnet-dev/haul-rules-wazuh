<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4401 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 759f9ea4-1daa-500b-92e9-247e67f48717 -->
  <rule id="245598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4401 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>