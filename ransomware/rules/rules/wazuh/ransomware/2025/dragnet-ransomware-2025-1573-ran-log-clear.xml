<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1573 — Event Log Clearing (VanHelsing) | Status: experimental | Sigma ID: 4ab1939a-aeb0-5135-9a05-be2529893f10 -->
  <rule id="395193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1573 — Event Log Clearing (VanHelsing)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>