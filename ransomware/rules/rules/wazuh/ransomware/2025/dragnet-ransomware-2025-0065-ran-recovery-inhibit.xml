<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0065 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8c8aec39-9dda-5fb6-b03f-91848a63a7d5 -->
  <rule id="469964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0065 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>