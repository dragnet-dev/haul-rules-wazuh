<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2592 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 2f6b01b6-e10d-516c-8b5a-81637d2be59a -->
  <rule id="603227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2592 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>