<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1259 — Event Log Clearing (rebornvc) | Status: deprecated | Sigma ID: 02f2d11a-b344-5768-a2ea-7fa662643b6b -->
  <rule id="504186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1259 — Event Log Clearing (rebornvc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>