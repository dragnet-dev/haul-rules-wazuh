<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7065 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c5d26c4a-cca4-5e98-97bb-96eb52448d2a -->
  <rule id="621228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7065 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>