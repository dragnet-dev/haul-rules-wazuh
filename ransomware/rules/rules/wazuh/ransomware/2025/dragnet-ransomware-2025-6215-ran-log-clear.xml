<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6215 — Event Log Clearing (kairos) | Status: deprecated | Sigma ID: 9245cf7b-a0ab-5872-a0e2-f95ba8b96661 -->
  <rule id="666927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6215 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>