<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2122 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8c95e1dd-0c32-554f-92a5-303f8d11223f -->
  <rule id="555341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2122 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>