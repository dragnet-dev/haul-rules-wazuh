<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0547 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 856b0ffc-23e3-5baa-81d0-a942812e3069 -->
  <rule id="493135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0547 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>