<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1346 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bcb4d302-23d3-534a-bf42-cf048a85c6f0 -->
  <rule id="431173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1346 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>