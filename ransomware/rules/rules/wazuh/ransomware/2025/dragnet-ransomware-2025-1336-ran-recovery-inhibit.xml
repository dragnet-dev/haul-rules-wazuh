<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1336 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: da642e4f-375f-5452-af87-bb58a0c30cfa -->
  <rule id="898286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1336 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>