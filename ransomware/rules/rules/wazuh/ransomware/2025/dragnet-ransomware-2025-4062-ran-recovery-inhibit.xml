<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4062 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3f521077-daea-56f9-a1eb-c507d177fe75 -->
  <rule id="152107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4062 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>