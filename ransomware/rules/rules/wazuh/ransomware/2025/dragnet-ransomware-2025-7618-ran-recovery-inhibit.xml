<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7618 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 389a81d7-7cc8-5668-b112-6fff9e026817 -->
  <rule id="175709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7618 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>