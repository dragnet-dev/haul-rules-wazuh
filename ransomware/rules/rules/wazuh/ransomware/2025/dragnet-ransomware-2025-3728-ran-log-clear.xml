<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3728 — Event Log Clearing (apos) | Status: deprecated | Sigma ID: f227963b-f438-55bf-9295-dd214359f2c4 -->
  <rule id="722796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3728 — Event Log Clearing (apos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>