<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7094 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 9f93bddd-81d4-502e-b365-a842fb79c17a -->
  <rule id="594397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7094 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>