<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6956 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: dfe4dfcf-0e0b-5b2b-8865-0980631b9e67 -->
  <rule id="271167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6956 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
