<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7010 — Event Log Clearing (brotherhood) | Status: deprecated | Sigma ID: 2ae5f817-405e-5ffe-982f-b8ffa7b061e9 -->
  <rule id="298558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7010 — Event Log Clearing (brotherhood)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>