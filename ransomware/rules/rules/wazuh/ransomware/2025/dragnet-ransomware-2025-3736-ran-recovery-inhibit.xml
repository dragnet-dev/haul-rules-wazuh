<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3736 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 38851911-ff9f-5f74-b0a5-ca5f392d2fb3 -->
  <rule id="385191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3736 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>