<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2630 — Event Log Clearing (d4rk4rmy) | Status: deprecated | Sigma ID: e3bf545c-f45a-5c2d-afa0-d21ca3b9f382 -->
  <rule id="179954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2630 — Event Log Clearing (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>