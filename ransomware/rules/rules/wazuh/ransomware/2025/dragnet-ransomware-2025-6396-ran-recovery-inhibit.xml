<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6396 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 9452b2d1-218d-5258-87eb-6141d5a97b30 -->
  <rule id="712432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6396 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>