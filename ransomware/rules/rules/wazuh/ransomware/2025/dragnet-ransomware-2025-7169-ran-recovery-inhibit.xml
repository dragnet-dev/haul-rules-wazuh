<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7169 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1919981b-6f82-57b2-9d72-83f062009ea8 -->
  <rule id="219981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7169 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>