<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3193 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 82541283-0c94-5ad6-a277-5f3971e8c109 -->
  <rule id="254128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3193 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>