<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3909 — Recovery Inhibition (J) | Status: experimental | Sigma ID: e1228ffc-1119-5a86-bd37-44cd5c8208fe -->
  <rule id="559663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3909 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>