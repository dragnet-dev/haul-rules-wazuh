<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6229 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a33211e2-e231-5fc4-a3fe-53c0a03bfa49 -->
  <rule id="233211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6229 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>