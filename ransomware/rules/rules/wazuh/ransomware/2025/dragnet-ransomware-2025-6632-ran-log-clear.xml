<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6632 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 86ba9f6b-bd41-5d9d-9fe3-58473c7a1d9d -->
  <rule id="952479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6632 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>