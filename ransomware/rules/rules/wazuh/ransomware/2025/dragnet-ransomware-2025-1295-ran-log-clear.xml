<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1295 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: f04b90a1-9c6c-5a62-8cd5-fc39cb4de5f7 -->
  <rule id="707590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1295 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>