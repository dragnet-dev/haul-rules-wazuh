<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1522 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: dd784ba6-2cd1-5d20-b49a-aa9c63dff1ed -->
  <rule id="948555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1522 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>