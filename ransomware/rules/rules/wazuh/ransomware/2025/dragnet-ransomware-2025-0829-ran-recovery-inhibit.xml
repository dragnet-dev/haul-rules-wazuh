<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0829 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 78ef9546-f214-52f1-8fb1-5b6de3b60bed -->
  <rule id="320795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0829 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>