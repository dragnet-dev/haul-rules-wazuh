<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2119 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: aae4acb7-41b5-5f1a-b61e-89901105af45 -->
  <rule id="800236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2119 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>