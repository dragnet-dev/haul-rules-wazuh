<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3334 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 830e9ea7-b76e-5c7c-b0ac-1bc81cbea1b4 -->
  <rule id="427198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3334 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>