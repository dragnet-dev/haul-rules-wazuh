<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6850 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 5591fef0-b4cc-57e5-821f-ddf243c3f285 -->
  <rule id="631550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6850 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>