<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6263 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ab060d5a-2f80-536d-85ec-9c17e2a42682 -->
  <rule id="136973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6263 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>