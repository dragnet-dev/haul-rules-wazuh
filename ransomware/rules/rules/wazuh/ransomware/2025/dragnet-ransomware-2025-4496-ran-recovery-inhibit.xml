<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4496 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: a63f5c9e-e64e-578b-83f1-dd8772f04d26 -->
  <rule id="123772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4496 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>