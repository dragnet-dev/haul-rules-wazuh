<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1355 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 1b971bc1-7341-51bf-be6b-1527f3767740 -->
  <rule id="960764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1355 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>