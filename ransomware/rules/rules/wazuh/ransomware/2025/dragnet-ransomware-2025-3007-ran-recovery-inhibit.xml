<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3007 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 90612aa4-ef0e-5048-9108-36158969adfe -->
  <rule id="649802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3007 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>