<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6168 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1e460c76-9e1c-5a86-addd-0fb6e3dcb1a8 -->
  <rule id="473727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6168 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>