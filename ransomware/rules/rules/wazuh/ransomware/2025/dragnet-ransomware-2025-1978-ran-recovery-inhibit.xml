<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1978 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 822e5794-8e16-57a2-b7e7-0919f8c2289f -->
  <rule id="516657" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1978 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>