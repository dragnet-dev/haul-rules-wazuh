<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4707 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 81686e1f-fc6e-5444-aee2-bd9668e74f20 -->
  <rule id="506990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4707 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>