<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6387 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 71dbc679-b2e0-51a2-825f-0136eb1bf772 -->
  <rule id="343326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6387 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>