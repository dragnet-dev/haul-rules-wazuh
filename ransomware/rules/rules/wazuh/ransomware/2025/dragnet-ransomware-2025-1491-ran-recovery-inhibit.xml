<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1491 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 43cb636f-3570-5e09-aa86-959782a8aa18 -->
  <rule id="321163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1491 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>