<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2059 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 93053210-68b2-5514-b502-ffcf40b10a3b -->
  <rule id="405321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2059 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>