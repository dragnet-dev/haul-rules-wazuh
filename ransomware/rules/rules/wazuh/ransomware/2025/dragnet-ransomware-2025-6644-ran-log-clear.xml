<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6644 — Event Log Clearing (global) | Status: deprecated | Sigma ID: 7f4ba3aa-c4e3-5df6-b8ef-c19fdb366c3d -->
  <rule id="663303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6644 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>