<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3675 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c8c065e-46b8-5848-b3b2-46298d0e9c0e -->
  <rule id="298006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3675 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>