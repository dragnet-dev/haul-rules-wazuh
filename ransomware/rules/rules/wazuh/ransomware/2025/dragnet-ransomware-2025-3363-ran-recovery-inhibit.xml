<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3363 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: a9eff323-fdc2-5b46-a8ca-8b0c0c1c6b86 -->
  <rule id="103033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3363 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
