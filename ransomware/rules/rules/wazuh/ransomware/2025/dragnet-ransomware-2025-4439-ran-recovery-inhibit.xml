<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4439 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 40323b9a-3950-505a-acd3-96a372b4256a -->
  <rule id="251799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4439 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>