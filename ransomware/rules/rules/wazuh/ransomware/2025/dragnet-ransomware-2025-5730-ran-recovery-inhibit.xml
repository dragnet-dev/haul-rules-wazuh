<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5730 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: cab89f10-4142-5cd0-a499-fb3a164cf79c -->
  <rule id="790239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5730 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>