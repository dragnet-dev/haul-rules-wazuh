<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3987 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d9301e7b-23d9-529d-9648-e4b9f312cacd -->
  <rule id="528830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3987 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>