<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7311 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 40fc6d38-c55c-5556-8198-5a6bb19f5bfa -->
  <rule id="878829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7311 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>