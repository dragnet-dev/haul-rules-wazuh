<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1531 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: be0f1c82-b6b5-5ab8-a060-6da6a12ca0b1 -->
  <rule id="466428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1531 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>