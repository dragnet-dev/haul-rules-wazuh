<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5843 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 7bdcd486-9ba3-5ee0-b2db-02c9383d49a9 -->
  <rule id="673414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5843 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>