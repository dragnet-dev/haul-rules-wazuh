<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3727 — Recovery Inhibition (skira) | Status: experimental | Sigma ID: 0a195239-a4a8-5704-9222-c6de036a5a55 -->
  <rule id="219523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3727 — Recovery Inhibition (skira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>