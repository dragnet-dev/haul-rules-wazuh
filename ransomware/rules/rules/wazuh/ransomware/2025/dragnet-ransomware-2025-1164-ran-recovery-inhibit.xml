<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1164 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 0684e38e-b8a1-53eb-b5db-e17f6c189ace -->
  <rule id="295838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1164 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>