<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6892 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: e50ad8f6-4f03-59dd-b624-6fe10015dd2c -->
  <rule id="213738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6892 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>