<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0178 — Event Log Clearing (kraken) | Status: experimental | Sigma ID: 1148f0a0-fb1f-5f85-b5d4-57b4f600d6b8 -->
  <rule id="341290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0178 — Event Log Clearing (kraken)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>