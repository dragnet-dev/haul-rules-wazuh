<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3180 — Event Log Clearing (medusalocker) | Status: experimental | Sigma ID: ede7fe32-1c43-5eea-b832-0e04a63ce5c2 -->
  <rule id="845406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3180 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>