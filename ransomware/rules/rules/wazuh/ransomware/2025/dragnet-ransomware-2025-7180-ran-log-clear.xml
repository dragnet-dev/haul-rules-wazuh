<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7180 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 380dc54e-2d0e-5cb1-80c1-c08efe5a98a6 -->
  <rule id="850054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7180 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>