<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0602 — Recovery Inhibition (silent) | Status: experimental | Sigma ID: fc87908f-f43a-50ec-b479-e3964ac04249 -->
  <rule id="828790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0602 — Recovery Inhibition (silent)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>