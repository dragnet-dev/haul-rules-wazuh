<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5759 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: eac9a231-0f2f-5cc5-86c2-73ecc517a4f6 -->
  <rule id="711142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5759 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>