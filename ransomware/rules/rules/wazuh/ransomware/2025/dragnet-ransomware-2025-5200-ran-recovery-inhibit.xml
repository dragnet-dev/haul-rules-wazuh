<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5200 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 8581040a-7bf7-5254-96c8-c4e2af173f07 -->
  <rule id="581040" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5200 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>