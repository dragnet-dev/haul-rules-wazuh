<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7106 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1ec3b6d0-ab63-55d3-b0cf-2c5bacf52bd3 -->
  <rule id="104749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7106 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>