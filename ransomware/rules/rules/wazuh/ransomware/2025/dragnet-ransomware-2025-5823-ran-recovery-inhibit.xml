<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5823 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b2d1b6a5-36b0-5b8a-a507-be93316f7848 -->
  <rule id="288276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5823 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>