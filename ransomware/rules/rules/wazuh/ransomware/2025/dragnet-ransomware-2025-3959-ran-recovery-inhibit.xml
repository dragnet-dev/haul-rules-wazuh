<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3959 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ff1f8392-fdae-57f1-b86d-2d4b4255fbee -->
  <rule id="583183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3959 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>