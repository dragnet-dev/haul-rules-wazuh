<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7121 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 71fb016d-e8d4-5935-b4d8-3a36d6308b9b -->
  <rule id="142701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7121 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>