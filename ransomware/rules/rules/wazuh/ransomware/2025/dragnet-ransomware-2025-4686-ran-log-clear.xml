<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4686 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: f9aefbc2-6281-5b18-9a6e-c966bef8bf46 -->
  <rule id="665019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4686 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>