<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6935 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: cb378a84-6e15-57f6-85f8-064ee9850ffc -->
  <rule id="654058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6935 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>