<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4237 — Recovery Inhibition (VanHelsing) | Status: experimental | Sigma ID: 802237d5-d4af-5a8c-8daa-f984ecbeebe8 -->
  <rule id="335805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4237 — Recovery Inhibition (VanHelsing)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>