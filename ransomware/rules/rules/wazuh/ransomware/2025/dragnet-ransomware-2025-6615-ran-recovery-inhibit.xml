<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6615 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 5d31cd0c-07c8-5504-9533-36f594ed465a -->
  <rule id="688941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6615 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>