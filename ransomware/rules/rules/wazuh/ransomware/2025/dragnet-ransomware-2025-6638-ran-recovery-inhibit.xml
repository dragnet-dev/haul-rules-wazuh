<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6638 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 3175db69-d9a6-5ea0-b26d-7aec000111cb -->
  <rule id="130196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6638 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>