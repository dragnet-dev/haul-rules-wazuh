<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4194 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4c09274b-2f7e-557f-9dce-f7a48d88a412 -->
  <rule id="509274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4194 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>