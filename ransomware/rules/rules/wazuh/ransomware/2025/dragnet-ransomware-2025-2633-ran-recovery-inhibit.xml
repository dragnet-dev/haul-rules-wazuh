<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2633 — Recovery Inhibition (play) | Status: experimental | Sigma ID: df8a4e4a-3410-5f62-9966-de2b9d1b83bc -->
  <rule id="430958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2633 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>