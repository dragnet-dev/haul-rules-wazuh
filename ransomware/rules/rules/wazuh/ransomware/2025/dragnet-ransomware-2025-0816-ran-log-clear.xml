<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0816 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 5bf5c2c6-1669-5ada-b22e-6fe76f2b37c3 -->
  <rule id="654522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0816 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>