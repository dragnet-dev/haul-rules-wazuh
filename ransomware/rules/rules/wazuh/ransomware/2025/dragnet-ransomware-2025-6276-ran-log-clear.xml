<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6276 — Event Log Clearing (sinobi) | Status: experimental | Sigma ID: d3ee4f16-5b7a-5a25-9df1-1c7d2ed8c0de -->
  <rule id="185839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6276 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>