<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3361 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: c424d87a-c64d-5895-bbd2-c626ee4ae632 -->
  <rule id="287978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3361 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>