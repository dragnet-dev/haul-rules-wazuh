<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3521 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 2f1565d3-93b5-598f-9e6b-fd6a69026ef1 -->
  <rule id="445053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3521 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>