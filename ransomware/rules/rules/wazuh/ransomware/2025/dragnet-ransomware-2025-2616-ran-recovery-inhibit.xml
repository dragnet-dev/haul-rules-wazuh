<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2616 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 95e475f5-c400-5e12-8599-52bf50e5fe85 -->
  <rule id="734475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2616 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>