<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6909 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 490b5924-099e-5cca-9014-0e833e71cc57 -->
  <rule id="751592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6909 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>