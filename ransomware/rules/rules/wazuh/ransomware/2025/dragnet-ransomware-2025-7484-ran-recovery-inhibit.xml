<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7484 — Recovery Inhibition (direwolf) | Status: test | Sigma ID: c6e499ed-ef37-54ea-88a2-73ff26bac310 -->
  <rule id="330499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7484 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>