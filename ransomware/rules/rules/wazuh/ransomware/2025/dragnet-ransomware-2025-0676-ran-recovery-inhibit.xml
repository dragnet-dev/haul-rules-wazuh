<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0676 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: dd1d20db-96f7-5063-a5e5-50b5d87139bf -->
  <rule id="938920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0676 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>