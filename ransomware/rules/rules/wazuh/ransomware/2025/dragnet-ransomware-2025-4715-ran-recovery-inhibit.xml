<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4715 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: d6cfb619-6253-5dd0-81a8-631aae00e671 -->
  <rule id="303796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4715 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>