<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7191 — Recovery Inhibition (medusa) | Status: test | Sigma ID: 494f110b-5534-54ab-979d-549afaa8ff6b -->
  <rule id="819110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7191 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>