<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4424 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 5e0d2824-4ff4-5c57-ac46-24372f9661f6 -->
  <rule id="705328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4424 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>