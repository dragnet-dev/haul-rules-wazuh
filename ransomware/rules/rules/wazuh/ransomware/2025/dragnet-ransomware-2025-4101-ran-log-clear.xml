<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4101 — Event Log Clearing (moneymessage) | Status: experimental | Sigma ID: 3c4ba1b8-9529-5713-982f-5e49368757d8 -->
  <rule id="748101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4101 — Event Log Clearing (moneymessage)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>