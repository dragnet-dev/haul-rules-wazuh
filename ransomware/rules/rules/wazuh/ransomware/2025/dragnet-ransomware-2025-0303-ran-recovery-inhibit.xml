<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0303 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 75126940-e35e-5f07-8e2c-aa8298f4d831 -->
  <rule id="412694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0303 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>