<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2962 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 92c813cf-4ba0-580f-ae82-a31f206102da -->
  <rule id="684813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2962 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>