<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0104 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: c1dd3591-2708-51c7-ae00-0c1df69adf83 -->
  <rule id="519735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0104 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>