<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0134 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e8ee6915-6790-5b0a-8bb8-ae1c206fcbad -->
  <rule id="312669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0134 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>