<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4744 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 2e89502a-e355-5b85-88b4-ab1215493a2c -->
  <rule id="289502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4744 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>