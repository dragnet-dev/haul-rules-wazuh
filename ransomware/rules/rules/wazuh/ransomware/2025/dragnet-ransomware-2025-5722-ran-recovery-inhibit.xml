<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5722 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9a3b21e6-dba1-5ae0-b714-5e35a702641d -->
  <rule id="769921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5722 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>