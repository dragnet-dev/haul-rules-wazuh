<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5916 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: bb78da2e-ed25-5abb-9e24-10a833e01ab0 -->
  <rule id="407386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5916 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>