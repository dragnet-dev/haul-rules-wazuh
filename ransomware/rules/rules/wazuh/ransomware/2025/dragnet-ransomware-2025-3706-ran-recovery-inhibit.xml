<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3706 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 15da325d-81d8-55bf-92ac-fb13cf73ff77 -->
  <rule id="558325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3706 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>