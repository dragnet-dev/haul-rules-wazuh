<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6284 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: 2ae261be-2eed-5fdf-be7d-7a1c8ad2ecea -->
  <rule id="280187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6284 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>