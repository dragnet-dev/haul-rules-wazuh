<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2787 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2f8edebc-cdbb-55e2-9fed-3bc6d930dc52 -->
  <rule id="261694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2787 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>