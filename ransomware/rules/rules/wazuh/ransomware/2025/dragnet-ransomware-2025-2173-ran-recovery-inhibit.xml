<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2173 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 45409573-12f7-5fa9-aeb0-06aa74ce2a55 -->
  <rule id="140957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2173 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>