<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1466 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 83061211-dd83-5e8e-9732-682fe6dbc475 -->
  <rule id="306121" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1466 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>