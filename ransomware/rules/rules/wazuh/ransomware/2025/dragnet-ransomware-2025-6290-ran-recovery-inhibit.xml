<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6290 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 838083b9-d564-5f97-a356-1fec8f86d3ab -->
  <rule id="909339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6290 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>