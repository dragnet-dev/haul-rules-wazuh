<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3727 — Event Log Clearing (skira) | Status: experimental | Sigma ID: d9be4d73-57e2-5a3e-99b7-e4d408535044 -->
  <rule id="423917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3727 — Event Log Clearing (skira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>