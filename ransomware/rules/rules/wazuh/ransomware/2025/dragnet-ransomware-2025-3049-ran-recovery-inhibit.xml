<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3049 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 50353591-c14a-584d-b4f9-c4bff514579e -->
  <rule id="635359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3049 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>