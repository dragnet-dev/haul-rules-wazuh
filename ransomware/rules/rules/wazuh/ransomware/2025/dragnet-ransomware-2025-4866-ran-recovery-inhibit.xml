<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4866 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 7c38fe22-8b1a-55e0-8403-f2c65c3839d7 -->
  <rule id="584382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4866 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>