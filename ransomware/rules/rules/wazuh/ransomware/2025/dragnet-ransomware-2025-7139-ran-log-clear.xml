<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7139 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 18bc52f7-ffe4-5d85-9731-a20733ec88c1 -->
  <rule id="574447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7139 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>