<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5837 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 722d2db7-5fd6-5900-8d68-02471177a58f -->
  <rule id="150445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5837 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>