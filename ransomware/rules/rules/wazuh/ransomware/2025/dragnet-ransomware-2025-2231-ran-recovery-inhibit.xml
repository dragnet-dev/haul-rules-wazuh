<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2231 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c1d1c527-d63d-5175-983c-a513e8c50f18 -->
  <rule id="518685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2231 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>