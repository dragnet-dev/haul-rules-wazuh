<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6094 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 92eaab1b-77c0-5e5b-9102-0a1ff29a7b53 -->
  <rule id="789387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6094 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>