<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7882 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 256f42d8-c4b8-5c2c-883a-f249b9858e38 -->
  <rule id="378285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7882 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>