<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2887 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c28ebb89-27f7-5a9f-aff9-c98482eef46d -->
  <rule id="633659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2887 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>