<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0859 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: af6e8530-c3ce-5944-849d-7fd9c66c2632 -->
  <rule id="211085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0859 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>