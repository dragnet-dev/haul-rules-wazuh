<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5344 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 95d49717-6556-52b5-bb47-d6aaf8d18e76 -->
  <rule id="733497" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5344 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>