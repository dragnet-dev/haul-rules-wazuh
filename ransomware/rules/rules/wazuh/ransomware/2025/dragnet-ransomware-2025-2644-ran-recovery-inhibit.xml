<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2644 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 03aec83a-288c-5ccc-a4ec-1cb29692abed -->
  <rule id="708483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2644 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>