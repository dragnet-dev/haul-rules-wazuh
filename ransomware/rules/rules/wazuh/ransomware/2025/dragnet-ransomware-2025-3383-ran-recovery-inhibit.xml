<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3383 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 175bdd88-58ad-5b7f-9a56-8bc32f109e39 -->
  <rule id="998378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3383 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>