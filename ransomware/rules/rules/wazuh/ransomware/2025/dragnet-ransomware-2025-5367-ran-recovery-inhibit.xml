<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5367 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 289ac6de-f6b2-5ef2-8bef-426a6a5c842a -->
  <rule id="265069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5367 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>