<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3852 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 287bc8fd-e041-5b99-80ce-d9e4f5478426 -->
  <rule id="185743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3852 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>