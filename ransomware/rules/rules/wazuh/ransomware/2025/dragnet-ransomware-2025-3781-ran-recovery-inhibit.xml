<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3781 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b88b36d6-3a6a-5df9-b518-b9fc3833e56c -->
  <rule id="201936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3781 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>