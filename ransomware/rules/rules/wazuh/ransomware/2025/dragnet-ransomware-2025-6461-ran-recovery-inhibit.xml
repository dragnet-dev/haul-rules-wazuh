<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6461 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: dc1962c3-4545-560f-829b-706b237a1c10 -->
  <rule id="501962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6461 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>