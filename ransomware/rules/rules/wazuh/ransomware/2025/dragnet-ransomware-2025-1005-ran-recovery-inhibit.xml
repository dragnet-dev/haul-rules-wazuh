<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1005 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 254efedc-f44d-5b47-8e8d-6ef12cb87380 -->
  <rule id="244222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1005 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>