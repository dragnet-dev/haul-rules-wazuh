<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5991 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 7553a47a-df18-5745-acab-8f92b66b1f11 -->
  <rule id="408584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5991 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>