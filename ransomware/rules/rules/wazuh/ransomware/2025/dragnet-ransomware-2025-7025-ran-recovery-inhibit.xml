<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7025 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 3bec8102-656f-52d3-b164-7e08651121f3 -->
  <rule id="734081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7025 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>