<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5041 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 688ed5d2-c382-544f-9960-41f5bf246b6b -->
  <rule id="963655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5041 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>