<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3885 — Recovery Inhibition (J) | Status: experimental | Sigma ID: afeb95ee-9463-5d35-b4c9-cd5f30c493b2 -->
  <rule id="103595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3885 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>