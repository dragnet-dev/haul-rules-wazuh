<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3925 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c80b01c3-ff4a-5909-b357-35f920f1f0ed -->
  <rule id="349101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3925 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>