<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7829 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: ee4d7d90-3059-580e-a11f-07e034b524d1 -->
  <rule id="805245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7829 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>