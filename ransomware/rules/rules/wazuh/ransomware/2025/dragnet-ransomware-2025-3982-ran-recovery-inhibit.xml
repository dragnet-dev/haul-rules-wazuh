<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3982 — Recovery Inhibition (minteye) | Status: deprecated | Sigma ID: 23a09a5a-77e4-5859-9a22-aaa5183241d5 -->
  <rule id="749545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3982 — Recovery Inhibition (minteye)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>