<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2469 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: e94270e9-594a-5965-a603-79aaf15daca8 -->
  <rule id="694270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2469 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>