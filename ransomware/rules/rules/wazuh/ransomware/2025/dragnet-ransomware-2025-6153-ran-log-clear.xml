<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6153 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 75ae26f4-3ec0-5fd2-af2b-26d33197bafc -->
  <rule id="237426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6153 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>