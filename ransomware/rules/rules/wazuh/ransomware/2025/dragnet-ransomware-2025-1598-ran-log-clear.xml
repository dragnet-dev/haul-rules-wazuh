<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1598 — Event Log Clearing (bert) | Status: experimental | Sigma ID: 0bee4576-184b-5cb5-870b-cb7233b495bb -->
  <rule id="454457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1598 — Event Log Clearing (bert)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>