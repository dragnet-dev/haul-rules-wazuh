<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0153 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d72c8c22-ea0d-5844-bee0-b9c54f3ecc2a -->
  <rule id="914380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0153 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>