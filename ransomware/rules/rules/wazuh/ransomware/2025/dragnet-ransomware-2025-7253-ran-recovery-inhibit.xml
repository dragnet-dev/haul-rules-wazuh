<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7253 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 481eb72f-9b3e-54bc-8496-88c0b4420d07 -->
  <rule id="433717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7253 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>