<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4093 — Shadow Copy Deletion (d4rk4rmy) | Status: deprecated | Sigma ID: cd7f463a-578e-5f53-8742-d1ebef86a510 -->
  <rule id="692746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4093 — Shadow Copy Deletion (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>