<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0051 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 858e308b-911c-570f-b770-5d874189b383 -->
  <rule id="574230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0051 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>