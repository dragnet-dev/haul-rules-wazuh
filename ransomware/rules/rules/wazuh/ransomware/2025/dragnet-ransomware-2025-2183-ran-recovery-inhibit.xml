<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2183 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 7d1d98c3-980e-5742-8cf5-39ee11336486 -->
  <rule id="302998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2183 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>