<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7232 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1c3b091e-1c4d-5859-b04c-9a45e3070a58 -->
  <rule id="139091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7232 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>