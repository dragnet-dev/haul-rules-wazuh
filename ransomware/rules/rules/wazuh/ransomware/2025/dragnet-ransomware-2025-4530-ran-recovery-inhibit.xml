<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4530 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 975095f4-c263-5091-9e40-dca2278987ab -->
  <rule id="401535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4530 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>