<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5280 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7ef8e791-7e99-5771-b683-85a52bbf09e1 -->
  <rule id="651027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5280 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>