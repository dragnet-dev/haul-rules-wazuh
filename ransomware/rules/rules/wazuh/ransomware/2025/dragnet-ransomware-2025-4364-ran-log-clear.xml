<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4364 — Event Log Clearing (RunSomeWares) | Status: experimental | Sigma ID: 4bd2d498-726b-5f9c-ba7f-bb6fdd291631 -->
  <rule id="241254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4364 — Event Log Clearing (RunSomeWares)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>