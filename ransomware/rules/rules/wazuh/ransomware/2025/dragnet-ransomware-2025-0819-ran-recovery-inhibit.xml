<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0819 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 99fcc434-8732-576f-bf28-e1b426cfd15a -->
  <rule id="595484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0819 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>