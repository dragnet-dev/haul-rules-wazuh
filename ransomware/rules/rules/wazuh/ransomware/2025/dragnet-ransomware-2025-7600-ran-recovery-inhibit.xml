<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7600 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: b08b5387-8a8c-585d-a0b7-473e159ba474 -->
  <rule id="973953" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7600 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
