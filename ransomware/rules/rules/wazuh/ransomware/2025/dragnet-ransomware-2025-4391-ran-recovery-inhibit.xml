<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4391 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 9c78300c-a674-58ac-be47-b73d33ef461a -->
  <rule id="767830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4391 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
