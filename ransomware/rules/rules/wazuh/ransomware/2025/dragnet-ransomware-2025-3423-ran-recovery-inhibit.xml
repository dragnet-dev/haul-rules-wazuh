<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3423 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 735d6af3-7989-5269-b33f-a9cf515a46de -->
  <rule id="183786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3423 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>