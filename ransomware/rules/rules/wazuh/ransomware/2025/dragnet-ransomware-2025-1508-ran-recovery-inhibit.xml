<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1508 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 733bd571-e665-5583-8f43-3880b7456a57 -->
  <rule id="178375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1508 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>