<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7634 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 7b29282d-0aa8-51a6-b14c-9b4a6717dd2a -->
  <rule id="432928" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7634 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>