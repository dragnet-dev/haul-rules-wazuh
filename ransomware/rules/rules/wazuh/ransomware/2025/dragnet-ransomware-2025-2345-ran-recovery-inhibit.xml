<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2345 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ed01d09b-2f4a-59fe-a2fc-f243afd1887f -->
  <rule id="292290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2345 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>