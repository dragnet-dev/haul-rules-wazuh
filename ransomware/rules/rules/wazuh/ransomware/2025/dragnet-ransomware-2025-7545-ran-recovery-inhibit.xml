<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7545 — Recovery Inhibition (incransom) | Status: test | Sigma ID: df3c3675-a953-520c-ba42-af9c30f5174e -->
  <rule id="974036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7545 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>