<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2412 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 410dae11-d720-55be-97ad-cf5233b7e437 -->
  <rule id="882862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2412 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>