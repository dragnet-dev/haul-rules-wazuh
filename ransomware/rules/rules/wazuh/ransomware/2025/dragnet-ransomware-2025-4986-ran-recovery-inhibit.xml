<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4986 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 497a385d-94d7-59fe-afd8-c866ae0d308d -->
  <rule id="862385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4986 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>