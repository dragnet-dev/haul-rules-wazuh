<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0452 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4db8e247-508e-5bd8-bf10-fe23bc447f64 -->
  <rule id="290222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0452 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>