<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6020 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1f648a96-92e6-51cf-a78e-14cd533e417e -->
  <rule id="663789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6020 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>