<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4992 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: e15c56f7-9fe9-548a-9cb4-c8223a55c31c -->
  <rule id="565256" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4992 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>