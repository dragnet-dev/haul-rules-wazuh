<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5830 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e2e9c49a-c45d-5d39-8934-075ee22a250f -->
  <rule id="159164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5830 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>