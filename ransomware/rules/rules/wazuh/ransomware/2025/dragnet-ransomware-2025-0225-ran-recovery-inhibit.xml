<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0225 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 08850c68-9432-53c2-bf7a-2f4203633120 -->
  <rule id="616126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0225 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>