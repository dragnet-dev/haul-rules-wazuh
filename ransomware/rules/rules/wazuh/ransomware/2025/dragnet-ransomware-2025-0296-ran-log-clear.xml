<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0296 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 83381e8f-9333-5f84-98a8-acee8b3804d9 -->
  <rule id="534110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0296 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>