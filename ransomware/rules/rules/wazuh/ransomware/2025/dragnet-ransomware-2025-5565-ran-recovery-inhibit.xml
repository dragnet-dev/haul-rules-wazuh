<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5565 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 41d7ec25-2043-5a4f-bd2d-3c50dd9f8711 -->
  <rule id="914668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5565 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>