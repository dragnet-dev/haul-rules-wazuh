<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3932 — Event Log Clearing (radar) | Status: deprecated | Sigma ID: 0b189430-f4ad-5497-9fbe-e0f286012358 -->
  <rule id="318943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3932 — Event Log Clearing (radar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>