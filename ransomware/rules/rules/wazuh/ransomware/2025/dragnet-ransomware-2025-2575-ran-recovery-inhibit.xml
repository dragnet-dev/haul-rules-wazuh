<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2575 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: ffc6e4f5-b6fb-5b83-a0f8-f2a609e74eb4 -->
  <rule id="348304" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2575 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>