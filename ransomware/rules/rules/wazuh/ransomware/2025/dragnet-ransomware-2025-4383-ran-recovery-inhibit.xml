<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4383 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 67098226-d530-5434-aa26-1aa8dceef211 -->
  <rule id="509822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4383 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>