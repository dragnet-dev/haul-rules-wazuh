<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0559 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 0e314a61-11e0-5301-b79f-ab642373719a -->
  <rule id="590346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0559 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>