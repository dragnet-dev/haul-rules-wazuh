<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4987 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d2d5c258-990d-57c2-9cc0-6ca9ab9c4863 -->
  <rule id="800922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4987 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>