<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4947 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: de25115a-4f2a-50f7-b2a4-bd9bac8a0ab8 -->
  <rule id="522511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4947 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>