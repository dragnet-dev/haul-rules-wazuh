<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0607 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 4e8157a8-b81d-544d-9d3c-a7c68d005113 -->
  <rule id="110522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0607 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>