<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7739 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d228db8a-d7b0-500d-83ed-9ae9acad2960 -->
  <rule id="786587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7739 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>