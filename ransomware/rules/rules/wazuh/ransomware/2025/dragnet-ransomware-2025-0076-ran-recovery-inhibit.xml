<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0076 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 81612534-57e7-5b35-8570-badd48f8cd6d -->
  <rule id="161253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0076 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>