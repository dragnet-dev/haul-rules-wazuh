<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5482 — Event Log Clearing (devman) | Status: test | Sigma ID: 3b6271f1-eb19-5c96-906a-93059e62f944 -->
  <rule id="640351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5482 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>