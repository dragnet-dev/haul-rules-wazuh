<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0644 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 06be5965-199b-59cd-ad3f-b89d332dc671 -->
  <rule id="926596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0644 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>