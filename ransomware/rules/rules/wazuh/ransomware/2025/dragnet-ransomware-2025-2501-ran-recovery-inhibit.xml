<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2501 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 510de531-5753-5ce9-8e6e-428cde6c79e4 -->
  <rule id="507825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2501 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>