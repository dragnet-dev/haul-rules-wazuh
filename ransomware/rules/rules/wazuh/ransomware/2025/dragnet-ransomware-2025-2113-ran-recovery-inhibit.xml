<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2113 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 3e23c118-f654-56f1-ac64-9fc4886e0614 -->
  <rule id="158011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2113 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>