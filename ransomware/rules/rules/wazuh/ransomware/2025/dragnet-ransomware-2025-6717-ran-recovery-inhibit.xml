<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6717 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: aac1b7b4-4c32-59f6-a845-8b7328466a0e -->
  <rule id="871477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6717 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>