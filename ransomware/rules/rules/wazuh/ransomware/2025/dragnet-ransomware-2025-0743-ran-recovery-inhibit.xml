<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0743 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ccf1170a-0c69-51f9-9e1e-9dd65b15b6f2 -->
  <rule id="679117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0743 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>