<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4141 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 0fa9edbb-da82-5447-8d8f-2f19990320cc -->
  <rule id="480667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4141 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>