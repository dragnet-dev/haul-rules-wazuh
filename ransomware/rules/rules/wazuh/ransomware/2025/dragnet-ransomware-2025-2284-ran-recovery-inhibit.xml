<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2284 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cd6f3920-6400-5a56-9058-7be6b437c056 -->
  <rule id="691139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2284 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>