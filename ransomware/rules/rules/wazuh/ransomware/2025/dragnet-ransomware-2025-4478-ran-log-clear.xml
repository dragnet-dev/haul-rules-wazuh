<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4478 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 4ecb2eca-eea5-5fef-a1d9-0f82a6e986e4 -->
  <rule id="627406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4478 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>