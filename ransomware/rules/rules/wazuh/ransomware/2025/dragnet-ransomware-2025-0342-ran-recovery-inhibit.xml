<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0342 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 88991830-754e-51a2-935b-3b7316c4d259 -->
  <rule id="899183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0342 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>