<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2292 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: 27a2bf60-52d1-5010-ae5f-496e48dc5a85 -->
  <rule id="332223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2292 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>