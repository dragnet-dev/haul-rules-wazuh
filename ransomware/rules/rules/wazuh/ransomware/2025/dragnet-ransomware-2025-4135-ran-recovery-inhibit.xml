<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4135 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: eecf1d1d-ebb4-5f17-8c87-6b67e912593b -->
  <rule id="881629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4135 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>