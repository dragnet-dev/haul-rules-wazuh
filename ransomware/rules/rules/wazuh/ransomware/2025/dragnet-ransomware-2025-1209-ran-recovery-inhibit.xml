<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1209 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 24a54b7e-9045-515e-9c0c-1f82c0178c4c -->
  <rule id="112757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1209 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>