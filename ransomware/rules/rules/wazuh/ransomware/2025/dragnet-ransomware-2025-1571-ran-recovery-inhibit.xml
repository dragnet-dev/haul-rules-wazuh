<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1571 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: edde4690-aa4a-50e9-81c8-c111922c7905 -->
  <rule id="789446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1571 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>