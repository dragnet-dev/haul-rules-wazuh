<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0079 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 1915fbad-ee18-58f4-94f3-9aa04f895e9a -->
  <rule id="747866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0079 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
