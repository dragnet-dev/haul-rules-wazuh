<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2598 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 939d5114-78a5-5e36-b6f9-2ac8e20ed4ad -->
  <rule id="703751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2598 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>