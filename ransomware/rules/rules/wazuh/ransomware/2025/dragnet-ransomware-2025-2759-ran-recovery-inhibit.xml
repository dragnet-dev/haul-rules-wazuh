<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2759 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 0910519b-6105-5eed-a029-2d26770f4e9e -->
  <rule id="268315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2759 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>