<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4640 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 90ad2bce-5eac-52e5-8ca9-46773981112f -->
  <rule id="214123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4640 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>