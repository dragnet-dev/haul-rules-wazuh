<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4841 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 31bca651-284b-5449-9faa-fd52efeef8ac -->
  <rule id="499946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4841 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>