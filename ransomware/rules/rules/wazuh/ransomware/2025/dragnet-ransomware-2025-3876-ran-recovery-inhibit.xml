<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3876 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: bdd9d157-9975-5704-a452-ba98a9696122 -->
  <rule id="460771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3876 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>