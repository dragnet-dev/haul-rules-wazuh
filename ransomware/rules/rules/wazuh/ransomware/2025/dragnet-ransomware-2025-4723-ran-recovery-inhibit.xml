<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4723 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 721a605a-7d6c-5aac-8c87-afd19d17e46b -->
  <rule id="354660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4723 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>