<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0022 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 14e19371-0ee8-5e6b-a8a1-936257f11d58 -->
  <rule id="681937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0022 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>