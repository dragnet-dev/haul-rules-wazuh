<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1537 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 1accaee7-6be3-509b-8244-848cb5e5fdb3 -->
  <rule id="956334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1537 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>