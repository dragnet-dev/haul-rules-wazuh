<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6636 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: 4f243fda-1e62-54ca-8bbf-4713a3797e11 -->
  <rule id="467903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6636 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>