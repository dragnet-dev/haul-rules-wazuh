<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5850 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 37f693e2-8d22-58a5-aa10-63e6c1270c9d -->
  <rule id="823102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5850 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>