<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5529 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 760fe492-1380-5440-aeed-f6021d9ad57c -->
  <rule id="248144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5529 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>