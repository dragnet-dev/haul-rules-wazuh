<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5729 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cafc54a9-21d0-56f2-9311-598b1590475e -->
  <rule id="796454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5729 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>