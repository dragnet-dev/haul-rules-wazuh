<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6781 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1a68f146-8e6c-5948-8f83-577c8268a731 -->
  <rule id="770314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6781 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>