<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0248 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: faa3a21e-e64b-53fa-ae35-844b49d22190 -->
  <rule id="216582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0248 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>