<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1119 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 14f5bebb-ebae-5440-a3eb-8b8031fea809 -->
  <rule id="912971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1119 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>