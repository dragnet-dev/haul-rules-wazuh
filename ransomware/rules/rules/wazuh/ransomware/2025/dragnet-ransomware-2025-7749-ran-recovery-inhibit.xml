<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7749 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3922489e-e85a-5cde-a03f-e88994a40d54 -->
  <rule id="422489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7749 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>