<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1551 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 4e7987a0-96a3-5710-a988-672046aa1414 -->
  <rule id="107802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1551 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>