<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5552 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 64e1c2cd-0d5b-58e6-9a55-dc7b58ef9365 -->
  <rule id="861082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5552 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>