<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4906 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: ea2e50f1-e99e-5299-b5e4-541e39c2f188 -->
  <rule id="248650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4906 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>