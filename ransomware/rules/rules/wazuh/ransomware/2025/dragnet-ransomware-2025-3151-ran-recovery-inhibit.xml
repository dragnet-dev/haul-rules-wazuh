<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3151 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b47ee989-3a9c-55e0-8b65-262ad38b3265 -->
  <rule id="338709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3151 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>