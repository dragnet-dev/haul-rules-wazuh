<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5136 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: 2d08cf52-503d-5e86-9e5b-5a2a2c1072a5 -->
  <rule id="354255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5136 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>