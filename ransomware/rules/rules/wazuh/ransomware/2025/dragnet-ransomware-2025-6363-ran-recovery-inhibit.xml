<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6363 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 45aa7bb1-8f42-5e54-b877-91d3a663dbe4 -->
  <rule id="170523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6363 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>