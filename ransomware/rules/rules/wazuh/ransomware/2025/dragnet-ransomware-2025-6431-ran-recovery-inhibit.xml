<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6431 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bed933fb-69e1-5555-a937-bc18e275ce54 -->
  <rule id="453933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6431 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>