<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1554 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 34f6ca49-b7e0-5699-8e8a-843390b85c8f -->
  <rule id="632778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1554 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>