<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1891 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 2510a037-7282-5612-97a8-9b1342887960 -->
  <rule id="517003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1891 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>