<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4343 — Recovery Inhibition (nightspire) | Status: experimental | Sigma ID: 0fd04322-55d3-532c-a6e0-988b88698f59 -->
  <rule id="830432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4343 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>