<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2664 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 35b1aa09-0294-5380-b622-4dc08021ebdf -->
  <rule id="662186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2664 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>