<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2058 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: f2488f3f-4ccb-54b7-a3b2-359ec7eba721 -->
  <rule id="739823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2058 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>