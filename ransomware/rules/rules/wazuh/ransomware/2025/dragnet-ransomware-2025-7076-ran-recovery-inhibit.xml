<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7076 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 18227f4c-079c-51bb-892e-52c2760cf8ef -->
  <rule id="316474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7076 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>