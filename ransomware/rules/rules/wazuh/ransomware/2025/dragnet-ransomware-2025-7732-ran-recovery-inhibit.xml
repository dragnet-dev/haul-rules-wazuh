<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7732 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7bdb1fcf-aaaa-50be-8783-784661c35b1f -->
  <rule id="673151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7732 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>