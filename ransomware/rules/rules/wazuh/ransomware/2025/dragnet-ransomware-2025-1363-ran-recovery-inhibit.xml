<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1363 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 789305cc-df09-58f1-994b-b8fed8bf7490 -->
  <rule id="128892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1363 — Recovery Inhibition (chaos)</description>
