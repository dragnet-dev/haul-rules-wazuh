<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6169 — Event Log Clearing (direwolf) | Status: experimental | Sigma ID: 25e2c128-8098-5ed1-ba50-f37d9a9e4c8b -->
  <rule id="428412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6169 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>