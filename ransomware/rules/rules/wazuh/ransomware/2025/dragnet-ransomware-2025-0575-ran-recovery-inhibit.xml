<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0575 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: e23e861a-2aa5-58b2-8446-f025883b3db0 -->
  <rule id="578286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0575 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>