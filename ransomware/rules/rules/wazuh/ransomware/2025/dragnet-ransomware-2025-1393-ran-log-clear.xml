<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1393 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: d576f04c-b2c2-5cfb-9f8a-2f4f33bf0381 -->
  <rule id="472310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1393 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>