<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3981 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5819e06a-e6f6-5385-83a8-5a2a161317e0 -->
  <rule id="411806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3981 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>