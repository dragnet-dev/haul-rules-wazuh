<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5039 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d907c326-63d3-59e8-8573-c700e5a7fcc1 -->
  <rule id="525243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5039 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>