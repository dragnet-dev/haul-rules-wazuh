<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4168 — Shadow Copy Deletion (d4rk4rmy) | Status: deprecated | Sigma ID: 2aad9de0-1330-5b69-b0d2-f6bed10f2693 -->
  <rule id="948157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4168 — Shadow Copy Deletion (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>