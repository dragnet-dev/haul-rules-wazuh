<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4926 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0d299f5f-eb46-550e-8605-65def164f5ac -->
  <rule id="427995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4926 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>