<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4486 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 699e5350-6825-5219-bbb5-128727b5677b -->
  <rule id="319853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4486 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>