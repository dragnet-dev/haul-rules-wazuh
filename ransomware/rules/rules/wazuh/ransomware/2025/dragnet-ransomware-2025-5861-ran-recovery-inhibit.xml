<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5861 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2d8973c9-df85-5207-9919-7f1fbeb9d359 -->
  <rule id="243580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5861 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>