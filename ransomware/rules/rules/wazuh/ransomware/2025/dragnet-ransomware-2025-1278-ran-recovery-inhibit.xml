<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1278 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7d53f4f8-8e6c-5b31-ae1b-c425754aaa38 -->
  <rule id="308634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1278 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>