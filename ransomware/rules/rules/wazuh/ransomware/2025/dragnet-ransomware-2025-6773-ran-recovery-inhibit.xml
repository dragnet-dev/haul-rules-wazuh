<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6773 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: d66c2321-2c25-502d-9e75-7354e95eeae3 -->
  <rule id="486823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6773 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>