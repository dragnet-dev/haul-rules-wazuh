<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0725 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 4d47b877-ac02-511d-b3bc-8a9eaf891ee7 -->
  <rule id="439638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0725 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>