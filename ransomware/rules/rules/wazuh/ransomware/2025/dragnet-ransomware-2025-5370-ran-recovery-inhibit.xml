<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5370 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: c30b3c65-0391-51e6-8dbc-5c6c83438d71 -->
  <rule id="550620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5370 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>