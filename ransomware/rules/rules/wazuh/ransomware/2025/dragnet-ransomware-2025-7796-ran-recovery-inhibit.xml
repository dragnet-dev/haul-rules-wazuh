<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7796 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: b392822e-b87e-5405-80a8-e3fab6d89383 -->
  <rule id="339282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7796 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>