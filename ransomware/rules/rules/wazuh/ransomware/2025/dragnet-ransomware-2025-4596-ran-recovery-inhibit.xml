<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4596 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 398a9a24-735e-5087-8e54-88c4260b4200 -->
  <rule id="220634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4596 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>