<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4643 — Event Log Clearing (global) | Status: experimental | Sigma ID: 24e82246-b2da-50a9-9c5a-551c0135c73f -->
  <rule id="488224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4643 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>