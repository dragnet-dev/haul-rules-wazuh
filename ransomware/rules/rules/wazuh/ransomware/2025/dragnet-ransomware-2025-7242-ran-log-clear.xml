<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7242 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 2ce95b2d-f0f8-5032-ba38-d7998033c5a8 -->
  <rule id="350331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7242 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>