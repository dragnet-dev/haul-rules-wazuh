<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3618 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ae5ac08b-1369-5db1-933c-c831e2ed0724 -->
  <rule id="968920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3618 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>