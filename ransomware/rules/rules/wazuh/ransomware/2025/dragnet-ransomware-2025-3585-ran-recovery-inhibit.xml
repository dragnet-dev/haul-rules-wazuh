<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3585 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 80e59928-c681-5d59-811b-7f936dce33b4 -->
  <rule id="494599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3585 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>