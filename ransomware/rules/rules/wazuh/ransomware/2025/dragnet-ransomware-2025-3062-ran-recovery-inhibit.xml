<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3062 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 50b8f2ed-6590-5b3e-9db5-45cbcee7554f -->
  <rule id="499032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3062 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>