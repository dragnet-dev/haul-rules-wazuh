<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6244 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b4511a05-50ee-51fa-bb91-7f0dc1782698 -->
  <rule id="132186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6244 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>