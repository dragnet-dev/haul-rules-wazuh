<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1763 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 69e9b1cd-8203-54ed-bd4c-f0c200615f44 -->
  <rule id="990351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1763 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>