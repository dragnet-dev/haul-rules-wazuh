<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2478 — Event Log Clearing (thegentlemen) | Status: experimental | Sigma ID: 85b5e17e-68a1-5c0f-85ee-c90642ab8125 -->
  <rule id="494541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2478 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>