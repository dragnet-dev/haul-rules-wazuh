<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5937 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f6165d23-cf29-526b-8e2f-480d73c2ddaa -->
  <rule id="798653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5937 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>