<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4768 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 15c2cadb-4ddd-5d3c-8c44-ca81e49cc9c4 -->
  <rule id="533357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4768 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>