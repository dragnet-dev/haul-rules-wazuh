<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0977 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5dfb92ff-8201-54c3-b472-241d450fc828 -->
  <rule id="705992" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0977 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>