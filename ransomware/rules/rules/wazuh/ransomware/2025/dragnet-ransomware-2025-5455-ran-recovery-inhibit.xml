<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5455 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8b32a513-9c9f-552d-88b7-06bd7220be71 -->
  <rule id="529225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5455 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>