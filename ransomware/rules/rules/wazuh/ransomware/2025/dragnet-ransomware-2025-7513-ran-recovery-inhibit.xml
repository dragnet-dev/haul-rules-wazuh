<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7513 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9f0b12fd-1136-597c-86e2-ca537e5af947 -->
  <rule id="845112" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7513 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>