<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2511 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f721e505-07b6-50e7-982f-92782ead4236 -->
  <rule id="815505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2511 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>