<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0846 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4602052f-902a-5d49-a2bf-384e5d8b1cf2 -->
  <rule id="202052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0846 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>