<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2533 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 5bcfe8ff-345f-5760-b06e-97377cd1a955 -->
  <rule id="260628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2533 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>