<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1738 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c2e22daa-3831-58dc-be53-4fe108852376 -->
  <rule id="545965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1738 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>