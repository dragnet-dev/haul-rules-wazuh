<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4028 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 2afa7612-e1b3-5c78-8ad7-93613f3583b6 -->
  <rule id="300276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4028 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>