<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0410 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: a7b0850c-5f72-5e54-8d50-a72032a28b6b -->
  <rule id="923085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0410 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>