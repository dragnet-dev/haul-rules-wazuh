<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3941 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: baa5f74c-1342-519e-8abe-ff355f306ccd -->
  <rule id="378557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3941 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>