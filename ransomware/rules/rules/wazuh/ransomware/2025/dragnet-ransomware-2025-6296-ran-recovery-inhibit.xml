<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6296 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3a5165d8-7cc1-51da-abf7-f5722ed88051 -->
  <rule id="462653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6296 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>