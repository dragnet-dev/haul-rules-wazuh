<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4093 — Event Log Clearing (d4rk4rmy) | Status: deprecated | Sigma ID: 1d1c8490-ba91-5a63-96d6-8f07655fd559 -->
  <rule id="268849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4093 — Event Log Clearing (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>