<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4918 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f6ab0c4d-ecf2-5815-9edf-d0aa1b66410f -->
  <rule id="217132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4918 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>