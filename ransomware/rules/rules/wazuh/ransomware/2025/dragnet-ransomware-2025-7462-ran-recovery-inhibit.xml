<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7462 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 6b7f9f56-70c2-59a9-a2d0-9a1f7eb76779 -->
  <rule id="159679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7462 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>