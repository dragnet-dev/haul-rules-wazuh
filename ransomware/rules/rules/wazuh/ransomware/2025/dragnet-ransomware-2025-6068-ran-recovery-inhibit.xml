<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6068 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 291a0fa4-ceca-5226-ba99-75a71789a0f5 -->
  <rule id="345210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6068 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>