<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0141 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 17e20bd5-5908-5b8f-a702-38a82f80153b -->
  <rule id="226909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0141 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>