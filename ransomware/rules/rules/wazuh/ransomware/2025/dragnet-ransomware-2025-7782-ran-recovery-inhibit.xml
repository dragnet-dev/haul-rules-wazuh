<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7782 — Recovery Inhibition (d4rk4rmy) | Status: experimental | Sigma ID: e845c9e9-49e8-5e1d-b4da-81a51533a0f5 -->
  <rule id="675329" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7782 — Recovery Inhibition (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>