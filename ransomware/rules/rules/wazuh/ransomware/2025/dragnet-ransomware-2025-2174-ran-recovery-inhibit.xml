<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2174 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 9f8f6374-0040-5363-a8ce-4f79e17aa93b -->
  <rule id="858363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2174 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>