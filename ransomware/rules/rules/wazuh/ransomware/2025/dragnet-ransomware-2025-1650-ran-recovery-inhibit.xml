<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1650 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a9855dcf-df84-50fa-aa42-499ea78c8c5b -->
  <rule id="957693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1650 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>