<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4387 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 80a9adfd-0f1f-5003-b61d-ae078f19a690 -->
  <rule id="704877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4387 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>