<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5278 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 84c3e9c7-283d-587a-828f-00a1c7e954b6 -->
  <rule id="470229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5278 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>