<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4186 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 7b526f03-00ab-5f2e-ac27-1151faf8ea93 -->
  <rule id="276431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4186 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>