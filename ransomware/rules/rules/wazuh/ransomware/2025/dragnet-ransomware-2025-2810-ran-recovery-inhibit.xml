<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2810 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1cc86da1-ff77-578a-854c-acc8a276c26d -->
  <rule id="198234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2810 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>