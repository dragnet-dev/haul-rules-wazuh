<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4890 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4c79cc1c-55ee-52a6-af49-b39e78833c62 -->
  <rule id="266028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4890 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>