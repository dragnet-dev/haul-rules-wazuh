<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4182 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e554d671-7c37-5dde-b103-d5bfbccc9106 -->
  <rule id="628776" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4182 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>