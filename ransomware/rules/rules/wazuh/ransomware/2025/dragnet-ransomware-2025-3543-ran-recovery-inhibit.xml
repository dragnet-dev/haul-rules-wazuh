<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3543 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3598bbf7-7258-58d1-a20b-64d8739eb57b -->
  <rule id="440415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3543 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>