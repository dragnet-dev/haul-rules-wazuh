<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7202 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b27732d2-9624-508a-b8b5-af92a16d25de -->
  <rule id="327732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7202 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>