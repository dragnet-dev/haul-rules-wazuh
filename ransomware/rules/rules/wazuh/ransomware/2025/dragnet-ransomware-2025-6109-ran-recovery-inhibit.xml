<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6109 — Recovery Inhibition (tridentlocker) | Status: experimental | Sigma ID: 3bcd38d4-9d51-5e42-960d-efaaa71dfecd -->
  <rule id="730938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6109 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>