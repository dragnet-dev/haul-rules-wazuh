<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5047 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ad999a9d-3281-5931-bd04-b6cad8263798 -->
  <rule id="183994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5047 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>