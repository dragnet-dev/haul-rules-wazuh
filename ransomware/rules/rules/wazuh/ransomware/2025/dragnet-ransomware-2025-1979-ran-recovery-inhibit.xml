<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1979 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 6aa9103d-e333-5c55-ba8d-409e3ee6bba5 -->
  <rule id="906910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1979 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>