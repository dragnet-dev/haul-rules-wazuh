<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7063 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 8cd01e76-dddb-53ca-bd18-f1468d8ea757 -->
  <rule id="104830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7063 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>