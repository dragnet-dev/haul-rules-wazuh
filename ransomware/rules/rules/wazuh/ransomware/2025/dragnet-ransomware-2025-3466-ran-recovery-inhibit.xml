<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3466 — Recovery Inhibition (nightspire) | Status: experimental | Sigma ID: c7d12f4b-88ce-5c03-b06d-cb7b3a02db5b -->
  <rule id="672207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3466 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>