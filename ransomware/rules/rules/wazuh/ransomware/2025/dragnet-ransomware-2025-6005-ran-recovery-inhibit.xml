<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6005 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 1a73d82d-7c71-513f-b438-e2929f047e83 -->
  <rule id="778182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6005 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>