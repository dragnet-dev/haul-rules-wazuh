<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5185 — Event Log Clearing (blackshrantac) | Status: experimental | Sigma ID: 1da2ea9c-3987-5e71-b267-84fbb1ddfed6 -->
  <rule id="414186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5185 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>