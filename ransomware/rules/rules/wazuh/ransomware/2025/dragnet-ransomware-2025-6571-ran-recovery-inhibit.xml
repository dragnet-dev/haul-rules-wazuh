<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6571 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3c1fcd76-c9f8-59d9-a6a3-a0b8d716590e -->
  <rule id="765741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6571 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>