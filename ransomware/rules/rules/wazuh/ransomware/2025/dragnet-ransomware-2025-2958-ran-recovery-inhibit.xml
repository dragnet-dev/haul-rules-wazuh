<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2958 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: 88f2056e-966b-5574-acad-8c89c7195ae0 -->
  <rule id="623205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2958 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>