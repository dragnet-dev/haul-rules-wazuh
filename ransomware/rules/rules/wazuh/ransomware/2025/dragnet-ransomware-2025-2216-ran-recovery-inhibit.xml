<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2216 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bbb29fa2-3491-54c0-9f6d-9d4e03c37b97 -->
  <rule id="405279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2216 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>