<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6709 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6ff896b6-f2c0-5497-b463-66c55ea79ea0 -->
  <rule id="991896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6709 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>