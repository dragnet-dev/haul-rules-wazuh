<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7619 — Event Log Clearing (frag) | Status: deprecated | Sigma ID: df184f86-0260-5b36-88fa-6f082f143731 -->
  <rule id="970959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7619 — Event Log Clearing (frag)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>