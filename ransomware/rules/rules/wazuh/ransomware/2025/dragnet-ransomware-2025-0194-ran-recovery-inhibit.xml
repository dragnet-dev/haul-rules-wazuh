<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0194 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8ef40cee-6f3c-584a-8102-e7639b42511b -->
  <rule id="159852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0194 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>