<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5160 — Event Log Clearing (apt73) | Status: experimental | Sigma ID: 37aa5ad4-b568-5d7f-abfb-4c4f3d12d727 -->
  <rule id="742810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5160 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>