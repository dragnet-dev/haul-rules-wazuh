<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6604 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: b6a0da73-cc1b-562d-8db7-6eb8ec4f7388 -->
  <rule id="377178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6604 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>