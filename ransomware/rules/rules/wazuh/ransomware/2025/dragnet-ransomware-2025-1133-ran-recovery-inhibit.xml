<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1133 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 4f489e31-7838-5fdd-8cce-432b0e0c6653 -->
  <rule id="471838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1133 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
