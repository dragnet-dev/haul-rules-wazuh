<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1132 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: c2ebee0d-6cd3-572a-85e1-505754a34d16 -->
  <rule id="955790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1132 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>