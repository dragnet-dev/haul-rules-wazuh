<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3214 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 019737b5-e8c1-51a2-93cc-d72958905531 -->
  <rule id="558035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3214 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
