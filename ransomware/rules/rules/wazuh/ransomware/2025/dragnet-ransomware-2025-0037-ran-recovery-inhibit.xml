<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0037 — Recovery Inhibition (tengu) | Status: experimental | Sigma ID: 45793666-beac-5040-a2c8-5ce3d7a3e155 -->
  <rule id="179366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0037 — Recovery Inhibition (tengu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>