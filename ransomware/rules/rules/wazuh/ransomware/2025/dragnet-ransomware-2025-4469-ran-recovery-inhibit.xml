<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4469 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 327e4f53-5d22-5c6c-8429-3339183ed269 -->
  <rule id="394395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4469 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>