<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0430 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 33e794f2-8953-5b9b-95fe-71355ef3c49d -->
  <rule id="684719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0430 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>