<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3228 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a57ff7d5-f3f9-5648-b0b6-8e2f71d03f44 -->
  <rule id="108477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3228 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
