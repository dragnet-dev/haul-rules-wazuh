<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0185 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 0fa9c05b-0fb3-5b75-a316-4a3fa414e76a -->
  <rule id="515605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0185 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>