<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5796 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 024802dc-f1ab-5d42-ad73-a096ecc35eba -->
  <rule id="149532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5796 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>