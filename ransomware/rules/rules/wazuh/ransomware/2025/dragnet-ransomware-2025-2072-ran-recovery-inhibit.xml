<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2072 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f7d2c325-cb7a-506c-aa31-f85170f22b98 -->
  <rule id="540443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2072 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>