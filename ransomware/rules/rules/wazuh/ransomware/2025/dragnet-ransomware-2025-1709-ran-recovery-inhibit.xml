<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1709 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 4199b435-2265-5f55-bb8c-0582a1dd6181 -->
  <rule id="519543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1709 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>