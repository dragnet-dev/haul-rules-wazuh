<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1513 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0e5e8b26-c519-53ff-88f0-4cc6632aa2fb -->
  <rule id="235792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1513 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>