<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4959 — Event Log Clearing (stormous) | Status: experimental | Sigma ID: 6d4c5ecb-b6ba-56c5-8e43-75e5d1e3a0a5 -->
  <rule id="202654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4959 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>