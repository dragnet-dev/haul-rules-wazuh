<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6434 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e575646b-7cc1-5f02-adf6-3ed7656ff92b -->
  <rule id="657564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6434 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>