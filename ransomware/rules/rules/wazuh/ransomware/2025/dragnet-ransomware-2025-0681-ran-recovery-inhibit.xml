<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0681 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 3bce3807-3729-530e-8d34-f7a2bf77224e -->
  <rule id="731038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0681 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>