<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5904 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: e69381b0-4a04-5994-b675-53d3e374df95 -->
  <rule id="669381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5904 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
