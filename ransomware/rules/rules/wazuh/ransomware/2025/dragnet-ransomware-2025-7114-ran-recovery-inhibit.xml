<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7114 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b48422dd-5114-5f47-b09e-610d18bf2929 -->
  <rule id="348422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7114 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>