<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7515 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: c5ea8f06-d8ed-5b47-b017-7da1840c9a5c -->
  <rule id="757583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7515 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>