<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1614 — Recovery Inhibition (clop) | Status: test | Sigma ID: ce710f8c-56ac-5c3a-8dc2-65e7ffaba960 -->
  <rule id="707375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1614 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>