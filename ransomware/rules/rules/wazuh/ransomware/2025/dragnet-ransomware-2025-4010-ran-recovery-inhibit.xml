<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4010 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0fc8bffa-0163-5756-ae86-fcd286599057 -->
  <rule id="557759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4010 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>