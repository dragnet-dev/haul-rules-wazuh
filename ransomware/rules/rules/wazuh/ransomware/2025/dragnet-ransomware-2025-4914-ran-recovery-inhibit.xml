<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4914 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6fde3856-3d78-5a32-8cc6-461670858463 -->
  <rule id="263838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4914 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>