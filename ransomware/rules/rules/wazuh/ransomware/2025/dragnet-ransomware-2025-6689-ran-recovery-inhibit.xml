<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6689 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e8ea4d38-14be-50e0-b6b8-7d49ede0d80c -->
  <rule id="799597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6689 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>