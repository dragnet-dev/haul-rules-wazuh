<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5827 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 9d74bf73-ccf2-59b4-97b3-2a8f3fa4b94a -->
  <rule id="538335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5827 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>