<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4178 — Event Log Clearing (global) | Status: deprecated | Sigma ID: 4ffc42be-c0d6-55a0-b9b2-b01fdee3e84b -->
  <rule id="347642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4178 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>