<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2577 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 00ba30e4-77d2-56c8-8df9-6434f747964d -->
  <rule id="380944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2577 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>