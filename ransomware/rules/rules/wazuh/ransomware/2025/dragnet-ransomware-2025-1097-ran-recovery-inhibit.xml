<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1097 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7e2a30cd-813a-543e-94c6-10c436be0260 -->
  <rule id="320230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1097 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>