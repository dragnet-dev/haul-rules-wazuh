<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6480 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d2465900-09e3-585f-b14b-501b85c83d52 -->
  <rule id="524659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6480 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>