<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4046 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: d5a81d69-d00a-535a-9113-45e8615b8cce -->
  <rule id="873309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4046 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>