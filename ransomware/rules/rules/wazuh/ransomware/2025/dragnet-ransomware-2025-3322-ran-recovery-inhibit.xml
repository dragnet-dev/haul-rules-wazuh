<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3322 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b79fe3b5-d3b5-5055-9cca-22b5d0aa2434 -->
  <rule id="420783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3322 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>