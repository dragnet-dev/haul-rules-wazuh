<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4942 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d8bee131-01f7-5d3f-9b29-5bffc153c261 -->
  <rule id="383021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4942 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>