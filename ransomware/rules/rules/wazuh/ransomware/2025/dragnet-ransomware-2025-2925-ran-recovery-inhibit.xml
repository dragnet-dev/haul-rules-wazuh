<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2925 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a624e1f7-4e62-5b56-8eca-ad8e60adce20 -->
  <rule id="899981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2925 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>