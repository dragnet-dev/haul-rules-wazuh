<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0038 — Recovery Inhibition (insomnia) | Status: experimental | Sigma ID: c8d23db5-5226-5dae-a74c-f4d677de23bb -->
  <rule id="697981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0038 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>