<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4446 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: d9c92dd0-940d-5680-84bd-170d1079683f -->
  <rule id="979085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4446 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>