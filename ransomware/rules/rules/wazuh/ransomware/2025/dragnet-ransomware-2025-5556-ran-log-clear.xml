<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5556 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: bd9bb183-3be5-51c7-a1c7-747d63f0fda7 -->
  <rule id="463311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5556 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>