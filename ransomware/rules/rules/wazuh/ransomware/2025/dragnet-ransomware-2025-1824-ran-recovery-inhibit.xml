<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1824 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ac3f6908-95a5-5a12-9619-90ab6467b8b9 -->
  <rule id="158369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1824 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>