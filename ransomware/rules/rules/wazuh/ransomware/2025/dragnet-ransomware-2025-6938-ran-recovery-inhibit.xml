<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6938 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 898062fd-3aaa-5c1f-ad45-2d1135c44c7a -->
  <rule id="969007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6938 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>