<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4728 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 445c7fb7-d97e-5a7f-901c-ea4baf1bc346 -->
  <rule id="341247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4728 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>