<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2519 — Event Log Clearing (rebornvc) | Status: deprecated | Sigma ID: 2d4d1a1f-7152-5944-9587-f531151b4b25 -->
  <rule id="364346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2519 — Event Log Clearing (rebornvc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>