<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0498 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bd2e7146-e5d5-5571-8194-1774de632c34 -->
  <rule id="428671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0498 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>