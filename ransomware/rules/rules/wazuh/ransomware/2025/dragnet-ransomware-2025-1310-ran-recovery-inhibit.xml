<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1310 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 420fc9b5-91cc-5727-885d-29ca696e12f6 -->
  <rule id="277729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1310 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>