<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6698 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 73fac008-b2bc-5c2e-9437-cc1f6afdfab2 -->
  <rule id="430200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6698 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>