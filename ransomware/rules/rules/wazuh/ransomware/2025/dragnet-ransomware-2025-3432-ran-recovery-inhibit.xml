<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3432 — Recovery Inhibition (secp0) | Status: experimental | Sigma ID: 64c29ba4-ac31-58fe-ab28-64cd02d23611 -->
  <rule id="858075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3432 — Recovery Inhibition (secp0)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>