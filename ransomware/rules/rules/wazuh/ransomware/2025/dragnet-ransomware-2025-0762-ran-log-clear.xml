<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0762 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 5d00bc69-dfa9-5f6d-921e-dbf87dbb6806 -->
  <rule id="680988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0762 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>