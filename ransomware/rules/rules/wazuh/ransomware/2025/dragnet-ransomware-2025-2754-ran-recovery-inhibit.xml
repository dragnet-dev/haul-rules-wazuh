<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2754 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d74aef79-1ae2-5463-a34e-f0d4d8170e48 -->
  <rule id="330703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2754 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>