<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3069 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: bc6aaaa7-e082-5089-8cea-4096c6eebe0c -->
  <rule id="627786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3069 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>