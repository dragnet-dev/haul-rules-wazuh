<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5586 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5d043ba8-269d-552e-8958-32845a8e1b13 -->
  <rule id="688699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5586 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>