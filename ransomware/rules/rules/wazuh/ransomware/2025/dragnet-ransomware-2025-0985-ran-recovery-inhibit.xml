<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0985 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 358b5102-1507-5c18-aac4-cbb52cde794a -->
  <rule id="439510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0985 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>