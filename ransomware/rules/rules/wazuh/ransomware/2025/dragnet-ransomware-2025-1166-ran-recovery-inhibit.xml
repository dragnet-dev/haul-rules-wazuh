<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1166 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 67ce236c-b48d-51c5-8826-ab8e7e67291b -->
  <rule id="935823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1166 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>