<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6930 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: d661b83c-ddb9-5994-a600-ff145e8f1362 -->
  <rule id="485878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6930 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>