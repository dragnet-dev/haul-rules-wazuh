<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3518 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 811af245-5936-5e05-812f-c29fedc772bb -->
  <rule id="377912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3518 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>