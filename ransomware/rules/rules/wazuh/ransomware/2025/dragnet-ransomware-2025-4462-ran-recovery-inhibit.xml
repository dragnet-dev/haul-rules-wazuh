<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4462 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9846d8fb-aa9f-5a72-9746-ec3d685dce65 -->
  <rule id="775498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4462 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>