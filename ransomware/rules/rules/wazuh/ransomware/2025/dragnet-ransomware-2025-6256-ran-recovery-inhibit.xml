<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6256 — Recovery Inhibition (qilin) | Status: test | Sigma ID: ee600c83-155d-5300-a4c1-3e91bd14c9c1 -->
  <rule id="317612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6256 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>