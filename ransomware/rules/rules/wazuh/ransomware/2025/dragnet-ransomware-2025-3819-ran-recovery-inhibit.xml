<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3819 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b70d138d-7926-5374-9a5a-428780e2cdcb -->
  <rule id="173313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3819 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>