<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4611 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2c803683-0a81-505b-8134-480cf92dae76 -->
  <rule id="980368" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4611 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>