<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0805 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 96543f56-088a-53e0-ad08-84132a03cb49 -->
  <rule id="744703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0805 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>