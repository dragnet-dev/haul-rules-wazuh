<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0459 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 21680b55-d0d7-5d7c-8736-51668e34163e -->
  <rule id="868915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0459 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>