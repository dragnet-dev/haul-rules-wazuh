<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5444 — Recovery Inhibition (pear) | Status: test | Sigma ID: 6de985eb-8032-5190-b6c6-0bb0620fdcad -->
  <rule id="958985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5444 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
