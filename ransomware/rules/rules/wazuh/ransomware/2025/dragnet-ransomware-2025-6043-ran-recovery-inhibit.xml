<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6043 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8b4eed48-b4b3-5ac6-a738-873c2e1262da -->
  <rule id="413645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6043 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>