<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5135 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 43b0339c-858c-506b-ac59-95c4bad14f1c -->
  <rule id="790339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5135 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>