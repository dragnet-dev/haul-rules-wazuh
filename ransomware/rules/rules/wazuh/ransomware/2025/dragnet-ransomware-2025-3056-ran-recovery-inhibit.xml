<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3056 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 18b4355b-ccca-50e9-bc02-90108dcb14b6 -->
  <rule id="394355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3056 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>