<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0070 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 82acdadf-68d4-5640-86da-d06438025999 -->
  <rule id="118202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0070 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>