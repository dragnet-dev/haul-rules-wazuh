<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2732 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fb168e40-3463-554c-b94a-585cac54cc2f -->
  <rule id="518702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2732 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>