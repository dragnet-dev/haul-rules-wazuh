<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5985 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 6e59f529-2afa-5aa4-a78e-4733e726ef29 -->
  <rule id="969595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5985 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>