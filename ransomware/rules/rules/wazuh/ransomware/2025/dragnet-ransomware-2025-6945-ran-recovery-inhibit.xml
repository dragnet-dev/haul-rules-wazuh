<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6945 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: cbb31c29-66c3-5a8c-811e-21ba93b4f64b -->
  <rule id="814908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6945 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>