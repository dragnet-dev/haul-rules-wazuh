<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4529 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a334a447-ae06-5f67-a4f5-f417d301edd4 -->
  <rule id="853544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4529 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
