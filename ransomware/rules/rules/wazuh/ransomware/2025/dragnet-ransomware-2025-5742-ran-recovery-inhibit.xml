<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5742 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 97dfd4e0-6e54-5954-85af-373335badf2d -->
  <rule id="508934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5742 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>