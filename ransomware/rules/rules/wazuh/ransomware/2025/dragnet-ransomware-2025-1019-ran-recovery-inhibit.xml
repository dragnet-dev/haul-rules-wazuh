<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1019 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a507d235-d61c-5d4e-b1cf-2a6a70c70f9c -->
  <rule id="881252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1019 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>