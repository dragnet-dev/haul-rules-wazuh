<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3811 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: c99a579a-ebb3-53a6-bffd-8945eb023279 -->
  <rule id="379457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3811 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>