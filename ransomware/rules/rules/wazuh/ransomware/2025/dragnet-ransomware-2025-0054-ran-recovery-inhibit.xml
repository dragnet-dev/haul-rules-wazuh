<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0054 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 95145a9b-7bf7-5abf-a186-804b4c282aa7 -->
  <rule id="722330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0054 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>