<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6122 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: b667da7c-72e6-528e-84c3-1e677122d8ae -->
  <rule id="386970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6122 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>