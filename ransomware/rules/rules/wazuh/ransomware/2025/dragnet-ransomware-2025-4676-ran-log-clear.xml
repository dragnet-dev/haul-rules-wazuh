<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4676 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 52a878ed-3d6c-524b-a6a4-a7eec1cfa84f -->
  <rule id="986062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4676 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>