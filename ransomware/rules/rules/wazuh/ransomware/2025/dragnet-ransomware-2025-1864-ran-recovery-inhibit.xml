<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1864 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 01158638-6984-5f03-ab0b-c5e29ce6f3d2 -->
  <rule id="358638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1864 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>