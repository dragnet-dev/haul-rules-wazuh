<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5666 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 398beae2-12f2-5307-9c0f-16523f05faa9 -->
  <rule id="833258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5666 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>