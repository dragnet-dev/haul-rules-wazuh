<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5456 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 8b99bbdf-928f-5327-b4cd-e9d003a93e21 -->
  <rule id="983931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5456 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>