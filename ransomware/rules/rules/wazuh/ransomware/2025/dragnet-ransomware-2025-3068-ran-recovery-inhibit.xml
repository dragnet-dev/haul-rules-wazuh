<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3068 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f2a5cd38-8409-511b-9bc8-9a1b56ff84a7 -->
  <rule id="953005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3068 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>