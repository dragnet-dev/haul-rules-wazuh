<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2771 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 25ea2cd4-1b47-5998-b1de-87e1c1c2b5a5 -->
  <rule id="261484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2771 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>