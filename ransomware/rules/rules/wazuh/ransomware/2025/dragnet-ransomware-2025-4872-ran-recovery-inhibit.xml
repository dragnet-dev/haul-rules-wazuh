<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4872 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c5a75614-2fd4-5cfe-8246-92d5ee4bae6a -->
  <rule id="310756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4872 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>