<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4673 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 4ed2d651-d5c1-508c-a951-3a5c9f258d8e -->
  <rule id="318056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4673 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>