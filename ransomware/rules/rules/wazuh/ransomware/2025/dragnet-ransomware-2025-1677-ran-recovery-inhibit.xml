<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1677 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 18317cf4-28d3-50a4-b52b-91ab0c0f5449 -->
  <rule id="289359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1677 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>