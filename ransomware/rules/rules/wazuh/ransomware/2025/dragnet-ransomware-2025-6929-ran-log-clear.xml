<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6929 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: 3fc61167-e115-5fbc-8424-e241b9318dbb -->
  <rule id="220611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6929 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>