<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1341 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 16b0f7bd-9402-56e8-a09f-17c9808ea4f9 -->
  <rule id="637723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1341 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>