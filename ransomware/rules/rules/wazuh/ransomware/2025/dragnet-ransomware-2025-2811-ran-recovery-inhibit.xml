<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2811 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 00117d7c-6be2-5254-9242-e74a4d815cb9 -->
  <rule id="417246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2811 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>