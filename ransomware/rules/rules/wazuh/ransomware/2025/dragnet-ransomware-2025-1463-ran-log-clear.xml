<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1463 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 2371d31a-5e2b-5b2a-af1a-b6b64d5f659e -->
  <rule id="294931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1463 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>