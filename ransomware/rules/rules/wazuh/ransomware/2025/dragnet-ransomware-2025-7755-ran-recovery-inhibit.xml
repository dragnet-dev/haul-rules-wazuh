<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7755 — Recovery Inhibition (incransom) | Status: test | Sigma ID: f41ff1ec-bbf3-5dd3-b57b-27761cd90a2d -->
  <rule id="447511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7755 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>