<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3258 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0a6b249c-1836-5b92-8028-6c59e16231fb -->
  <rule id="907249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3258 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
