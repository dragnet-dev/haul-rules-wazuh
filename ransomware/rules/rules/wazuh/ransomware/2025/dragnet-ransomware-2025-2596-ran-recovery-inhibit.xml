<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2596 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fdd3cfce-573e-5d07-b527-3c7f572460b7 -->
  <rule id="597135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2596 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>