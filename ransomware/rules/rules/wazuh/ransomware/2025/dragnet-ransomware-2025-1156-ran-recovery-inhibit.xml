<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1156 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 80c96e0b-c8c1-5dd1-ad46-aa8313c9e4d4 -->
  <rule id="368750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1156 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>