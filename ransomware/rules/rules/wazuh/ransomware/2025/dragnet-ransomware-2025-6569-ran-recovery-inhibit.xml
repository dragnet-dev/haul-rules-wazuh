<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6569 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 0fa6ee2d-1b37-5605-8c56-0452f43d4809 -->
  <rule id="217742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6569 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>