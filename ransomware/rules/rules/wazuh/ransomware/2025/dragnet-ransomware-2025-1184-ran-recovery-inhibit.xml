<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1184 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 06dd6097-78c8-555c-b4fc-e5a329bd8cff -->
  <rule id="957609" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1184 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>