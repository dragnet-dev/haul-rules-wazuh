<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7592 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d92f2437-3df9-58b6-9029-83ee7f84a43d -->
  <rule id="528724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7592 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>