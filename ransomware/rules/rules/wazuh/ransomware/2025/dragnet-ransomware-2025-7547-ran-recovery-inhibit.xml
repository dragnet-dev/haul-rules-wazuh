<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7547 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 407d5780-5151-56e1-a4ac-1c283befc68f -->
  <rule id="325578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7547 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>