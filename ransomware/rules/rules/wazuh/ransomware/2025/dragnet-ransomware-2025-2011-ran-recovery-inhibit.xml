<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2011 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: d43d9ebc-fa5a-5eae-9cfb-17bb24a6b2fa -->
  <rule id="840318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2011 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>