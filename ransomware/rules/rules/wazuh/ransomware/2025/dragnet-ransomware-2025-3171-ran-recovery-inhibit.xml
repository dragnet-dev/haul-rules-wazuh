<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3171 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 3c8aca9b-db4f-5dc1-a080-87c06aac5d01 -->
  <rule id="793130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3171 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>