<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5672 — Event Log Clearing (devman) | Status: deprecated | Sigma ID: dee8ea8c-44c4-56a9-8418-6f0b5b2869b9 -->
  <rule id="231242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5672 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>