<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7388 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 262859f1-f236-5593-a3f2-f0796879ce76 -->
  <rule id="705759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7388 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>