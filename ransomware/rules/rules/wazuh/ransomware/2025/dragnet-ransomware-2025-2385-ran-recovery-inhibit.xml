<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2385 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 829d89e5-7d9f-5330-abd7-d71b152963d6 -->
  <rule id="527789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2385 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>