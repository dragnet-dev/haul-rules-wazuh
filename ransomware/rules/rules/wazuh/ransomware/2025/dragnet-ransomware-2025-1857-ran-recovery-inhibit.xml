<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1857 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8e8139a6-bcb2-5fef-b6b9-8c8f3b821625 -->
  <rule id="628139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1857 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>