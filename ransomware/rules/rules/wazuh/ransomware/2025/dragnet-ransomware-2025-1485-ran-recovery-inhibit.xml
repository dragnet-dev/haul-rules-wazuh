<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1485 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 71438bcd-ff20-5623-a927-e9e791196bcb -->
  <rule id="343019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1485 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>