<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5351 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cac5d674-30f9-5c53-a70e-db8b3c04adf4 -->
  <rule id="791336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5351 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>