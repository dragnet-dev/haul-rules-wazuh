<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7836 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: ba955f5b-569b-5229-ae60-c2a2793de343 -->
  <rule id="391295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7836 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>