<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2586 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: caf9bac9-6ced-5dc8-b6f5-60aff3d13a75 -->
  <rule id="314810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2586 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>