<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6903 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 7b34e252-f889-533f-ac21-5e20db4632c3 -->
  <rule id="273582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6903 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>