<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5137 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 1fc70769-37cb-5976-9a5e-7a55122fd537 -->
  <rule id="687076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5137 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>