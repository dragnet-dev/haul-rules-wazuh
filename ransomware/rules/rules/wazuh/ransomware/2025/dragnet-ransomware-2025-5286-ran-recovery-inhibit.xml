<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5286 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 0cfd843f-351d-54b8-a550-b6c159611a57 -->
  <rule id="725843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5286 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>