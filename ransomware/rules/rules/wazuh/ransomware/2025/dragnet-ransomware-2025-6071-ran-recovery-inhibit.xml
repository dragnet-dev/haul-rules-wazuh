<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6071 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 973d22cc-cff0-5e13-bdba-590279f866aa -->
  <rule id="758122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6071 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>