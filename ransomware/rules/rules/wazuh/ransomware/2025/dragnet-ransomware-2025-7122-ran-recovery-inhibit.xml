<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7122 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0af46e86-76ac-5cdf-bdf5-44f96351d594 -->
  <rule id="207508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7122 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>