<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1480 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: f5e13136-b3ba-5061-a4b3-7003abba75f5 -->
  <rule id="794131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1480 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>