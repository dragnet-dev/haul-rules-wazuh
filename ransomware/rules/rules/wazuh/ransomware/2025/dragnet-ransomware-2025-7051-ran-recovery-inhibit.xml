<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7051 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 2a09befc-01f8-5369-961f-f7f8a16854de -->
  <rule id="277694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7051 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>