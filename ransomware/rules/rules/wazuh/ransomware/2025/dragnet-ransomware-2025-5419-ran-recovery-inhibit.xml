<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5419 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 80cca2c0-9b05-58f9-a1da-540732247322 -->
  <rule id="709542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5419 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>