<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4786 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6fcef7f5-bf2b-54d0-88e9-82d72ffb774c -->
  <rule id="179677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4786 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>