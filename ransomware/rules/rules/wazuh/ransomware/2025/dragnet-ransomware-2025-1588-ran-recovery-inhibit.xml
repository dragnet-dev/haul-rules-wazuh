<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1588 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 427d1317-9765-5073-bbb5-c3884419ad83 -->
  <rule id="645131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1588 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>