<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1433 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 5db49be7-cfb6-5d52-a743-9fa8fdafba60 -->
  <rule id="699195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1433 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>