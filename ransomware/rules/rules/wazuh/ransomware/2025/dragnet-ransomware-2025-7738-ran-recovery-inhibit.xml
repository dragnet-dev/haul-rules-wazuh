<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7738 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8fb7ab63-f5a1-5dc1-99d4-723a0f9fc4df -->
  <rule id="587403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7738 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>