<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0025 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: d67bfd5e-64d9-50f5-8a29-d886afe10b45 -->
  <rule id="302301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0025 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>