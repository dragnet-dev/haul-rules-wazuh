<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2698 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d878b596-a935-5aa1-bd79-2e3e61b76fbd -->
  <rule id="520595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2698 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>