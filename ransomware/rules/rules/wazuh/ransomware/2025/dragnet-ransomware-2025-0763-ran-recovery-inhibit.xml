<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0763 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 411c7875-1f39-5be9-bdb6-ffd3c8be13b8 -->
  <rule id="388787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0763 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>