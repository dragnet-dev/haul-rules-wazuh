<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4315 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a99e911e-5284-5c15-b536-95404d6eb3c3 -->
  <rule id="959891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4315 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>