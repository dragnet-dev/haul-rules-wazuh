<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1550 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 59c72284-0466-5a78-9416-522f2586fd56 -->
  <rule id="667228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1550 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>