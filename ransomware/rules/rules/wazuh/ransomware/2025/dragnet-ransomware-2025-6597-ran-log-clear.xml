<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6597 — Event Log Clearing (J) | Status: experimental | Sigma ID: 2272c6cc-9d3a-5b4d-95d9-ff5a2e34c3db -->
  <rule id="518348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6597 — Event Log Clearing (J)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>