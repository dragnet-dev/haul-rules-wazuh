<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3492 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 75721312-7ce7-5b96-86fb-7b25d5c2d7fa -->
  <rule id="472131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3492 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>