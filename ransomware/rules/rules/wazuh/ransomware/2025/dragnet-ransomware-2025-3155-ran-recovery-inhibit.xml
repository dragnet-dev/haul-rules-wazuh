<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3155 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 535915bd-2990-5ab5-b840-82eb90aa1cb2 -->
  <rule id="574651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3155 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>