<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1603 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 333ff2ae-468f-5efc-9454-2a567df58768 -->
  <rule id="280522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1603 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>