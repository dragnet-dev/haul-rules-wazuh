<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4359 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: afa305ef-e91f-5a6b-a702-b5a5a5c8c202 -->
  <rule id="210305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4359 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>