<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3359 — Event Log Clearing (devman) | Status: deprecated | Sigma ID: 7e26b20e-83d1-5bc9-9b51-50392a5e87f1 -->
  <rule id="320272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3359 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>