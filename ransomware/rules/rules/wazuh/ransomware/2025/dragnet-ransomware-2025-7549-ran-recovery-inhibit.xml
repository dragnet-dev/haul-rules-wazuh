<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7549 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dfd5b4ec-8c47-55cc-9158-085ad876c593 -->
  <rule id="430514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7549 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>