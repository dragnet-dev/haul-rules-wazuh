<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2675 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 66a59b8d-9bdf-5d97-ab10-8ce3d105c9f6 -->
  <rule id="906555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2675 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>