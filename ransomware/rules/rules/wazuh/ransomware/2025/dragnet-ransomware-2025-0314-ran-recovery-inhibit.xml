<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0314 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 571e195f-168d-51ef-9dc7-2edf2199d1d1 -->
  <rule id="250195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0314 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>