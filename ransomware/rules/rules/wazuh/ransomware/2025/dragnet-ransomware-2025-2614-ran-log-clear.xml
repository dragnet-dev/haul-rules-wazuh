<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2614 — Event Log Clearing (cephalus) | Status: experimental | Sigma ID: 7b8ce12b-5593-5ad9-a003-40463b337169 -->
  <rule id="571341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2614 — Event Log Clearing (cephalus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>