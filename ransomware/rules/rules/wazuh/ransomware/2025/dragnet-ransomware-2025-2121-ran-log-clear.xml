<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2121 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: 69cdf3f5-0ef2-5dfa-a5fa-3e7c748e1797 -->
  <rule id="259193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2121 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>