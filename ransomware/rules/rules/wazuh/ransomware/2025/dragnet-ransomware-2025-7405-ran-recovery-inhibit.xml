<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7405 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f2f44c88-f2b8-51c1-98de-cf37155f82c2 -->
  <rule id="415916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7405 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>