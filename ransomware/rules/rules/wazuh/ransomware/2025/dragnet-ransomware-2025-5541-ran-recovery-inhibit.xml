<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5541 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 59d54138-53b8-529f-aebb-08a81c41fde9 -->
  <rule id="675413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5541 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>