<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3653 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 86cb728c-bb2a-5b46-adf3-7f87b3514744 -->
  <rule id="521972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3653 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>