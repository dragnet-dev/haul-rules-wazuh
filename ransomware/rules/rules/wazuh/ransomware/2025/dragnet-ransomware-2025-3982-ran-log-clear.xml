<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3982 — Event Log Clearing (minteye) | Status: deprecated | Sigma ID: 91a11627-0baf-5ff8-af82-006f56e4f732 -->
  <rule id="666116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3982 — Event Log Clearing (minteye)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>