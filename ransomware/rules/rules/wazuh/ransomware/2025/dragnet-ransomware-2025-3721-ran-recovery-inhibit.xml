<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3721 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 7797ea0c-5aa9-58cb-8254-72a140431164 -->
  <rule id="296266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3721 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>