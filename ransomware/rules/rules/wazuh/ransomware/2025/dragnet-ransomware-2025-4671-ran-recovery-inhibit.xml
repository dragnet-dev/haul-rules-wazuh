<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4671 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: ed8b74c2-8ec1-5e25-8f90-3816d69adfc9 -->
  <rule id="305974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4671 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>