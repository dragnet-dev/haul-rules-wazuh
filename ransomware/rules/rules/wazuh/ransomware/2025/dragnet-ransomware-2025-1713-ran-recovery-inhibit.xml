<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1713 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 8b746975-70d6-5716-ade7-2e06011d60a6 -->
  <rule id="597469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1713 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>