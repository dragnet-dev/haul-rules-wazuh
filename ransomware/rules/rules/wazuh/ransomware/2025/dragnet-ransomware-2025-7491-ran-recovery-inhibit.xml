<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7491 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 31572dbf-e1e0-5dc3-9b44-3c7768c141f3 -->
  <rule id="982651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7491 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>