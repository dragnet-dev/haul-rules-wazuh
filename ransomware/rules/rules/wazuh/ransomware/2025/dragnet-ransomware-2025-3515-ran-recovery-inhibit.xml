<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3515 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2a05e59c-8a4e-5c13-a199-988cd916fd74 -->
  <rule id="529459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3515 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>