<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6846 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 0c804e40-c4cc-5746-a951-2bd61dde0367 -->
  <rule id="348784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6846 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>