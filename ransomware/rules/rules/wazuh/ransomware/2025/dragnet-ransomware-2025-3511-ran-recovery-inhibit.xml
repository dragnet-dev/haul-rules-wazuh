<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3511 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e3b6dff5-d879-5d96-a421-4849073b7156 -->
  <rule id="587199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3511 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>