<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2984 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ba78999c-7080-5968-8dd2-1a92d31a9048 -->
  <rule id="167899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2984 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>