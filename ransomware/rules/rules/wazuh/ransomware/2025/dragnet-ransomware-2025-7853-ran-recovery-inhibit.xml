<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7853 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 945a0364-429f-5ff2-8ab7-3e25ac7cd87b -->
  <rule id="713003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7853 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>