<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3559 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 9963b7cd-ff03-591d-9815-9e608db1d368 -->
  <rule id="794197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3559 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>