<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2587 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: 2d4c0ec3-3a30-51a8-986c-75ad9e2a49ba -->
  <rule id="364174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2587 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>