<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1744 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d7fe3384-1c01-529e-a585-daf5418cf6bd -->
  <rule id="932633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1744 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>