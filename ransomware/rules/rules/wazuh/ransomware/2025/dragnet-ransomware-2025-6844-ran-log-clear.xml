<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6844 — Event Log Clearing (desolator) | Status: experimental | Sigma ID: 7510d0b8-3045-5f78-bf07-a8ce318aa2d1 -->
  <rule id="401730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6844 — Event Log Clearing (desolator)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>