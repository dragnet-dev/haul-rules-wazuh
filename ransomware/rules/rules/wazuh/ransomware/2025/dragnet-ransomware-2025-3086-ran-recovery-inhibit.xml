<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3086 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c1525d54-fa7f-528b-85e9-1ed7c549463e -->
  <rule id="244413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3086 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>