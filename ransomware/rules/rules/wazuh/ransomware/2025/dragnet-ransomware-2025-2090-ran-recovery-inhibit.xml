<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2090 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6d87cad1-59f6-5b01-96ef-3dd4d3890e09 -->
  <rule id="212874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2090 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
