<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1967 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 87b6623c-f9ec-543a-b9e6-034b666995e1 -->
  <rule id="603662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1967 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>