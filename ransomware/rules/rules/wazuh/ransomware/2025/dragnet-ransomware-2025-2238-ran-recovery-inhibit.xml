<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2238 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: f8e3fbe7-a7ec-5cc9-ae2f-d3497309c6ad -->
  <rule id="308539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2238 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>