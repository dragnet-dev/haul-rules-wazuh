<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5787 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 02d50875-784f-5224-9006-caa599264542 -->
  <rule id="150875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5787 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>