<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1414 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: f10171d0-a56c-554c-be39-3725923d9e9d -->
  <rule id="710171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1414 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>