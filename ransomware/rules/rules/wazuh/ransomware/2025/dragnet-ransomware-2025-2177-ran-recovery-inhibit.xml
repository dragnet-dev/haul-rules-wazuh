<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2177 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9e47fd62-3ca6-57a9-8c87-b9f7b1646be3 -->
  <rule id="557085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2177 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>