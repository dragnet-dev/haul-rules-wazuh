<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3625 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6a70bb37-4564-5943-a8ea-544ede2f0239 -->
  <rule id="131707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3625 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>