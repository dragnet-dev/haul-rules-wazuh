<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3767 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 09b7b9f1-ab68-597d-a650-aea4e140663a -->
  <rule id="487839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3767 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>