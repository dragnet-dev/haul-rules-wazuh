<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5009 — Recovery Inhibition (cephalus) | Status: experimental | Sigma ID: 3b2d411c-5a1e-52c1-b712-4872d7869df6 -->
  <rule id="585411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5009 — Recovery Inhibition (cephalus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>