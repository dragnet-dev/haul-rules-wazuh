<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6713 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6caa8853-343d-52fd-9fb4-39e56cfcbfb4 -->
  <rule id="181888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6713 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>