<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2344 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 0475dcb1-f29f-5dff-814a-dfb32f1b0bf7 -->
  <rule id="249131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2344 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>