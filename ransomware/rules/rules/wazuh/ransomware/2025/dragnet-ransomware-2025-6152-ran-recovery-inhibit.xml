<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6152 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5b87e87a-270c-5c2d-908a-de32eb4a68b0 -->
  <rule id="670068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6152 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>