<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2641 — Event Log Clearing (minteye) | Status: deprecated | Sigma ID: 3478691a-e8a3-553a-a3db-1b4b3fd378b5 -->
  <rule id="878691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2641 — Event Log Clearing (minteye)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>