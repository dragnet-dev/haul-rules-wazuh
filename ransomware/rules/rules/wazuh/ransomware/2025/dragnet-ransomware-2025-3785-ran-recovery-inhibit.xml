<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3785 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 34e1411f-7a66-5f02-a163-c032d946749a -->
  <rule id="281411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3785 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>