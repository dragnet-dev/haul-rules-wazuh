<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2979 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1f841816-d001-567c-b902-f398f932c4c3 -->
  <rule id="584181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2979 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>