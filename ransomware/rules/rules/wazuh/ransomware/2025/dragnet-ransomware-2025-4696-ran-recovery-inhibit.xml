<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4696 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 3c52b71a-c7e1-5f03-b1cb-70a7fa946db5 -->
  <rule id="784371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4696 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>