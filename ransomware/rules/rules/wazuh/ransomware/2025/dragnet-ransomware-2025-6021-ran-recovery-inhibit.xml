<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6021 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: bef16640-ca07-5013-adc0-5d00631bb8e4 -->
  <rule id="455166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6021 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>