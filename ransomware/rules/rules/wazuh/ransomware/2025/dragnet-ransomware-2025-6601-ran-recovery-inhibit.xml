<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6601 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 0da70cf9-628b-54f3-85cd-ec80ed87bba8 -->
  <rule id="298927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6601 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>