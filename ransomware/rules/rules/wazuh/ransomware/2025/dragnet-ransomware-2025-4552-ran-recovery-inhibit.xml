<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4552 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 64b36f66-035f-5f98-b946-92da19a28847 -->
  <rule id="856591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4552 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>