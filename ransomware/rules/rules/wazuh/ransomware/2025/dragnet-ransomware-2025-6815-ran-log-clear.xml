<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6815 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 1df97466-9ba4-522f-bd95-3f1e6514e2d7 -->
  <rule id="399746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6815 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>