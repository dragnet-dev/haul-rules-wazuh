<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1549 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4859904c-b4e6-594b-8249-ec240bc2e914 -->
  <rule id="459904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1549 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>