<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2329 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 730362f1-4e93-5010-b43c-cbb9f39fe720 -->
  <rule id="985807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2329 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>