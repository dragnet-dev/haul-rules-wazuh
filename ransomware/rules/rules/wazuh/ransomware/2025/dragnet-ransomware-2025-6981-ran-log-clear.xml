<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6981 — Event Log Clearing (securotrop) | Status: test | Sigma ID: 3ea8d735-4490-5d90-b49e-9df73e759efc -->
  <rule id="804617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6981 — Event Log Clearing (securotrop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>