<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6971 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 8f737a9a-0ccd-5211-b894-f7cee18e702f -->
  <rule id="599802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6971 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>