<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4533 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3681bd91-fe03-5d67-a6d5-7b6a38ae151c -->
  <rule id="525259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4533 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>