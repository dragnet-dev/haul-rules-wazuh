<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5354 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 14af21cb-3ae4-599b-8f50-c9727c47875f -->
  <rule id="714748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5354 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>