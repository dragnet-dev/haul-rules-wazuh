<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0946 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: c4085316-021f-54e5-a0a5-f3929114a898 -->
  <rule id="440853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0946 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>