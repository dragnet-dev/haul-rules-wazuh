<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1170 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 004a3f13-357f-5f67-8e40-a877ad093a3b -->
  <rule id="390313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1170 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>