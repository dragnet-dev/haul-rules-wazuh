<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1836 — Event Log Clearing (anubis) | Status: test | Sigma ID: 9d619c33-9bd6-5007-8c95-2b8fb1b90f99 -->
  <rule id="821916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1836 — Event Log Clearing (anubis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>