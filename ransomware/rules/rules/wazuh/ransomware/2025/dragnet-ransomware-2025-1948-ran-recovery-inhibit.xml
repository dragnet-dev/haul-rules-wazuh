<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1948 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 255525fe-fa06-5379-bb84-9627507bcd85 -->
  <rule id="588415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1948 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>