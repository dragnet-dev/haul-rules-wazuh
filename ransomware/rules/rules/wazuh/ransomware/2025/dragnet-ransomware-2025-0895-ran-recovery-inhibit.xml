<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0895 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 1bad7674-e8d2-5c28-b772-822e2543910b -->
  <rule id="885767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0895 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>