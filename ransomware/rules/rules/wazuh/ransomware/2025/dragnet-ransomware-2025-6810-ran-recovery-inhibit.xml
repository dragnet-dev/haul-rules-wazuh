<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6810 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 96da5076-41e4-59f0-ac0c-264c72e995c2 -->
  <rule id="779450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6810 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>