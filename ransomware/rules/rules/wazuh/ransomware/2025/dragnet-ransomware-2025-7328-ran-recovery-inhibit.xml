<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7328 — Recovery Inhibition (skira) | Status: experimental | Sigma ID: 6a6695e2-0fde-55bd-ad36-10c526b4958c -->
  <rule id="266695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7328 — Recovery Inhibition (skira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>