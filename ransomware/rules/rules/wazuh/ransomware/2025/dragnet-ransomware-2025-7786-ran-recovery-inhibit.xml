<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7786 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: c68a1a50-f692-515a-93db-c1348f58e619 -->
  <rule id="647706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7786 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>