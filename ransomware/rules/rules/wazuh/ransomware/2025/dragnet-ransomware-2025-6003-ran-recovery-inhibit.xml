<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6003 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 91be42f2-c6d9-5dc7-82db-8381efdaa9d7 -->
  <rule id="648642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6003 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>