<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1315 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 36b15c98-0a5f-5bf9-83dc-bba3856b1488 -->
  <rule id="494529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1315 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>