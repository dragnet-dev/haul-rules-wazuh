<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6827 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 4dc0b1b2-7691-5ae5-ba80-719306f3038a -->
  <rule id="290511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6827 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>