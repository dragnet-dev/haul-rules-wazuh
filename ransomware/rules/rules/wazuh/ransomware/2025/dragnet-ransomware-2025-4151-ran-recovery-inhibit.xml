<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4151 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 08ba079a-55b1-51ad-86cc-a77bfc577a17 -->
  <rule id="534079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4151 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>