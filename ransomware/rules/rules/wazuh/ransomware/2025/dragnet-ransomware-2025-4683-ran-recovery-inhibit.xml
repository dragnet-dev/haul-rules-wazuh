<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4683 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 50fa3ddd-6beb-5f53-825c-3badb59de871 -->
  <rule id="388061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4683 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>