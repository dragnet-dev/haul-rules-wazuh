<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4012 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: d239805f-f534-50c6-b438-aa6e8a154d56 -->
  <rule id="523980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4012 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>