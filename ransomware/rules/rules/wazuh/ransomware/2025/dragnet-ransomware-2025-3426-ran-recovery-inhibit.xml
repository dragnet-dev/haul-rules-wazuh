<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3426 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b09ce8bd-2d9b-5453-8ab7-df5ff4a5968b -->
  <rule id="241108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3426 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>