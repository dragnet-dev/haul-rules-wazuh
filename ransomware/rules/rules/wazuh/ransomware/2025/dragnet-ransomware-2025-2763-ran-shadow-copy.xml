<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2763 — Shadow Copy Deletion (VanHelsing) | Status: experimental | Sigma ID: 90c84d6f-75bc-5ed3-86a8-824920ee3fb5 -->
  <rule id="624557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2763 — Shadow Copy Deletion (VanHelsing)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>