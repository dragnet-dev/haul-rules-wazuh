<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2138 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 6b889511-b46f-5f4e-9562-a6c45eee8afa -->
  <rule id="278895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2138 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>