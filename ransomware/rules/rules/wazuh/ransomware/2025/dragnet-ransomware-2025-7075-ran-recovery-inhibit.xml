<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7075 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 3c73602c-11c0-5c88-8ced-26cd8f42beac -->
  <rule id="773602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7075 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>