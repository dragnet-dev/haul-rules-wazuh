<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4631 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: bcc66f65-5b69-50d9-a17c-01fe559c2c2b -->
  <rule id="433071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4631 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>