<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5760 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 565ae17f-49f4-59a9-9d77-bc1563d7d52a -->
  <rule id="648141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5760 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>