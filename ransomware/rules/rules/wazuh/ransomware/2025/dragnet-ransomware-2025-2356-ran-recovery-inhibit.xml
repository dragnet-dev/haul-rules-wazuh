<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2356 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 49a33d12-8794-5a6a-8d5d-0d61fc99c339 -->
  <rule id="470941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2356 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>