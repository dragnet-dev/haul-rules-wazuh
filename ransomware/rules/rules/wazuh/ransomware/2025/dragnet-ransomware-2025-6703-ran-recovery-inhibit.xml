<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6703 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bee571a2-aabf-5908-9e9c-e4291a499e49 -->
  <rule id="454571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6703 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>