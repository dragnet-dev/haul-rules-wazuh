<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6493 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: ae0e0039-1589-5c85-8f1a-8a5f075f24b7 -->
  <rule id="185400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6493 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>