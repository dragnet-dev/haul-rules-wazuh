<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6473 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 85e87a19-46db-542b-9456-07e8d5f68167 -->
  <rule id="499802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6473 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>