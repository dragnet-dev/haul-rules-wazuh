<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3211 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dd1f8828-e50a-5748-a1c0-6795543a8cfe -->
  <rule id="939188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3211 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>