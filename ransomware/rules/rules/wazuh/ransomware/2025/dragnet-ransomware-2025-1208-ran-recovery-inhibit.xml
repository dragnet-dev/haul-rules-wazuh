<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1208 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ab79c691-2c22-51b1-81a1-095f0f645734 -->
  <rule id="148766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1208 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>