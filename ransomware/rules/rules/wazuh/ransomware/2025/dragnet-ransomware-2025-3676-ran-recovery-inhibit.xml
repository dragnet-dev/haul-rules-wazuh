<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3676 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 26205fc1-7526-52f3-bb67-9e47651c501e -->
  <rule id="508732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3676 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>