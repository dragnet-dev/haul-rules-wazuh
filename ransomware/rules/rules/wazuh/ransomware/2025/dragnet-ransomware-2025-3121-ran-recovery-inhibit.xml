<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3121 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 42837b93-5420-5487-b5d8-4d3cac6875b4 -->
  <rule id="654039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3121 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>