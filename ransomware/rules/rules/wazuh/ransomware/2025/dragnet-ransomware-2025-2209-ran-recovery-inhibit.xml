<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2209 — Recovery Inhibition (qilin) | Status: test | Sigma ID: dbfc51f7-5ea0-54e7-9aca-187a229f6344 -->
  <rule id="331651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2209 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>