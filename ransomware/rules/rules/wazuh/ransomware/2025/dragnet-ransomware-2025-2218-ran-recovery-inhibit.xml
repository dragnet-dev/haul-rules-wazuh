<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2218 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7445a68b-145f-540b-afca-e7361b5c0f22 -->
  <rule id="391306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2218 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>