<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5894 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: af84d9f2-2376-5263-bab7-c6f3101113a4 -->
  <rule id="213579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5894 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>