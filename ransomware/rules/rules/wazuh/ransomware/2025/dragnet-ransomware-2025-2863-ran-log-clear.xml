<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2863 — Event Log Clearing (GDLockerSec) | Status: experimental | Sigma ID: 8e1c0667-c41d-5852-b59d-c179351d5da2 -->
  <rule id="574806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2863 — Event Log Clearing (GDLockerSec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>