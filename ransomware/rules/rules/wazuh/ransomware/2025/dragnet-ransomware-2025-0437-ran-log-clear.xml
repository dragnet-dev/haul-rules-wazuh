<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0437 — Event Log Clearing (devman) | Status: experimental | Sigma ID: 05b223bb-2563-5dae-a0d2-9bfa6f6bcaa9 -->
  <rule id="659579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0437 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>