<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3760 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 8c6656de-7001-5d98-a826-1e4333ae03a0 -->
  <rule id="606656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3760 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>