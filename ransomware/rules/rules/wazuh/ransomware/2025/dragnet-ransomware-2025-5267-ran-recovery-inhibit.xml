<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5267 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 11c3c0a7-79e8-5940-8622-f3e485b45a19 -->
  <rule id="422410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5267 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>