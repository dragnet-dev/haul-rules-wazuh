<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4507 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: cd0a39e5-cd58-5e8d-8de9-8420e636ca99 -->
  <rule id="681039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4507 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>