<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5414 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f828ddf5-3acf-5349-935f-6484be488ee3 -->
  <rule id="552189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5414 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>