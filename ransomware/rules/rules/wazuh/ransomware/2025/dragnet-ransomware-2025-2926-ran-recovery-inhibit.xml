<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2926 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 933084db-1941-5ce5-ac97-ce2562b43612 -->
  <rule id="629357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2926 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
