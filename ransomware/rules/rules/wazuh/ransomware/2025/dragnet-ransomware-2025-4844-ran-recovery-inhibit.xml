<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4844 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ee65182a-4bf3-57fa-b9ec-cae98a411a02 -->
  <rule id="686518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4844 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>