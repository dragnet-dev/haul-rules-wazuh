<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0933 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e069c10e-db42-5b01-9d91-061e4ea84a2c -->
  <rule id="551161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0933 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>