<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4121 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: e91c570c-0e56-59a9-b7fa-9118a3e06724 -->
  <rule id="686857" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4121 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>