<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6242 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3d426a4a-f5ed-5c4f-8dd5-62fa779664b4 -->
  <rule id="928264" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6242 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>