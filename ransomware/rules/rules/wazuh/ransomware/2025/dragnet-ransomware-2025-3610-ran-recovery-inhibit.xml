<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3610 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: b8cd4018-29cd-520b-9436-ddee6e23e042 -->
  <rule id="441340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3610 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>