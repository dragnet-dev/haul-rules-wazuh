<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0418 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 0aad3b6f-92f4-591a-a292-22c260358425 -->
  <rule id="873396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0418 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>