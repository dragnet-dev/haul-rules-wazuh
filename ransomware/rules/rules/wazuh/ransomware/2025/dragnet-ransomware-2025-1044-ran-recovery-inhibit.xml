<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1044 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: fe7bd806-c8d2-5860-af0b-6286b82adadf -->
  <rule id="322218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1044 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>