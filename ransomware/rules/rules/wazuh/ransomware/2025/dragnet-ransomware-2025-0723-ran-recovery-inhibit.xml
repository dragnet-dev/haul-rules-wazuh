<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0723 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a68e65c4-6d6d-5998-b6ef-10d13a3c08bf -->
  <rule id="910265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0723 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>