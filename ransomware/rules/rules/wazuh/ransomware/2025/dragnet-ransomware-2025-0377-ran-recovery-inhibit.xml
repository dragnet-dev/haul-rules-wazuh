<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0377 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: f2d5e1ac-b50d-5c5f-a435-322a7fc99467 -->
  <rule id="412941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0377 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>