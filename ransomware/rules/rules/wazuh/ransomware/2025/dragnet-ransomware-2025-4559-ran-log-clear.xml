<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4559 — Event Log Clearing (skira) | Status: experimental | Sigma ID: 9bf71510-5269-521e-9434-cd21a73fa405 -->
  <rule id="795715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4559 — Event Log Clearing (skira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>