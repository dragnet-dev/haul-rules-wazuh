<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0347 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7c75c597-0975-57bf-98fc-488f14a83b86 -->
  <rule id="296125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0347 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>