<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3132 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 13a2a67e-450a-51bf-909b-933edc79bd9f -->
  <rule id="892267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3132 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>