<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0458 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 9b7f0430-95ab-50b7-9bd3-2756f4584a91 -->
  <rule id="792704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0458 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>