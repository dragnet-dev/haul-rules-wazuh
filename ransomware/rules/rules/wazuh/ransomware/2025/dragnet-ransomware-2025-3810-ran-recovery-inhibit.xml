<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3810 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 22fea8bd-358c-58a1-a1f4-d602d26d70f5 -->
  <rule id="769899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3810 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>