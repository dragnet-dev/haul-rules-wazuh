<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7569 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 8256e8e5-35bd-5778-b9a1-1f1d30c8b40c -->
  <rule id="521108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7569 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>