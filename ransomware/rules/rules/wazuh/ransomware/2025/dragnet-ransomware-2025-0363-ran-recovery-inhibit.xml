<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0363 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: fc839a3e-ca3a-5c73-835e-3b790f350b36 -->
  <rule id="545434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0363 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>