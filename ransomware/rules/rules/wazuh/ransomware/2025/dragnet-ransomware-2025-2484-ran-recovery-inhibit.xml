<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2484 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 6acc779a-1eba-5e64-9674-6374448068ec -->
  <rule id="134077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2484 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>