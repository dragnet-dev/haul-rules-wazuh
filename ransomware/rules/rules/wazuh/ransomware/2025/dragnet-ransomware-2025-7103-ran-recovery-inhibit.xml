<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7103 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2aa2c3a6-1e99-5f10-befd-4cf3badaf4c1 -->
  <rule id="291643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7103 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>