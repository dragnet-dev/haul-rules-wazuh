<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3668 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: a8e1f305-89ab-57e3-b86a-9c16c25405da -->
  <rule id="187513" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3668 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>