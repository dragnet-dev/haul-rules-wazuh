<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7267 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 91e87080-ef8a-57cf-95a7-003b4ceefaa9 -->
  <rule id="670870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7267 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>