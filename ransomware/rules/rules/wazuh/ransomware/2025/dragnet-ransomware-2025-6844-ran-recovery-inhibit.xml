<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6844 — Recovery Inhibition (desolator) | Status: experimental | Sigma ID: f4cd6802-218c-53c9-8706-4280ecd4b4a1 -->
  <rule id="462968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6844 — Recovery Inhibition (desolator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>