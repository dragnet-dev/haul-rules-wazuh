<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2853 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: f314ab33-5afd-5829-92fa-61f82368ab89 -->
  <rule id="420555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2853 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>