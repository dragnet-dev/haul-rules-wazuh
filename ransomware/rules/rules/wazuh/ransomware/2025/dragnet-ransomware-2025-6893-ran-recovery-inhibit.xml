<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6893 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 42a3b57c-4be6-5d51-87b9-45c2decb41e0 -->
  <rule id="291795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6893 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>