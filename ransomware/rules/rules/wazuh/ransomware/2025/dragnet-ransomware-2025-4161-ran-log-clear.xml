<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4161 — Event Log Clearing (everest) | Status: experimental | Sigma ID: ee2a6acf-64ac-5d36-9fa5-c741aeb5cfe2 -->
  <rule id="799626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4161 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>