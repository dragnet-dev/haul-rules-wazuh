<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1753 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: d7a8bfd4-4d3b-52ad-86e0-3a3ce9439a04 -->
  <rule id="339359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1753 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>