<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5222 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 1888a77f-3ca1-5a31-bbf9-6092466255af -->
  <rule id="421877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5222 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>