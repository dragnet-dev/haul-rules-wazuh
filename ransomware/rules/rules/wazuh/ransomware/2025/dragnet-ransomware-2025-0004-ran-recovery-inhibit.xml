<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0004 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e34fe823-ebb0-5302-82d0-a484ec2e1564 -->
  <rule id="173588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0004 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>