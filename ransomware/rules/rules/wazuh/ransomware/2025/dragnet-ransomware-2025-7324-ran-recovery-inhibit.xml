<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7324 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 1e96e065-4b98-5b2e-99ce-8816956a6517 -->
  <rule id="555006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7324 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>