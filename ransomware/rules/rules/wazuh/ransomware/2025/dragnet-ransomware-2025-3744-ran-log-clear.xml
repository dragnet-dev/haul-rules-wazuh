<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3744 — Event Log Clearing (satanlockv2) | Status: experimental | Sigma ID: 6e03bb18-4cab-5ec0-ad72-e4a50cd9f4bf -->
  <rule id="216955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3744 — Event Log Clearing (satanlockv2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>