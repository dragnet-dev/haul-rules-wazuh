<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6598 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6a14a1ee-f5d6-5f00-83fe-58bad4373d25 -->
  <rule id="898341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6598 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>