<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6049 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9bac56a4-f2c4-52a5-8872-f333acdf640f -->
  <rule id="485256" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6049 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>