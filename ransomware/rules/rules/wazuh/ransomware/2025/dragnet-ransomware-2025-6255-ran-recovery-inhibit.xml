<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6255 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f216fb7f-da6e-5047-bb93-a02a20961839 -->
  <rule id="395547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6255 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>