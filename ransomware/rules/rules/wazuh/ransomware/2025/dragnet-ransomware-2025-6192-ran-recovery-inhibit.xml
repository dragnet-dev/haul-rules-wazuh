  <rule id="449002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6192 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
