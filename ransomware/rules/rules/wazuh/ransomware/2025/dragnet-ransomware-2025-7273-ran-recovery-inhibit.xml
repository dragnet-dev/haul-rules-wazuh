<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7273 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: b9843694-8127-547f-afdb-0b210ae17a4e -->
  <rule id="398436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7273 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
