<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3382 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9ad27261-0baf-570a-8af4-622445f6de97 -->
  <rule id="777272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3382 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>