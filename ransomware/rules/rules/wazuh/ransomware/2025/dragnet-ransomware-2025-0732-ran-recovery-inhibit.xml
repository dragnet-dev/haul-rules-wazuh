<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0732 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2b80a875-dea0-5158-b825-3802da3bd567 -->
  <rule id="809087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0732 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>