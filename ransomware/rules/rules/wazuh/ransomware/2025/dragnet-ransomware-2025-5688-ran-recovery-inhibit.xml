<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5688 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e611ab48-8c4a-5d88-9f76-f2c80e3fb2b1 -->
  <rule id="240587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5688 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>