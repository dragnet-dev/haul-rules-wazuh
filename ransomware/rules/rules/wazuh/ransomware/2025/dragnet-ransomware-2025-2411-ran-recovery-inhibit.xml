<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2411 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: f50b527d-bb1d-5efd-87df-4cf899ffe5fd -->
  <rule id="781152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2411 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>