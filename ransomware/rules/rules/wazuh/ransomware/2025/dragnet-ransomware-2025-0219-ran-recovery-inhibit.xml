<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0219 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 05190c5b-115a-52a2-a52f-de1cbb2ee0f4 -->
  <rule id="788411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0219 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>