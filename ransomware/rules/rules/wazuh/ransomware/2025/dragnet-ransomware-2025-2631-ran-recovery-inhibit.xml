<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2631 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: b1fd0431-c70d-5ede-b8fb-d10dba64a5a3 -->
  <rule id="266904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2631 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>