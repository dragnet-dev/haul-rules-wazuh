<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0245 — Recovery Inhibition (nitrogen) | Status: test | Sigma ID: adc75198-0974-55d8-a5c7-c8b6c571518c -->
  <rule id="180751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0245 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>