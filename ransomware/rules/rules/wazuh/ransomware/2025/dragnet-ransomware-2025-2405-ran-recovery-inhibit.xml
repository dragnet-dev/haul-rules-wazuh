<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2405 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: bf4aa4ee-86ae-590b-ac7c-fa6f939ce35d -->
  <rule id="501544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2405 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>