<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4811 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: daf320e4-dd58-56b9-952a-e341256e668f -->
  <rule id="903320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4811 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>