<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3813 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 11a53f01-23f8-5fd0-b7f5-5e18349129b1 -->
  <rule id="384630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3813 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>