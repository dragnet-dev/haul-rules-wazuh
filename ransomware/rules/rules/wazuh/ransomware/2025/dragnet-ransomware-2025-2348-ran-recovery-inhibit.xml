<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2348 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 0c60fdfa-b536-57cb-9351-f651a0fb1e05 -->
  <rule id="765023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2348 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>