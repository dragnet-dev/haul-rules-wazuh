<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4778 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 9d421362-5693-5b84-a275-dba4cd1d74d4 -->
  <rule id="774213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4778 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>