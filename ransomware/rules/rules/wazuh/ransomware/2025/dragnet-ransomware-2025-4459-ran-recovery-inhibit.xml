<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4459 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 05053c56-1c71-505e-aa19-bf1c62b8004b -->
  <rule id="986056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4459 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>