<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4086 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 08f278a4-9107-5e5f-98e3-6bbd5e8ba467 -->
  <rule id="592458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4086 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>