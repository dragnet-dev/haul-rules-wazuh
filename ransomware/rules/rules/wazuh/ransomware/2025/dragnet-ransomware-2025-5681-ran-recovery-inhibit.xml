<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5681 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ec69f26a-2894-54b0-b5a2-2ae85c172156 -->
  <rule id="287192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5681 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
