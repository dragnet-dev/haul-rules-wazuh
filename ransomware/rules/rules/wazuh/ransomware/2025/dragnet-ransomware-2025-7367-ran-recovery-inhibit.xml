<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7367 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 1d47dac5-a996-5dec-9807-14c062261d59 -->
  <rule id="474412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7367 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>