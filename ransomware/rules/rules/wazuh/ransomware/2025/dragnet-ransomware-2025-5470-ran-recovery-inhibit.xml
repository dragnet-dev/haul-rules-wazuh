<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5470 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 1180e807-1aad-5909-949a-9f93555cc2d0 -->
  <rule id="189480" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5470 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>