<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1056 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 8897b4ee-5bd0-5e19-a510-1d78dba7b8d5 -->
  <rule id="623634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1056 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>