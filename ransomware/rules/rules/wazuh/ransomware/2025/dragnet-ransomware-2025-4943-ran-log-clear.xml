<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4943 — Event Log Clearing (payoutsking) | Status: deprecated | Sigma ID: b2a8b982-929c-5b68-a5dd-77f956f75153 -->
  <rule id="284599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4943 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>