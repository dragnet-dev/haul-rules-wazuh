<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6853 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9e9885e7-1fb8-58f8-9ad7-2670b1ca9629 -->
  <rule id="789885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6853 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>