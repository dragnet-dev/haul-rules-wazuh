<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0101 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 138a6417-9ea6-5a10-867a-f474e7d54ad8 -->
  <rule id="518641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0101 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>