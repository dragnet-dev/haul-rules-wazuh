<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4231 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 750a7c78-0d2c-5299-a853-7c3733ee338e -->
  <rule id="221724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4231 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>