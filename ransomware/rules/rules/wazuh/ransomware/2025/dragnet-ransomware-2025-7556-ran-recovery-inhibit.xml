<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7556 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7b1d3bb9-0c7d-5889-88a4-10f9c65313a9 -->
  <rule id="553499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7556 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>