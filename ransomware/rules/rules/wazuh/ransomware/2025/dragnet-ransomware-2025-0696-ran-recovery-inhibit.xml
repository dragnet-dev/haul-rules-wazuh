<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0696 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: df0884b4-893c-5dd1-bb9a-74e01a6ea365 -->
  <rule id="530884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0696 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>