<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3724 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: d037ce2a-4e09-5bca-b91d-9766b08cc6e8 -->
  <rule id="737678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3724 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>