<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1653 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 40a0284e-eb1b-5ce4-ba1a-1671603ef2c0 -->
  <rule id="300284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1653 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>