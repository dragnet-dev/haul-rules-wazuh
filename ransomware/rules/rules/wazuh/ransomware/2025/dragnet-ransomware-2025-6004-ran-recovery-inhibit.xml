<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6004 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f5b8f485-b0d9-56bd-b90a-5112186df85a -->
  <rule id="487034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6004 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>