<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6865 — Recovery Inhibition (bravox) | Status: experimental | Sigma ID: be59ffda-76e9-560e-8991-5354266bd33f -->
  <rule id="479359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6865 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>