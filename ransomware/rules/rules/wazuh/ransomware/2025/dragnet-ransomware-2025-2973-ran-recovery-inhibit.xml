<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2973 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 95581d82-35bd-5825-b2b1-e6640a5b1ac5 -->
  <rule id="729309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2973 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>