<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2672 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: 899fc7d8-5727-579c-9173-d1d5c18704a9 -->
  <rule id="603967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2672 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>