<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0566 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 680a2c36-0235-5606-8a1c-ea98b7c2f2ff -->
  <rule id="942444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0566 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>