<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6245 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 595cc92c-cd07-59f0-a4e6-a7c716608141 -->
  <rule id="725249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6245 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>