<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6512 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 6ff906ef-fef1-50f3-905e-81feb9319866 -->
  <rule id="991906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6512 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>