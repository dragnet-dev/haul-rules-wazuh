<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4119 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ca4abbcd-b420-534b-b5a3-a7b7fef4745a -->
  <rule id="293051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4119 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>