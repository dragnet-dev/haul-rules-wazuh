<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2902 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: dc841f30-4da2-5347-ad19-73ed57efb8b3 -->
  <rule id="933471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2902 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>