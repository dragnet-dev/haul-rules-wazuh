<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3364 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 55f38279-a38a-5d14-a883-b3af39503611 -->
  <rule id="953827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3364 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>