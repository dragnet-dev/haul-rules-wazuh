<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2690 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2fe63d6d-5c70-5335-948a-665e6cdf53b4 -->
  <rule id="426621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2690 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>