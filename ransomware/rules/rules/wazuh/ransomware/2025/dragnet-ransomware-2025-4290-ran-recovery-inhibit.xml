<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4290 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 1db6d980-d4aa-53c5-84d9-718746a9c44a -->
  <rule id="510998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4290 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>