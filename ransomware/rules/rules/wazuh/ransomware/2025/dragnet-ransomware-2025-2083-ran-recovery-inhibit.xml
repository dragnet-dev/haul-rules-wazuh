<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2083 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 81562506-082b-5200-80e0-f05bf7149555 -->
  <rule id="156250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2083 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>