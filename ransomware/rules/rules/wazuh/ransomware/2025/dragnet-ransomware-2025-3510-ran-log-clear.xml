<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3510 — Event Log Clearing (ms13089) | Status: test | Sigma ID: f2912f93-611b-5cf1-9972-9527804d8302 -->
  <rule id="746607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3510 — Event Log Clearing (ms13089)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>