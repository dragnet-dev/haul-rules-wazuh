<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1399 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 48d4fd07-2bef-5524-9130-aae3bf3fa7c9 -->
  <rule id="300637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1399 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>