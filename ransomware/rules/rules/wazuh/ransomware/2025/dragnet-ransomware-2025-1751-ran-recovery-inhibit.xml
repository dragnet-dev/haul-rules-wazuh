<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1751 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: d06e2347-693e-54d1-a36b-9a700c1dbb1d -->
  <rule id="391023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1751 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>