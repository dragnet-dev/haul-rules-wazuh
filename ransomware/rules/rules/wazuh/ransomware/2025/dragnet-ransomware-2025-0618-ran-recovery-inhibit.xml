<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0618 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: e7a306d3-90ec-5e96-afe6-c68bcd7a6490 -->
  <rule id="662306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0618 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>