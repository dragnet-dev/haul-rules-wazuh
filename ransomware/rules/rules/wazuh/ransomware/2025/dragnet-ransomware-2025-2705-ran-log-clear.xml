<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2705 — Event Log Clearing (flocker) | Status: experimental | Sigma ID: a1e78d98-4984-5904-bff3-c6f3d9441283 -->
  <rule id="909261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2705 — Event Log Clearing (flocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>