<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2939 — Event Log Clearing (underground) | Status: experimental | Sigma ID: 47acccef-b066-5b77-b704-3e419f96c8ab -->
  <rule id="524428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2939 — Event Log Clearing (underground)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>