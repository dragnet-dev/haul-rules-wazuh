<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5098 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 1ac17014-1e2d-5c72-9cc1-5c58b002e266 -->
  <rule id="781701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5098 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>