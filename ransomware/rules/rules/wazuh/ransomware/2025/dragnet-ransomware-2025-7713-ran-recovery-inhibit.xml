<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7713 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f7bcf8f6-e4ee-5a4a-8533-a058b657f226 -->
  <rule id="260958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7713 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>