<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4368 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 12079fc4-a95c-5c63-92f3-dec9a36b8eb3 -->
  <rule id="492476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4368 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>