<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7248 — Event Log Clearing (sinobi) | Status: experimental | Sigma ID: 8ccf3669-4fd7-51ee-b0e1-12f51ca94f99 -->
  <rule id="104736" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7248 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>