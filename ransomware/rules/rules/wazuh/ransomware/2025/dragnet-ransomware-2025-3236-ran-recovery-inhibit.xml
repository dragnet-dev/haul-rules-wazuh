<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3236 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c176b938-f34d-5464-984c-d4979b01a6db -->
  <rule id="248279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3236 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>