<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4847 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 4ba14cad-08a1-5710-bd6e-320cc585aefe -->
  <rule id="236236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4847 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>