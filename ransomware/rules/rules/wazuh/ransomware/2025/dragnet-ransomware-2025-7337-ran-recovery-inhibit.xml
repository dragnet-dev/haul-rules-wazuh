<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7337 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a1846bd5-ae39-5b64-897f-d700da086da2 -->
  <rule id="829547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7337 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>