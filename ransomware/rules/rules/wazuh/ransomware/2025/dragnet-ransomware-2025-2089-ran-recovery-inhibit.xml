<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2089 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 98b32668-5aa8-54bd-8f6c-62010e57f090 -->
  <rule id="779326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2089 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>