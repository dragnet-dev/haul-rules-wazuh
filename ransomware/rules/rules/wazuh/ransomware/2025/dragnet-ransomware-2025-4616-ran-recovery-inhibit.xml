<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4616 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b2aa6fa9-e7f7-5add-b314-abdc3acce4c9 -->
  <rule id="214831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4616 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>