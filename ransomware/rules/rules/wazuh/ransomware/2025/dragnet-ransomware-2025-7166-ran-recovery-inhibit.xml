<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7166 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1880a8a3-0847-5727-a168-fd2b0c82ae46 -->
  <rule id="414538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7166 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>