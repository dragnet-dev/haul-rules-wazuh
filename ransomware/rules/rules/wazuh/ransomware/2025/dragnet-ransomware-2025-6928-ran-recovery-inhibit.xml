<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6928 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 24116ea5-e4ba-54bf-9f0e-84bd1e10f783 -->
  <rule id="873930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6928 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>