<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4938 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: f9c7a4cb-3013-573a-a49c-fb3eade5c4f7 -->
  <rule id="590824" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4938 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>