<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2874 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 306e5275-114e-5e6e-a9cf-6f02236d87c8 -->
  <rule id="510527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2874 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>