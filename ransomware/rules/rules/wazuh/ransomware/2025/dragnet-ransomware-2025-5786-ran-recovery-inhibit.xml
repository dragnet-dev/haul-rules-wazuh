<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5786 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 25f3a129-2da0-5649-a722-d36094b07c86 -->
  <rule id="445812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5786 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>