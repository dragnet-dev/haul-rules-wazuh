<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4053 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: b69fe918-397c-585e-afeb-e782593cda3c -->
  <rule id="395189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4053 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>