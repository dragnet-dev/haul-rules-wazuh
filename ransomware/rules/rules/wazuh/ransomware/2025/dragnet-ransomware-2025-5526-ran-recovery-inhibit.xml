<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5526 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fd942e2e-23e9-54bd-b8ec-6ebb54786f15 -->
  <rule id="563086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5526 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>