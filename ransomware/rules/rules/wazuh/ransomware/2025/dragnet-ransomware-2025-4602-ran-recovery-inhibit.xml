<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4602 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 9d942c47-1f6c-5211-8535-db1bb5aadf2e -->
  <rule id="827084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4602 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>