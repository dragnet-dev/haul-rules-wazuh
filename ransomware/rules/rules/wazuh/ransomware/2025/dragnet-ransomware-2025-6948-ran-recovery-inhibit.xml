<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6948 — Recovery Inhibition (cephalus) | Status: experimental | Sigma ID: 2c4a3b01-a22e-5bc6-8a67-3acb373c2ad6 -->
  <rule id="338299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6948 — Recovery Inhibition (cephalus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>