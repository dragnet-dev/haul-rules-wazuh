<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1929 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5d8da812-6f54-583f-82f2-049172a6bc29 -->
  <rule id="703468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1929 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>