<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7377 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: d87b01bc-c319-5cd6-a97e-12605a2d307a -->
  <rule id="520301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7377 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>