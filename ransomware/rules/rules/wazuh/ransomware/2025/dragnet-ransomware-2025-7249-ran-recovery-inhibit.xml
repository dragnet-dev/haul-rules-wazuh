<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7249 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 31db7d2b-f4f2-5629-be24-2178f0b76383 -->
  <rule id="504925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7249 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>