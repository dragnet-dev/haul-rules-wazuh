<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2763 — Event Log Clearing (VanHelsing) | Status: experimental | Sigma ID: 0e9430c1-c86b-5293-a445-87baccf3a341 -->
  <rule id="690892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2763 — Event Log Clearing (VanHelsing)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>