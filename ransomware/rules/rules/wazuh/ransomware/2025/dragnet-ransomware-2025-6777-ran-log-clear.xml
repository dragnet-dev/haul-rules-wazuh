<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6777 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 64de3f1e-6298-5a3e-8c1d-0a5f55091bb6 -->
  <rule id="957023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6777 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>