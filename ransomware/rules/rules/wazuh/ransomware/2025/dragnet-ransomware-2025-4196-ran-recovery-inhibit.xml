<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4196 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c42a69e8-a8fa-5a93-b6fd-b820aa8f0471 -->
  <rule id="288269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4196 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>