<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4203 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5bba2dec-43b6-5544-8ac9-0334eb70ea19 -->
  <rule id="257165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4203 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>