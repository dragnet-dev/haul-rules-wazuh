<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7614 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 32d043be-8b05-5a79-aa16-543affecd890 -->
  <rule id="400699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7614 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>