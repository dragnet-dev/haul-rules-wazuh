<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5738 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 68bff528-2338-5c33-b83a-27a5f2e338b9 -->
  <rule id="215995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5738 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>