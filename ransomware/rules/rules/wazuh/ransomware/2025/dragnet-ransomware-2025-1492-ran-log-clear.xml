<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1492 — Event Log Clearing (skira) | Status: experimental | Sigma ID: bebdbfa5-ef7c-5bc9-8c37-e45ce2d93c6b -->
  <rule id="900415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1492 — Event Log Clearing (skira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>