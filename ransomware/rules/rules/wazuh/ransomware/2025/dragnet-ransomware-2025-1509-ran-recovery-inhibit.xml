<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1509 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 51d40428-f1e2-5780-a078-cf489e51ea60 -->
  <rule id="294042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1509 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>