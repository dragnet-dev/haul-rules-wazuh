<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1635 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: b6df423f-49f1-55d7-8341-3a35f76cf0ab -->
  <rule id="391942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1635 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>