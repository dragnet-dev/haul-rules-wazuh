<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4190 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 06f7c164-4409-509a-b214-2088fa664eb7 -->
  <rule id="988416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4190 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>