<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1486 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 94423f83-3899-5f4a-ae71-19f418baa6b4 -->
  <rule id="710783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1486 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>