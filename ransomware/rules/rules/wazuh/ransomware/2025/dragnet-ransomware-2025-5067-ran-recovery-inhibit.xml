<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5067 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 32860ead-4942-5f79-b2fa-db5b5e05d445 -->
  <rule id="412394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5067 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
