<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2303 — Recovery Inhibition (clop) | Status: test | Sigma ID: dbe3ed77-584c-5e56-bed6-7bcd1c3f9deb -->
  <rule id="107085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2303 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>