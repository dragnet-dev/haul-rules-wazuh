<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1191 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fcac46e0-8f2c-5b95-9444-f1c0cffd3b59 -->
  <rule id="268446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1191 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>