<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5209 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 2643017d-f7dc-5829-84bc-385df0f16252 -->
  <rule id="943017" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5209 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>