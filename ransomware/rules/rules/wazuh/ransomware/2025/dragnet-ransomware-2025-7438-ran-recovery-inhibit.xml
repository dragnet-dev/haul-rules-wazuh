<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7438 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 391e1248-30fe-5334-b60d-14544a03a5d9 -->
  <rule id="970124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7438 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>