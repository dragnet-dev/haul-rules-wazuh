<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6785 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cb506926-b22c-5ff1-b9aa-da9a4f07a44c -->
  <rule id="335069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6785 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>