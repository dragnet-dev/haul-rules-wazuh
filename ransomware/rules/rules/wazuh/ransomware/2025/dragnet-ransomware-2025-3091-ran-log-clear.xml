<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3091 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 6a4b6f78-1f20-5937-b7d4-7cf8951b36a7 -->
  <rule id="125711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3091 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>