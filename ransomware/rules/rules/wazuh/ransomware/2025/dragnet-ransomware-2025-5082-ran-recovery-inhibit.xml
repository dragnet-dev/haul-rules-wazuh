<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5082 — Recovery Inhibition (lynx) | Status: test | Sigma ID: decb9eeb-8c5a-5e70-9387-82b04a94489f -->
  <rule id="225758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5082 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>