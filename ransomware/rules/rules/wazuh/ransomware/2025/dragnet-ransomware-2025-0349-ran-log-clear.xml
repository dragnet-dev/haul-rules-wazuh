<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0349 — Event Log Clearing (crazyhunter) | Status: experimental | Sigma ID: 87e814a1-262a-5b6f-a91e-08cd82242516 -->
  <rule id="606814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0349 — Event Log Clearing (crazyhunter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>