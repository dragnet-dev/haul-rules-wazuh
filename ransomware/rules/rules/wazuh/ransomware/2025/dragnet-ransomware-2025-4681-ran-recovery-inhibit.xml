<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4681 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7fe4dfa5-aeef-55e8-b41d-ea24bd2512f8 -->
  <rule id="839007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4681 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>