<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0599 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: b9fc207c-703c-5164-a8d2-b2d7494ac72f -->
  <rule id="471620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0599 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>