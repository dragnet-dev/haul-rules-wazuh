<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4869 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 48fe7e14-24a6-5f98-b66a-6173c7c71cc6 -->
  <rule id="306846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4869 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>