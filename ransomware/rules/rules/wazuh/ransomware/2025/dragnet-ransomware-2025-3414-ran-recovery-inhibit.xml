<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3414 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: de4aed0f-3186-5365-95bb-f4b7400fef28 -->
  <rule id="212301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3414 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>