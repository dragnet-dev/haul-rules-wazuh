<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7198 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2f979cc6-1b24-59f7-bab9-867492f4f54a -->
  <rule id="682828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7198 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>