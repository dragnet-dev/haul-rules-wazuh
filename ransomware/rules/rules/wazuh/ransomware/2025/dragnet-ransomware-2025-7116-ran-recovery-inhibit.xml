<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7116 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7d939d30-7215-5ca1-88cc-a978bf6a9617 -->
  <rule id="315037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7116 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>