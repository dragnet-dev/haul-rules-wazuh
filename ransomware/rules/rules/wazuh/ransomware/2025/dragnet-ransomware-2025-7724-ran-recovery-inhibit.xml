<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7724 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2a7f533b-40f0-5463-a9d0-df2f44b1aeaf -->
  <rule id="647533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7724 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>