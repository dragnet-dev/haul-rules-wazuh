<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0755 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 17b5e533-481f-52dd-a694-fce8f60811b0 -->
  <rule id="137453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0755 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>