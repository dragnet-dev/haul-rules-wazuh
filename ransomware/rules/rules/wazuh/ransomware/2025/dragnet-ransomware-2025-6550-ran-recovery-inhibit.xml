<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6550 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9588df36-a9c4-5f26-bed5-82fd56f1ca6f -->
  <rule id="754751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6550 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>