<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6972 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: bf12a4cd-9028-51bb-a04a-4403317c912a -->
  <rule id="458024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6972 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>