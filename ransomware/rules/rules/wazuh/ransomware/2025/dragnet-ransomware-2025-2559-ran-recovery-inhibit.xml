<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2559 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 5c4bc118-82b9-5431-a3e5-a48b7d70436c -->
  <rule id="667321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2559 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>