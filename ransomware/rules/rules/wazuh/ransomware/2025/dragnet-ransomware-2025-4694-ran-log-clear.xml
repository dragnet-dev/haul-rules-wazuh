<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4694 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 5b9a792b-1ee3-5636-85c9-ac12a9de9fa2 -->
  <rule id="671479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4694 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>