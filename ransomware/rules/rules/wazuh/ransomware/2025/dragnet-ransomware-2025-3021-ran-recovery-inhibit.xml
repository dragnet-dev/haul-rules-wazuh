<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3021 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 12de8726-3707-5978-b23f-2e000901b162 -->
  <rule id="694872" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3021 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>