<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4819 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: d0a7ba53-96bd-5752-9c05-bc0d5b127744 -->
  <rule id="952378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4819 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>