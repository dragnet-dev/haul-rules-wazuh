<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1275 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 8db3c291-cc50-5d80-9add-3e15cb2e5728 -->
  <rule id="127802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1275 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>