<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3900 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 23983d69-856a-5041-9d4a-a353b3562377 -->
  <rule id="337416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3900 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>