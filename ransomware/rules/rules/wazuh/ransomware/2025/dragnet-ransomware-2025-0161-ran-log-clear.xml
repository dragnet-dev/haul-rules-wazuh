<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0161 — Event Log Clearing (obscura) | Status: deprecated | Sigma ID: b48112b0-522d-514a-bf5f-6dfc6e507137 -->
  <rule id="348112" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0161 — Event Log Clearing (obscura)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>