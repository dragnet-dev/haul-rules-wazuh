<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0045 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 2af82684-ad51-50c8-91b7-97333ad941d6 -->
  <rule id="678268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0045 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>