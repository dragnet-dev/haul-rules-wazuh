<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1037 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 95c5e2f4-cf59-5db0-ad3c-cbf57ecb6f5c -->
  <rule id="752142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1037 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>