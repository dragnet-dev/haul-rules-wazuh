<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2738 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: c4d1c097-8ea3-524f-9c48-b8f4cc46f7a5 -->
  <rule id="595480" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2738 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>