<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3473 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 3c2bee2b-16b7-53cf-a41b-cb0baa77fa81 -->
  <rule id="768846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3473 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>