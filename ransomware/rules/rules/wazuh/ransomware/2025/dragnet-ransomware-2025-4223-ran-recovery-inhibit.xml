<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4223 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d1f9f853-5dab-5abb-9298-7206cdc14e38 -->
  <rule id="779198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4223 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>