<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1999 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c8fb2b72-cfef-5d77-a224-4e316c0f35e3 -->
  <rule id="883083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1999 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>