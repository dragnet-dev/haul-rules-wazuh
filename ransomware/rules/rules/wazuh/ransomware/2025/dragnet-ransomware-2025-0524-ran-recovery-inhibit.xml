<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0524 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: ddf4892e-a286-5ee4-a908-59de0def0d02 -->
  <rule id="951489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0524 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>