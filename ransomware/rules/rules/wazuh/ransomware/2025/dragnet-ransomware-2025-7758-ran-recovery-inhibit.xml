<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7758 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 256b86f7-9460-50b6-b6f7-90d24e96e993 -->
  <rule id="372591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7758 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>