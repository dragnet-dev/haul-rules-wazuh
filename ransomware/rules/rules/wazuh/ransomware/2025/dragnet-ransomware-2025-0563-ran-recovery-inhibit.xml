<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0563 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 43b6ed08-3d39-5ab0-bcbe-5b06677a0441 -->
  <rule id="991213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0563 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>