<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5772 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 3a30c4a9-b3c4-5e8e-b83a-2aa6a990920c -->
  <rule id="626794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5772 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>