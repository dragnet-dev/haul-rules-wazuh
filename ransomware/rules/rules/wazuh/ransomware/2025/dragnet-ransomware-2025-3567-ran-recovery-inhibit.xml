<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3567 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 5b5af06d-ff60-5a2f-a00d-3e8190484bc2 -->
  <rule id="644150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3567 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>