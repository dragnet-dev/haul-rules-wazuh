<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3871 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2ee244ca-fd9d-5f41-a0e6-dae2783e821e -->
  <rule id="403916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3871 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>