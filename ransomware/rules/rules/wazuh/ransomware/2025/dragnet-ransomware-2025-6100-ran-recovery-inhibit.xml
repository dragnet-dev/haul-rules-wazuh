<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6100 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 8a4c8f28-7310-59e4-9031-1645004749c5 -->
  <rule id="945103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6100 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>