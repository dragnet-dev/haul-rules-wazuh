<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3234 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: b65a6b4e-e270-5cf7-b0ea-8c8f77d951f6 -->
  <rule id="384107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3234 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>