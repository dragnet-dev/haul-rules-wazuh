<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2899 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 09c6d029-eae9-51b0-9e92-c8323e19226f -->
  <rule id="806902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2899 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>