<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5163 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 789c6cd3-2367-5613-a396-d64fd2816f61 -->
  <rule id="321868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5163 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>