<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1251 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3e28dad4-55ca-5329-a9ff-a2fb5242696c -->
  <rule id="794586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1251 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>