<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3048 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: ce561c55-a2ce-5764-b7c8-c44cf86d36f3 -->
  <rule id="704988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3048 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>