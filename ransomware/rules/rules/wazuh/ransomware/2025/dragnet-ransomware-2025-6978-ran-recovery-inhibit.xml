<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6978 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 120128af-fc9b-585d-b695-dfca4b33aef7 -->
  <rule id="222058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6978 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>