<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7742 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: c7fec9df-4fa4-5ec0-a253-c2855675a82c -->
  <rule id="842689" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7742 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>