<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3906 — Event Log Clearing (cephalus) | Status: deprecated | Sigma ID: 698a6eee-e280-50c7-ad97-eb4a1ecc7dc3 -->
  <rule id="988590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3906 — Event Log Clearing (cephalus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>