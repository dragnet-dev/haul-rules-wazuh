<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7712 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 63ca4374-3081-5d5b-93ff-365c7f7e64f9 -->
  <rule id="833043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7712 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>