<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3308 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8150eb83-299f-568e-9b22-f5c5f3efe165 -->
  <rule id="386635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3308 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>