<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5297 — Recovery Inhibition (everest) | Status: test | Sigma ID: 3250ccc7-076f-5ab5-8b73-3e3e6c7a4aa1 -->
  <rule id="815276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5297 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>