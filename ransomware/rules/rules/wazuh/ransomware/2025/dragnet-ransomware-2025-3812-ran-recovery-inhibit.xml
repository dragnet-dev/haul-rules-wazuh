<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3812 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1e28c503-ceb2-58d8-95aa-11e6283a004b -->
  <rule id="446050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3812 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>