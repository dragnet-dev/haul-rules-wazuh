<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3363 — Event Log Clearing (kairos) | Status: experimental | Sigma ID: 25a48e8e-0268-5175-856b-7eaf1ed77ffb -->
  <rule id="367828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3363 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>