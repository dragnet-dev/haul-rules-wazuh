<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0942 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c963b3b1-6dee-53ff-be31-718dd362a202 -->
  <rule id="374193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0942 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>