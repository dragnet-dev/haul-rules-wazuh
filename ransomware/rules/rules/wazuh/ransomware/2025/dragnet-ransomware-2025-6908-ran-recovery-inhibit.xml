<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6908 — Recovery Inhibition (tengu) | Status: experimental | Sigma ID: cc186517-3f1c-5539-8bd2-892af37a9b15 -->
  <rule id="341865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6908 — Recovery Inhibition (tengu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
