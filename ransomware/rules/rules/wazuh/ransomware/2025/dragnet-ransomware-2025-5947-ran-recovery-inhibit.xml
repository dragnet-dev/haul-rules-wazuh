<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5947 — Recovery Inhibition (bert) | Status: experimental | Sigma ID: df33fd6f-0901-5bb0-8aa0-66eb8543e24e -->
  <rule id="417501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5947 — Recovery Inhibition (bert)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>