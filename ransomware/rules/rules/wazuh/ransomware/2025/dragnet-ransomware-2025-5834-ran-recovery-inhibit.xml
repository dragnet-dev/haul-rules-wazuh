<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5834 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: 360a445b-cbdf-5236-a641-2a8a47c97e71 -->
  <rule id="470445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5834 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>