<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3951 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 92c306cf-a61f-5e9c-bc41-f333d7021626 -->
  <rule id="684306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3951 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>