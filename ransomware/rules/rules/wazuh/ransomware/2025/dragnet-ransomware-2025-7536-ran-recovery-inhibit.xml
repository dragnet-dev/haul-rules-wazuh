<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7536 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: cd1b0ba0-a152-5076-a155-24a539a17421 -->
  <rule id="852331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7536 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>