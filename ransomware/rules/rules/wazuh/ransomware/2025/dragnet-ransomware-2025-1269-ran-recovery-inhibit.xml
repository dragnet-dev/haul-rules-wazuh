<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1269 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 0c960a4d-fd78-56a2-9c00-33f73ceefe67 -->
  <rule id="373704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1269 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>