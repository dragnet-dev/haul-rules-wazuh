<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6573 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e65863ce-011d-5f57-8080-7fab71b03fb5 -->
  <rule id="665863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6573 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>