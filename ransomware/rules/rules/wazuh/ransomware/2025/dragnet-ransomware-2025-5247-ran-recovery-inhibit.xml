<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5247 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 40d4968f-fd49-5b7e-b73a-ef50dcd2cd80 -->
  <rule id="334968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5247 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>