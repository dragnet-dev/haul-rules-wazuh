<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2581 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 959277d2-8ab3-5bc0-8e53-3fe5cebdc679 -->
  <rule id="148445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2581 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>