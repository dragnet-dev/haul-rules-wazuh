<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5478 — Recovery Inhibition (devman) | Status: test | Sigma ID: 84987a2c-53c5-5f04-819b-c2222057ef62 -->
  <rule id="559802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5478 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>