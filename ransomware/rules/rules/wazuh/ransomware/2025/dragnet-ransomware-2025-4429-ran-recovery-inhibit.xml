<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4429 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e2514527-2ed1-5139-85cb-93a1eabb23c8 -->
  <rule id="625145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4429 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>