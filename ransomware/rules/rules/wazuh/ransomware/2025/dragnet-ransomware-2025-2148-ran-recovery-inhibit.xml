<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2148 — Recovery Inhibition (J) | Status: experimental | Sigma ID: bfc0ce71-6959-5d42-a111-9e7c79fadb83 -->
  <rule id="754286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2148 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>