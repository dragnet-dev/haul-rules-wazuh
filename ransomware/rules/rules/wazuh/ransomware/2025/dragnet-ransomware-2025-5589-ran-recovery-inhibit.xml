<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5589 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 50ec855b-f233-5051-86d1-2adbb5750ac9 -->
  <rule id="503685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5589 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>