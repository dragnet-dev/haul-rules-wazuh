<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6622 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d1a2d5ba-c530-503c-a688-5d22f1c9484f -->
  <rule id="770055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6622 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>