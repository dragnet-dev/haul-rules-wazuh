<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6678 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: fc3712b1-1f51-57d0-af08-a7f5c1d1f176 -->
  <rule id="823712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6678 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>