<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2904 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: b78dd879-0bfa-53e7-ad90-d1840dbbf7af -->
  <rule id="417898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2904 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>