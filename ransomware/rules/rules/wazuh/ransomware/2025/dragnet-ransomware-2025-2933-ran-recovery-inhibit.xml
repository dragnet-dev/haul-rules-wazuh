<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2933 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: d6140219-9eb6-54e9-8fa6-cf99784c5896 -->
  <rule id="561402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2933 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>