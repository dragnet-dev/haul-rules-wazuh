<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6337 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b54a8560-c003-5b9d-a279-0e607b2ef8c0 -->
  <rule id="147485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6337 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>