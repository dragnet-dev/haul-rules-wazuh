<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4278 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bbb89096-b1c1-5678-924d-7fdaef41d2a7 -->
  <rule id="403890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4278 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>