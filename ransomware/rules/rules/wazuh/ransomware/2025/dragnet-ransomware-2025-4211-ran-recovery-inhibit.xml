<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4211 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 97a44e9a-b364-5497-9a57-a80ffe9ec6c9 -->
  <rule id="799918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4211 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>