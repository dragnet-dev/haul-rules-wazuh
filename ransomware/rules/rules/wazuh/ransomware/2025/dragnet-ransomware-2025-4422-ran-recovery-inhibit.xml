<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4422 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 27df8fbb-77ff-5acd-a5bf-379f05c2822a -->
  <rule id="341743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4422 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>