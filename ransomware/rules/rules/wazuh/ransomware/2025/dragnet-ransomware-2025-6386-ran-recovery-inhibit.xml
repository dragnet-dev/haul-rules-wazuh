<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6386 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 88b39fec-71fc-553f-baaa-1daa5b823839 -->
  <rule id="571039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6386 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>