<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5185 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: fa319e58-ba65-5993-9ff9-a5a7a100aa82 -->
  <rule id="505118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5185 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>