<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1107 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: 8eb91c78-8cd0-5033-8e59-ba95b23e9cb7 -->
  <rule id="154268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1107 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>