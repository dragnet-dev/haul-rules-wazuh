<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7338 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 8cf38b2e-b5bb-56f9-a478-17d6dc5bcc9a -->
  <rule id="108619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7338 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>