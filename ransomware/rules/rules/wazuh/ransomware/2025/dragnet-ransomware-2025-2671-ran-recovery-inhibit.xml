<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2671 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5d709fca-81cd-52b7-9a89-4a2a0744192c -->
  <rule id="699359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2671 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>