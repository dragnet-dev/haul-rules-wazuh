<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7127 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 94e305c3-8c3c-5225-9230-ec343e419ec4 -->
  <rule id="718305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7127 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>