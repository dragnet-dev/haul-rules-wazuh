<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4073 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1d8d618a-be28-5141-9ae4-599cea37ac61 -->
  <rule id="381618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4073 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>