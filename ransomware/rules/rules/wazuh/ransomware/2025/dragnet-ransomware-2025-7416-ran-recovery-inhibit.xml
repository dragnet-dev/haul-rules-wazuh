<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7416 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 303d5cbd-f498-5f09-9a0b-d74406c2af59 -->
  <rule id="845643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7416 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>