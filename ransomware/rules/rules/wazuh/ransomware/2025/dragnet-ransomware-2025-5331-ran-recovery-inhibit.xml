<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5331 — Recovery Inhibition (tengu) | Status: experimental | Sigma ID: c9e1c18b-c8b4-583e-8552-da980d477f3d -->
  <rule id="725081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5331 — Recovery Inhibition (tengu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>