<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3035 — Event Log Clearing (play) | Status: test | Sigma ID: 6ec5ea54-73ce-5ad6-b0dd-abd7e6bc45e1 -->
  <rule id="137834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3035 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>