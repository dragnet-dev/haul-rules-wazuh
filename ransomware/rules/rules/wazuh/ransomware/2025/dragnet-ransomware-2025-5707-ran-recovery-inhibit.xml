<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5707 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 42cc0000-8c95-5951-a211-1f7234b489cb -->
  <rule id="295600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5707 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>