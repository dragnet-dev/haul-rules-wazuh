<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2935 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3503f4d9-b2c7-5321-89e7-0fbf67e83985 -->
  <rule id="970157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2935 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>