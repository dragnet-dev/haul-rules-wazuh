<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0669 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 2cb89300-b547-5473-b264-6cd0f1a31eea -->
  <rule id="958930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0669 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>