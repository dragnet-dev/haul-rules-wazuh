<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1393 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a423790f-08fe-5a03-b2c3-55f93e113777 -->
  <rule id="242379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1393 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>