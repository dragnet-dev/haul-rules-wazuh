<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6017 — Recovery Inhibition (qilin) | Status: test | Sigma ID: b4d6f81f-3972-5cb4-b307-447061d78029 -->
  <rule id="340318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6017 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
