<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7228 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 17f6dd14-39f8-5bc6-bbc6-ec9ba8da1445 -->
  <rule id="264771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7228 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>