<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1104 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: cb7b69dd-2947-527c-ad67-042afa569df5 -->
  <rule id="660369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1104 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>