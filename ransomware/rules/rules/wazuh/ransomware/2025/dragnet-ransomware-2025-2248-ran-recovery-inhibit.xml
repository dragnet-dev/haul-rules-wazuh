<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2248 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 40754477-5253-5626-9cc8-b7f0a7f82ff1 -->
  <rule id="575447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2248 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>