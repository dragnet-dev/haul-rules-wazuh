<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3319 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: e7caaf51-0b3f-550c-8bc1-7009c5bd5879 -->
  <rule id="785679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3319 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>