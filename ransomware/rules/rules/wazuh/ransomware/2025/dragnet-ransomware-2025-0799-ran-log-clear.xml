<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0799 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 6f10b6de-cf8b-5b3a-a7e8-9c38584b39e2 -->
  <rule id="977716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0799 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>