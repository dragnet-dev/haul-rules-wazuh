<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3641 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: ec596514-99de-5a07-bf7d-d52d72703087 -->
  <rule id="665965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3641 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>