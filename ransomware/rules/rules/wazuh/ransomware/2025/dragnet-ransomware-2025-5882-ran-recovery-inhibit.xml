<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5882 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: d5425446-378a-59c1-ba4c-67bcb654772c -->
  <rule id="554254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5882 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>