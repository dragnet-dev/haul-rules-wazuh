<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4125 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a792be89-c6ad-5eb2-89d5-f3b61e6d30d3 -->
  <rule id="162942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4125 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>