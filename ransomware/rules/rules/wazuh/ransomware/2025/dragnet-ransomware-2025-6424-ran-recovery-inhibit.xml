<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6424 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6470f509-456f-5a2a-9545-e8c6322b3fb4 -->
  <rule id="235355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6424 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>