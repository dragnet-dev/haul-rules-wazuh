<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1733 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: 8d1e87f5-fd88-51a6-90d0-0f7c8a85b1f6 -->
  <rule id="559087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1733 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>