<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2573 — Event Log Clearing (kairos) | Status: experimental | Sigma ID: 8e24922b-c703-5f5b-98c8-163e8250f969 -->
  <rule id="622492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2573 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>