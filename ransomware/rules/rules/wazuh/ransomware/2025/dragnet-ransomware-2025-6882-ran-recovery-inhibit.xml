<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6882 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 41c56571-04cc-5cfa-b3b3-47d52465c1f5 -->
  <rule id="485657" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6882 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>