<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6685 — Event Log Clearing (datacarry) | Status: deprecated | Sigma ID: b72826b7-006e-5cf3-b69c-41eaa153e1e1 -->
  <rule id="372826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6685 — Event Log Clearing (datacarry)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>