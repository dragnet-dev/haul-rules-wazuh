<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1318 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fa62c475-3ef3-54a7-8175-34bda3fb46af -->
  <rule id="510044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1318 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>