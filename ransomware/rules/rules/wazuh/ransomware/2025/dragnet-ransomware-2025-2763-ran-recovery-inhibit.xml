<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2763 — Recovery Inhibition (VanHelsing) | Status: experimental | Sigma ID: 07af55c3-d195-5e3a-9233-336c333ce147 -->
  <rule id="548092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2763 — Recovery Inhibition (VanHelsing)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>