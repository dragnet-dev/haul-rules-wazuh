<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2618 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9a8cd819-1bde-55e5-b160-41076118153b -->
  <rule id="464938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2618 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>