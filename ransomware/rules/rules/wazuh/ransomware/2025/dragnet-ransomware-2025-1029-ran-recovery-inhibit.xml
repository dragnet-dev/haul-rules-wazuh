<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1029 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bab8c5be-1207-5cbb-b743-10653f2bdd82 -->
  <rule id="380605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1029 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>