<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0332 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d3c6e324-4464-51da-b3cc-e3963f7a5fe9 -->
  <rule id="825103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0332 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>