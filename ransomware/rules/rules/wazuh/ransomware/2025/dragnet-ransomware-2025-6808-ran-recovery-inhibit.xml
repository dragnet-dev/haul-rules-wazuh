<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6808 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 26dc849c-d5cf-5ef1-b2db-e08b274e752d -->
  <rule id="676849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6808 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>