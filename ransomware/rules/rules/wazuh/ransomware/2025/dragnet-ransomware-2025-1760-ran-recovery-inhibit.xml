<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1760 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 188b1c51-34e8-543f-9017-02f4157fd630 -->
  <rule id="430685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1760 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>