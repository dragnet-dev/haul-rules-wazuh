<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2883 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: cc991e36-5ba4-5ce5-8bf4-c1d0530d3c78 -->
  <rule id="679870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2883 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>