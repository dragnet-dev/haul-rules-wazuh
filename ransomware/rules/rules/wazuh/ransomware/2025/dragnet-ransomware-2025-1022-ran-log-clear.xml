<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1022 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: 5f356a0a-4bc9-580b-9ed5-0fcbded7dab4 -->
  <rule id="725706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1022 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>