<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0020 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 5f10dd91-b75d-511e-ad42-ebe9cf1d7d02 -->
  <rule id="734781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0020 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>