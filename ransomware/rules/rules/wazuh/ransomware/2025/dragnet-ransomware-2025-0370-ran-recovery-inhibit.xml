<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0370 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a19e9469-f6c2-5ed9-a417-4a33eb50c7af -->
  <rule id="831894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0370 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>