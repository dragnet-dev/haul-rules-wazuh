<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6265 — Recovery Inhibition (kazu) | Status: experimental | Sigma ID: 9d8c0cd7-805e-587d-89c4-46e8301ed84d -->
  <rule id="541612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6265 — Recovery Inhibition (kazu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>