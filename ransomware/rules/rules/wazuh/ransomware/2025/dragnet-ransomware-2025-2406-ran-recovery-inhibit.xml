<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2406 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 8bad9105-2636-50bc-ae4e-a18f27601d31 -->
  <rule id="975791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2406 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>