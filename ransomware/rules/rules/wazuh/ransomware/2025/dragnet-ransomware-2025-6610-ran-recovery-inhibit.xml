<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6610 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 91bdd1b9-884e-5282-9d03-16cf68f502da -->
  <rule id="257731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6610 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>