<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3388 — Recovery Inhibition (cephalus) | Status: experimental | Sigma ID: 74c04d61-37e0-5a73-8a72-94c4126cfc48 -->
  <rule id="213677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3388 — Recovery Inhibition (cephalus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>