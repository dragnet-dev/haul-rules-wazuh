<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4047 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 8fc4fb53-7d34-5a84-a6f5-21bc5d81ac38 -->
  <rule id="589275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4047 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>