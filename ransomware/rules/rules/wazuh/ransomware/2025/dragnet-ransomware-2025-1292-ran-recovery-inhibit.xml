<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1292 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: efbdabf1-2987-5151-90cf-3ecb75f3272d -->
  <rule id="511659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1292 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>