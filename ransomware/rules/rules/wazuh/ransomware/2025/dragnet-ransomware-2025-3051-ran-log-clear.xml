<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3051 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 498fd8dd-e2ba-509d-8b06-64f83994a2c4 -->
  <rule id="477418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3051 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>