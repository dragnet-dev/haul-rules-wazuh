<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2806 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ebe0900d-9dfd-5e80-8252-ec553e3c4154 -->
  <rule id="274090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2806 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>