<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5718 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 17bd8d13-e9b3-59e2-8e2d-a4b5dfcb4d12 -->
  <rule id="167011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5718 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>