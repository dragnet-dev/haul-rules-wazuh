<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4855 — Event Log Clearing (IMNCrew) | Status: experimental | Sigma ID: 79f841a5-bd8f-5805-95ae-0783919d48d4 -->
  <rule id="479841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4855 — Event Log Clearing (IMNCrew)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>