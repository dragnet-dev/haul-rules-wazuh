<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7921 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c6f19d3f-f7b3-511f-8fe0-88a9503ebfbe -->
  <rule id="649917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7921 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>