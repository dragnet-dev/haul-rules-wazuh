<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6886 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 60307ccd-ebfb-5e05-983a-f53863972ca1 -->
  <rule id="238796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6886 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>