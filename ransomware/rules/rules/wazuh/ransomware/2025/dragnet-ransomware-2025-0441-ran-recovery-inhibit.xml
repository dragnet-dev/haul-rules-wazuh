<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0441 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 0f692ab8-3824-53c0-b8d5-e2b9bd34d554 -->
  <rule id="517323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0441 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>