<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4085 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1d4ce2e8-bf11-5194-9b01-d0eaadf9152c -->
  <rule id="475246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4085 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>