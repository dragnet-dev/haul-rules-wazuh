<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6273 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 7d3bc858-6ddc-556b-a969-398f22ee22e2 -->
  <rule id="609568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6273 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>