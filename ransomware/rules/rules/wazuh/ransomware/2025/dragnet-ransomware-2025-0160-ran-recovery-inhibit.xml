<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0160 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4b587960-f52b-5508-8702-01adf3dee5b3 -->
  <rule id="458796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0160 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>