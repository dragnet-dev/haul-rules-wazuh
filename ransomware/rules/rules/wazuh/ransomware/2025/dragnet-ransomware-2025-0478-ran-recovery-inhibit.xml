<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0478 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: aa96b891-934f-50e4-a4df-a2226971ed4c -->
  <rule id="135478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0478 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>