<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2236 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0344155d-4e70-55ff-8b59-0ee1930136c6 -->
  <rule id="206493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2236 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>