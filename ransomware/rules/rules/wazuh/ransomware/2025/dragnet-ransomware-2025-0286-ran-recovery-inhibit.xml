<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0286 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 50fe2da5-b9d4-5c07-ab10-a0b4fc41eb1c -->
  <rule id="388685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0286 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>