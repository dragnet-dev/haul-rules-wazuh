<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3778 — Recovery Inhibition (d4rk4rmy) | Status: experimental | Sigma ID: e5b455d4-485c-5394-85b4-64169271d537 -->
  <rule id="631455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3778 — Recovery Inhibition (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>