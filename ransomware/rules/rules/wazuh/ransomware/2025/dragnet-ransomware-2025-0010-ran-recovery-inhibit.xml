<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0010 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 2ee2ec65-0677-5ea2-8e5e-1f5ef3736b8e -->
  <rule id="220748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0010 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>