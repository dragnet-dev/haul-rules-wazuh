<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5954 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 0ba126b7-8922-5476-853a-40cfdc5bfed7 -->
  <rule id="378027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5954 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>