<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6201 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 3fc13018-8a0a-5573-bb66-f22027e2a013 -->
  <rule id="220130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6201 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>