<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3725 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: dd9af78b-6ee6-5d57-865e-2fb2aafd70b1 -->
  <rule id="382397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3725 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>