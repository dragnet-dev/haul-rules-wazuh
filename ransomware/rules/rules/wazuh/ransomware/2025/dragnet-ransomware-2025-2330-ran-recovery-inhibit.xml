<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2330 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: c45315b8-ad71-5e4d-aedb-a2b0ec5185fd -->
  <rule id="445315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2330 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>