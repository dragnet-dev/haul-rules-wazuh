<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2527 — Event Log Clearing (satanlockv2) | Status: experimental | Sigma ID: 60a38399-a92b-5726-b5f8-732286bbc9e3 -->
  <rule id="803839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2527 — Event Log Clearing (satanlockv2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>