<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2913 — Shadow Copy Deletion (d4rk4rmy) | Status: deprecated | Sigma ID: 5a9ed33d-8645-5366-b2c1-92a3d5d46580 -->
  <rule id="629413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2913 — Shadow Copy Deletion (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>