<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6113 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5e69adad-df8e-5d0e-85d5-a10a9fbb5b1d -->
  <rule id="724237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6113 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>