<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3385 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 6e596582-5ee2-52b6-a9ee-b810d878dc99 -->
  <rule id="305965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3385 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>