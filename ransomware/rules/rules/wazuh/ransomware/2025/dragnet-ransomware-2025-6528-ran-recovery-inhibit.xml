<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6528 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 2e566a0c-0bd2-5b09-ba11-330949865987 -->
  <rule id="350660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6528 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>