<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1905 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f5c48e11-795b-5904-a296-083a7232cd8f -->
  <rule id="487982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1905 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>