<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7153 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 5e046b76-2c40-5fbc-84a6-e41d15ccaa7b -->
  <rule id="704747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7153 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>