<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7714 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3b02cf19-0ccf-58a2-a709-0cb364da884e -->
  <rule id="711119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7714 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>