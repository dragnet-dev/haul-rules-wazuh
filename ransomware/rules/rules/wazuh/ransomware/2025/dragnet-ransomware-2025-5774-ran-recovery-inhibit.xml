<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5774 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a368692f-819a-5de3-8c64-1a19b1ab42c0 -->
  <rule id="236869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5774 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>