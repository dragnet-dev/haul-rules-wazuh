<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2648 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 68558522-385e-5be5-917d-eadffe2e22e0 -->
  <rule id="655852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2648 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>