<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6545 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b28eecd2-7669-555a-a36a-ec8b9dedae32 -->
  <rule id="224108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6545 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>