<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4086 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9dbfdd5e-4f62-5c8b-9184-df24828ab9ee -->
  <rule id="538269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4086 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>