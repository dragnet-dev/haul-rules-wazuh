<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7179 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: afbfb422-457c-5e4c-8e9b-a3eb3f46e2ba -->
  <rule id="998674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7179 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>