<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0208 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bdcab314-0ece-5f25-8cbd-1717082098a2 -->
  <rule id="673873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0208 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>