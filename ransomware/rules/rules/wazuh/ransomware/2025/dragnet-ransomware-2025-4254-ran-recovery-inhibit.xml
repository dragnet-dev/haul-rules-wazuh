<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4254 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: fef84d4b-76ea-5ada-8549-4e4bed2b0d8b -->
  <rule id="327757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4254 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>