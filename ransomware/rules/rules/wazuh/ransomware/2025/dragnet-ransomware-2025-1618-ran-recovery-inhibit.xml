<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1618 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: ac3220eb-78df-55b2-8cf0-6636de181721 -->
  <rule id="923220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1618 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>