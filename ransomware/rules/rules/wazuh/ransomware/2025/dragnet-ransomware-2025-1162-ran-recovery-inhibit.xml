<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1162 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 02096826-f5d0-5bde-8e79-9feb204df9de -->
  <rule id="396826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1162 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>