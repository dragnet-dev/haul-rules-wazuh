<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4201 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 9d33b88f-9c35-5b05-ad5a-e81c306604d8 -->
  <rule id="817398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4201 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>