<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0155 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 22683275-1a13-5ad6-bd91-ee0014975953 -->
  <rule id="568327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0155 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>