<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4572 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 994d9f9c-1734-5996-bc5a-5f6673aece82 -->
  <rule id="846879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4572 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>