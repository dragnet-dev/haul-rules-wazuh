<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6332 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 037682c5-79d9-536d-932b-ac94afc273d4 -->
  <rule id="729245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6332 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>