<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5930 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f2583586-5282-5bff-8771-d52738274b43 -->
  <rule id="725835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5930 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>