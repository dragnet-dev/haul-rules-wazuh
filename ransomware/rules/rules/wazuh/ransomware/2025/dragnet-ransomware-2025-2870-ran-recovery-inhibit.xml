<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2870 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 3486ecca-36c6-5173-9be1-b7c077b9c270 -->
  <rule id="882444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2870 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>