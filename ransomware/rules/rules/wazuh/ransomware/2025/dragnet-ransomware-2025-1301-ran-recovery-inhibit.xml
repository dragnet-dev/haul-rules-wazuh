<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1301 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: f5d01a22-4811-52f0-bf37-d8fb59f683d4 -->
  <rule id="488826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1301 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>