<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5561 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: e2760fe8-3695-5721-a8f4-fe3f8a4f7dc3 -->
  <rule id="584175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5561 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>