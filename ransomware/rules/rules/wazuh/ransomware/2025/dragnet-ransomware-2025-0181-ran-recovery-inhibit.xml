<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0181 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: dba4da15-e6bd-5251-95cd-e5a7e08d581a -->
  <rule id="997082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0181 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>