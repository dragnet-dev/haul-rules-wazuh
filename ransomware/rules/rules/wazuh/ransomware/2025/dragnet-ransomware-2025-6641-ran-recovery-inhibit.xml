<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6641 — Recovery Inhibition (J) | Status: experimental | Sigma ID: e2bc1c10-f27a-57b7-97e6-af3f7a32e652 -->
  <rule id="546428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6641 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>