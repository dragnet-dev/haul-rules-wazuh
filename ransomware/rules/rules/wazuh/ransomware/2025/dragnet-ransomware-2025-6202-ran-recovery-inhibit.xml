<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6202 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: d6fc6522-311b-54e2-bda5-07d91247dc36 -->
  <rule id="906865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6202 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>