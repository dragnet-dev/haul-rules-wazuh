<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0283 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 5b0fa752-a1cf-5f0b-8aa3-55f7a22b6abc -->
  <rule id="632107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0283 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>