<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5215 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: ec2d704d-4c4f-5c7f-a794-3644db557613 -->
  <rule id="280570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5215 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>