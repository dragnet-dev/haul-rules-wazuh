<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5741 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 47ca8731-92ec-5cad-a66e-b21a273268c7 -->
  <rule id="423487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5741 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>