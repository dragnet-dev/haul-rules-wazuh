<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5762 — Recovery Inhibition (ransomhouse) | Status: test | Sigma ID: 35feed74-ed75-59af-87ee-6c2dea794909 -->
  <rule id="659021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5762 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>