<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1737 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 87b75a91-4056-56c2-988d-305645cd86c9 -->
  <rule id="546010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1737 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>