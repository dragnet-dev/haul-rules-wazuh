<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0922 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: fc8df3bf-df6e-5415-b8f2-99990b85f1a9 -->
  <rule id="273913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0922 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>