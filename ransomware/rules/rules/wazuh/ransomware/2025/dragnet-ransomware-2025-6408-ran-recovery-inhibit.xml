<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6408 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e26a4efd-0b50-54f4-89f7-be183b50ccd1 -->
  <rule id="152238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6408 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>