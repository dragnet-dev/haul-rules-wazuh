<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0993 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 67ee91e9-1315-5e85-8be4-c79bd100b4b6 -->
  <rule id="939091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0993 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>