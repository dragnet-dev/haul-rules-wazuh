<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2670 — Event Log Clearing (J) | Status: experimental | Sigma ID: 8b255661-7a5a-512f-90da-f4a755e105ee -->
  <rule id="592556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2670 — Event Log Clearing (J)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>