<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3556 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: dcfc21c6-2b55-5b84-88a2-d43ed887e1e3 -->
  <rule id="357221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3556 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>