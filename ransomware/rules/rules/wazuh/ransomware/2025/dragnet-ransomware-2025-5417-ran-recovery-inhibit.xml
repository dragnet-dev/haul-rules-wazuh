<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5417 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 8253c478-3a4a-5add-9a0c-fd0f162b433f -->
  <rule id="520604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5417 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>