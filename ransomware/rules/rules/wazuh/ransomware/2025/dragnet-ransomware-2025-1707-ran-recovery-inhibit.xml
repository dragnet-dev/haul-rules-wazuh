<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1707 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: ec1bcaff-b974-5516-920c-a7ed0d406b5c -->
  <rule id="773674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1707 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>