<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2042 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 01e4b8b1-ea1b-56eb-8a7a-664de2542c10 -->
  <rule id="701391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2042 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>