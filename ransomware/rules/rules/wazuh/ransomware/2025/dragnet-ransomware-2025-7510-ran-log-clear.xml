<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7510 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 4f6e569b-92c4-5e9d-9b85-332e9ded3f51 -->
  <rule id="475056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7510 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>