<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5497 — Recovery Inhibition (devman) | Status: test | Sigma ID: 2e595555-c564-58b3-98ca-47f75cc8338e -->
  <rule id="259555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5497 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>