<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4222 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ee346cc3-71b2-5458-b269-61d863509f34 -->
  <rule id="313548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4222 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>