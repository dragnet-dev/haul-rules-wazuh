<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2634 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 08253af3-6a0a-507b-ab06-dacc3ec0e1d7 -->
  <rule id="412943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2634 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>