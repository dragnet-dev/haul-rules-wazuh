<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4435 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 626cce32-95e4-5acd-b7c3-2d3f8b5cd108 -->
  <rule id="867374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4435 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
