<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0750 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 44d2c242-c884-5b08-b135-1573017d6d8e -->
  <rule id="347642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0750 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>