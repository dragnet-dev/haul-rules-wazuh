<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2479 — Event Log Clearing (thegentlemen) | Status: experimental | Sigma ID: dd3ae732-a6d8-5e93-a2d8-a3f5de298c79 -->
  <rule id="367027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2479 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>