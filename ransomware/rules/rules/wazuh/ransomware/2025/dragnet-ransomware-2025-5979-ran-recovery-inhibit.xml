<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5979 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 3c4432d5-7c65-56af-8be5-5e44eec05cec -->
  <rule id="770925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5979 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>