<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1375 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 3163ef89-9d8b-5a6d-b65e-687dbed22482 -->
  <rule id="999678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1375 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>