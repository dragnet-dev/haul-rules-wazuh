<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5845 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 8440b669-2bd6-5117-86fc-dab60fb4212e -->
  <rule id="550516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5845 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>