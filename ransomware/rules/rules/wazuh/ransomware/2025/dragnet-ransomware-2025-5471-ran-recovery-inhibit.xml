<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5471 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cb11713d-efce-5b76-abcb-6c9255795f2b -->
  <rule id="331171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5471 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>