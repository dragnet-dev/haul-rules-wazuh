<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7700 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: 4437ca34-4779-5807-87b7-7790e7528dcd -->
  <rule id="336074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7700 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>