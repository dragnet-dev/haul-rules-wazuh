<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2606 — Event Log Clearing (shinyhunters) | Status: experimental | Sigma ID: dfee9d75-045c-5410-a24d-c0b6f7f3feb3 -->
  <rule id="272317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2606 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>