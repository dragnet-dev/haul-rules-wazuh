<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4766 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7a173e94-494f-5052-b959-ffe0d5f762ea -->
  <rule id="254782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4766 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>