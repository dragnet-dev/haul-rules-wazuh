<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5993 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 78cddcc9-5393-559b-8128-2f15681d099a -->
  <rule id="764508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5993 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>