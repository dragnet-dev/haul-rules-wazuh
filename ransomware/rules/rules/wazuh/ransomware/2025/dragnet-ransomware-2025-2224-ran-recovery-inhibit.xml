<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2224 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5153d7bc-f9cf-56c0-9165-8a69a1bef085 -->
  <rule id="693883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2224 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>