<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2980 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: 06f87422-5ce2-529d-a919-1d3364f85a97 -->
  <rule id="318742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2980 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>