<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2294 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 6b434c90-93a3-5471-99ab-e5e96e769baa -->
  <rule id="918956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2294 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>