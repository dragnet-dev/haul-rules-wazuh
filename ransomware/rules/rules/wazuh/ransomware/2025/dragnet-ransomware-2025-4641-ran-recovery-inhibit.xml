<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4641 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 1fda7d82-23cd-5043-8875-ea4f6df68f40 -->
  <rule id="504765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4641 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>