<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4381 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8e4e8253-57bb-5b9a-9cb4-def0209ad337 -->
  <rule id="579882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4381 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>