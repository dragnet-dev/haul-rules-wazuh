<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7753 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: c89c7507-b743-5490-a1aa-52cb003eed41 -->
  <rule id="363675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7753 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>