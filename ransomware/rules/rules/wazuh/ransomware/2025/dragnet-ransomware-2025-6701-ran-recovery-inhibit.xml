<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6701 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: c5675608-a833-56f6-b824-a47475b9137d -->
  <rule id="456756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6701 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>