<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5315 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 9af38425-6516-5453-a18d-bdcdeb4062e4 -->
  <rule id="779384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5315 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>