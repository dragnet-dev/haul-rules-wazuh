<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5671 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e25fb8a3-b8c8-592e-80d0-ce9cb5b0ed9b -->
  <rule id="150518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5671 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>