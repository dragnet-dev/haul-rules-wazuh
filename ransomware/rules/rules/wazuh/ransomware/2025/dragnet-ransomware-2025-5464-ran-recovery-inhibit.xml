<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5464 — Recovery Inhibition (handala) | Status: test | Sigma ID: 907bacf5-5650-5ca7-8fbe-b99752d9e2cc -->
  <rule id="218060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5464 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>