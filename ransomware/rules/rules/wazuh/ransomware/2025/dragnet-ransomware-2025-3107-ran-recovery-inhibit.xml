<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3107 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: a2996c1e-4a41-58ea-a6b0-d4cae5515259 -->
  <rule id="847948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3107 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>