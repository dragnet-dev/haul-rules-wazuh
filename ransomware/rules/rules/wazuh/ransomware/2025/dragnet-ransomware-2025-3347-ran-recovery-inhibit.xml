<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3347 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ec575713-2619-56d5-b985-f6de31215b82 -->
  <rule id="665757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3347 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>