<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2843 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 9a2d0daf-3f94-52dd-8bc5-809197e82b04 -->
  <rule id="449613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2843 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>