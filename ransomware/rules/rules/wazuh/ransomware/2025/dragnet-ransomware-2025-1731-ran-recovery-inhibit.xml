<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1731 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 390829e7-c432-505a-92ba-b585cfb1956d -->
  <rule id="953278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1731 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>