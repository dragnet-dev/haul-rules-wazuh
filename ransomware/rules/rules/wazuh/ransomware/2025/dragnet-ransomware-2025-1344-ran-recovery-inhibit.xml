<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1344 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 949b881d-3bc7-5fbf-86b3-27a310124df9 -->
  <rule id="719588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1344 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>