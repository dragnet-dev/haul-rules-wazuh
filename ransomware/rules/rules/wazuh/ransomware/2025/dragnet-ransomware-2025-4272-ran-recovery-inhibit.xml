<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4272 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 0335a82a-2b82-5c7a-bba7-f39b2eca2fc5 -->
  <rule id="593322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4272 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>