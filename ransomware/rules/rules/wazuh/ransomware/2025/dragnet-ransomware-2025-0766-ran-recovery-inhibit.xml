<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0766 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: a635c691-62b2-5127-a14d-e8b02a47c1f6 -->
  <rule id="901726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0766 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>