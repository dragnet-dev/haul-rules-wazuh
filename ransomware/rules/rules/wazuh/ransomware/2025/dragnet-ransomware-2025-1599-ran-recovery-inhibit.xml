<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1599 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: df3903e9-cb6a-5ace-8468-aeae8778576e -->
  <rule id="533903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1599 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>