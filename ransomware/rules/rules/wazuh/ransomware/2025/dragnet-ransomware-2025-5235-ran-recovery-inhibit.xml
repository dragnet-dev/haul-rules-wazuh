<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5235 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 55a9684f-59fc-57b4-945e-5c6284adf9f4 -->
  <rule id="909684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5235 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>