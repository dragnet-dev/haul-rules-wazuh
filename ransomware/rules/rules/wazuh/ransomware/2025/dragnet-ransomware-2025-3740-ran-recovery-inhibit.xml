<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3740 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: cb885963-a6b5-5e14-abde-016491871c47 -->
  <rule id="338859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3740 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>