<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2554 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: a2dd8028-fc8e-555d-ac83-d97da69ac4b5 -->
  <rule id="933380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2554 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>