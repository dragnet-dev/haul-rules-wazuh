<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0044 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: d529be55-cce6-55b0-849a-e792bba91068 -->
  <rule id="863614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0044 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>