<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2768 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3a058089-75d9-58a6-b939-8db80581a36e -->
  <rule id="505808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2768 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>