<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6040 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 064fb6ce-ccf6-58c1-a756-8f2b0b10a9d2 -->
  <rule id="961708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6040 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>