<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3693 — Event Log Clearing (payoutsking) | Status: experimental | Sigma ID: f9d67962-73a9-55f7-b059-626556c574b2 -->
  <rule id="857679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3693 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>