<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6346 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f0e9b23e-6b14-5648-99b9-4f4304822066 -->
  <rule id="363952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6346 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>