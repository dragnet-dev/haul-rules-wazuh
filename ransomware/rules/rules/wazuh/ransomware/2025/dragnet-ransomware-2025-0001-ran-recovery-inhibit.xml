<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0001 — Recovery Inhibition (coinbasecartel) | Status: experimental | Sigma ID: c37a5228-adea-5da1-8047-54d14e22cb6a -->
  <rule id="280252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0001 — Recovery Inhibition (coinbasecartel)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>