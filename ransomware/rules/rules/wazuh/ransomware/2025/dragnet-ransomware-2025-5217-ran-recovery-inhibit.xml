<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5217 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 586ced9d-c3d9-5921-8b97-d5f0bf370172 -->
  <rule id="703565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5217 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>