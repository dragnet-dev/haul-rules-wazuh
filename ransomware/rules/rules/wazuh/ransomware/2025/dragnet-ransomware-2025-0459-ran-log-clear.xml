<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0459 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 6cdbcabd-b1a0-52ec-9a09-e2afb86f8a07 -->
  <rule id="934154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0459 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>