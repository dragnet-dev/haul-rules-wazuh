<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0577 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 77b0af3a-7b66-565b-90c6-60b93eadff75 -->
  <rule id="582255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0577 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
