<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4085 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 94ca2dbd-e98e-5b6f-b48f-9b5ba5dc44bb -->
  <rule id="382605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4085 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>