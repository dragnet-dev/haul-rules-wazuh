<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4115 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 25a7d79e-99fe-56b7-b073-9c960f7fc69e -->
  <rule id="372579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4115 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>