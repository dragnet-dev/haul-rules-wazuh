<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7141 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8826b4e4-3f4c-5d54-b170-9dac9223966e -->
  <rule id="612274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7141 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>