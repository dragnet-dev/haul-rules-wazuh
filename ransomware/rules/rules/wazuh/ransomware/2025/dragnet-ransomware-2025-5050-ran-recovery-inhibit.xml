<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5050 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c6adc5b3-4e9a-55eb-bf85-3217f46a5915 -->
  <rule id="788765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5050 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>