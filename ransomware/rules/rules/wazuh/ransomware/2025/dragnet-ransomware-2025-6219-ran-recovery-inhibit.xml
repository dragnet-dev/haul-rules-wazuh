<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6219 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f4b028e2-46e5-5f98-8fb8-38570f9151a5 -->
  <rule id="775028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6219 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>