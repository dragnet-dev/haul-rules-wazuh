<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3745 — Recovery Inhibition (kazu) | Status: experimental | Sigma ID: df3c6a52-7b49-570d-8fcf-a3422bf8cf37 -->
  <rule id="418506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3745 — Recovery Inhibition (kazu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>