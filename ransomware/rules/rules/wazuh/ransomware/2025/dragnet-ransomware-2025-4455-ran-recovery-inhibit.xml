<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4455 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: da44f9a5-99ce-59e5-8774-b76ebd100585 -->
  <rule id="895199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4455 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>