<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2387 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 18bee8f2-b255-510d-838b-130f6980521e -->
  <rule id="685263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2387 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>