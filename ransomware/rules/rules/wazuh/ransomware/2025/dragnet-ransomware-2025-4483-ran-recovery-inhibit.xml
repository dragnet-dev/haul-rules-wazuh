<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4483 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 27fd6034-3620-53d7-b8b8-b78431f4f24c -->
  <rule id="965603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4483 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>