<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5019 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b1fc844a-d444-5f8d-ac47-c29f81f95c24 -->
  <rule id="266884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5019 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>