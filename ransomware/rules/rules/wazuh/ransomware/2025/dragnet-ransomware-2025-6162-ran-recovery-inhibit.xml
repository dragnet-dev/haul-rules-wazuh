<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6162 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: e77130c8-799e-5f1d-9669-95815163d90a -->
  <rule id="677130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6162 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>