<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2214 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e762cc90-0561-5e5a-9650-22affddcf300 -->
  <rule id="279276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2214 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>