<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1569 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 41b2dcd3-9b9a-56cf-be21-8de153a18c64 -->
  <rule id="908252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1569 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>