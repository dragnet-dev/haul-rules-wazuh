<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4360 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 399ba1f5-4f06-562b-b9c4-ced2fbd175c7 -->
  <rule id="223301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4360 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>