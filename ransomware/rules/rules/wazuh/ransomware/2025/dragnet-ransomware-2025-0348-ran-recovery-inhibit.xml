<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0348 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 24e166ae-c653-506a-a853-4c40ac176d86 -->
  <rule id="170666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0348 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>