<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3260 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1ee6f2ac-ccd9-58c3-9084-e787925aa390 -->
  <rule id="164202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3260 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>