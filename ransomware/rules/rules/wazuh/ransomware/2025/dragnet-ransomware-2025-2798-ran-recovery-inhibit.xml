<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2798 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2df63f60-1e5d-500e-a37e-73016c782001 -->
  <rule id="377023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2798 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>