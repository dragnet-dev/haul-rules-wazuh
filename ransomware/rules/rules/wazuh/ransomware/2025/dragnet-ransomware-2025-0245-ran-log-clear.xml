<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0245 — Event Log Clearing (nitrogen) | Status: test | Sigma ID: fbde4397-dc59-5381-b7b5-ff721391b9b5 -->
  <rule id="247843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0245 — Event Log Clearing (nitrogen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>