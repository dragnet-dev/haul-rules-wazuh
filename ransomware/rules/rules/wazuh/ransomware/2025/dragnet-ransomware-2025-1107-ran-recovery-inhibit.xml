<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1107 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 288c235e-1ec6-599f-8d22-52e36af5f96d -->
  <rule id="220235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1107 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>