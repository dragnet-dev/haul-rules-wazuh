<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3253 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: fc4b8c22-969d-5fc1-ae01-99e058777cdc -->
  <rule id="263340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3253 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
