<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7177 — Recovery Inhibition (warlock) | Status: experimental | Sigma ID: 240c0472-dde9-5987-92c5-cffde1d6643f -->
  <rule id="352047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7177 — Recovery Inhibition (warlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>