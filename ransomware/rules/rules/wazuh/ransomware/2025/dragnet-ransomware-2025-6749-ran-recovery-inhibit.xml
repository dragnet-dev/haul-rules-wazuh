<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6749 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: c3b256a7-b71b-51b5-949e-3a5611efe3e0 -->
  <rule id="279256" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6749 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>