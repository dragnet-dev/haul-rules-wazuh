<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2707 — Recovery Inhibition (ransomhouse) | Status: test | Sigma ID: 5c62445b-b124-5671-bf69-89121a71baa8 -->
  <rule id="362445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2707 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>