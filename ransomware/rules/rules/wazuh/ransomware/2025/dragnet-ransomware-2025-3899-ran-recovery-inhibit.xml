<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3899 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d1b8d2b6-d130-5cd9-8b94-cb047ce369fd -->
  <rule id="772612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3899 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
