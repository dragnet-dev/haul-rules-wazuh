<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1057 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e7e2b281-8ac5-5220-8efd-49ec22c856f1 -->
  <rule id="286032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1057 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>