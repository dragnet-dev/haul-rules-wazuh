<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6671 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 5bf9d88b-a0bf-5432-aa35-648aeaf173c4 -->
  <rule id="655178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6671 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>