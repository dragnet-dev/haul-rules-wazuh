<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3296 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 6b057aa4-7643-59eb-9c19-9ee5a08fdbac -->
  <rule id="912922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3296 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>