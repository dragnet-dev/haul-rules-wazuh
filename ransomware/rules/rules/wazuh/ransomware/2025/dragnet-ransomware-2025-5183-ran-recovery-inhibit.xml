<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5183 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 91678f86-ce16-5d81-9a34-52d1bd99ce01 -->
  <rule id="666863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5183 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>