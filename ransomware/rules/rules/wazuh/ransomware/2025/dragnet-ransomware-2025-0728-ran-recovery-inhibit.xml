<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0728 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5f8a182b-1855-553b-b808-079b8c98a0c4 -->
  <rule id="733818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0728 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>