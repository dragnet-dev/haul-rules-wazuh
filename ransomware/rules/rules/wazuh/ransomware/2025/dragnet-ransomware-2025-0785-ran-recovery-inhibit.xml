<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0785 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bdff2c55-7461-5691-8f9f-3037d84ec6d8 -->
  <rule id="682284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0785 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>