<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1842 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 89e17848-0389-56db-8976-2447750e7b83 -->
  <rule id="638178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1842 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>