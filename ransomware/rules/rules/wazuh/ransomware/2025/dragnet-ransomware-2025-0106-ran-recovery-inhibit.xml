<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0106 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: bad0eb83-0839-5ee8-b533-757dfa3b175a -->
  <rule id="552075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0106 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>