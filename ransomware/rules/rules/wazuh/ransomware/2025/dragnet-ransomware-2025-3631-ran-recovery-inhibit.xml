<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3631 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1b9b2fca-9c50-5262-aa6c-2ed367d0e6ed -->
  <rule id="756764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3631 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>