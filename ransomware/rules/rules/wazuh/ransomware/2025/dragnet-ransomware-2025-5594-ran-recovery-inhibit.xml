<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5594 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: d4e57ee1-2803-518c-bbeb-b1880fbecb10 -->
  <rule id="853726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5594 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>