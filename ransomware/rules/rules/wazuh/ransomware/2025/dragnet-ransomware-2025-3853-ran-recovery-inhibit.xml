<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3853 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 74754a65-4578-56fd-9e99-a3fad41b4557 -->
  <rule id="396074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3853 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>