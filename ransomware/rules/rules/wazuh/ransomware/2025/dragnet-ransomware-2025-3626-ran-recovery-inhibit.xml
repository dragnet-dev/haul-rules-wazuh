<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3626 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 2e71c08c-ac08-5758-889f-78c427fa4040 -->
  <rule id="374808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3626 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>