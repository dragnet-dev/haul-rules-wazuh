<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2492 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 5e90c55d-79b7-59cb-ac1d-f76ee3767816 -->
  <rule id="718525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2492 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>