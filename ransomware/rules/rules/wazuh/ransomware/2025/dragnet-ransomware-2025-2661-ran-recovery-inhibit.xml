<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2661 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: defc7069-131a-5064-86e3-022533ecbd42 -->
  <rule id="408470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2661 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>