<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6927 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: ecbc7e0f-e143-51f4-8761-c09b8c3c77cd -->
  <rule id="796766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6927 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>