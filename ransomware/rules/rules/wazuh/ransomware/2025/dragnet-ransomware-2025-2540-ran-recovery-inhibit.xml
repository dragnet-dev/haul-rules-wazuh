<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2540 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 979f7d00-f091-5277-81f8-d557330c1d4e -->
  <rule id="808765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2540 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>