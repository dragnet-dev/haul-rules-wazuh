<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4330 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c0d35380-3aa4-5aa0-8566-f830e92cacba -->
  <rule id="233353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4330 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>