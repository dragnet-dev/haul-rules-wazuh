<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3278 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 38dd36d2-6e59-55ef-933d-0163c18be0d4 -->
  <rule id="718989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3278 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>