<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1455 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2f214dfb-bcf3-5482-9d0f-711d97f91a4b -->
  <rule id="487007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1455 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>