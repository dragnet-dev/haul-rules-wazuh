<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7789 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6b677931-d89a-544a-9a45-8759c8513a33 -->
  <rule id="276779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7789 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>