<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4239 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 2f38a6fd-5d04-5364-9d1d-0c146bd8c9cb -->
  <rule id="530991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4239 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>