<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7661 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: ac9b6b5b-cf19-5ddd-a8a2-a210426f3cfb -->
  <rule id="928107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7661 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>