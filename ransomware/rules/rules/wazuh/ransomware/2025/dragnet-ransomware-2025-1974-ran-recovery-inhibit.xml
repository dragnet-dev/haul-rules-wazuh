<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1974 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 2efb2fda-ee4a-5971-aec2-1ac4aa5e9b01 -->
  <rule id="224367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1974 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>