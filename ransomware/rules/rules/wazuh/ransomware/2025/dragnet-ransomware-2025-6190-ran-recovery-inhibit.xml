<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6190 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: dc2fe0fd-20f8-5503-8b7b-3bddc173ca17 -->
  <rule id="339660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6190 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>