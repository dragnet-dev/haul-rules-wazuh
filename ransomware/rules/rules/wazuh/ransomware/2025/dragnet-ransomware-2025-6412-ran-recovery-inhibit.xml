<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6412 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 864232a4-61c4-5cd1-8393-b12b1855c1f6 -->
  <rule id="427722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6412 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>