<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1214 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: b76ff81b-9eef-516b-ba10-30efc6b5e9b5 -->
  <rule id="413118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1214 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>