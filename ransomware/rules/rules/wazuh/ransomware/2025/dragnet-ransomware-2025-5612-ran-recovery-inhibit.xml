<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5612 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 06019b0d-93cf-5f17-bf00-7833f6810ab1 -->
  <rule id="210413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5612 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>