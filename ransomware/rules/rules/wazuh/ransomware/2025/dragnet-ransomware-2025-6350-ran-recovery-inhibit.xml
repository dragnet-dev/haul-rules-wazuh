<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6350 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b3aec83d-932a-5205-9f6a-91639a282168 -->
  <rule id="256448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6350 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>