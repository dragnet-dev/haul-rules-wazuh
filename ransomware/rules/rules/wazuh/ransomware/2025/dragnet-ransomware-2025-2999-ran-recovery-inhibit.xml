<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2999 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c6caab43-a831-52f0-b235-e17628292b7b -->
  <rule id="309419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2999 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>