<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3177 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d1b3654a-5ebc-53a4-bc40-10310edef76e -->
  <rule id="407365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3177 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>