<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5376 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e48ae790-2d41-53bb-b3bd-0a29c28ba368 -->
  <rule id="208627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5376 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>