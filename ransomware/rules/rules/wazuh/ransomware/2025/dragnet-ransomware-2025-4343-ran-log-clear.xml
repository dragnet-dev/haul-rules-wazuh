<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4343 — Event Log Clearing (nightspire) | Status: experimental | Sigma ID: 606a156e-5476-5f53-98bd-7f1828d8a81a -->
  <rule id="806156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4343 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>