<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4699 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e5ce38cd-6a55-5eb1-a106-8fe03f7ad487 -->
  <rule id="232638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4699 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>