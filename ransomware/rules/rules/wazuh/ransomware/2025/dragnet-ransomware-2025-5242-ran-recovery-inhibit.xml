<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5242 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 981729f8-2d54-5170-b42d-77829a19596c -->
  <rule id="507679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5242 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>