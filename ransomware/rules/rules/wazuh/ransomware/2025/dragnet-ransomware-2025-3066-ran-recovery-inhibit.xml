<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3066 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 39cb71b0-1755-5593-8d2f-91c07232d6aa -->
  <rule id="218771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3066 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>