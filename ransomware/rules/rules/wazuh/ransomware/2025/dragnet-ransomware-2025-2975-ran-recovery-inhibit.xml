<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2975 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 53066490-b478-5c95-a6e9-5c218099e81d -->
  <rule id="906649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2975 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>