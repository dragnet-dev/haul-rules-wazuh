<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2647 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 2576e5d9-2092-538b-ba58-099310831559 -->
  <rule id="396893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2647 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>