<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1395 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 61fc9459-9cd2-5c45-9cb4-ed014fe260c6 -->
  <rule id="786894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1395 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>