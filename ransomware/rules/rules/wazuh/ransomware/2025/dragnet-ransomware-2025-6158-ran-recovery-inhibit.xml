<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6158 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6880aa96-fc5a-5fc8-a500-71f1758ad198 -->
  <rule id="961450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6158 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>