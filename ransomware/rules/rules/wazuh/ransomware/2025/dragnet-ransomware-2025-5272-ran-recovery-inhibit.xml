<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5272 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f3c67346-198e-543d-b0ad-f43221c00a4c -->
  <rule id="760673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5272 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>