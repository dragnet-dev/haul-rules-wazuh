<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2602 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bc1d90e1-7f1b-5c6e-b860-4a5df7e439f6 -->
  <rule id="410990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2602 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>