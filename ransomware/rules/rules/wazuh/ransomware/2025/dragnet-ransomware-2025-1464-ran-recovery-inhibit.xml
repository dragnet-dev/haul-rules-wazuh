<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1464 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 7ed0cd87-5894-5a50-8767-c528ea38a7e8 -->
  <rule id="794445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1464 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>