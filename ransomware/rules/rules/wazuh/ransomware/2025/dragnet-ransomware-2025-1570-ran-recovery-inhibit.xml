<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1570 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d70695f3-f330-5286-b7d0-a059639b96e8 -->
  <rule id="570695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1570 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>