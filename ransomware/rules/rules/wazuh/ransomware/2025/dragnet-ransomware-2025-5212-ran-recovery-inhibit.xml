<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5212 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e58a4f3e-14d7-5201-9b29-5c320ebfc91d -->
  <rule id="234159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5212 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>