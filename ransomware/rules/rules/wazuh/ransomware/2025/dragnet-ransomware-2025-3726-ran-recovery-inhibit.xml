<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3726 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: de414b66-4e83-5bd1-b3ff-722ea74d512f -->
  <rule id="958635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3726 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>