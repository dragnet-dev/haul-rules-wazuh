<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6729 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 0527a966-671e-558c-b07d-645d69a69aa2 -->
  <rule id="442966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6729 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>