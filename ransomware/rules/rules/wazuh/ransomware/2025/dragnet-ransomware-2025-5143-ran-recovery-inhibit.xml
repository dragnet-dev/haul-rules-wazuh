<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5143 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b430d6cd-8e22-5dd7-898f-53f76556a014 -->
  <rule id="128936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5143 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>