<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6008 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 911ac3bd-3688-5dca-9fe3-350a5904b9f4 -->
  <rule id="633883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6008 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>