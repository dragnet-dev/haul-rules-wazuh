<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0253 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: cddfe31c-01a7-5d53-83b2-887377f23ae2 -->
  <rule id="432623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0253 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>