<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1027 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: d0ca4795-a524-5256-b52a-6acd5cf4ea18 -->
  <rule id="748247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1027 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>