<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1084 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d645051d-3bc5-5ff9-9957-2d5b9cbe38e6 -->
  <rule id="564505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1084 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>