<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0631 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4ed3bd2b-236d-5edb-a192-99469cc1aff5 -->
  <rule id="629117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0631 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>