<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5445 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: adf54dd4-9a2a-5007-8c46-bf4eafae50be -->
  <rule id="953677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5445 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>