<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0068 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6df9d44c-e517-516b-badd-8a105034b4c3 -->
  <rule id="215974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0068 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>