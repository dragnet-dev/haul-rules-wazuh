<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4877 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: eeb6bc00-d05f-591c-b194-e6720e5c6ce9 -->
  <rule id="878364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4877 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>