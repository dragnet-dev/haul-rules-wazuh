<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7346 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 76b98787-e894-5447-a77d-5357cf336123 -->
  <rule id="427987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7346 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>