<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5519 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ce8c9616-3ccf-5543-84bd-f2bdf35405d9 -->
  <rule id="710096" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5519 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>