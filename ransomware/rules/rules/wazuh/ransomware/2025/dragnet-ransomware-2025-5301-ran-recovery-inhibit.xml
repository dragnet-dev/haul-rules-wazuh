<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5301 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: c65aee2f-b00c-5aed-9f99-4d4b579d7379 -->
  <rule id="784238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5301 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>