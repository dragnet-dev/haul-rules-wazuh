<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1426 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 65608d42-7602-5d81-9095-d993ae4f49bd -->
  <rule id="249741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1426 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>