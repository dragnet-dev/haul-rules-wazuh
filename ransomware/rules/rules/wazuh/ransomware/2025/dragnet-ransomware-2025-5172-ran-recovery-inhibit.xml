<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5172 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0fd6db87-1e02-5331-b0d6-abd74f219003 -->
  <rule id="294358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5172 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>