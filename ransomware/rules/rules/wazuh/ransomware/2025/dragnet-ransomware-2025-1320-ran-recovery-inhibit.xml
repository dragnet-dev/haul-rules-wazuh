<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1320 — Recovery Inhibition (qilin) | Status: test | Sigma ID: d785e48c-a7f1-5837-a320-06703a9d2db1 -->
  <rule id="505744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1320 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>