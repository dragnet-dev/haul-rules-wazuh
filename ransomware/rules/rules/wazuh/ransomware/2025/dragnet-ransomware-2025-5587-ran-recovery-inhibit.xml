<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5587 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 34b43332-6c43-5fb2-83b7-1ae5d3bbbe64 -->
  <rule id="254333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5587 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>