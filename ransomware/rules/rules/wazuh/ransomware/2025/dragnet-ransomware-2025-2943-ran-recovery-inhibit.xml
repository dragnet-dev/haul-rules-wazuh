<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2943 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 575be8f6-1de3-52ab-9c22-09e05487e894 -->
  <rule id="673908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2943 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>