<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1266 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 68c24df9-d9e9-5622-be82-81156b6263d5 -->
  <rule id="960397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1266 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>