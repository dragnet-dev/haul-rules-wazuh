<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4416 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: e98a9c2e-38bd-5bf2-8e90-cbdcd10ebd3e -->
  <rule id="336636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4416 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>