<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1256 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 40b69884-ce7b-59ec-bc73-a95b430c55c6 -->
  <rule id="316988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1256 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>