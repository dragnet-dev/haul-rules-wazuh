<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1785 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 5947a405-6f59-51a8-8be9-817df6a04cba -->
  <rule id="616240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1785 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>