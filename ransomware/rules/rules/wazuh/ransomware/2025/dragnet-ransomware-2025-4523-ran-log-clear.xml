<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4523 — Event Log Clearing (benzona) | Status: deprecated | Sigma ID: a7a640a0-5204-54d7-8e09-4b3c7f13b300 -->
  <rule id="922640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4523 — Event Log Clearing (benzona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>