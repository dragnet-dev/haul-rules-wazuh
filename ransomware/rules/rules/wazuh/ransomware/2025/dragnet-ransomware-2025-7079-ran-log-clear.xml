<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7079 — Event Log Clearing (pear) | Status: experimental | Sigma ID: 5138bbfc-c80c-5ea1-a5f1-b4e99c3c6df8 -->
  <rule id="515515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7079 — Event Log Clearing (pear)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>