<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0264 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 1208fdf2-e8bf-5991-bab4-a8d467423831 -->
  <rule id="552031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0264 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>