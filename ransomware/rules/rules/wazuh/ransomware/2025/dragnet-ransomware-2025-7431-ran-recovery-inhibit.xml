<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7431 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: e2bb1cba-dba4-5a61-8a45-f6b734480698 -->
  <rule id="546268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7431 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>