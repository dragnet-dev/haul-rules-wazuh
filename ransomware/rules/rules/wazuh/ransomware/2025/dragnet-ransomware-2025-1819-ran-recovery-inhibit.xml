<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1819 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 8b73a665-1d83-56e0-ab81-6e882274bf52 -->
  <rule id="535786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1819 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>