<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3008 — Recovery Inhibition (qilin) | Status: test | Sigma ID: a7eef402-f823-577d-ad50-2ca016c89a29 -->
  <rule id="920954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3008 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>