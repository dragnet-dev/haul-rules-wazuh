<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4646 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 723d4170-17f4-54dd-bf9c-daf2021b6cb1 -->
  <rule id="358141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4646 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>