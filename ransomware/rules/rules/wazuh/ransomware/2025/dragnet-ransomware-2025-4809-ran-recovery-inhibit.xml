<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4809 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e0caa850-fe7a-5c3f-872b-8898e950aecf -->
  <rule id="466828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4809 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>