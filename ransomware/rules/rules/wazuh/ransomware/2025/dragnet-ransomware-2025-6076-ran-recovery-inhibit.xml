<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6076 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2e27241b-1780-585a-a022-9826eafb39f2 -->
  <rule id="227241" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6076 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>