<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5943 — Event Log Clearing (teamxxx) | Status: experimental | Sigma ID: 78285957-c058-572b-92fd-8dad3c4a86a8 -->
  <rule id="728595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5943 — Event Log Clearing (teamxxx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>