<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0492 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 4e336e5e-017f-5957-bfab-2389b483b582 -->
  <rule id="453390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0492 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>