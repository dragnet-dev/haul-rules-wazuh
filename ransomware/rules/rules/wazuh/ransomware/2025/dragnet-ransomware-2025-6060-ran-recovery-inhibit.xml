<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6060 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9e763ea9-199e-5f1a-999b-b387f3ad72d7 -->
  <rule id="840222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6060 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>