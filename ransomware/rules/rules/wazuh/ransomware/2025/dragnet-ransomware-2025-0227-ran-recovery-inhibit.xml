<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0227 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 88cdaa4a-9e9d-558a-872a-f77a9e95871b -->
  <rule id="519818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0227 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>