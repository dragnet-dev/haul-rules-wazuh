<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5919 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 81a87e62-38b4-5dff-b2c4-f02fa7531c0b -->
  <rule id="391006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5919 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>