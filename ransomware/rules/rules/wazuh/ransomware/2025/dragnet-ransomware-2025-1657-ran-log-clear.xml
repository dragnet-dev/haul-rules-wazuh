<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1657 — Event Log Clearing (arkana) | Status: deprecated | Sigma ID: d4e77541-cd08-545c-bdbe-c2d443b9e9b8 -->
  <rule id="458775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1657 — Event Log Clearing (arkana)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>