<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1811 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 8bbcf89f-0790-5478-a1ee-31284b75dbc9 -->
  <rule id="423678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1811 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>