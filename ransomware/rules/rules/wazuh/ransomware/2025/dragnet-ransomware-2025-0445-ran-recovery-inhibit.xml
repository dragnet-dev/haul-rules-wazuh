<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0445 — Recovery Inhibition (qilin) | Status: test | Sigma ID: beaeb65a-6827-5086-8fb5-1720da6255ec -->
  <rule id="710356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0445 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
