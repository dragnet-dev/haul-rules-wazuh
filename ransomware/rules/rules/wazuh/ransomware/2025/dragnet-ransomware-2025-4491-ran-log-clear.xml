<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4491 — Event Log Clearing (nova) | Status: experimental | Sigma ID: 28ee8b82-a3ea-5b63-b847-4de77d1cf9c4 -->
  <rule id="385099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4491 — Event Log Clearing (nova)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>