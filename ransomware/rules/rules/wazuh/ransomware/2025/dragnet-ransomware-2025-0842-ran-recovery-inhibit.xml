<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0842 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: d005565b-c4ee-56b0-9e20-fd7ae87c6a6c -->
  <rule id="500556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0842 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>