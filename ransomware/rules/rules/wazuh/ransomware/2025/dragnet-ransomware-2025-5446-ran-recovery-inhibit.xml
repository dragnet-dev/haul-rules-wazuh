<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5446 — Recovery Inhibition (insomnia) | Status: experimental | Sigma ID: ec698950-ac88-5ef9-8265-ffa31cb3f84c -->
  <rule id="666989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5446 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>