<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6629 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: de18fb92-dd3b-540e-bb8f-49e9c31eb333 -->
  <rule id="388059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6629 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>