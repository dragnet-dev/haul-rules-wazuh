<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3013 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d7e160fd-0a3e-562a-b6b5-a3d530639edd -->
  <rule id="506160" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3013 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>