<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7586 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: f06841a7-255b-5cb6-bbf0-3b4ba9f49657 -->
  <rule id="706841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7586 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>