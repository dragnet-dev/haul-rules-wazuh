<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2495 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 03535a9e-b300-53ea-ae64-007374e33463 -->
  <rule id="151358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2495 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>