<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6520 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: c287a5d8-3063-5906-9488-0eb81e9d7b3a -->
  <rule id="266025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6520 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>