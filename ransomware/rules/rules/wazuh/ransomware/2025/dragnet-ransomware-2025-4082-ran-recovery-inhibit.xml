<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4082 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: c9ed8d27-4241-536c-857d-4ff9b01e41b1 -->
  <rule id="921901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4082 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>