<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3562 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: bdcdf46c-d3f2-54b7-b826-92529c560a2d -->
  <rule id="674394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3562 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>