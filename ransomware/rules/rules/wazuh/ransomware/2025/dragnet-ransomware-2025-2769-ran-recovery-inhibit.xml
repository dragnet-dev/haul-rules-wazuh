<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2769 — Recovery Inhibition (GDLockerSec) | Status: experimental | Sigma ID: fa7bcf61-302e-5a2f-9613-3822d306a986 -->
  <rule id="471695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2769 — Recovery Inhibition (GDLockerSec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>