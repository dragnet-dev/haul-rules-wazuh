<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0740 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eb57bc23-da14-5242-a9e4-b9c9edc6df94 -->
  <rule id="730780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0740 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>