<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2718 — Recovery Inhibition (walocker) | Status: experimental | Sigma ID: 6916ed81-ec5f-52f2-b552-7eae4b6a8c01 -->
  <rule id="970733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2718 — Recovery Inhibition (walocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>