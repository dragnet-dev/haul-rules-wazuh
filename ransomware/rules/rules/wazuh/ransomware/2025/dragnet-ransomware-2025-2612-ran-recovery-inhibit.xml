<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2612 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4545142f-f6f4-5a08-9bee-c202460aaaf6 -->
  <rule id="145142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2612 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>