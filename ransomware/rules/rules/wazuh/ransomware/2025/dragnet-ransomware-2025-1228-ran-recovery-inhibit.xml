<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1228 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f616b1b9-c397-552c-8b04-458dd59d7f08 -->
  <rule id="798671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1228 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>