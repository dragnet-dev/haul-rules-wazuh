<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3227 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5723ecc3-31b7-5a56-bbe6-e905acb06078 -->
  <rule id="665324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3227 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>