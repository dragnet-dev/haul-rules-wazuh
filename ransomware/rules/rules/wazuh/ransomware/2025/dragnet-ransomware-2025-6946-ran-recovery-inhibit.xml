<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6946 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5b8d4d6a-b7bf-5337-80bd-3130062ac1f5 -->
  <rule id="652237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6946 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>