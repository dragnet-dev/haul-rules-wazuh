<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6532 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7c5c3311-3f55-539a-978c-43086d0fff01 -->
  <rule id="293233" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6532 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>