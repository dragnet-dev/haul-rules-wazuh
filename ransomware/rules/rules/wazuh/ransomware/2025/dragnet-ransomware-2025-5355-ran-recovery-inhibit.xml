<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5355 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: e1bc1d5e-1561-5dd1-9320-1bfe82ccaf18 -->
  <rule id="505469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5355 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>