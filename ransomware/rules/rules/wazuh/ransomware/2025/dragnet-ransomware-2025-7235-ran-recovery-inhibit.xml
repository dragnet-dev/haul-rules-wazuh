<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7235 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 0571670e-bc82-5389-aeb9-a349d976db30 -->
  <rule id="246734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7235 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>