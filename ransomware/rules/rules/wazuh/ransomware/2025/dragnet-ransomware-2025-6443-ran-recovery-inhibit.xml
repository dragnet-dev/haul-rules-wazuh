<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6443 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 767a8ce2-05e4-5e6d-a131-4fb940275522 -->
  <rule id="265260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6443 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>