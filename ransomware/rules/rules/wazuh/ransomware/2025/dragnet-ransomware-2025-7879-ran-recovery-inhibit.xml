<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7879 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e53eb26a-24d2-5d0b-9f1c-6aed8e484e25 -->
  <rule id="222032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7879 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>