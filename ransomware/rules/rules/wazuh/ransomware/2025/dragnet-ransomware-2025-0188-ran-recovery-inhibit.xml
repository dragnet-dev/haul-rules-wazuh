<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0188 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: cb30d604-ab18-5590-8ef1-bd488f88a089 -->
  <rule id="652936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0188 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>