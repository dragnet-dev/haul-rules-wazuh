<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2985 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b9367278-ad83-5e00-9f44-e1292c7f1b0f -->
  <rule id="393672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2985 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>