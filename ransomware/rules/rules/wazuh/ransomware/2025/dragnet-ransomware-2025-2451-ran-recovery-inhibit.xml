<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2451 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 96647326-c955-53b2-8d60-f6464026b5fa -->
  <rule id="764732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2451 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>