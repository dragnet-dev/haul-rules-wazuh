<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4724 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1f35cc27-8336-51f3-8ca4-c1a439c3af90 -->
  <rule id="927642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4724 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>