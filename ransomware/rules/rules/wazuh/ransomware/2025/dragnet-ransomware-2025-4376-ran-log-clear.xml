<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4376 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: e2be3c7d-80e7-58ee-8ca1-1802b8e08647 -->
  <rule id="546780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4376 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>