<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7351 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d9dbb699-8332-5fba-8ab2-bd9ef45a41fa -->
  <rule id="428596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7351 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>