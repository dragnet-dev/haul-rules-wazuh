<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6900 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 1c1b1e7b-1188-5900-8394-0ef3572db80c -->
  <rule id="111507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6900 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>