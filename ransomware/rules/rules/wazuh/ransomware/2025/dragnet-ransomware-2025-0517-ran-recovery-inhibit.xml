<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0517 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: 296e0920-b76d-50d3-bc25-c3d87d1fbb19 -->
  <rule id="350092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0517 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>