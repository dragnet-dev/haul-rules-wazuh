<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5693 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3e88f559-c9a7-5767-af8a-d72aa1e39445 -->
  <rule id="206235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5693 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>