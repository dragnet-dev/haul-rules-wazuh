<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4972 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0f39f454-6a82-5c2d-8aeb-3ace99a36c20 -->
  <rule id="763945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4972 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>