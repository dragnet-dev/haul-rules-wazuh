<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0966 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f4351628-b00e-59fe-b113-c765a264800f -->
  <rule id="743516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0966 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>