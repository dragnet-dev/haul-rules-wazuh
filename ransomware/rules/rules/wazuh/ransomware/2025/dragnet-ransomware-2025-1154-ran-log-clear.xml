<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1154 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 6e5d3cb2-c6b7-5f2f-940f-bc12d81f82c5 -->
  <rule id="230940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1154 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>