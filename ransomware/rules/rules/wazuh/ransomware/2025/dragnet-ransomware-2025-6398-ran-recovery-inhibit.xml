<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6398 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 320ef905-a090-5641-8a28-bcd56e66adb5 -->
  <rule id="215990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6398 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>