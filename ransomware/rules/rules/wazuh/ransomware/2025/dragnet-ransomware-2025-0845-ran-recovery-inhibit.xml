<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0845 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cd8af0e8-28fd-5c83-b690-37ebb49e5659 -->
  <rule id="870230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0845 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>