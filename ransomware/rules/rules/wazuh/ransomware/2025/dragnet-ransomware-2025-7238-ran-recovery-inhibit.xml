<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7238 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 99ac0fb3-4876-57e3-ba22-1de6dfb7c887 -->
  <rule id="582575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7238 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>