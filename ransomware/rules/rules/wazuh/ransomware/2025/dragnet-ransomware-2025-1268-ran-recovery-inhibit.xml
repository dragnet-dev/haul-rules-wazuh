<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1268 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: dd90336a-83e2-5d3e-b98b-e2b6d6651eb9 -->
  <rule id="519033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1268 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>