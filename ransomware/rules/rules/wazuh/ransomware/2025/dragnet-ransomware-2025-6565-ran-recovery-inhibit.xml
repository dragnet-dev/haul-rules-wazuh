<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6565 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1dd2332b-38d2-51a6-9900-32558f148d10 -->
  <rule id="372332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6565 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>