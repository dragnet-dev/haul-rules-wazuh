<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1514 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5c9b859c-7a58-5d95-a503-e598490928e4 -->
  <rule id="687585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1514 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>