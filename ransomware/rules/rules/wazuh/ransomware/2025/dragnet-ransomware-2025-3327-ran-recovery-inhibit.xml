<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3327 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c3e86492-06eb-52d5-a298-4b0c4350ead4 -->
  <rule id="282864" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3327 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>