<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2364 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e11749a6-25de-555f-8a7a-ee1ed862d802 -->
  <rule id="611749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2364 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>