<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3710 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 0fc6c322-9610-5673-842c-5929c07de0da -->
  <rule id="542832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3710 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>