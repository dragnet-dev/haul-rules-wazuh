<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4702 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: d5d5855a-68ab-557a-b25a-b910bb188645 -->
  <rule id="473585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4702 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>