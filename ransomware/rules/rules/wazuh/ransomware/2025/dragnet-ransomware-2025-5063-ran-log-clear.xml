<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5063 — Event Log Clearing (blackshrantac) | Status: experimental | Sigma ID: 9de05a12-e12c-587b-a72c-0208ad3491b0 -->
  <rule id="541690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5063 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>