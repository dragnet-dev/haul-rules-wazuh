<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4944 — Event Log Clearing (anubis) | Status: test | Sigma ID: 28ae8e93-eff4-5b21-9c17-ac85f4106b62 -->
  <rule id="374862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4944 — Event Log Clearing (anubis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>