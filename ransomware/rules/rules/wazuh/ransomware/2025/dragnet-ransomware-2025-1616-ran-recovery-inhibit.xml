<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1616 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5df76844-f0a5-5092-a7e6-a9049fa2e493 -->
  <rule id="703768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1616 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>