<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3142 — Recovery Inhibition (radar) | Status: experimental | Sigma ID: e87e2a5f-9fb3-5747-b939-f78997df484e -->
  <rule id="309002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3142 — Recovery Inhibition (radar)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>