<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6441 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0c07a955-7320-5756-bb27-79c4b3fff3f4 -->
  <rule id="232295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6441 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>