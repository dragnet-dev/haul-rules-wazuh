<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1566 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 906a4947-cb1d-54c2-bdf7-fbd6a874c483 -->
  <rule id="650649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1566 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>