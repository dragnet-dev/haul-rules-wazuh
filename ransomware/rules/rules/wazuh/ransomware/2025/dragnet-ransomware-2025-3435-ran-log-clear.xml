<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3435 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: c03764d4-d484-5a21-b691-a132bd503f73 -->
  <rule id="403764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3435 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>