<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2727 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 797b3aa9-eba5-5b0b-bf89-6485360a6491 -->
  <rule id="342138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2727 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>