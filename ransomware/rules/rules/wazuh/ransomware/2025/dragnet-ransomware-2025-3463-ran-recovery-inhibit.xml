<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3463 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 635058d8-db15-5a9d-afe0-f082be0c4209 -->
  <rule id="360941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3463 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>