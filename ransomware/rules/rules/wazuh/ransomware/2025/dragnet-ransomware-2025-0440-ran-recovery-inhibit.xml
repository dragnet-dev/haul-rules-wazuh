<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0440 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 609c60e2-a778-5546-b4ea-77d744042645 -->
  <rule id="410574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0440 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>