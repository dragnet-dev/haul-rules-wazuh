<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2117 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6a16e0dc-cfbc-5cd4-9c10-e85f1228929a -->
  <rule id="898700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2117 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>