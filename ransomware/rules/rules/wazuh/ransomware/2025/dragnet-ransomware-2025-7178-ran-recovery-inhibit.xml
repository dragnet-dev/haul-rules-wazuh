<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7178 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1117a997-4f00-5899-834a-17aaa591d1af -->
  <rule id="988299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7178 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>