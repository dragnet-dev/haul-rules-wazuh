<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1220 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 93b09666-e334-52ad-a69e-ddb98dfaa238 -->
  <rule id="699096" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1220 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>