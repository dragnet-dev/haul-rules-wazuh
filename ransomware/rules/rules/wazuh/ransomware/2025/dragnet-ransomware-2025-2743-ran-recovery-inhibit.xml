<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2743 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 824d1355-b71e-5c4b-91c5-cd84bce7f22a -->
  <rule id="519713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2743 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>