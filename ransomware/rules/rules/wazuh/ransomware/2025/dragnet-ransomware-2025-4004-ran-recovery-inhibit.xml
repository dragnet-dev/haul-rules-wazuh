<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4004 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d835ddf3-5051-58fa-915d-112b73fef276 -->
  <rule id="941981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4004 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>