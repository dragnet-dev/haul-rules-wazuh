<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1063 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ecc843d9-29a1-530c-bdd7-6af00bdd91f9 -->
  <rule id="288843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1063 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>