<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5393 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 8ddd29a7-5bc8-53a1-aad8-ae8c1a0bae9f -->
  <rule id="131729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5393 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>