<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6782 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: f873cf4a-73e0-5e05-b83b-78b008eceeeb -->
  <rule id="563695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6782 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>