<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4059 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 4cdbd055-87ab-540b-9dc8-2c1cba5ebaf5 -->
  <rule id="548130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4059 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>