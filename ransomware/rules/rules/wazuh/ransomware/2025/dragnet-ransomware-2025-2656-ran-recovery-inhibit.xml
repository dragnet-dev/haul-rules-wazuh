<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2656 — Recovery Inhibition (qilin) | Status: test | Sigma ID: e1243897-0941-5bd4-8992-d5623a95adb8 -->
  <rule id="612438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2656 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>