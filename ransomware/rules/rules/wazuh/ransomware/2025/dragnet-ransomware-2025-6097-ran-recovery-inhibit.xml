<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6097 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 52ec7b00-64f8-5f50-a4bc-8f95558dd37f -->
  <rule id="467803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6097 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>