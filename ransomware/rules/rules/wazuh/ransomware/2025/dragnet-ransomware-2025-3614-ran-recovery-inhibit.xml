<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3614 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: caf7c5b1-c732-5f1f-b956-d1c7a42e5812 -->
  <rule id="796445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3614 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>