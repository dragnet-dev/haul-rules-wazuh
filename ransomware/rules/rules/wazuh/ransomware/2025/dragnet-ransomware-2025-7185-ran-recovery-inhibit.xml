<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7185 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: eabae9bb-165a-53eb-90d2-b148183773fc -->
  <rule id="714549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7185 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>