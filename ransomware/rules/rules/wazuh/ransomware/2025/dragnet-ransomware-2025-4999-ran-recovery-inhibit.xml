<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4999 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: eecd91fe-e161-53e6-93ec-b6b5d9d25314 -->
  <rule id="813391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4999 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>