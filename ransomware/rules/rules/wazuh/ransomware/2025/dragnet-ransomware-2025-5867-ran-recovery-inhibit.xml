<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5867 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 222a8df5-b8f4-55c2-9a1f-a4826162e63c -->
  <rule id="220991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5867 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>