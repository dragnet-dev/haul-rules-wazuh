<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0061 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b4aef021-378a-518a-996a-5d7a365b152e -->
  <rule id="297430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0061 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>