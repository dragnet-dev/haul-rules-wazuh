<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2486 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 879c2afe-413e-5b27-9bee-66b07e58f680 -->
  <rule id="552202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2486 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>