<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6058 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 87fb80a7-e008-5f3e-a749-aec2ca523ff6 -->
  <rule id="552380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6058 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>