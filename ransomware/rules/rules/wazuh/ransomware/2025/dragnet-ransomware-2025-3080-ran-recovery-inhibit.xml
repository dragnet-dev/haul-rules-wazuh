<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3080 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 859b1fd5-859d-5134-8663-4690daee6bbe -->
  <rule id="500831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3080 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>