<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1087 — Event Log Clearing (lockbit5) | Status: test | Sigma ID: bfeb8828-adee-55e9-b0d0-2c1c1d9f22c3 -->
  <rule id="513188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1087 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>