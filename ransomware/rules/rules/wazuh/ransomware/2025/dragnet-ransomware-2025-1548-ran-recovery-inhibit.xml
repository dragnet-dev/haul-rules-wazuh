<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1548 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 51dd3013-02b9-5c57-a988-efa8d4560356 -->
  <rule id="527730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1548 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>