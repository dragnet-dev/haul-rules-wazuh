<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4095 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: fd443e6f-7b54-5ef5-ac26-6f1fea992b2e -->
  <rule id="555102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4095 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>