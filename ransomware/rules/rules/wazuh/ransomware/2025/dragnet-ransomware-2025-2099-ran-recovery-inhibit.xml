<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2099 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e86ed8ed-2ed0-54fe-9835-4cfffc180485 -->
  <rule id="306538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2099 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>