<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3207 — Recovery Inhibition (VanHelsing) | Status: experimental | Sigma ID: 0f9187b2-62fc-5bc6-9e05-0ac64b03e8f8 -->
  <rule id="847003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3207 — Recovery Inhibition (VanHelsing)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>