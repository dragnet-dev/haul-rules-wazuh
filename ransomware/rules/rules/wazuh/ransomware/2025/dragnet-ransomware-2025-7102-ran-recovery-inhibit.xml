<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7102 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 48f4c569-5991-5168-afd9-65749e62e559 -->
  <rule id="453565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7102 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>