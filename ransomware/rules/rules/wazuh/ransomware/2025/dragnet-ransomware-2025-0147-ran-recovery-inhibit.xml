<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0147 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 6c708a84-ccb8-59e8-94d7-a76a7075376b -->
  <rule id="939338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0147 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>