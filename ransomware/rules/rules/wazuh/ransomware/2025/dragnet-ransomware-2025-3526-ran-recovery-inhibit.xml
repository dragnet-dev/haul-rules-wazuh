<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3526 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b109c3ea-ff32-5986-9834-9e14b93044a9 -->
  <rule id="977563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3526 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>