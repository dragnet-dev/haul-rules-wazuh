<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0421 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 207cc88e-f53f-51b2-bf47-c13b43a892fb -->
  <rule id="919688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0421 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>