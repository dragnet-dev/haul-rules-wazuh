<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2416 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 92ea9d24-b54e-5969-a65d-f5191e617857 -->
  <rule id="305917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2416 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>