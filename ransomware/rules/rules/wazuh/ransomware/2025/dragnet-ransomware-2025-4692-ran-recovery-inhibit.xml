<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4692 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9fd54a36-eeff-54c7-b0a9-cc857f2356b5 -->
  <rule id="592074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4692 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>