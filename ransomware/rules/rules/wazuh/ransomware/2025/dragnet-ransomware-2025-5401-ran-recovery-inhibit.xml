<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5401 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 8e822323-afd1-57fa-9694-0a181ca48ee3 -->
  <rule id="628223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5401 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>