<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0902 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 8e41fc09-c95c-556b-88f0-edd8cdc5119d -->
  <rule id="145948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0902 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>