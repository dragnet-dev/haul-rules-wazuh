<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5266 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: bd346899-a272-5603-83a2-4bd8f51b408b -->
  <rule id="193468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5266 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>