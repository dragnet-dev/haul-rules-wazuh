<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2767 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: e82d99ad-e502-52a6-8ba4-5afb992afead -->
  <rule id="672599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2767 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>