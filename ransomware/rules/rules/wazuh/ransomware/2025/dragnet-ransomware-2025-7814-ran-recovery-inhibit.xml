<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7814 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 3e4daba7-65f7-5dfe-8001-071a9dc3ea0a -->
  <rule id="859403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7814 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>