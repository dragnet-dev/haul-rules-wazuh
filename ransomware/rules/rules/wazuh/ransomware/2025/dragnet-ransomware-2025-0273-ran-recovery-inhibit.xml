<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0273 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 34afe346-e39f-5e13-8ff3-76ba8c72a931 -->
  <rule id="620783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0273 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>