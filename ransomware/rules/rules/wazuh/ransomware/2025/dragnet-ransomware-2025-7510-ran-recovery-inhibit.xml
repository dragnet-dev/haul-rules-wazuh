<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7510 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 54ed1bcf-2e10-5b64-a760-6784a5f9ffe6 -->
  <rule id="549787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7510 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>