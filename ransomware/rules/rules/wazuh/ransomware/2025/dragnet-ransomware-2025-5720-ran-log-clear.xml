<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5720 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 3b0a7ac3-17a5-5d6f-b37e-a77f717057a3 -->
  <rule id="712122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5720 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>