<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1775 — Recovery Inhibition (J) | Status: experimental | Sigma ID: b8f4352c-315b-5c1f-9541-9e19628d208e -->
  <rule id="203435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1775 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>