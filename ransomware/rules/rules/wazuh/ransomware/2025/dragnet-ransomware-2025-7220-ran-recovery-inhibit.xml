<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7220 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0428201e-060c-5f3d-9812-f1bf66c243ef -->
  <rule id="651230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7220 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>