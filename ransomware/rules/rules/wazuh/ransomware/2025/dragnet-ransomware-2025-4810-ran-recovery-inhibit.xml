<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4810 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: b26f314f-c99c-5d03-8553-fd56dcedcd17 -->
  <rule id="103131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4810 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>