<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1706 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0ca1a08c-0121-5db1-9221-407f6e4027c8 -->
  <rule id="634608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1706 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>