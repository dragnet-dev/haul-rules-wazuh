<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0506 — Event Log Clearing (nova) | Status: experimental | Sigma ID: 00276c50-4c92-56a7-8c35-fa3eaa1b5ff2 -->
  <rule id="928504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0506 — Event Log Clearing (nova)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>