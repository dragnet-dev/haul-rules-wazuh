<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6300 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 6c533cca-0a57-585c-8144-423f3947c410 -->
  <rule id="936540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6300 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>