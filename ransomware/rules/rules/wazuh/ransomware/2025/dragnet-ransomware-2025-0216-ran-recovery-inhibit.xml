<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0216 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d7fb7027-00eb-59f2-80ce-e1b0007d992c -->
  <rule id="932370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0216 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>