<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0362 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b8977038-3b24-50d4-8418-a7ad266e91e8 -->
  <rule id="389770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0362 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>