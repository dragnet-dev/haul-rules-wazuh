<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2528 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: bf05ce10-2c38-5780-975a-e84077025ac7 -->
  <rule id="491086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2528 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>