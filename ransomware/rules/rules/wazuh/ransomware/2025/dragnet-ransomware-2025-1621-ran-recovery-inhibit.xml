<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1621 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: eb8d0ca0-f378-59d2-9957-a122eb96c270 -->
  <rule id="738572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1621 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>