<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2128 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 47644fbf-fd55-5cc5-ae27-e478aa9e52f0 -->
  <rule id="597115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2128 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>