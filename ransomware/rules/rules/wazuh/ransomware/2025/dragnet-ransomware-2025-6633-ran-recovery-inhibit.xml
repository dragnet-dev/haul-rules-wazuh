<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6633 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c39fcddc-4c57-5dce-88ca-67dc0826e26b -->
  <rule id="678989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6633 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>