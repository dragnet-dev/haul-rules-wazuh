<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5385 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b2967fa5-746c-557a-9d10-de128087d85b -->
  <rule id="107487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5385 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>