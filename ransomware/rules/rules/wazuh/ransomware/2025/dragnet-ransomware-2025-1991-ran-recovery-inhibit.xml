<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1991 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 43bd9447-f703-570a-832c-488221fb07dc -->
  <rule id="319794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1991 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>