<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7546 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 363e9635-2cfa-5374-b093-467db9d9b026 -->
  <rule id="522963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7546 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>