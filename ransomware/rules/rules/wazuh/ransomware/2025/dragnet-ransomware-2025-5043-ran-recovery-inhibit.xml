<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5043 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3528c44e-b268-5bd4-b5c5-253a60de03de -->
  <rule id="346044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5043 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>