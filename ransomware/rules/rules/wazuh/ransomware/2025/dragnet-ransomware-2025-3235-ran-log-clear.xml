<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3235 — Event Log Clearing (nitrogen) | Status: experimental | Sigma ID: 47b0e476-fd4b-5567-b726-420f3ebc35d4 -->
  <rule id="420944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3235 — Event Log Clearing (nitrogen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>