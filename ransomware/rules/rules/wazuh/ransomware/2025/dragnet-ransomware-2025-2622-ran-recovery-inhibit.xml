<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2622 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: fac558cc-8aab-518a-916c-275de6a7d420 -->
  <rule id="512558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2622 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>