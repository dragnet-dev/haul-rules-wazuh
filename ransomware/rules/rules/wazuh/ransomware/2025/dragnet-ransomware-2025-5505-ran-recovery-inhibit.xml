<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5505 — Recovery Inhibition (devman) | Status: test | Sigma ID: be585806-1795-5af8-a05a-356abee99871 -->
  <rule id="205858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5505 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>