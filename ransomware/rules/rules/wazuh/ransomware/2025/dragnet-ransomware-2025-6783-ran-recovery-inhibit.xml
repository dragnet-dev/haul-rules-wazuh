<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6783 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 56a8b483-e11e-5a70-b23d-01dc27922c2f -->
  <rule id="650994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6783 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>