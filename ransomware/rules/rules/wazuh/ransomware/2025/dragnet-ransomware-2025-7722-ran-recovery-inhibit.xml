<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7722 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d271137d-16ae-564b-b157-c3e0b0ae8266 -->
  <rule id="527113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7722 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>