<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5430 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 05027d73-6dea-516a-bed9-92bceabfb180 -->
  <rule id="944573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5430 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>