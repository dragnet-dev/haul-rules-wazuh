<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4624 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d5f6ab88-1533-5dec-8870-da0eaaa61e56 -->
  <rule id="269707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4624 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>