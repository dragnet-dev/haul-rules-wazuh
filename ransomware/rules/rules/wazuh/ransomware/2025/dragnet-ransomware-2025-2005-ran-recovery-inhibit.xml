<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2005 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 14352577-a854-5e22-90fc-6360b0ae9c36 -->
  <rule id="635257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2005 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>