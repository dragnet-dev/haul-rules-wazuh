<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0678 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: 72ef0780-6cc8-55e0-866c-aeee0baf7bf1 -->
  <rule id="167107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0678 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>