<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7032 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 0ede72de-e644-5a29-a1f7-2cc9f88703f6 -->
  <rule id="790765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7032 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>