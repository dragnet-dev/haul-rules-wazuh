<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7654 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f5edf75b-eee2-5fc8-8ec1-b3fb71785ef8 -->
  <rule id="186877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7654 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>