<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1963 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a99582af-4a34-5398-aae0-b75537593494 -->
  <rule id="299582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1963 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>