<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2172 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 4c45564c-1cc7-58be-960f-5300cc793a0a -->
  <rule id="545564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2172 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>