<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7333 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f9ea17ef-155f-504d-815b-10d9d9f9f63e -->
  <rule id="593817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7333 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>