<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4077 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 71b4ca5d-5de1-5e9a-a0b8-163646afd45a -->
  <rule id="337546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4077 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>