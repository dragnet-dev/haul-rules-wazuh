<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4038 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8b2e1f95-6830-594c-a6a6-86d644db219d -->
  <rule id="965791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4038 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>