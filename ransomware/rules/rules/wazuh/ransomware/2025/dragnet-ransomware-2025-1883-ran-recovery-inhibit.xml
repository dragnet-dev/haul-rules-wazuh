<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1883 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 484e2be5-7d48-551a-a1ed-099d6da20bbb -->
  <rule id="441323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1883 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>