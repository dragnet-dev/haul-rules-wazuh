<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1484 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: bce351d7-d6d4-587e-ae9e-6335fae18958 -->
  <rule id="422351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1484 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>