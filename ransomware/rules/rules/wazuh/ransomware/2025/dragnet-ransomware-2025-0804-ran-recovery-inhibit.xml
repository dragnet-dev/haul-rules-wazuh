<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0804 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 86704c10-4cb8-5db7-b710-1141465a0e7b -->
  <rule id="587276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0804 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
