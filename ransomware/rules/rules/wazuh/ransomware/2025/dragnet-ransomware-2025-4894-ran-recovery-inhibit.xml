<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4894 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 6c868e24-b36f-53ea-b9a0-febcde4f0804 -->
  <rule id="941902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4894 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>