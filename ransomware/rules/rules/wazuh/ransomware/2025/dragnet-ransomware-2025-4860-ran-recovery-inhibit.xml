<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4860 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4cc468fb-fdbb-573d-b16f-33fc003cc2f2 -->
  <rule id="428468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4860 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>