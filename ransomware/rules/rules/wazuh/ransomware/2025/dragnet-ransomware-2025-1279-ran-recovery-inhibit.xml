<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1279 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cbe07b16-0a0f-535a-9ab6-f343bf29f163 -->
  <rule id="819323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1279 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>