<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4043 — Event Log Clearing (radiant) | Status: experimental | Sigma ID: 8d1751cf-2500-5a3a-8496-35fec5e6c17d -->
  <rule id="611751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4043 — Event Log Clearing (radiant)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>