<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1769 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 16869a27-3753-51ce-98a5-52008e9ed74e -->
  <rule id="999142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1769 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>