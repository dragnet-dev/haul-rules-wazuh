<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6407 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: a61399e4-ca68-5187-913b-835b0699dda9 -->
  <rule id="261399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6407 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>