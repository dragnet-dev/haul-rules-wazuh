<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1790 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 20794107-73bc-5080-b252-eb5507d2240f -->
  <rule id="379410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1790 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>