<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5587 — Event Log Clearing (J) | Status: experimental | Sigma ID: 7c9fbbdf-3719-5020-a51e-8bf947db4b09 -->
  <rule id="719931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5587 — Event Log Clearing (J)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>