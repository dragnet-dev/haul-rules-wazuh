<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7359 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3fb54da7-7c54-5092-9f04-92b727dcb3da -->
  <rule id="831277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7359 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>