<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7823 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fa220920-7cb9-5d75-aa27-a0032d97ab7d -->
  <rule id="802209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7823 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>