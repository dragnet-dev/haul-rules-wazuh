<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7101 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: bb0b582b-9cdb-57b7-9816-622afe11912b -->
  <rule id="393158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7101 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>