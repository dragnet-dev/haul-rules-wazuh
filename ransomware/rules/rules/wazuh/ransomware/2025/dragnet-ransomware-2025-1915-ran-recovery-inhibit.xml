<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1915 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9b17f0de-8b61-5c08-befd-18c27b3a09fe -->
  <rule id="782870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1915 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>