<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2086 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0b0fdb4e-a344-5a9d-b887-1428419f8013 -->
  <rule id="146194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2086 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>