<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3980 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 20b4de95-3275-5033-a077-e4218304bfe2 -->
  <rule id="486069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3980 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>