<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0046 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: f0844f3a-eb36-5741-b8d2-fddd227e04c4 -->
  <rule id="713519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0046 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>