<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6421 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a15dd977-4daf-5aee-8499-6103bd936d87 -->
  <rule id="900619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6421 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>