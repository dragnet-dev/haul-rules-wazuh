<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3861 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e301f98f-ea77-5968-a3fe-a0591831fa27 -->
  <rule id="588319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3861 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>