<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3366 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 35970704-3c0b-51fe-a561-29f519a96eb6 -->
  <rule id="997070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3366 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>