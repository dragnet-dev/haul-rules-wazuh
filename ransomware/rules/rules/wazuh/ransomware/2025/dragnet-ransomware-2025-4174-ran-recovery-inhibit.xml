<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4174 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 21a17daa-bc24-5e84-857a-4c735ebdc455 -->
  <rule id="862170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4174 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>