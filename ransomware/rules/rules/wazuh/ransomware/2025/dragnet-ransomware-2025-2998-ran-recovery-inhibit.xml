<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2998 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: ce9a359c-c67e-5e53-89f9-4750fc36aef1 -->
  <rule id="711435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2998 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>