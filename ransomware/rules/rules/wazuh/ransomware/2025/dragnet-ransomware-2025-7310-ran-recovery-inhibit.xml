<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7310 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 19e0aaa1-852d-5c86-a03a-7323c340cac3 -->
  <rule id="528010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7310 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>