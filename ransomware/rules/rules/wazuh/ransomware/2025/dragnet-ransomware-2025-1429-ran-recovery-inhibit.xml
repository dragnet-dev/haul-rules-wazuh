<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1429 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7159707d-f8a7-5ab0-8817-582d6de624f9 -->
  <rule id="959707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1429 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>