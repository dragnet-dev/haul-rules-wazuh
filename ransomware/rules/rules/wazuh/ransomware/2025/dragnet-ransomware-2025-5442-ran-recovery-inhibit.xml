<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5442 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 51b64598-5e68-5283-9793-4679a334e3ad -->
  <rule id="276459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5442 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>