<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7001 — Recovery Inhibition (akira) | Status: experimental | Sigma ID: ab0dfe6e-3a74-5f42-abb7-b07cdac7446b -->
  <rule id="807742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7001 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>