<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0412 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: c38b2b19-2e1c-5e11-9b68-9b209ec9c83b -->
  <rule id="571083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0412 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>