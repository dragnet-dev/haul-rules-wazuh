<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3664 — Event Log Clearing (d4rk4rmy) | Status: experimental | Sigma ID: 6e1400f0-2827-5ade-bab8-6dcd2d4ba409 -->
  <rule id="301400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3664 — Event Log Clearing (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>