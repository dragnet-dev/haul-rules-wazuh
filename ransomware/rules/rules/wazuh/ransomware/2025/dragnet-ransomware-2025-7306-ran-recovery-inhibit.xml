<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7306 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: e76807ab-77fa-57ec-b641-ef00e4ecea61 -->
  <rule id="676807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7306 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>