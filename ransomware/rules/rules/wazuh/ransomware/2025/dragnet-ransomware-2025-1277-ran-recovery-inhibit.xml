<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1277 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: fbba07f2-6649-520e-9ac8-758dd0f593c8 -->
  <rule id="244207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1277 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>