<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6026 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: cb3fade2-8f58-59e1-ab25-d3d0562d85d6 -->
  <rule id="331181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6026 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>