<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1273 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 789e69e8-2fea-5fc1-9986-4a37c80479e4 -->
  <rule id="463869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1273 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>