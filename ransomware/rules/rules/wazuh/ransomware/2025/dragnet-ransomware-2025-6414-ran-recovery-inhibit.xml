<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6414 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 796c2310-2359-5155-a013-7d5cb3c1e13f -->
  <rule id="474823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6414 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>