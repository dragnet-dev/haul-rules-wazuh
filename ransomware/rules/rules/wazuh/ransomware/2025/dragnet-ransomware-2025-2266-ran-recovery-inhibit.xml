<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2266 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c929771b-977d-594b-a589-35d27e9f3c7f -->
  <rule id="492977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2266 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>