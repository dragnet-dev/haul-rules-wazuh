<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7479 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 6789edce-0954-5180-a731-daeba021f99e -->
  <rule id="938221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7479 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>