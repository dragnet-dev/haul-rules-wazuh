<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4369 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: ecba430e-1beb-5dca-8d24-5301aa535243 -->
  <rule id="760243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4369 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
