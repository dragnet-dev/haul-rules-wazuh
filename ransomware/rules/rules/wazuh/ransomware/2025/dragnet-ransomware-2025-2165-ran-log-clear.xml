<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2165 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 89289c16-5eb0-5e2b-b8f8-b6109ebaae5f -->
  <rule id="628636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2165 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>