<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6470 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 9fcc0f38-0ae1-5916-8c0b-5180fdef02af -->
  <rule id="345295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6470 — Recovery Inhibition (nova)</description>
