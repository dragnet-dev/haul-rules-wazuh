<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1422 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 58a14542-ad8a-5312-825a-4ccdc2a13324 -->
  <rule id="481454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1422 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>