<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5679 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 6df3f23f-7e6e-5221-b034-0e8d5149c912 -->
  <rule id="215032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5679 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>