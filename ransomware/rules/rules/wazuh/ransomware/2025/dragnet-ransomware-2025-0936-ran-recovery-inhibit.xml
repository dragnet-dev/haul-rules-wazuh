<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0936 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1295b031-57e9-5f34-b3ba-a5f77e93d64d -->
  <rule id="373103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0936 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>