<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2937 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 26a98e29-9795-5731-b3a7-95d058647b2b -->
  <rule id="631822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2937 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>