<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0411 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ebf41ca8-1c3d-54cf-a8c3-689319c8dc4b -->
  <rule id="740668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0411 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>