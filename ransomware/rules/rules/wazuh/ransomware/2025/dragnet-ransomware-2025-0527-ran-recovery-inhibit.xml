<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0527 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: 230bcf42-91c1-590f-99e9-cfaa06909b9a -->
  <rule id="551034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0527 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>