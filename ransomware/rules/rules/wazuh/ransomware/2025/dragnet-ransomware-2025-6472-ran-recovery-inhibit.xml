<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6472 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 9d354e61-81a2-507a-a3eb-b697be25f7ce -->
  <rule id="817678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6472 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>