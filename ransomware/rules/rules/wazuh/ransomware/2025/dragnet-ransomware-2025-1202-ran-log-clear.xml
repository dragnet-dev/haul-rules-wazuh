<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1202 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 5d7275e1-5c03-5aa7-af84-d0fcde532f01 -->
  <rule id="696414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1202 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>