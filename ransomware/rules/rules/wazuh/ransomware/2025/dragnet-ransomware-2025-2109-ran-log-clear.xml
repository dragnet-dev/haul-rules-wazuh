<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2109 — Event Log Clearing (crypto24) | Status: deprecated | Sigma ID: 0b7ecf7c-866c-57f5-bd78-b950c7bc9460 -->
  <rule id="430237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2109 — Event Log Clearing (crypto24)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>