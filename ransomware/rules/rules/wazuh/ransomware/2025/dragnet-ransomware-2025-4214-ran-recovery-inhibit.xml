<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4214 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 68709c76-33fe-5960-b1d1-6e6271b307ba -->
  <rule id="299356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4214 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>