<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0987 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 546a8603-132b-50bf-b196-c3a61b6759a5 -->
  <rule id="746860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0987 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>