<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0733 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 987a6287-6927-5f9a-8c88-8c97e79aef30 -->
  <rule id="780262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0733 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>