<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4927 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 970c03e4-7309-5c58-b731-05d1240ec274 -->
  <rule id="753203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4927 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>