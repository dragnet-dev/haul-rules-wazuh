<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5363 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6a8fc368-9243-5a12-9929-5e4cbda51b2f -->
  <rule id="136603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5363 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>