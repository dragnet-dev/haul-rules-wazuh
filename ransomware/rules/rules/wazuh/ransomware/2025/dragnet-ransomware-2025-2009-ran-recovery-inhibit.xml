<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2009 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c8c3f46d-9868-5d91-ab2d-88aab959fa06 -->
  <rule id="696634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2009 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>