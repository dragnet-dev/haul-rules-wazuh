<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3821 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ff775f60-056d-516c-899f-71e67c8b073d -->
  <rule id="592415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3821 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>