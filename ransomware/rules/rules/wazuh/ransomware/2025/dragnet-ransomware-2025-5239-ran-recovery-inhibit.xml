<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5239 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 625ed994-b3c3-537d-8287-f59d4b06970c -->
  <rule id="802379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5239 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>