<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5875 — Event Log Clearing (silent) | Status: experimental | Sigma ID: 448bdb38-b460-554d-94b8-74671f1d9cc9 -->
  <rule id="138043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5875 — Event Log Clearing (silent)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>