<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3953 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 7a7b7db8-fdca-5c23-a5cc-2d6a074c7943 -->
  <rule id="543005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3953 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>