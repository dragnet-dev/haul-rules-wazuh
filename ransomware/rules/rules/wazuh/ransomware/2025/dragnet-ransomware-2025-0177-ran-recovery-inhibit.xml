<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0177 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: c65e4585-55e9-5407-9261-9f13bb926658 -->
  <rule id="325445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0177 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>