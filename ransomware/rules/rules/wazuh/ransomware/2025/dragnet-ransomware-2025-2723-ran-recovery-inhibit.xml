<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2723 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: c87289e5-c652-5d18-8680-42317e24cef3 -->
  <rule id="487289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2723 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>