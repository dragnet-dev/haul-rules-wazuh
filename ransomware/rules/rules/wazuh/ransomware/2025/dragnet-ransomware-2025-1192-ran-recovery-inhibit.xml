<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1192 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: dd1dccb7-fe08-5854-9a2c-198a43be7dd3 -->
  <rule id="159788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1192 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>