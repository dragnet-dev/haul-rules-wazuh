<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3434 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fdd0b81e-b54a-5ddc-8a9c-c1056533a3aa -->
  <rule id="297718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3434 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>