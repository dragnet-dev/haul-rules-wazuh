<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4852 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: ffb52b13-b249-5de0-bec0-35775be58a66 -->
  <rule id="346443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4852 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>