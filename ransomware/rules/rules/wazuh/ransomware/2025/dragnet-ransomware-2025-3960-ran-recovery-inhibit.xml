<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3960 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 06907a4d-76d6-58b3-9198-19c744ca289d -->
  <rule id="305224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3960 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>