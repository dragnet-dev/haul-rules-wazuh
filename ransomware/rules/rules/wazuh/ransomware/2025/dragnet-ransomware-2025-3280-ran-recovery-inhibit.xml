<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3280 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 2a19a636-53dc-5e6b-b439-1c9816afe349 -->
  <rule id="551463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3280 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>