<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7687 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 45f6dded-b4cc-512c-a6e3-153f5c8b8b21 -->
  <rule id="183357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7687 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>