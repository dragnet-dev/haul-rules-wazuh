<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2157 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: f205c851-e44a-5b55-af2c-39cf360ae737 -->
  <rule id="732928" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2157 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>