<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7541 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 44e81ef6-5354-5ac5-a9a1-71f12943c036 -->
  <rule id="350110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7541 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>