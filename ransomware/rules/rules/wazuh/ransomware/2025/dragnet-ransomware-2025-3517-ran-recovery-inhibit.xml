<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3517 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 04835b3d-b080-5bed-ad06-0180de67ea1e -->
  <rule id="779421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3517 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>