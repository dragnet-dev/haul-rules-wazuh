<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7587 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2f07977e-6985-528c-8774-02e4e5a08e20 -->
  <rule id="307977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7587 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>