<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7527 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c4391b46-a639-54fc-b106-cbb495b49b4c -->
  <rule id="290267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7527 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>