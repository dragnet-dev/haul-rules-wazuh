<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6187 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 146c671c-5862-52f7-8d65-72d00f756a97 -->
  <rule id="648671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6187 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>