<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4730 — Recovery Inhibition (bravox) | Status: test | Sigma ID: cb485abd-afdf-56bb-bb64-c8f6db5fb13b -->
  <rule id="655770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4730 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>