<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1876 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 828fb242-e516-5b59-baf7-32cf6bce0150 -->
  <rule id="422192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1876 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>