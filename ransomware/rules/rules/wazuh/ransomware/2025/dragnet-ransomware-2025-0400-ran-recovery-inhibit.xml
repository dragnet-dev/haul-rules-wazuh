<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0400 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 15c7794b-92e4-5c90-b4a2-42951ed4e6d8 -->
  <rule id="827794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0400 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>