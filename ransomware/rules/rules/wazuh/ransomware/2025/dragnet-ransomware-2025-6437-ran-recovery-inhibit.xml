<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6437 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ca68b958-f24a-5ea0-a4e5-8b1fd36b129f -->
  <rule id="642999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6437 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>