<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5076 — Event Log Clearing (GDLockerSec) | Status: experimental | Sigma ID: 5db1ebd4-faab-5b62-bb5e-343f4b182dcb -->
  <rule id="337931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5076 — Event Log Clearing (GDLockerSec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>