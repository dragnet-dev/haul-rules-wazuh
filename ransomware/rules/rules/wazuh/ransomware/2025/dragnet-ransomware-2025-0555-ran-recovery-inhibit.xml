<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0555 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 4a1e7db8-bb89-5ebe-80ac-69a946bc5780 -->
  <rule id="199325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0555 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>