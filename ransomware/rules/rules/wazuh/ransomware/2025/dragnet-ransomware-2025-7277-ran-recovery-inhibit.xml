<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7277 — Recovery Inhibition (tridentlocker) | Status: experimental | Sigma ID: 264e9451-ff24-53be-85d9-e374f19ccf3a -->
  <rule id="738945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7277 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>