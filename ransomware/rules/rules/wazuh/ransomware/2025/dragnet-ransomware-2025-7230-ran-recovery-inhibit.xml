<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7230 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 4aefff38-9089-53a9-acd4-06dbed825796 -->
  <rule id="511103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7230 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
