<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1859 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 0b3c7acb-ed7a-5988-9c0e-7a5c1a399daa -->
  <rule id="261164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1859 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>