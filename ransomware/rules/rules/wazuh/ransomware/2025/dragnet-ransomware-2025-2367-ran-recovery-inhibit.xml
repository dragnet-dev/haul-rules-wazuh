<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2367 — Recovery Inhibition (J) | Status: experimental | Sigma ID: f5d6246b-c222-5df6-ad7d-53903b5c5a87 -->
  <rule id="793624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2367 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>