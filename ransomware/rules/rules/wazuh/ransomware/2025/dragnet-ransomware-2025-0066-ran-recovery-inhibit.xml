<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0066 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 56acb147-e796-5ede-b275-61ae9a8688f6 -->
  <rule id="621391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0066 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>