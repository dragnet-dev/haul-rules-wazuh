<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1753 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b54f9494-7332-5d43-b10b-608f37419e00 -->
  <rule id="147994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1753 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>