<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0446 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 86029fee-f32d-5415-801e-3022e4e86e02 -->
  <rule id="576479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0446 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>