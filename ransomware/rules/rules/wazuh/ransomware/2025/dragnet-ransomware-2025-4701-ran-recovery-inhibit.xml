<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4701 — Recovery Inhibition (cephalus) | Status: experimental | Sigma ID: 399dff59-9d67-5aa5-ba74-3f9a9c8bfac3 -->
  <rule id="837887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4701 — Recovery Inhibition (cephalus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>