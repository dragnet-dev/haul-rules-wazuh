<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5574 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 7a9bdc06-72e2-5549-a5e1-f9db948a7a78 -->
  <rule id="637020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5574 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>