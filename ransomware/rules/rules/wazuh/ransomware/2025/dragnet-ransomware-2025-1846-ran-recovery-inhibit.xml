<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1846 — Recovery Inhibition (brotherhood) | Status: experimental | Sigma ID: be8fbbc2-a15e-5d96-bea3-4479d071217d -->
  <rule id="719195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1846 — Recovery Inhibition (brotherhood)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>