<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0033 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 41463a26-6630-5dea-839c-a8dd41d14901 -->
  <rule id="434182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0033 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>