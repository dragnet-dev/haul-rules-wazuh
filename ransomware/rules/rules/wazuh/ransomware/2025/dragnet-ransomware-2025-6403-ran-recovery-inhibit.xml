<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6403 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 2c762951-1f46-56db-b73a-2da4a4ff5833 -->
  <rule id="976295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6403 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>