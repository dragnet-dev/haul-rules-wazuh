<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3703 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: a600fdf6-8da7-55dc-8ef4-5092b5c91d1f -->
  <rule id="113853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3703 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>