<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4409 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: a6769a94-961c-586f-a663-f12213ed85a6 -->
  <rule id="908314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4409 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>