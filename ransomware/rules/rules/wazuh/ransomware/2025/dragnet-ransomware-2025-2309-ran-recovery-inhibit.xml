<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2309 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: ff6f36a3-8666-506a-bac9-ae111a440351 -->
  <rule id="591136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2309 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>