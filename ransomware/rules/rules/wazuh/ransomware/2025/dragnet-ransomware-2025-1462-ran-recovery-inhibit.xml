<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1462 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bccfddd2-2da6-50f8-938d-1f781e4d1621 -->
  <rule id="773981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1462 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>