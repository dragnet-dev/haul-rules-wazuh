<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0369 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2418fb61-6529-5d2a-ad9b-c549dd4bba8a -->
  <rule id="892596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0369 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>