<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3380 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c86198fe-2e13-5221-8f22-7db6294adbfc -->
  <rule id="486198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3380 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
