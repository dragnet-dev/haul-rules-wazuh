<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1779 — Recovery Inhibition (bqtlock) | Status: experimental | Sigma ID: 85889de7-a4d5-588e-9efe-a4f945f8dfc7 -->
  <rule id="574237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1779 — Recovery Inhibition (bqtlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>