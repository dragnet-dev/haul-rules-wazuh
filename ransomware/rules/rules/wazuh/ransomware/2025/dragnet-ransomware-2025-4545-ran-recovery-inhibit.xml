<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4545 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 9a2aba84-74d4-5e4b-abcf-38ff67235c98 -->
  <rule id="118778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4545 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>