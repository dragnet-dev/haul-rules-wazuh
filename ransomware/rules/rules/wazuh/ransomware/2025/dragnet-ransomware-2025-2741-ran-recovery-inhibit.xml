<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2741 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ace079f2-a2c0-5782-bf4a-063a87bce5ae -->
  <rule id="166079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2741 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>