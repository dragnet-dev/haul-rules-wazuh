<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0165 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 8725db82-0871-5a51-9c60-d4366920ec6f -->
  <rule id="533819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0165 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>