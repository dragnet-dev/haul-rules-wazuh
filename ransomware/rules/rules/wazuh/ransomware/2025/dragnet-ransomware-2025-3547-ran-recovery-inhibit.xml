<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3547 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3b433bee-8246-5a5e-8b5f-08d1d4028459 -->
  <rule id="915038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3547 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>