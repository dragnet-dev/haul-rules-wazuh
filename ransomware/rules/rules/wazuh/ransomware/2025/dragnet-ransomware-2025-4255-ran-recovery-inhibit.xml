<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4255 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e61ebde8-bb13-544d-bd44-276afbccd61e -->
  <rule id="688029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4255 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>