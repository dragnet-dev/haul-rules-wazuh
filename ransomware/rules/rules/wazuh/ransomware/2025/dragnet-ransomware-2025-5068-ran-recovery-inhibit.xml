<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5068 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8e15ea4c-fb66-59d4-aea6-b444ecd68e7b -->
  <rule id="139274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5068 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>