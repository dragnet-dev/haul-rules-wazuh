<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1543 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: f3513b5a-d2bd-5387-963d-7c7055bc7bc9 -->
  <rule id="756219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1543 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>