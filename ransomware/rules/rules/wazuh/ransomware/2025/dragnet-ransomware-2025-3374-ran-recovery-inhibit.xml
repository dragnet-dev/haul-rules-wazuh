<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3374 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7c8e08be-03c2-5502-b9d6-d18ad3a40627 -->
  <rule id="298208" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3374 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>