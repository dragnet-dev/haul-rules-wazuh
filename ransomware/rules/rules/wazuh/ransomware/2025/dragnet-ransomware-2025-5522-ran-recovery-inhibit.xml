<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5522 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 20945859-77fb-5782-b230-475b810f4df9 -->
  <rule id="394585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5522 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>