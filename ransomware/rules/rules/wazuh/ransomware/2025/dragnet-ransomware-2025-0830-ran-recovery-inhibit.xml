<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0830 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 1592de6a-81ed-5496-9b5e-39894b854b04 -->
  <rule id="577746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0830 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>