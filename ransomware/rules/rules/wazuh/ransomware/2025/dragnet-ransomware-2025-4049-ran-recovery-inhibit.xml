<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4049 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9273f23e-cb07-5974-8be6-df32e376d154 -->
  <rule id="683832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4049 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>