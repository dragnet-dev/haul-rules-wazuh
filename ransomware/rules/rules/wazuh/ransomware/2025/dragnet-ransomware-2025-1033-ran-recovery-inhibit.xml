<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1033 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 80055af8-425e-5d22-8e8c-6f13a5d25e76 -->
  <rule id="480890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1033 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>