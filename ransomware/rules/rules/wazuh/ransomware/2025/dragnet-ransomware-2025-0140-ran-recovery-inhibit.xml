<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0140 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: bc71700c-7caf-53f3-8506-8e256c1a8559 -->
  <rule id="187170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0140 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>