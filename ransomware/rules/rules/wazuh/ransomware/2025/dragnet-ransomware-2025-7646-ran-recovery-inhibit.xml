<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7646 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ea4172f1-40e2-5430-a812-656afaffe673 -->
  <rule id="644172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7646 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>