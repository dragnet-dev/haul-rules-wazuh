<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2748 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e9511630-0215-54ad-9bb9-92cf290b5a92 -->
  <rule id="695116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2748 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>