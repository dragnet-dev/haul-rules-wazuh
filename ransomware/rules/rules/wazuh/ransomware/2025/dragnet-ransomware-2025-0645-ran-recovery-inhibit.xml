<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0645 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a66dcc31-a831-54be-87ff-9bfa59df642c -->
  <rule id="869868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0645 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>