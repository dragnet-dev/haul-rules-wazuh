<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5987 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9238cf34-8066-57af-8f17-eff2084b9bd9 -->
  <rule id="665135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5987 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>