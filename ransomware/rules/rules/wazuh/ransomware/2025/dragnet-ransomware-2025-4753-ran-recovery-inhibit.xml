<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4753 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: cc489d1f-fd3f-5acd-b491-9d51e20f2aec -->
  <rule id="671837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4753 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>