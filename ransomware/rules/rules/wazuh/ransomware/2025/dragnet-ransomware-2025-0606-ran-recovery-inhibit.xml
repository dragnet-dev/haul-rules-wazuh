<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0606 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 135fed6c-fa09-5ff3-836f-f91ade7ac8c5 -->
  <rule id="270376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0606 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>