<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0531 — Event Log Clearing (play) | Status: experimental | Sigma ID: eb2c5f0f-ba6b-50df-9f18-1b1f10eb54c7 -->
  <rule id="723135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0531 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>