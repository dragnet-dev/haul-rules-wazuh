<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6775 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: a06145de-3096-5456-b014-fa7a8f1f305d -->
  <rule id="206145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6775 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>