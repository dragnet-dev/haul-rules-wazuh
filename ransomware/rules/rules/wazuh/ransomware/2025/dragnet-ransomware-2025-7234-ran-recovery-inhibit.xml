<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7234 — Recovery Inhibition (tengu) | Status: experimental | Sigma ID: ea19746b-7d34-52bb-b375-9a31f521a470 -->
  <rule id="641974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7234 — Recovery Inhibition (tengu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>