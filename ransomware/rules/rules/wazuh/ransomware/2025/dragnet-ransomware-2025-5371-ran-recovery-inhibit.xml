<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5371 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d3180daa-9e34-52dc-be57-4cd1acba8291 -->
  <rule id="430893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5371 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>