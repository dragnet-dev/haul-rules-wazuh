<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3996 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 083c089a-90a0-5b40-9e21-153ef2a08ab1 -->
  <rule id="540089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3996 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
