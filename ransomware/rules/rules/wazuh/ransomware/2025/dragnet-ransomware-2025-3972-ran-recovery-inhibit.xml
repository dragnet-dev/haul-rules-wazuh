<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3972 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1f63b661-f40b-5298-bf91-ca08b17753b6 -->
  <rule id="661966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3972 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>