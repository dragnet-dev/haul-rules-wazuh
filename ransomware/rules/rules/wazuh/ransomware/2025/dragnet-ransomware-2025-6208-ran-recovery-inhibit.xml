<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6208 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 1e209e76-aee7-5e5b-89a1-f9ee4024058e -->
  <rule id="433587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6208 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>