<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6397 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 6caae4cb-7ac7-5718-96b1-41800e33869b -->
  <rule id="951024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6397 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>