<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3448 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 60a4e650-08ac-5574-9ae9-7b3e58d062ee -->
  <rule id="752786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3448 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>