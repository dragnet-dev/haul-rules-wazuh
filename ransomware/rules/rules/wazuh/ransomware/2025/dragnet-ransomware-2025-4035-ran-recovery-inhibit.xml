<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4035 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: a6cdd196-326c-530e-a96f-26c582e15554 -->
  <rule id="874691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4035 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>