<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2750 — Event Log Clearing (teamxxx) | Status: experimental | Sigma ID: 8e946ce3-635e-56c5-95f5-09d9e6e8fa57 -->
  <rule id="587148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2750 — Event Log Clearing (teamxxx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>