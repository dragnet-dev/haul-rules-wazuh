<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2382 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: db2cfb5f-d1ba-5fe0-b6f3-1ebdddefbdfa -->
  <rule id="981755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2382 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>