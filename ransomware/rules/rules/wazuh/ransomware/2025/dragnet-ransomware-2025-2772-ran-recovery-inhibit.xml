<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2772 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d8a3357f-df01-5216-bcd6-815db673dddf -->
  <rule id="518335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2772 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>