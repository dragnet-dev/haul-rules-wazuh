<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3133 — Event Log Clearing (flocker) | Status: experimental | Sigma ID: d8990feb-3012-5bc1-a3c3-86e65e5bb71c -->
  <rule id="523855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3133 — Event Log Clearing (flocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>