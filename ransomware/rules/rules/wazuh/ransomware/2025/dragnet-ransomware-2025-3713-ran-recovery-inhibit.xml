<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3713 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 8fda7fd4-ef78-5ea0-a39c-959c15a6ed66 -->
  <rule id="592287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3713 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>