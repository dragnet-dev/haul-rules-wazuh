<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5316 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 3d8137d8-1589-53a6-9a15-242424f5e1c5 -->
  <rule id="990205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5316 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>