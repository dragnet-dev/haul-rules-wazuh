<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1328 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e3e363a6-9549-5dd3-b090-1cab4dbe3d84 -->
  <rule id="602363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1328 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>