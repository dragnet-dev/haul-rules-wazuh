<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7570 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 6e9eb537-d106-568b-a441-e53a9630fd72 -->
  <rule id="241395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7570 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>