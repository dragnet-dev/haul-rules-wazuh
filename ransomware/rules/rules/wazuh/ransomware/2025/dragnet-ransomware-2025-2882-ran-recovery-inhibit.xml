<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2882 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: e715d78b-bbfc-5fe3-b73c-58b42cf3c63d -->
  <rule id="654537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2882 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>