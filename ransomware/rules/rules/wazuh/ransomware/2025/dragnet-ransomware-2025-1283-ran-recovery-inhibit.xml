<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1283 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: dda8081d-1cd4-5970-a214-dc72036fa6aa -->
  <rule id="946808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1283 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>