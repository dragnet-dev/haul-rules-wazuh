<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0784 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 95e840a2-c7bc-594a-8246-8def88e8cba8 -->
  <rule id="734840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0784 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>