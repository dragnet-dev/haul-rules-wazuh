<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6728 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 42945224-57e8-5f2a-a235-27402fd7bbab -->
  <rule id="794522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6728 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>