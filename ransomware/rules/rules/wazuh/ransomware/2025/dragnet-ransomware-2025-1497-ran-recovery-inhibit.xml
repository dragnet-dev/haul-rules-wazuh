<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1497 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9c3adfd0-bd58-5ad9-8faf-7f4f78c32622 -->
  <rule id="204831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1497 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>