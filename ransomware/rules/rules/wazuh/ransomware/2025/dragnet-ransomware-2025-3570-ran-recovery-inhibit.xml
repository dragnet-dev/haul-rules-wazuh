<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3570 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 06da452d-bd03-5c5c-a392-f059ba829959 -->
  <rule id="954452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3570 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>