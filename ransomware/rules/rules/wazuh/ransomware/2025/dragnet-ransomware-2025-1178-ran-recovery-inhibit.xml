<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1178 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 551b396a-e409-5fc9-a9ba-52529255ae5e -->
  <rule id="827396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1178 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>