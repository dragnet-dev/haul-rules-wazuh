<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2478 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 6de63ce8-aaa1-58e3-ad82-d63c7c31f07f -->
  <rule id="213820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2478 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>