<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4974 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: a2bb84ef-522a-5fe3-a50c-5f435b5edd56 -->
  <rule id="929984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4974 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>