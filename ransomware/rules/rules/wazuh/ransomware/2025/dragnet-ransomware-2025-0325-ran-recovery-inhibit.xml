<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0325 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c19d98ec-46c1-5c66-8f09-66e46326b776 -->
  <rule id="251798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0325 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>