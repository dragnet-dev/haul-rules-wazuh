<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5984 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a72631fe-8923-5e14-9d1d-85dd053f2f32 -->
  <rule id="272631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5984 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>