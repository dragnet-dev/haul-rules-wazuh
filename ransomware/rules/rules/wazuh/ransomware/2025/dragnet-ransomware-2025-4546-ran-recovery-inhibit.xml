<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4546 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0abaf20a-7680-53bb-b327-a5a4c6f582f7 -->
  <rule id="895120" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4546 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>