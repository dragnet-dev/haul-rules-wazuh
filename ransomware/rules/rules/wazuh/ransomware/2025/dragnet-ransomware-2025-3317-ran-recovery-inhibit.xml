<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3317 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 1fffd2c4-7a5a-5766-8059-c96487e993ac -->
  <rule id="510692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3317 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>