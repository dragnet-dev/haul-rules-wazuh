<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5878 — Recovery Inhibition (silent) | Status: experimental | Sigma ID: 8ebfde62-3e71-5d7f-8364-87c54e24bf25 -->
  <rule id="455230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5878 — Recovery Inhibition (silent)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>