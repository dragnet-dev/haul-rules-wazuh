<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3387 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 947ba33a-8865-5c78-89fb-789fc4554635 -->
  <rule id="726183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3387 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>