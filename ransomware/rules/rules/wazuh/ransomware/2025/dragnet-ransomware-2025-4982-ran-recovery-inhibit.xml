<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4982 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 3ed4a489-8493-5db3-9dc1-2d9f6e98899d -->
  <rule id="808744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4982 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>