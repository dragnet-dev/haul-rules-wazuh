<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3583 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: afd45ee7-3364-5eb4-87cd-5d57414bc420 -->
  <rule id="101534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3583 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>