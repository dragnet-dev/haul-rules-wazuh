<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4270 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: d75de9cd-0c20-5d0e-a75e-d190ff7d1e19 -->
  <rule id="922229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4270 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>