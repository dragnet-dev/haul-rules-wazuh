<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1617 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3ff5d170-9bf2-55e4-a550-c5bd0b1c26fa -->
  <rule id="837731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1617 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>