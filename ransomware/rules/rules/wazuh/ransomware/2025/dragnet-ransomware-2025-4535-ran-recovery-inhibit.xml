<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4535 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d00fb188-eda9-5357-b053-3246533571f1 -->
  <rule id="730511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4535 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>