<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3790 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 5b5066b0-42a0-5cd8-ab93-3e55ee54522f -->
  <rule id="341067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3790 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>