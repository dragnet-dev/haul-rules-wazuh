<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2368 — Recovery Inhibition (satanlockv2) | Status: experimental | Sigma ID: 742733c5-c4fb-5b63-ae6e-3954f15894f1 -->
  <rule id="283740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2368 — Recovery Inhibition (satanlockv2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>