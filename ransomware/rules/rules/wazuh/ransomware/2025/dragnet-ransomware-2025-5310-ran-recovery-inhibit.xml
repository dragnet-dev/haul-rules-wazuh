<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5310 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7f536d97-eb92-5cd7-ab5f-32f47d78600d -->
  <rule id="340589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5310 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>