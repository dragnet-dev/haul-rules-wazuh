<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6628 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 3620fe90-d3c5-5232-ae32-22cf8bcc9bde -->
  <rule id="369749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6628 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>