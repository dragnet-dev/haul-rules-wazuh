<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4005 — Event Log Clearing (sinobi) | Status: test | Sigma ID: 49ed0fb0-05c7-55d7-bf58-ca7f7ac7b5b7 -->
  <rule id="344975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4005 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>