<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3320 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: c1d2851a-f812-598a-a801-5a956306e390 -->
  <rule id="249285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3320 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>