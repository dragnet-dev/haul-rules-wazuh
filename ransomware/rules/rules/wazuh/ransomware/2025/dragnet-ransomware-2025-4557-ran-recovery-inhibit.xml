<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4557 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 874f8235-acfc-5e2c-9e14-e9ef4ed7eeed -->
  <rule id="599982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4557 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>