<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3507 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 8bc79ad7-bcd4-54db-b8d9-8391800cdddc -->
  <rule id="978874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3507 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>