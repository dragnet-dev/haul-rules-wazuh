<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4057 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: c94e7527-e5e5-508a-baaa-3a135fd3c5f8 -->
  <rule id="371875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4057 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>