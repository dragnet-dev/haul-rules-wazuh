<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1877 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 543f7074-d54b-58ce-bacf-f36e933728c0 -->
  <rule id="703707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1877 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
