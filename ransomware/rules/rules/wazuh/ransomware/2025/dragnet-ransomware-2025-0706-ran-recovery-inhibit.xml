<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0706 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: caba8372-c780-57ad-a35e-6e43d172486a -->
  <rule id="789883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0706 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>