<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5394 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b3658514-d941-5798-91f5-e6e13d11bd7d -->
  <rule id="336585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5394 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>