<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3059 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5a2f5140-74d3-55a7-b460-b6b7471ff7fa -->
  <rule id="644751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3059 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>