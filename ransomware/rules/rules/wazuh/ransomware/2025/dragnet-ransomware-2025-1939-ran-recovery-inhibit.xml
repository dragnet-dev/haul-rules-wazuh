<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1939 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 23a76995-4e07-51e6-ae94-68ec3bff9cbe -->
  <rule id="287699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1939 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>