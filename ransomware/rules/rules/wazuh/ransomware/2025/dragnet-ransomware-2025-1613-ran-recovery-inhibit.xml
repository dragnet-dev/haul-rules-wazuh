<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1613 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0ae2e9f2-8e30-5bc0-95e1-a4aa4dfeb08e -->
  <rule id="961919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1613 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>