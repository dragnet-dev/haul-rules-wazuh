<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5120 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: cd0b15fe-21a8-520a-a436-8357974380a0 -->
  <rule id="681115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5120 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>