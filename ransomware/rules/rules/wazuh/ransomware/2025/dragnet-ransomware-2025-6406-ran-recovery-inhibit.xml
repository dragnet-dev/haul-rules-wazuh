<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6406 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cf5b94b0-9159-5780-9c78-9b50f0e48abf -->
  <rule id="721194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6406 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>