<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2357 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9ee01ab8-0da2-54da-96b1-b821f43c39e3 -->
  <rule id="567226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2357 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>