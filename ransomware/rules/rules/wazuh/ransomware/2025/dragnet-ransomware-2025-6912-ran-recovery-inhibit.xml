<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6912 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a369f2df-36ad-5ec8-a3fd-609090b359a4 -->
  <rule id="859192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6912 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>