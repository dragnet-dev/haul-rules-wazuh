<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3122 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 6c25753a-9950-57e7-97cd-ba1ff568c48f -->
  <rule id="282575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3122 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>