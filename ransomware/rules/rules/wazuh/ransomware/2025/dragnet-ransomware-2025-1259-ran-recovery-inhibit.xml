<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1259 — Recovery Inhibition (rebornvc) | Status: deprecated | Sigma ID: 53f75eb2-8bde-51d0-9645-6791be4b7c71 -->
  <rule id="582014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1259 — Recovery Inhibition (rebornvc)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>