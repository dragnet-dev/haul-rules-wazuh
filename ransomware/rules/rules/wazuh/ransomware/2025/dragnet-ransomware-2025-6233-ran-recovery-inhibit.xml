<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6233 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 0fe59a24-58fb-599b-b39c-18411eee9cf0 -->
  <rule id="573542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6233 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>