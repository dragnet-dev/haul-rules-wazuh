<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7328 — Event Log Clearing (skira) | Status: experimental | Sigma ID: 6e120628-5b1d-5966-92d2-c7ff3961b794 -->
  <rule id="301206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7328 — Event Log Clearing (skira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>