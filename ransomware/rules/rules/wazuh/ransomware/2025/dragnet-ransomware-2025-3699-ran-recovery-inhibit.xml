<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3699 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: dd0cb736-7828-5306-91ba-993e6795e6f6 -->
  <rule id="359637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3699 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>