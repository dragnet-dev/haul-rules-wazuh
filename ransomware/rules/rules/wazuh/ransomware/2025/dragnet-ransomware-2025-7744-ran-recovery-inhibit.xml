<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7744 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d51be38d-6673-5bd4-a460-e5bb6c03ad39 -->
  <rule id="860463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7744 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>