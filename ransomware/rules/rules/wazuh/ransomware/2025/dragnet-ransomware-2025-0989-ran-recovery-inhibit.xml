<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0989 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 76ed65d3-a9db-5d7c-a7cf-bc7c1eecec26 -->
  <rule id="269365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0989 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>