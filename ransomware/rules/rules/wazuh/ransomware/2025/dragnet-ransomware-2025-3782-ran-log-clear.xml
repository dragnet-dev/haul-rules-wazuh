<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3782 — Event Log Clearing (obscura) | Status: deprecated | Sigma ID: e3e9155a-7b8d-5fcc-beb0-aff0b25c75fe -->
  <rule id="602915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3782 — Event Log Clearing (obscura)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>