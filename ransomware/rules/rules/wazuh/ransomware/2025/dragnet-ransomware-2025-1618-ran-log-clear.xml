<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1618 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 6b1f6aaa-a6fe-50b5-b820-4422c941d5a1 -->
  <rule id="144266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1618 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>