<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3481 — Event Log Clearing (genesis) | Status: test | Sigma ID: e3ae73d5-2f3f-566a-a7ff-fe79698246f7 -->
  <rule id="178273" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3481 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>