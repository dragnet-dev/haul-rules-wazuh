<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3432 — Event Log Clearing (secp0) | Status: experimental | Sigma ID: feea5a67-e965-5cbc-80fe-335cfce1504f -->
  <rule id="641370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3432 — Event Log Clearing (secp0)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>