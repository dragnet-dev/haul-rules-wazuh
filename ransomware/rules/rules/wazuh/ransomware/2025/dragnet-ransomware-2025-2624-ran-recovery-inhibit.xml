<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2624 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 81985ef4-1eae-502d-876d-27746546c970 -->
  <rule id="511774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2624 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>