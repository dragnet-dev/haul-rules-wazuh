<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2166 — Recovery Inhibition (radar) | Status: experimental | Sigma ID: c6225ae7-52d7-5556-8ac1-31e4063e6ee0 -->
  <rule id="319610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2166 — Recovery Inhibition (radar)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>