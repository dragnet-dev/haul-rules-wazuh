<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0874 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: cacca874-6d8b-5644-9630-c72427cb3fe9 -->
  <rule id="306668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0874 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>