<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3531 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 0fb9fed7-779f-5f11-9288-caea5e59ae7b -->
  <rule id="521901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3531 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>