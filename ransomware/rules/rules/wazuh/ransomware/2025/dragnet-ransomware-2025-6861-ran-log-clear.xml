<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6861 — Event Log Clearing (blackshrantac) | Status: experimental | Sigma ID: 2b8e23b5-cb7a-5d85-b13b-1221a2187ad3 -->
  <rule id="535579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6861 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>