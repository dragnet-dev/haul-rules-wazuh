<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2601 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: fbb1f248-bf73-5a96-8643-269990663132 -->
  <rule id="243512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2601 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>