<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0403 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 19748e50-d5f7-59d4-a53e-9fbd983273cc -->
  <rule id="559825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0403 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>