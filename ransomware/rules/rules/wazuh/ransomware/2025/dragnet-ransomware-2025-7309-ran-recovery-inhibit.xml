<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7309 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 88fb6f01-afa7-5040-ae5f-5c7a2887cc9e -->
  <rule id="144751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7309 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>