<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1957 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 81ee25fd-7d35-5180-9293-d97d933ccf4d -->
  <rule id="397425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1957 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>