<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7681 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bb2791e4-870f-537b-8586-beb701cddf3a -->
  <rule id="172791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7681 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>