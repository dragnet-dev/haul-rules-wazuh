<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3777 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d04db9c1-8467-5dbf-8801-ad45f99bbafb -->
  <rule id="740439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3777 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>