<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0692 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4c5821d5-c32d-58e9-bf9b-6f5a7dcc893c -->
  <rule id="653149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0692 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>