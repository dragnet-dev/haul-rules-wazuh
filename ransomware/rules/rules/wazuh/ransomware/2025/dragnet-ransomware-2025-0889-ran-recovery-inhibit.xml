<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0889 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: a06f4180-f6f9-5bf9-a788-9cf639615870 -->
  <rule id="811141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0889 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>