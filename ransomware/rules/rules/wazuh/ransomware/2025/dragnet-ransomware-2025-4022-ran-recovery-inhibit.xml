<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4022 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 8982a95a-bacc-52f3-a702-063712573967 -->
  <rule id="637229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4022 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>