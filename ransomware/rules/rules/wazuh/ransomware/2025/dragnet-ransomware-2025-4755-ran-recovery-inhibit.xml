<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4755 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f2bfdf70-54ef-5d5a-aae9-f8cc931d0f1e -->
  <rule id="210591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4755 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>