<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3512 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 17777015-fa18-5bf7-b6ae-2a1a457e2eec -->
  <rule id="977701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3512 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>