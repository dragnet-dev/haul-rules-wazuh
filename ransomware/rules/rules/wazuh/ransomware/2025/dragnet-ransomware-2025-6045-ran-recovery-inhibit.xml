<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6045 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: e150c9fc-be47-5601-8265-8f536a7e3876 -->
  <rule id="564129" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6045 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>