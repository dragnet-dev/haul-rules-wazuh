<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1330 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2137a27d-b291-585b-9689-6a000f6e490e -->
  <rule id="820227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1330 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>