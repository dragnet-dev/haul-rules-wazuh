<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5168 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1a07ec00-50bd-5b97-97c7-ed517d47281a -->
  <rule id="476280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5168 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>