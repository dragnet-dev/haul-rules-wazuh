<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3245 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ac2511fb-0a26-5a5c-b811-3b8159821e86 -->
  <rule id="922511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3245 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>