<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0383 — Recovery Inhibition (orca) | Status: experimental | Sigma ID: b9aca5bb-8cc5-576e-97cb-aa834c33563a -->
  <rule id="501865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0383 — Recovery Inhibition (orca)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>