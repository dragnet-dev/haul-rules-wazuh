<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1996 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: db6003d3-a4f5-58ed-b9fd-641ff65279bc -->
  <rule id="496003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1996 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>