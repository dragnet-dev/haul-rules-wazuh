<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4997 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b0b55104-e472-5a3c-b552-8bc531a83983 -->
  <rule id="971551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4997 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>