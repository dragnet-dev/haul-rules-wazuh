<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7884 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 47a3b7fd-3298-56e7-8f1c-9e5a51242b1b -->
  <rule id="419797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7884 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>