<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6925 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 14701038-39ee-5a74-b6e6-0782179f3925 -->
  <rule id="670103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6925 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>