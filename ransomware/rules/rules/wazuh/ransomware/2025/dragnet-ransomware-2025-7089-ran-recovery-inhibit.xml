<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7089 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: adcfc74d-9c02-5066-b59a-601ace959fec -->
  <rule id="919327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7089 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>