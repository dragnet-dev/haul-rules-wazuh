<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0633 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c93faede-fd7f-52c7-84b9-a014d2c3d3cc -->
  <rule id="900142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0633 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>