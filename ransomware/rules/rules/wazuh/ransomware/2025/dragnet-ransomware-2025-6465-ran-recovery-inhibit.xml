<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6465 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7ded35a2-f8ce-53a0-b73e-3568c99ede16 -->
  <rule id="623735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6465 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>