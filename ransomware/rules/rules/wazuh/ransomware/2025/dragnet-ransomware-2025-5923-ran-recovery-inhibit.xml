<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5923 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7a284739-8913-5f7b-aa6c-9a3b9fdbb162 -->
  <rule id="422847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5923 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>