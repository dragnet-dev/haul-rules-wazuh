<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1825 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 3d42d06f-c82b-592e-9e77-b82dd43cb432 -->
  <rule id="928506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1825 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>