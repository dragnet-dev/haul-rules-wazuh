<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4175 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ab7ea5da-dcb3-598e-a852-723b597a2a6c -->
  <rule id="897865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4175 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>