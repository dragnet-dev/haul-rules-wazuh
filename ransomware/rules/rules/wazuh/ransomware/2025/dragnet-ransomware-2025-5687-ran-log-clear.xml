<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5687 — Event Log Clearing (AiLock) | Status: deprecated | Sigma ID: 03098ab3-6ddd-59e2-bce4-dd97cb36b511 -->
  <rule id="832593" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5687 — Event Log Clearing (AiLock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>