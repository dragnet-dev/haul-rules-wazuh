<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3442 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ee873327-bb72-5a5d-99b5-7326ba3d8b8a -->
  <rule id="688733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3442 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>