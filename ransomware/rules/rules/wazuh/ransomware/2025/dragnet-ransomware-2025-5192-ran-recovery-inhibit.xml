<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5192 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 2517f113-987f-5481-83a3-d780b4a2f12d -->
  <rule id="528711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5192 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>