<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1420 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 9f7c8a98-daaa-5356-a95e-2c4eb4fa6b5b -->
  <rule id="590378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1420 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>