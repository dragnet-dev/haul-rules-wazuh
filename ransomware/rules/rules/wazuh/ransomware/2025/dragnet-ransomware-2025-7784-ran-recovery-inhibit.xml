<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7784 — Recovery Inhibition (qilin) | Status: test | Sigma ID: efd572e9-352a-5dc6-bab5-a9a77e12761d -->
  <rule id="337572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7784 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>