<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4594 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 510c90d6-fb53-550a-99b3-a831d1446f8f -->
  <rule id="576653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4594 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>