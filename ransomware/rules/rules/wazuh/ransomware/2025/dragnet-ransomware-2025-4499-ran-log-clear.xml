<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4499 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: b2d71ae2-042d-5822-b577-f39dbe247f94 -->
  <rule id="289146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4499 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>