<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2520 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ccd0e84b-f549-5d2e-8f09-089b6f91b233 -->
  <rule id="843348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2520 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>