<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2314 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 60e417b3-a6e1-52ed-b1bb-68ab892ba379 -->
  <rule id="390683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2314 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>