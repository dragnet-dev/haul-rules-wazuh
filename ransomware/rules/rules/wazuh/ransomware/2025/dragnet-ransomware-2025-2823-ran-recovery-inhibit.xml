<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2823 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 832d1508-99b1-5d7e-83f3-19cee994cbf9 -->
  <rule id="532515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2823 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>