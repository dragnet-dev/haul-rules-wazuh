<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6665 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e81d5e1b-3a2e-57bf-8690-7d655f08a31b -->
  <rule id="293534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6665 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>