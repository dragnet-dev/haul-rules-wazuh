<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5608 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 93f74473-e35e-51b6-9f21-2a3b55798432 -->
  <rule id="703744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5608 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>