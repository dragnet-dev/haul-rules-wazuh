<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0084 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 110c3441-81ca-5af7-bf86-8757ba644c6e -->
  <rule id="972344" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0084 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>