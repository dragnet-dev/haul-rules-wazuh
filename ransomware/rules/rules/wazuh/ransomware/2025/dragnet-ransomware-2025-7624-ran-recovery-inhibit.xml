<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7624 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: df98b729-e13b-5e47-bdd0-8962874254dc -->
  <rule id="983797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7624 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>