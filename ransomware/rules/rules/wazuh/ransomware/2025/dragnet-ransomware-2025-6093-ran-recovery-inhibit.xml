<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6093 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 7442d3a0-d89e-5bd0-88c2-a5584d888d87 -->
  <rule id="390853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6093 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>