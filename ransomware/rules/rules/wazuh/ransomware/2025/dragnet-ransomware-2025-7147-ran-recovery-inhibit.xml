<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7147 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 7fd149df-3d49-5d46-9bde-61fec8692aef -->
  <rule id="345149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7147 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>