<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5615 — Event Log Clearing (payoutsking) | Status: experimental | Sigma ID: dfd76075-dd34-5abf-9fa4-06fd2a3f3a8a -->
  <rule id="981760" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5615 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>