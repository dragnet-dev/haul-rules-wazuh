  <rule id="821452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6902 — Event Log Clearing (crypto24)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
