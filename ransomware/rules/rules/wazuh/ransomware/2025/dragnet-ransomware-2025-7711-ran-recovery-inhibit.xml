<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7711 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 52e9dd59-cb2c-5854-91d4-e7d898c38f37 -->
  <rule id="468285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7711 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>