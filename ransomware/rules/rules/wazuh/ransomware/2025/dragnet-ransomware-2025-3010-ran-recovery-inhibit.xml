<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3010 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 6477c0b9-b7a1-5556-bf48-b2daadf4d177 -->
  <rule id="236440" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3010 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>