<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7915 — Event Log Clearing (devman) | Status: experimental | Sigma ID: bb1c8094-2bfc-5b62-9bb0-c5c5e84b7a21 -->
  <rule id="394880" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7915 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>