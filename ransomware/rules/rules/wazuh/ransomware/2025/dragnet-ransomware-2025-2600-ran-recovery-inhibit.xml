<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2600 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1289746d-a2fb-5a25-a022-eed039663595 -->
  <rule id="489746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2600 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
