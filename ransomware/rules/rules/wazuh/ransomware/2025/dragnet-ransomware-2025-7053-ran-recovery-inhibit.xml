<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7053 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6cc0199e-e714-5c73-93ca-43551d319aab -->
  <rule id="940019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7053 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>