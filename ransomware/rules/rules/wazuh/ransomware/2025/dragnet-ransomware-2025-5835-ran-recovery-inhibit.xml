<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5835 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b2228ec8-b5eb-547e-9174-8ff41a642fbf -->
  <rule id="995662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5835 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>