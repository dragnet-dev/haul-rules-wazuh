<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6982 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: a0a70f8e-5411-549f-963a-3a1c7bc0d20c -->
  <rule id="877135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6982 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>