<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0923 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7635f53a-a89f-55e3-bf61-ddbd1ecee121 -->
  <rule id="421755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0923 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>