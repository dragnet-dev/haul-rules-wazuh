<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3048 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: eccf9df4-4d67-5135-b8be-eed467530d8c -->
  <rule id="799837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3048 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>