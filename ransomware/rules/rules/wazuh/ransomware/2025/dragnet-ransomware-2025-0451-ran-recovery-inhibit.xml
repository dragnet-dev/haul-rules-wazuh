<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0451 — Recovery Inhibition (qilin) | Status: test | Sigma ID: b6e44aed-90af-5710-83e2-6337b67f10ec -->
  <rule id="392714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0451 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>