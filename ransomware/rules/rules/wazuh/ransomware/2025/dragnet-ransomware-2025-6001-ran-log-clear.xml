<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6001 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 0567ebce-54a6-5467-82b3-a499993f81e3 -->
  <rule id="626204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6001 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>