<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5355 — Shadow Copy Deletion (blackshrantac) | Status: experimental | Sigma ID: ae14f09e-299b-5d84-91f5-d76e9c5ef7a2 -->
  <rule id="186390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5355 — Shadow Copy Deletion (blackshrantac)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>