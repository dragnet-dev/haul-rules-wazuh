<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5059 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 233668fc-8cf6-51cd-859c-f5b60d0fbe9e -->
  <rule id="238703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5059 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>