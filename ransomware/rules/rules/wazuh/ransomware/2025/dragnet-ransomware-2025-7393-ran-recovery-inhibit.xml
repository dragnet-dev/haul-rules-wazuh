<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7393 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 257c1779-03ed-5a31-aec3-e561d54e5ac8 -->
  <rule id="624177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7393 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>