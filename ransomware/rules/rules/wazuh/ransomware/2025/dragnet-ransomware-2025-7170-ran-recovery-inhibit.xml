<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7170 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 51861ce7-bfa0-5d64-bde0-3a0202e70c5b -->
  <rule id="776622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7170 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>