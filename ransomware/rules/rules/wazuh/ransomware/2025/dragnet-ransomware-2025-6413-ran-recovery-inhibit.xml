<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6413 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 494db266-644c-559f-a923-649defa04da1 -->
  <rule id="466832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6413 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>