<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6515 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 34f15429-ecaf-5c10-a251-a6ee33f22cdb -->
  <rule id="291542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6515 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>