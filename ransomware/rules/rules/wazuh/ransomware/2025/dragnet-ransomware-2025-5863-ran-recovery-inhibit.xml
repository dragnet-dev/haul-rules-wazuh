<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5863 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: ed447079-eed0-53a2-a7a9-0c472bcd1b70 -->
  <rule id="674470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5863 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
