<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1092 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 6e441291-3500-5dfb-b58b-2525c54056f9 -->
  <rule id="304412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1092 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>