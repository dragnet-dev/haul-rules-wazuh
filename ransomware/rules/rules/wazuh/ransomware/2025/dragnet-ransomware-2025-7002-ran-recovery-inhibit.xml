<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7002 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e7743d0a-5534-5598-9267-f87069f5e6d5 -->
  <rule id="663901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7002 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>