<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3715 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4ed2a518-e029-571c-8d6d-8dae42780127 -->
  <rule id="318025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3715 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>