<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3109 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 51feb172-b4c0-5482-90dc-977bdb5ea77c -->
  <rule id="429711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3109 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>