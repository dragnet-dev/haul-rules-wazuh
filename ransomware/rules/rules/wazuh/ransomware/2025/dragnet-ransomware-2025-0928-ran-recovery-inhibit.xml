<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0928 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dd3ac3a5-4bf7-5855-850c-c79e03c3f6f0 -->
  <rule id="367003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0928 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>