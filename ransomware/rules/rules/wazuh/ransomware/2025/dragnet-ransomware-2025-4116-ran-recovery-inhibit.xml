<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4116 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 758e5393-c7f8-5962-8af1-a3223c569cbc -->
  <rule id="414253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4116 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>