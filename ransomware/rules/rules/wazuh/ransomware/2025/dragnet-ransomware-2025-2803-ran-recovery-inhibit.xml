<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2803 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3f08888f-f3d1-590b-b8bd-9f5dbd765ec1 -->
  <rule id="108888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2803 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>