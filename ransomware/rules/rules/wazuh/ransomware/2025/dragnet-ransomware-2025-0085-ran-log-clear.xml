<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0085 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 6d9f1991-7b99-5cf2-b6be-8a0c368bca79 -->
  <rule id="959919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0085 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>