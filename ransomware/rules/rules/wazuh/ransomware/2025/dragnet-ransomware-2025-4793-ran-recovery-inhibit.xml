<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4793 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 40aae445-6fb2-590b-876c-ece1b8551467 -->
  <rule id="865744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4793 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>