<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2594 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 05367688-00e2-51da-b418-6e0bd520f95f -->
  <rule id="967688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2594 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>