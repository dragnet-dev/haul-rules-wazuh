<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4426 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: d58dd958-e4bf-52f8-9dcc-10a182257986 -->
  <rule id="878699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4426 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>