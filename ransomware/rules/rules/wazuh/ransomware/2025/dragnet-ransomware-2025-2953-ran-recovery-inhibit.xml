<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2953 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 930872df-968f-572a-b192-518148a9b40f -->
  <rule id="593965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2953 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>