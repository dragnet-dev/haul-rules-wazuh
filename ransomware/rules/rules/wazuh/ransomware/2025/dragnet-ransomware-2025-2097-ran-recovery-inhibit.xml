<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2097 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: b5dd6c96-b27c-5464-83c8-c4cf738aef2c -->
  <rule id="345868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2097 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>