<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7083 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 197f45c8-6601-5890-96c5-2931493a97e2 -->
  <rule id="667932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7083 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
