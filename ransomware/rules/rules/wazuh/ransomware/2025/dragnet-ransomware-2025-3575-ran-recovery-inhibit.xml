<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3575 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 28504796-c4f7-5f1b-9b20-f51fd98519a2 -->
  <rule id="250479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3575 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>