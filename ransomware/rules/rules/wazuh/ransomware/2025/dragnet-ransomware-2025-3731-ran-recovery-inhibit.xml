<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3731 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 6482511d-c15a-5f2a-92d4-151f38c13c2c -->
  <rule id="282511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3731 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>