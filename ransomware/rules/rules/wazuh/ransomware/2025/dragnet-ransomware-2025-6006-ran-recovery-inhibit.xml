<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6006 — Recovery Inhibition (play) | Status: experimental | Sigma ID: efea7f87-c5c5-5500-b1b4-0756cb33e90b -->
  <rule id="927007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6006 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>