<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5395 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e2fe71ed-aa2f-577b-b324-0031e44804f4 -->
  <rule id="160671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5395 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>