<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7707 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: dd2f2b37-1a5d-5a0a-b46c-be5a185483d7 -->
  <rule id="365163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7707 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>