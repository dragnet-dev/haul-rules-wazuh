<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4743 — Recovery Inhibition (insomnia) | Status: test | Sigma ID: fbb1ac53-d4e6-5543-a2a4-230ec2aeba19 -->
  <rule id="509548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4743 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
