<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0879 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 71f70e08-c650-5541-adf2-4adf555f5b3c -->
  <rule id="142734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0879 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>