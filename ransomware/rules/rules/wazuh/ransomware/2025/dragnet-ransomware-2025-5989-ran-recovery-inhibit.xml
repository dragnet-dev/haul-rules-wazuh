<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5989 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 78d8af66-1743-591c-9530-11d9224b292e -->
  <rule id="630383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5989 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>