<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1783 — Recovery Inhibition (bqtlock) | Status: experimental | Sigma ID: f8f0b687-a23d-5153-ae63-fdaccd4b31a6 -->
  <rule id="568916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1783 — Recovery Inhibition (bqtlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>