<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3627 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f9786ccb-abbf-590f-8b76-0aec8590ab77 -->
  <rule id="856588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3627 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>