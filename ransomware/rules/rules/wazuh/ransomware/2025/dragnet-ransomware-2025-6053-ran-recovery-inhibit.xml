<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6053 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 583c4f88-0b25-54c9-a72f-0ab527ca2139 -->
  <rule id="694479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6053 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>