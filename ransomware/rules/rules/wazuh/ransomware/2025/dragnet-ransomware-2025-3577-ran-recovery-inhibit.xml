<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3577 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 54dddf5f-5b7c-53f6-83db-ff53c49b1889 -->
  <rule id="995743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3577 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>