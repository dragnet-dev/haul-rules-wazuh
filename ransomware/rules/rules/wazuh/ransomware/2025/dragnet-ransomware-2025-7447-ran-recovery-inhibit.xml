<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7447 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 1579f7a7-debc-53cc-b5e6-c662de659543 -->
  <rule id="544762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7447 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>