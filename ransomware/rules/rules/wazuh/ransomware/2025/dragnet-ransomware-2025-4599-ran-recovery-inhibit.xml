<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4599 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 23eb111c-c976-51ac-b6fe-3802dc183975 -->
  <rule id="823111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4599 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>