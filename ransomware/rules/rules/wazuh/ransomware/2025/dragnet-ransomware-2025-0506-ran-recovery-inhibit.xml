<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0506 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: b384e0fc-903c-54cb-ba0a-b656d0396a13 -->
  <rule id="121580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0506 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>