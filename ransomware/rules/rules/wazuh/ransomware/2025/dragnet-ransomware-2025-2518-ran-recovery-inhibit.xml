<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2518 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: e936fd07-4e6d-5f3a-9ff7-e6e826afbdc7 -->
  <rule id="323869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2518 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>