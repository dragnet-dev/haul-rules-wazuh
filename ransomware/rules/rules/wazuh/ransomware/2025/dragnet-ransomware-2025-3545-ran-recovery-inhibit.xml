<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3545 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: d48370f3-a76e-5d2c-97e7-275984b3ee47 -->
  <rule id="548370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3545 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>