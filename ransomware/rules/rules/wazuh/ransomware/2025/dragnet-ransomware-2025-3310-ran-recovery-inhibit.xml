<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3310 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a3f017ad-f677-54b4-837e-95a62f57a995 -->
  <rule id="863017" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3310 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>