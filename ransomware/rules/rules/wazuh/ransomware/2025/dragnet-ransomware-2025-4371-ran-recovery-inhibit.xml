<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4371 — Recovery Inhibition (clop) | Status: deprecated | Sigma ID: 7abc51bf-3fff-52af-ae8d-91e88d5f7b56 -->
  <rule id="542051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4371 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
