<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6169 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: a83b795c-9abc-5cb6-be14-951011bff067 -->
  <rule id="933979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6169 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>