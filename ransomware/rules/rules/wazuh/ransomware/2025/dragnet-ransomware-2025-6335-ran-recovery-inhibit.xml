<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6335 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 35218127-1814-50e0-9256-4e8d7ff67177 -->
  <rule id="921812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6335 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>