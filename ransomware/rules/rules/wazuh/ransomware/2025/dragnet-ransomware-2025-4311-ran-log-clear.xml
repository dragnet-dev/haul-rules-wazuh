<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4311 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: fcc3ad19-45e2-5fcc-a9cc-a01cdb942ec4 -->
  <rule id="553581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4311 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>