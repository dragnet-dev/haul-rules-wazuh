<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0098 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ad77c132-b4a6-5072-987f-ac6fcabd6a78 -->
  <rule id="180441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0098 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>